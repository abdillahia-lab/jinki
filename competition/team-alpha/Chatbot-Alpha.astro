---
/**
 * Jinki Intelligence Assistant — Chatbot Widget
 * Team Alpha, Round 8
 *
 * Floating chat widget with glass-morphism design, pre-built conversation
 * flows, dark/light theme support, and full mobile responsiveness.
 * All JS is inline — no external dependencies.
 */
---

<!-- Floating trigger button -->
<button
  id="jinki-chat-trigger"
  aria-label="Open Jinki Assistant"
  aria-haspopup="dialog"
  aria-expanded="false"
  style="
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9998;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--glass-shadow), 0 0 20px rgba(0, 229, 255, 0.15);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    outline: none;
  "
>
  <!-- Pulse ring -->
  <span
    id="jinki-chat-pulse"
    aria-hidden="true"
    style="
      position: absolute;
      inset: -4px;
      border-radius: 50%;
      border: 2px solid var(--accent);
      opacity: 0;
      animation: jinki-pulse-ring 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    "
  ></span>
  <!-- Radar icon -->
  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" style="position: relative; z-index: 1;">
    <circle cx="14" cy="14" r="12" stroke="var(--accent)" stroke-width="1.5" opacity="0.3"/>
    <circle cx="14" cy="14" r="8" stroke="var(--accent)" stroke-width="1.5" opacity="0.5"/>
    <circle cx="14" cy="14" r="4" stroke="var(--accent)" stroke-width="1.5" opacity="0.7"/>
    <circle cx="14" cy="14" r="2" fill="var(--accent)"/>
    <line x1="14" y1="14" x2="23" y2="8" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" opacity="0.9"/>
  </svg>
  <!-- Unread badge -->
  <span
    id="jinki-chat-badge"
    aria-label="Unread messages"
    style="
      position: absolute;
      top: -2px;
      right: -2px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #ff4757;
      color: #fff;
      font-family: var(--font-label);
      font-size: 11px;
      font-weight: 700;
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 2;
      border: 2px solid var(--bg-primary);
    "
  >1</span>
</button>

<!-- Chat panel -->
<div
  id="jinki-chat-panel"
  role="dialog"
  aria-label="Jinki Intelligence Assistant"
  aria-modal="false"
  style="
    position: fixed;
    bottom: 96px;
    right: 24px;
    z-index: 9999;
    width: 400px;
    height: 520px;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    box-shadow: var(--glass-shadow);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: scale(0.85) translateY(20px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.25s ease;
    transform-origin: bottom right;
  "
>
  <!-- Glossy shine overlay -->
  <div aria-hidden="true" style="
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
    z-index: 0;
  "></div>

  <!-- Header -->
  <div style="
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--glass-border);
    flex-shrink: 0;
  ">
    <div style="display: flex; align-items: center; gap: 10px;">
      <!-- Bot avatar -->
      <div style="
        width: 32px;
        height: 32px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--accent), rgba(0, 229, 255, 0.5));
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      ">
        <svg width="18" height="18" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <circle cx="14" cy="14" r="8" stroke="#fff" stroke-width="2" opacity="0.7"/>
          <circle cx="14" cy="14" r="3" fill="#fff"/>
          <line x1="14" y1="14" x2="21" y2="9" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <div style="
          font-family: var(--font-headline);
          font-size: 14px;
          font-weight: 600;
          color: var(--text-primary);
          line-height: 1.2;
        ">Jinki Assistant</div>
        <div style="display: flex; align-items: center; gap: 5px;">
          <span id="jinki-chat-status-dot" style="
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #34d399;
            display: inline-block;
            box-shadow: 0 0 6px rgba(52, 211, 153, 0.6);
          "></span>
          <span style="
            font-family: var(--font-body);
            font-size: 11px;
            color: var(--text-tertiary);
            line-height: 1;
          ">Online</span>
        </div>
      </div>
    </div>
    <!-- Minimize button -->
    <button
      id="jinki-chat-minimize"
      aria-label="Minimize chat"
      style="
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: none;
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-tertiary);
        transition: background 0.2s ease, color 0.2s ease;
      "
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
    </button>
  </div>

  <!-- Messages area -->
  <div
    id="jinki-chat-messages"
    role="log"
    aria-live="polite"
    aria-label="Chat messages"
    style="
      position: relative;
      z-index: 1;
      flex: 1;
      overflow-y: auto;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: var(--text-tertiary) transparent;
    "
  ></div>

  <!-- Quick replies container -->
  <div
    id="jinki-chat-quick-replies"
    role="group"
    aria-label="Quick reply options"
    style="
      position: relative;
      z-index: 1;
      padding: 0 16px 8px;
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      flex-shrink: 0;
    "
  ></div>

  <!-- Input bar -->
  <div style="
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--glass-border);
    flex-shrink: 0;
  ">
    <!-- Attachment button -->
    <button
      id="jinki-chat-attach"
      aria-label="Attach file"
      style="
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: none;
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-tertiary);
        transition: color 0.2s ease;
        flex-shrink: 0;
      "
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
      </svg>
    </button>
    <!-- Text input -->
    <input
      id="jinki-chat-input"
      type="text"
      placeholder="Ask about aerial intelligence..."
      autocomplete="off"
      aria-label="Type your message"
      style="
        flex: 1;
        height: 40px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--surface-container-low);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 14px;
        padding: 0 14px;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
      "
    />
    <!-- Send button -->
    <button
      id="jinki-chat-send"
      aria-label="Send message"
      style="
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: none;
        background: var(--accent);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #050508;
        transition: opacity 0.2s ease, transform 0.15s ease;
        flex-shrink: 0;
      "
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
      </svg>
    </button>
  </div>
</div>

<style>
  /* Pulse ring animation */
  @keyframes jinki-pulse-ring {
    0% { transform: scale(1); opacity: 0.5; }
    70% { transform: scale(1.35); opacity: 0; }
    100% { transform: scale(1.35); opacity: 0; }
  }

  /* Typing indicator bounce */
  @keyframes jinki-dot-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-5px); }
  }

  /* Message slide-up */
  @keyframes jinki-msg-enter {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Trigger hover */
  #jinki-chat-trigger:hover {
    transform: scale(1.08) !important;
    box-shadow: var(--glass-shadow), 0 0 30px rgba(0, 229, 255, 0.25) !important;
  }
  #jinki-chat-trigger:active {
    transform: scale(0.95) !important;
  }

  /* Minimize hover */
  #jinki-chat-minimize:hover {
    background: var(--surface-container-high) !important;
    color: var(--text-primary) !important;
  }

  /* Attachment hover */
  #jinki-chat-attach:hover {
    color: var(--accent) !important;
  }

  /* Input focus */
  #jinki-chat-input:focus {
    border-color: var(--accent) !important;
    box-shadow: 0 0 0 3px var(--accent-glow) !important;
  }

  /* Send hover */
  #jinki-chat-send:hover {
    opacity: 0.85;
    transform: scale(1.05);
  }
  #jinki-chat-send:active {
    transform: scale(0.95);
  }

  /* Scrollbar within messages */
  #jinki-chat-messages::-webkit-scrollbar { width: 4px; }
  #jinki-chat-messages::-webkit-scrollbar-track { background: transparent; }
  #jinki-chat-messages::-webkit-scrollbar-thumb {
    background: var(--text-tertiary);
    border-radius: 2px;
  }

  /* Panel open state — set via JS */
  #jinki-chat-panel.jinki-chat-open {
    transform: scale(1) translateY(0) !important;
    opacity: 1 !important;
    pointer-events: auto !important;
  }

  /* Trigger hidden when panel open on mobile */
  @media (max-width: 767px) {
    #jinki-chat-panel {
      bottom: 0 !important;
      right: 0 !important;
      left: 0 !important;
      top: 0 !important;
      width: 100% !important;
      height: 100% !important;
      border-radius: 0 !important;
      transform-origin: bottom center !important;
    }
    #jinki-chat-trigger {
      bottom: 16px !important;
      right: 16px !important;
    }
    .jinki-chat-open ~ #jinki-chat-trigger,
    body:has(.jinki-chat-open) #jinki-chat-trigger {
      display: none !important;
    }
  }

  /* Print: hide chatbot entirely */
  @media print {
    #jinki-chat-trigger,
    #jinki-chat-panel {
      display: none !important;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    #jinki-chat-panel {
      transition: opacity 0.01ms !important;
    }
    #jinki-chat-pulse {
      animation: none !important;
    }
  }
</style>

<script>
  (function () {
    /* ─── DOM refs ─── */
    const trigger = document.getElementById('jinki-chat-trigger');
    const panel = document.getElementById('jinki-chat-panel');
    const minimize = document.getElementById('jinki-chat-minimize');
    const messages = document.getElementById('jinki-chat-messages');
    const quickReplies = document.getElementById('jinki-chat-quick-replies');
    const input = document.getElementById('jinki-chat-input');
    const sendBtn = document.getElementById('jinki-chat-send');
    const badge = document.getElementById('jinki-chat-badge');
    const pulse = document.getElementById('jinki-chat-pulse');

    if (!trigger || !panel || !messages || !input || !sendBtn) return;

    let isOpen = false;
    let unreadCount = 0;
    let conversationStarted = false;

    /* ─── Conversation tree ─── */
    const FLOWS = {
      welcome: {
        messages: [
          "Hello! I'm Jinki's aerial intelligence assistant. How can I help you today?"
        ],
        quickReplies: [
          { label: 'Schedule Assessment', flow: 'assessment' },
          { label: 'Learn About Services', flow: 'services' },
          { label: 'Pricing Info', flow: 'pricing' },
          { label: 'Talk to Human', flow: 'human' },
        ],
      },
      assessment: {
        messages: [
          "Great choice! Our Facility Intelligence Audit provides a comprehensive aerial assessment of your site.",
          "The process includes thermal scanning, structural analysis, and a detailed intelligence report with actionable recommendations.",
          "I can connect you with our assessment team to schedule a walkthrough. What type of facility would you like assessed?"
        ],
        quickReplies: [
          { label: 'Data Center', flow: 'assessment_dc' },
          { label: 'Energy / Utility', flow: 'assessment_energy' },
          { label: 'Security Perimeter', flow: 'assessment_security' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      assessment_dc: {
        messages: [
          "Data centers are one of our core specialties. Our aerial thermal intelligence can identify cooling inefficiencies, hotspots, and equipment anomalies across your entire facility.",
          "We typically deliver the full assessment report within 5 business days of the site visit.",
          "Would you like to schedule a call with our data center intelligence team?"
        ],
        quickReplies: [
          { label: 'Yes, Schedule a Call', flow: 'schedule_confirm' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      assessment_energy: {
        messages: [
          "Our energy and utility assessments cover transmission lines, substations, solar arrays, and wind infrastructure.",
          "We use multi-sensor aerial platforms to detect thermal anomalies, vegetation encroachment, and structural degradation.",
          "Ready to discuss your energy infrastructure needs?"
        ],
        quickReplies: [
          { label: 'Yes, Schedule a Call', flow: 'schedule_confirm' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      assessment_security: {
        messages: [
          "Our perimeter security assessments provide a full aerial intelligence sweep of your facility's security posture.",
          "This includes vulnerability mapping, blind-spot identification, and integration recommendations for persistent aerial monitoring.",
          "Want to connect with our security intelligence team?"
        ],
        quickReplies: [
          { label: 'Yes, Schedule a Call', flow: 'schedule_confirm' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      schedule_confirm: {
        messages: [
          "Excellent! Please visit our contact page or reach out directly at contact@jinki.ai and we'll get you scheduled within 24 hours.",
          "Is there anything else I can help with?"
        ],
        quickReplies: [
          { label: 'Learn About Services', flow: 'services' },
          { label: 'Pricing Info', flow: 'pricing' },
          { label: "That's All, Thanks!", flow: 'goodbye' },
        ],
      },
      services: {
        messages: [
          "Jinki provides two core service models:",
          "1. **Facility Intelligence Audit** — A one-time comprehensive aerial assessment with a detailed intelligence report and recommendations.",
          "2. **Autonomous Deployment** — Persistent, autonomous aerial monitoring with real-time intelligence feeds and automated alerts.",
          "Which would you like to learn more about?"
        ],
        quickReplies: [
          { label: 'Intelligence Audit', flow: 'service_audit' },
          { label: 'Autonomous Deployment', flow: 'service_deploy' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      service_audit: {
        messages: [
          "Our Facility Intelligence Audit is a 6-step process: scoping, mission planning, data capture, AI-powered analysis, intelligence synthesis, and deliverable presentation.",
          "You receive a comprehensive report with thermal maps, anomaly classifications, risk scores, and prioritized recommendations.",
          "It's the ideal starting point for organizations new to aerial intelligence."
        ],
        quickReplies: [
          { label: 'Schedule an Audit', flow: 'schedule_confirm' },
          { label: 'Autonomous Deployment', flow: 'service_deploy' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      service_deploy: {
        messages: [
          "Our Autonomous Deployment provides persistent aerial monitoring from a permanently stationed dock at your facility.",
          "Missions run autonomously — 150 to 200 per month — with real-time thermal, visual, and LiDAR intelligence piped directly to your operations dashboard.",
          "This is our most advanced offering for facilities that need continuous situational awareness."
        ],
        quickReplies: [
          { label: 'Schedule a Demo', flow: 'schedule_confirm' },
          { label: 'Intelligence Audit', flow: 'service_audit' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      pricing: {
        messages: [
          "Pricing is tailored to each engagement based on facility size, sensor requirements, and service model.",
          "Our Intelligence Audits start with a complimentary scoping call to understand your needs before providing a detailed proposal.",
          "For Autonomous Deployments, pricing is structured as a monthly intelligence subscription.",
          "The best next step is a quick call with our team. Shall I help you get connected?"
        ],
        quickReplies: [
          { label: 'Yes, Connect Me', flow: 'schedule_confirm' },
          { label: 'Learn About Services', flow: 'services' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      human: {
        messages: [
          "Of course! You can reach our team directly:",
          "**Email:** contact@jinki.ai\n**Response time:** Within 1 business day",
          "Alternatively, use the contact form on our website and a team member will follow up promptly."
        ],
        quickReplies: [
          { label: 'Learn About Services', flow: 'services' },
          { label: 'Schedule Assessment', flow: 'assessment' },
          { label: 'Back to Menu', flow: 'welcome' },
        ],
      },
      goodbye: {
        messages: [
          "Thank you for your interest in Jinki! Feel free to come back anytime. Have a great day!"
        ],
        quickReplies: [
          { label: 'Start Over', flow: 'welcome' },
        ],
      },
    };

    /* ─── Helpers ─── */
    function getTime() {
      return new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    function parseMarkdown(text) {
      return text
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n/g, '<br>');
    }

    function createMessageEl(content, sender) {
      const isBot = sender === 'bot';
      const wrapper = document.createElement('div');
      wrapper.style.cssText = `
        display: flex;
        justify-content: ${isBot ? 'flex-start' : 'flex-end'};
        animation: jinki-msg-enter 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      `;
      wrapper.setAttribute('role', 'article');
      wrapper.setAttribute('aria-label', `${isBot ? 'Assistant' : 'You'}: ${content.replace(/<[^>]+>/g, '')}`);

      const bubble = document.createElement('div');
      if (isBot) {
        bubble.style.cssText = `
          max-width: 85%;
          padding: 10px 14px;
          border-radius: 12px 12px 12px 4px;
          background: linear-gradient(135deg, rgba(0, 229, 255, 0.12), rgba(0, 229, 255, 0.05));
          border: 1px solid rgba(0, 229, 255, 0.15);
          font-family: var(--font-body);
          font-size: 13px;
          line-height: 1.55;
          color: var(--text-primary);
        `;
      } else {
        bubble.style.cssText = `
          max-width: 85%;
          padding: 10px 14px;
          border-radius: 12px 12px 4px 12px;
          background: var(--glass-bg);
          border: 1px solid var(--glass-border);
          backdrop-filter: blur(12px);
          -webkit-backdrop-filter: blur(12px);
          font-family: var(--font-body);
          font-size: 13px;
          line-height: 1.55;
          color: var(--text-primary);
        `;
      }
      bubble.innerHTML = parseMarkdown(content);

      const ts = document.createElement('div');
      ts.style.cssText = `
        font-family: var(--font-mono);
        font-size: 10px;
        color: var(--text-tertiary);
        margin-top: 4px;
        text-align: ${isBot ? 'left' : 'right'};
        padding: 0 2px;
      `;
      ts.textContent = getTime();

      const container = document.createElement('div');
      container.style.cssText = `max-width: 85%; display: flex; flex-direction: column;`;
      container.appendChild(bubble);
      container.appendChild(ts);
      wrapper.appendChild(container);
      return wrapper;
    }

    function createTypingIndicator() {
      const wrapper = document.createElement('div');
      wrapper.id = 'jinki-typing';
      wrapper.setAttribute('role', 'status');
      wrapper.setAttribute('aria-label', 'Assistant is typing');
      wrapper.style.cssText = `
        display: flex;
        justify-content: flex-start;
        animation: jinki-msg-enter 0.25s ease both;
      `;
      const bubble = document.createElement('div');
      bubble.style.cssText = `
        padding: 12px 18px;
        border-radius: 12px 12px 12px 4px;
        background: linear-gradient(135deg, rgba(0, 229, 255, 0.1), rgba(0, 229, 255, 0.03));
        border: 1px solid rgba(0, 229, 255, 0.12);
        display: flex;
        gap: 5px;
        align-items: center;
      `;
      for (let i = 0; i < 3; i++) {
        const dot = document.createElement('span');
        dot.style.cssText = `
          width: 6px;
          height: 6px;
          border-radius: 50%;
          background: var(--accent);
          opacity: 0.6;
          animation: jinki-dot-bounce 1.2s ease infinite;
          animation-delay: ${i * 0.15}s;
        `;
        bubble.appendChild(dot);
      }
      wrapper.appendChild(bubble);
      return wrapper;
    }

    function renderQuickReplies(replies) {
      quickReplies.innerHTML = '';
      if (!replies || !replies.length) return;
      replies.forEach((r, i) => {
        const btn = document.createElement('button');
        btn.textContent = r.label;
        btn.setAttribute('aria-label', r.label);
        btn.style.cssText = `
          padding: 6px 14px;
          border-radius: 20px;
          border: 1px solid rgba(0, 229, 255, 0.25);
          background: rgba(0, 229, 255, 0.06);
          color: var(--accent);
          font-family: var(--font-label);
          font-size: 12px;
          font-weight: 500;
          cursor: pointer;
          transition: background 0.2s ease, border-color 0.2s ease, transform 0.15s ease;
          white-space: nowrap;
          opacity: 0;
          animation: jinki-msg-enter 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) ${0.1 + i * 0.06}s both;
        `;
        btn.addEventListener('mouseenter', () => {
          btn.style.background = 'rgba(0, 229, 255, 0.15)';
          btn.style.borderColor = 'rgba(0, 229, 255, 0.4)';
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.background = 'rgba(0, 229, 255, 0.06)';
          btn.style.borderColor = 'rgba(0, 229, 255, 0.25)';
        });
        btn.addEventListener('click', () => handleQuickReply(r));
        quickReplies.appendChild(btn);
      });
    }

    function scrollToBottom() {
      requestAnimationFrame(() => {
        messages.scrollTop = messages.scrollHeight;
      });
    }

    /* ─── Conversation engine ─── */
    async function runFlow(flowKey) {
      const flow = FLOWS[flowKey];
      if (!flow) return;

      quickReplies.innerHTML = '';

      for (let i = 0; i < flow.messages.length; i++) {
        // Show typing indicator
        const typing = createTypingIndicator();
        messages.appendChild(typing);
        scrollToBottom();

        await new Promise(r => setTimeout(r, 500 + Math.random() * 400));

        // Remove typing, add message
        typing.remove();
        const msgEl = createMessageEl(flow.messages[i], 'bot');
        messages.appendChild(msgEl);
        scrollToBottom();

        // Increment unread if closed
        if (!isOpen) {
          unreadCount++;
          badge.textContent = unreadCount;
          badge.style.display = 'flex';
        }
      }

      // Show quick replies
      renderQuickReplies(flow.quickReplies);
      scrollToBottom();
    }

    function handleQuickReply(reply) {
      // Add user message
      const userMsg = createMessageEl(reply.label, 'user');
      messages.appendChild(userMsg);
      scrollToBottom();

      runFlow(reply.flow);
    }

    function handleUserInput() {
      const text = input.value.trim();
      if (!text) return;

      const userMsg = createMessageEl(text, 'user');
      messages.appendChild(userMsg);
      input.value = '';
      scrollToBottom();

      // Simple keyword match fallback
      const lower = text.toLowerCase();
      let flowKey = 'welcome';
      if (lower.includes('assess') || lower.includes('audit') || lower.includes('inspect')) {
        flowKey = 'assessment';
      } else if (lower.includes('service') || lower.includes('offer') || lower.includes('what do you')) {
        flowKey = 'services';
      } else if (lower.includes('pric') || lower.includes('cost') || lower.includes('how much')) {
        flowKey = 'pricing';
      } else if (lower.includes('human') || lower.includes('person') || lower.includes('agent') || lower.includes('speak') || lower.includes('contact') || lower.includes('email')) {
        flowKey = 'human';
      } else if (lower.includes('deploy') || lower.includes('autonomous') || lower.includes('monitor')) {
        flowKey = 'service_deploy';
      } else if (lower.includes('data center') || lower.includes('datacenter') || lower.includes('thermal')) {
        flowKey = 'assessment_dc';
      } else if (lower.includes('energy') || lower.includes('grid') || lower.includes('solar') || lower.includes('wind')) {
        flowKey = 'assessment_energy';
      } else if (lower.includes('security') || lower.includes('perimeter') || lower.includes('surveillance')) {
        flowKey = 'assessment_security';
      } else {
        // Generic fallback
        const typing = createTypingIndicator();
        messages.appendChild(typing);
        scrollToBottom();
        setTimeout(() => {
          typing.remove();
          const fallback = createMessageEl(
            "Thanks for your message! I can help with scheduling assessments, learning about our services, pricing information, or connecting you with our team. What would you like to explore?",
            'bot'
          );
          messages.appendChild(fallback);
          renderQuickReplies(FLOWS.welcome.quickReplies);
          scrollToBottom();
        }, 600);
        return;
      }
      runFlow(flowKey);
    }

    /* ─── Open / close ─── */
    function openPanel() {
      isOpen = true;
      panel.classList.add('jinki-chat-open');
      trigger.setAttribute('aria-expanded', 'true');
      unreadCount = 0;
      badge.style.display = 'none';
      pulse.style.animationPlayState = 'paused';
      pulse.style.opacity = '0';
      sessionStorage.setItem('jinki-chat-open', '1');

      if (!conversationStarted) {
        conversationStarted = true;
        runFlow('welcome');
      }

      // Focus input after animation
      setTimeout(() => input.focus(), 380);
    }

    function closePanel() {
      isOpen = false;
      panel.classList.remove('jinki-chat-open');
      trigger.setAttribute('aria-expanded', 'false');
      pulse.style.animationPlayState = 'running';
      pulse.style.opacity = '';
      sessionStorage.setItem('jinki-chat-open', '0');
      trigger.focus();
    }

    /* ─── Event listeners ─── */
    trigger.addEventListener('click', () => {
      if (isOpen) closePanel();
      else openPanel();
    });

    minimize.addEventListener('click', closePanel);

    sendBtn.addEventListener('click', handleUserInput);

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        handleUserInput();
      }
    });

    // Escape to minimize
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closePanel();
      }
    });

    // Click outside to minimize (not close entirely)
    document.addEventListener('mousedown', (e) => {
      if (isOpen && !panel.contains(e.target) && !trigger.contains(e.target)) {
        closePanel();
      }
    });

    /* ─── Restore session state ─── */
    if (sessionStorage.getItem('jinki-chat-open') === '1') {
      // Delay slightly so page renders first
      setTimeout(openPanel, 500);
    }
  })();
</script>
