<script>
  // Department filter
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.ca-filter__btn');
    const roles = document.querySelectorAll('.ca-role');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const dept = btn.getAttribute('data-dept');

        // Update active button
        filterBtns.forEach(b => {
          b.classList.remove('ca-filter__btn--active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('ca-filter__btn--active');
        btn.setAttribute('aria-selected', 'true');

        // Filter roles
        roles.forEach(role => {
          const roleDept = role.getAttribute('data-department');
          if (dept === 'All' || roleDept === dept) {
            role.removeAttribute('data-hidden');
          } else {
            role.setAttribute('data-hidden', 'true');
          }
        });
      });
    });

    // Accordion toggle
    const roleHeaders = document.querySelectorAll('.ca-role__header');
    roleHeaders.forEach(header => {
      header.addEventListener('click', () => {
        const expanded = header.getAttribute('aria-expanded') === 'true';
        const bodyId = header.getAttribute('aria-controls');
        const body = document.getElementById(bodyId);

        // Close all others
        roleHeaders.forEach(h => {
          h.setAttribute('aria-expanded', 'false');
          const otherBody = document.getElementById(h.getAttribute('aria-controls'));
          if (otherBody) otherBody.removeAttribute('data-open');
        });

        // Toggle current
        if (!expanded) {
          header.setAttribute('aria-expanded', 'true');
          if (body) body.setAttribute('data-open', 'true');
        }
      });
    });
  });
</script>
