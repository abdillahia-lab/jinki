---
/*
  Careers Page — Team Alpha, Round 11
  Jinki Aerial Intelligence

  Sections:
  1. Culture hero with floating glass perk cards
  2. Open roles — accordion with department filter
  3. Benefits grid — 6 cards with icons
  4. Culture gallery — placeholder image grid
  5. Application CTA — general inquiry form
*/
import Layout from '../../src/layouts/Layout.astro';
import Nav from '../../src/components/Nav.astro';
import Footer from '../../src/components/Footer.astro';

const perks = [
  { icon: 'public', label: 'Remote-First', delay: '0s' },
  { icon: 'account_balance', label: 'Equity', delay: '1s' },
  { icon: 'school', label: 'Learning Budget', delay: '2s' },
  { icon: 'flight_takeoff', label: 'Flight Operations', delay: '3s' },
];

const departments = ['All', 'Engineering', 'Operations', 'Analytics', 'Sales'];

const roles = [
  {
    id: 'swe-platform',
    title: 'Senior Platform Engineer',
    department: 'Engineering',
    location: 'Remote (US)',
    type: 'Full-time',
    description: 'Build and scale the cloud infrastructure powering our aerial intelligence pipeline — from ingest through analysis to client delivery. You will own the data platform that processes terabytes of sensor data per week.',
  },
  {
    id: 'ml-cv',
    title: 'Computer Vision / ML Engineer',
    department: 'Engineering',
    location: 'Remote (US)',
    type: 'Full-time',
    description: 'Design and train models for thermal anomaly detection, structural assessment, and vegetation analysis across our four industry verticals. Production ML experience and familiarity with geospatial data are essential.',
  },
  {
    id: 'ops-lead',
    title: 'Flight Operations Lead',
    department: 'Operations',
    location: 'Northern Virginia',
    type: 'Full-time',
    description: 'Lead field deployment teams executing autonomous and piloted aerial missions for critical infrastructure clients. FAA Part 107 certification required; experience with enterprise-grade aerial platforms strongly preferred.',
  },
  {
    id: 'data-analyst',
    title: 'Geospatial Data Analyst',
    department: 'Analytics',
    location: 'Remote (US)',
    type: 'Full-time',
    description: 'Transform raw aerial captures into structured intelligence products — thermal maps, 3D models, NDVI composites, and prioritized maintenance reports. GIS expertise and experience with photogrammetry workflows required.',
  },
  {
    id: 'ae',
    title: 'Account Executive — Infrastructure',
    department: 'Sales',
    location: 'Remote (US)',
    type: 'Full-time',
    description: 'Own the full sales cycle for enterprise infrastructure clients — data centers, utilities, and large-scale facilities. Consultative selling experience and understanding of technical procurement processes preferred.',
  },
  {
    id: 'ops-tech',
    title: 'Field Operations Technician',
    department: 'Operations',
    location: 'Northern Virginia',
    type: 'Contract',
    description: 'Support deployment, maintenance, and monitoring of autonomous aerial stations at client sites. Hands-on technical aptitude and willingness to travel regionally required.',
  },
];

const benefits = [
  { icon: 'health_and_safety', title: 'Healthcare', desc: 'Comprehensive medical, dental, and vision coverage for you and your dependents.' },
  { icon: 'savings', title: '401(k)', desc: 'Competitive retirement plan with employer match to help you build long-term wealth.' },
  { icon: 'home', title: 'Remote Work', desc: 'Work from anywhere in the US. Quarterly team gatherings for collaboration and connection.' },
  { icon: 'menu_book', title: 'Learning Budget', desc: '$3,000 annual stipend for conferences, courses, certifications, and professional development.' },
  { icon: 'computer', title: 'Equipment', desc: 'Premium hardware setup shipped to your door — laptop, monitors, peripherals, and more.' },
  { icon: 'beach_access', title: 'Flexible PTO', desc: 'Generous paid time off with no hard cap. We trust you to manage your time responsibly.' },
];

const galleryPlaceholders = [
  { label: 'Field deployment', aspect: 'landscape' },
  { label: 'Analytics workspace', aspect: 'landscape' },
  { label: 'Team collaboration', aspect: 'portrait' },
  { label: 'Conference presentation', aspect: 'landscape' },
  { label: 'Equipment preparation', aspect: 'portrait' },
  { label: 'Client briefing', aspect: 'landscape' },
];
---

<Layout title="Careers — Jinki Aerial Intelligence" description="Join the team building aerial intelligence for critical infrastructure. Open roles in engineering, operations, analytics, and sales.">
  <Nav />
  <main id="main-content">

    <!-- ============ 1. CULTURE HERO ============ -->
    <section class="ca-hero" aria-label="Careers at Jinki">
      <div class="ca-hero__content">
        <span class="label reveal">Careers</span>
        <h1 class="reveal reveal-delay-1">Build the Future of<br/><span class="ca-gradient-text">Aerial Intelligence</span></h1>
        <p class="ca-hero__sub reveal reveal-delay-2">
          We are assembling the team that will define how the world's most critical
          facilities are monitored, maintained, and protected. If hard problems at the
          intersection of autonomous systems, AI, and real-world impact excite you — we
          want to hear from you.
        </p>
      </div>
      <div class="ca-hero__perks" aria-hidden="true">
        {perks.map((p) => (
          <div class="ca-hero__perk-card" style={`animation-delay: ${p.delay};`}>
            <span class="material-symbols-outlined" style="font-size: 24px; color: var(--accent); font-variation-settings: 'FILL' 1;">{p.icon}</span>
            <span class="ca-hero__perk-label">{p.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ 2. OPEN ROLES ============ -->
    <section class="ca-section" aria-label="Open Roles">
      <div class="ca-section__inner">
        <div class="ca-section__header reveal">
          <span class="label">Open Roles</span>
          <h2 style="margin-top: 8px;">Current Openings</h2>
          <p class="ca-section__subtitle">
            We are hiring across engineering, operations, analytics, and sales.
          </p>
        </div>

        <!-- Department Filter -->
        <div class="ca-filter reveal" role="tablist" aria-label="Filter by department">
          {departments.map((dept) => (
            <button
              class={`ca-filter__btn ${dept === 'All' ? 'ca-filter__btn--active' : ''}`}
              role="tab"
              aria-selected={dept === 'All' ? 'true' : 'false'}
              data-dept={dept}
            >
              {dept}
            </button>
          ))}
        </div>

        <!-- Roles Accordion -->
        <div class="ca-roles" id="ca-roles-list">
          {roles.map((role) => (
            <div class="ca-role reveal" data-department={role.department}>
              <button
                class="ca-role__header"
                aria-expanded="false"
                aria-controls={`role-${role.id}`}
                id={`btn-${role.id}`}
              >
                <div class="ca-role__info">
                  <h3 class="ca-role__title">{role.title}</h3>
                  <div class="ca-role__meta">
                    <span class="ca-role__tag ca-role__tag--dept">{role.department}</span>
                    <span class="ca-role__tag">{role.location}</span>
                    <span class="ca-role__tag">{role.type}</span>
                  </div>
                </div>
                <span class="ca-role__chevron material-symbols-outlined" style="font-variation-settings: 'FILL' 0;" aria-hidden="true">expand_more</span>
              </button>
              <div class="ca-role__body" id={`role-${role.id}`} role="region" aria-labelledby={`btn-${role.id}`}>
                <p class="ca-role__desc">{role.description}</p>
                <a href="#ca-apply" class="ca-role__apply btn-premium">Apply Now</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 3. BENEFITS GRID ============ -->
    <section class="ca-section" style="background: var(--bg-elevated);" aria-label="Benefits">
      <div class="ca-section__inner">
        <div class="ca-section__header reveal" style="text-align: center; margin-bottom: 56px;">
          <span class="label">Benefits</span>
          <h2 style="margin-top: 8px;">How We Take Care of Our Team</h2>
        </div>
        <div class="ca-benefits-grid">
          {benefits.map((b, i) => (
            <div class={`ca-benefit-card reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="ca-benefit-card__icon">
                <span class="material-symbols-outlined" style="font-size: 28px; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">{b.icon}</span>
              </div>
              <h3 class="ca-benefit-card__title">{b.title}</h3>
              <p class="ca-benefit-card__desc">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 4. CULTURE GALLERY ============ -->
    <section class="ca-section" aria-label="Life at Jinki">
      <div class="ca-section__inner">
        <div class="ca-section__header reveal" style="text-align: center; margin-bottom: 48px;">
          <span class="label">Life at Jinki</span>
          <h2 style="margin-top: 8px;">Where Intelligence Meets Impact</h2>
        </div>
        <div class="ca-gallery">
          {galleryPlaceholders.map((item, i) => (
            <div class={`ca-gallery__item ca-gallery__item--${item.aspect} reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="ca-gallery__placeholder">
                <span class="material-symbols-outlined" style="font-size: 36px; color: var(--text-tertiary); font-variation-settings: 'FILL' 0;" aria-hidden="true">image</span>
                <span class="ca-gallery__label">{item.label}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 5. APPLICATION CTA ============ -->
    <section class="ca-section" id="ca-apply" style="background: var(--bg-elevated);" aria-label="Apply">
      <div class="ca-section__inner" style="max-width: 720px; text-align: center;">
        <div class="ca-section__header reveal" style="text-align: center; margin-bottom: 40px;">
          <span class="label">Apply</span>
          <h2 style="margin-top: 8px;">Don't See Your Role?</h2>
          <p class="ca-section__subtitle" style="margin: 16px auto 0;">
            We are always interested in exceptional people. Send us your resume and a
            brief note about what draws you to aerial intelligence.
          </p>
        </div>

        <form class="ca-apply-form reveal reveal-delay-1" action="#" method="POST">
          <div class="ca-apply-form__row">
            <div class="ca-apply-form__field">
              <label for="ca-name" class="ca-apply-form__label">Full Name</label>
              <input type="text" id="ca-name" name="name" required autocomplete="name" class="ca-apply-form__input" placeholder="Jane Smith" />
            </div>
            <div class="ca-apply-form__field">
              <label for="ca-email" class="ca-apply-form__label">Email</label>
              <input type="email" id="ca-email" name="email" required autocomplete="email" class="ca-apply-form__input" placeholder="jane@example.com" />
            </div>
          </div>
          <div class="ca-apply-form__field">
            <label for="ca-message" class="ca-apply-form__label">Tell us about yourself</label>
            <textarea id="ca-message" name="message" rows="5" class="ca-apply-form__input ca-apply-form__textarea" placeholder="What excites you about aerial intelligence? What would you bring to the team?"></textarea>
          </div>
          <div class="ca-apply-form__field">
            <label for="ca-resume" class="ca-apply-form__label">Resume (PDF)</label>
            <input type="file" id="ca-resume" name="resume" accept=".pdf,.doc,.docx" class="ca-apply-form__file" />
          </div>
          <button type="submit" class="ca-apply-form__submit btn-premium">
            Submit Application
          </button>
        </form>

        <p class="ca-apply-fallback reveal reveal-delay-2" style="margin-top: 32px; font-size: 0.875rem; color: var(--text-tertiary);">
          Or email us directly at
          <a href="mailto:careers@jinki.ai" style="color: var(--accent);">careers@jinki.ai</a>
        </p>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* =============================================
     CAREERS PAGE — TEAM ALPHA
     ============================================= */

  /* --- 1. Culture Hero --- */
  .ca-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 160px clamp(20px, 5vw, 80px) 100px;
    text-align: center;
    overflow: hidden;
    background: var(--surface-container-lowest);
  }

  .ca-hero__content {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .ca-hero__content h1 {
    font-size: clamp(2.2rem, 4.5vw + 0.5rem, 3.5rem);
    line-height: 1.08;
    margin-bottom: 24px;
  }

  .ca-gradient-text {
    background: linear-gradient(135deg, #00E5FF, #34D399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ca-hero__sub {
    font-size: clamp(1rem, 1.3vw + 0.5rem, 1.15rem);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  /* Floating perk cards */
  .ca-hero__perks {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .ca-hero__perk-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    animation: ca-float 6s ease-in-out infinite;
    opacity: 0.7;
  }

  .ca-hero__perk-card:nth-child(1) { top: 20%; left: 8%; }
  .ca-hero__perk-card:nth-child(2) { top: 15%; right: 8%; animation-delay: 1.5s; }
  .ca-hero__perk-card:nth-child(3) { bottom: 22%; left: 12%; animation-delay: 3s; }
  .ca-hero__perk-card:nth-child(4) { bottom: 18%; right: 10%; animation-delay: 4.5s; }

  @keyframes ca-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-8px) rotate(0.5deg); }
    66% { transform: translateY(4px) rotate(-0.5deg); }
  }

  .ca-hero__perk-label {
    font-family: var(--font-headline);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }

  /* --- Shared Section --- */
  .ca-section {
    padding: 100px clamp(20px, 5vw, 80px);
  }

  .ca-section__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .ca-section__header {
    margin-bottom: 48px;
  }

  .ca-section__header h2 {
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    line-height: 1.12;
  }

  .ca-section__subtitle {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin-top: 12px;
  }

  /* --- 2. Department Filter --- */
  .ca-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
  }

  .ca-filter__btn {
    font-family: var(--font-headline);
    font-size: 13px;
    font-weight: 600;
    padding: 8px 20px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .ca-filter__btn:hover {
    border-color: var(--border-hover);
    color: var(--text-primary);
  }

  .ca-filter__btn--active {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
  }

  :global([data-theme="light"]) .ca-filter__btn--active {
    color: #fff;
  }

  /* --- Roles Accordion --- */
  .ca-roles {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ca-role {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ca-role:hover {
    border-color: var(--border-hover);
  }

  .ca-role[data-hidden="true"] {
    display: none;
  }

  .ca-role__header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 24px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--text-primary);
    transition: background 0.2s ease;
  }

  .ca-role__header:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  :global([data-theme="light"]) .ca-role__header:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  .ca-role__info {
    flex: 1;
  }

  .ca-role__title {
    font-family: var(--font-headline);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .ca-role__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ca-role__tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 100px;
    background: var(--bg-card);
    color: var(--text-tertiary);
    border: 1px solid var(--border);
  }

  .ca-role__tag--dept {
    color: var(--accent);
    border-color: rgba(0, 229, 255, 0.2);
    background: var(--accent-glow);
  }

  .ca-role__chevron {
    font-size: 24px;
    color: var(--text-tertiary);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .ca-role__header[aria-expanded="true"] .ca-role__chevron {
    transform: rotate(180deg);
  }

  .ca-role__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), padding 0.4s ease;
    padding: 0 24px;
  }

  .ca-role__body[data-open="true"] {
    max-height: 300px;
    padding: 0 24px 24px;
  }

  .ca-role__desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 20px;
    max-width: 700px;
  }

  .ca-role__apply {
    display: inline-block;
    font-family: var(--font-headline);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 10px 28px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent), #0099aa);
    color: #000;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ca-role__apply:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px var(--accent-glow-strong);
  }

  :global([data-theme="light"]) .ca-role__apply {
    color: #fff;
  }

  /* --- 3. Benefits Grid --- */
  .ca-benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .ca-benefit-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ca-benefit-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .ca-benefit-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
  }

  .ca-benefit-card__icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: transform 0.3s ease;
  }

  .ca-benefit-card:hover .ca-benefit-card__icon {
    transform: scale(1.08);
  }

  .ca-benefit-card__title {
    font-family: var(--font-headline);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .ca-benefit-card__desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* --- 4. Culture Gallery --- */
  .ca-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 200px;
    gap: 16px;
  }

  .ca-gallery__item--portrait {
    grid-row: span 2;
  }

  .ca-gallery__placeholder {
    width: 100%;
    height: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: border-color 0.3s ease;
  }

  .ca-gallery__placeholder:hover {
    border-color: var(--border-hover);
  }

  .ca-gallery__label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* --- 5. Application Form --- */
  .ca-apply-form {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ca-apply-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .ca-apply-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .ca-apply-form__label {
    font-family: var(--font-headline);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .ca-apply-form__input {
    font-family: var(--font-body);
    font-size: 15px;
    padding: 12px 16px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface-container-low);
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .ca-apply-form__input::placeholder {
    color: var(--text-tertiary);
  }

  .ca-apply-form__input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .ca-apply-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .ca-apply-form__file {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    padding: 10px 0;
  }

  .ca-apply-form__file::file-selector-button {
    font-family: var(--font-headline);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 8px 16px;
    margin-right: 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ca-apply-form__file::file-selector-button:hover {
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  .ca-apply-form__submit {
