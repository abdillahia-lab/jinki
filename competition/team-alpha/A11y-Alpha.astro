---
import '../../styles/global.css';
const title = 'Accessibility Enhancement — Team Alpha | Jinki';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Team Alpha accessibility best practices showcase for Jinki Aerial Intelligence" />
  <title>{title}</title>
  <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=accessibility,check_circle,close,contrast,dark_mode,keyboard,light_mode,motion_photos_paused,notifications,remove_red_eye,skip_next,visibility&display=swap" rel="stylesheet" />
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('jinki-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <style is:inline>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body>
  <!-- 1. Skip-to-Content Link -->
  <a href="#main-content" class="skip-link" id="skip-link">Skip to main content</a>

  <header class="page-header" role="banner">
    <div class="header-inner">
      <div style="display:flex;align-items:center;gap:12px;">
        <span class="material-symbols-outlined" style="font-size:32px;color:var(--accent);" aria-hidden="true">accessibility</span>
        <div>
          <h1 class="page-title">Accessibility Enhancement</h1>
          <p class="team-badge">Team Alpha &mdash; Round 14</p>
        </div>
      </div>
      <nav aria-label="Page sections">
        <ul class="section-nav" role="list">
          <li><a href="#skip-nav">Skip Nav</a></li>
          <li><a href="#focus-trap">Focus Trap</a></li>
          <li><a href="#live-region">Live Region</a></li>
          <li><a href="#data-tables">Tables</a></li>
          <li><a href="#contrast">Contrast</a></li>
          <li><a href="#keyboard">Keyboard</a></li>
          <li><a href="#reduced-motion">Motion</a></li>
          <li><a href="#high-contrast">Hi-Contrast</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="main-content" role="main" style="max-width:1200px;margin:0 auto;padding:32px 24px 80px;">

    <!-- Section 1: Skip-to-Content Demo -->
    <section id="skip-nav" class="demo-section" aria-labelledby="skip-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">01</span>
        <h2 id="skip-heading">Skip-to-Content Link</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">Press <kbd>Tab</kbd> from the top of the page to reveal the skip link. It bypasses navigation and jumps directly to the main content area.</p>
        <div class="skip-demo-box">
          <div class="skip-visual" aria-hidden="true">
            <div class="fake-nav">
              <div class="fake-logo"></div>
              <div class="fake-links">
                <div class="fake-link"></div>
                <div class="fake-link"></div>
                <div class="fake-link"></div>
              </div>
            </div>
            <div class="skip-indicator">
              <span class="material-symbols-outlined" style="font-size:18px;">skip_next</span>
              Skip to main content
            </div>
            <div class="fake-content">
              <div class="fake-h1"></div>
              <div class="fake-paragraph"></div>
              <div class="fake-paragraph short"></div>
            </div>
          </div>
        </div>
        <div class="code-block">
          <code>&lt;a href="#main-content" class="skip-to-content"&gt;Skip to main content&lt;/a&gt;</code>
        </div>
        <div class="best-practices">
          <h3>Best Practices</h3>
          <ul>
            <li>Visually hidden until focused with <code>:focus</code></li>
            <li>First focusable element in the DOM</li>
            <li>Links to <code>#main-content</code> which has <code>role="main"</code></li>
            <li>High contrast styling on focus for visibility</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Section 2: Focus Trap -->
    <section id="focus-trap" class="demo-section" aria-labelledby="trap-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">02</span>
        <h2 id="trap-heading">Focus Trap for Modals</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">When a modal opens, keyboard focus is trapped inside it. <kbd>Tab</kbd> cycles only through modal controls; <kbd>Escape</kbd> closes the modal.</p>
        <button class="btn-premium demo-trigger" id="open-modal-btn" aria-haspopup="dialog" style="background:var(--accent);color:#000;border:none;padding:12px 28px;border-radius:10px;font-family:var(--font-label);font-weight:600;cursor:pointer;font-size:15px;">
          Open Demo Modal
        </button>
        <div class="focus-trap-demo" id="demo-modal" role="dialog" aria-modal="true" aria-labelledby="modal-title" aria-describedby="modal-desc" hidden>
          <div class="modal-backdrop" data-close-modal></div>
          <div class="modal-content glass-panel" style="border-radius:16px;">
            <div class="modal-header">
              <h3 id="modal-title">Mission Confirmation</h3>
              <button class="modal-close" id="close-modal-btn" aria-label="Close modal">
                <span class="material-symbols-outlined">close</span>
              </button>
            </div>
            <p id="modal-desc" style="color:var(--text-secondary);margin:16px 0;">Confirm deployment of aerial intelligence mission for thermal inspection of sector 7. Focus is trapped in this dialog.</p>
            <div class="modal-fields">
              <label for="mission-name">Mission Name</label>
              <input type="text" id="mission-name" value="Thermal Sweep Alpha" style="width:100%;padding:10px 14px;border-radius:8px;border:1px solid var(--outline-variant);background:var(--surface-container);color:var(--text-primary);font-family:var(--font-body);font-size:14px;margin:4px 0 16px;" />
              <label for="priority-select">Priority Level</label>
              <select id="priority-select" style="width:100%;padding:10px 14px;border-radius:8px;border:1px solid var(--outline-variant);background:var(--surface-container);color:var(--text-primary);font-family:var(--font-body);font-size:14px;margin:4px 0 16px;">
                <option>Standard</option>
                <option>High</option>
                <option>Critical</option>
              </select>
            </div>
            <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:20px;">
              <button class="btn-secondary" data-close-modal style="padding:10px 24px;border-radius:10px;border:1px solid var(--outline-variant);background:transparent;color:var(--text-primary);font-family:var(--font-label);font-weight:600;cursor:pointer;">Cancel</button>
              <button class="btn-premium" data-close-modal style="background:var(--accent);color:#000;border:none;padding:10px 24px;border-radius:10px;font-family:var(--font-label);font-weight:600;cursor:pointer;">Confirm</button>
            </div>
          </div>
        </div>
        <div class="code-block" style="margin-top:20px;">
          <code>role="dialog" aria-modal="true" aria-labelledby="..." aria-describedby="..."</code>
        </div>
      </div>
    </section>

    <!-- Section 3: ARIA Live Region -->
    <section id="live-region" class="demo-section" aria-labelledby="live-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">03</span>
        <h2 id="live-heading">ARIA Live Regions</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">Dynamic content changes are announced to screen readers via <code>aria-live</code> regions. Try the controls below.</p>
        <div class="live-demo-grid">
          <div class="live-panel">
            <h3>Alert (Assertive)</h3>
            <div class="live-output" id="alert-output" role="alert" aria-live="assertive" aria-atomic="true">
              <span class="material-symbols-outlined" style="font-size:18px;color:var(--accent);" aria-hidden="true">notifications</span>
              <span id="alert-text">No alerts</span>
            </div>
            <button class="live-btn" id="trigger-alert" style="background:var(--error);color:#fff;border:none;padding:8px 20px;border-radius:8px;font-family:var(--font-label);font-weight:600;cursor:pointer;font-size:13px;">
              Trigger Alert
            </button>
          </div>
          <div class="live-panel">
            <h3>Status (Polite)</h3>
            <div class="live-output" id="status-output" role="status" aria-live="polite" aria-atomic="true">
              <span class="material-symbols-outlined" style="font-size:18px;color:var(--accent);" aria-hidden="true">notifications</span>
              <span id="status-text">Missions completed: 0</span>
            </div>
            <button class="live-btn" id="trigger-status" style="background:var(--accent);color:#000;border:none;padding:8px 20px;border-radius:8px;font-family:var(--font-label);font-weight:600;cursor:pointer;font-size:13px;">
              Complete Mission
            </button>
          </div>
          <div class="live-panel">
            <h3>Log (Polite, non-atomic)</h3>
            <div class="live-output log-output" id="log-output" role="log" aria-live="polite" aria-atomic="false">
              <span id="log-text" class="log-entries">System ready.</span>
            </div>
            <button class="live-btn" id="trigger-log" style="background:var(--surface-container-high);color:var(--text-primary);border:1px solid var(--outline-variant);padding:8px 20px;border-radius:8px;font-family:var(--font-label);font-weight:600;cursor:pointer;font-size:13px;">
              Add Log Entry
            </button>
          </div>
        </div>
        <div class="code-block" style="margin-top:20px;">
          <code>aria-live="assertive" | "polite" &mdash; aria-atomic="true" | "false"</code>
        </div>
      </div>
    </section>

    <!-- Section 4: Accessible Data Tables -->
    <section id="data-tables" class="demo-section" aria-labelledby="table-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">04</span>
        <h2 id="table-heading">Screen Reader-Friendly Data Tables</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">Properly structured tables with <code>&lt;caption&gt;</code>, <code>&lt;th scope&gt;</code>, and <code>&lt;thead&gt;</code>/<code>&lt;tbody&gt;</code> help screen readers navigate tabular data.</p>
        <div class="table-wrapper" tabindex="0" role="region" aria-label="Inspection results table">
          <table class="a11y-table">
            <caption>Aerial Inspection Results &mdash; Q1 2026</caption>
            <thead>
              <tr>
                <th scope="col">Sector</th>
                <th scope="col">Anomalies</th>
                <th scope="col">Severity</th>
                <th scope="col">Status</th>
                <th scope="col">Recommendation</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">Data Center A3</th>
                <td>12</td>
                <td><span class="severity high">High</span></td>
                <td>Action Required</td>
                <td>Immediate thermal remediation</td>
              </tr>
              <tr>
                <th scope="row">Solar Array B1</th>
                <td>3</td>
                <td><span class="severity low">Low</span></td>
                <td>Monitoring</td>
                <td>Schedule Q2 follow-up</td>
              </tr>
              <tr>
                <th scope="row">Perimeter Zone C</th>
                <td>7</td>
                <td><span class="severity medium">Medium</span></td>
                <td>In Progress</td>
                <td>Fence line vegetation clearing</td>
              </tr>
              <tr>
                <th scope="row">Crop Field D2</th>
                <td>5</td>
                <td><span class="severity medium">Medium</span></td>
                <td>Scheduled</td>
                <td>NDVI re-scan after irrigation</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="code-block" style="margin-top:20px;">
          <code>&lt;th scope="col"&gt; for column headers &mdash; &lt;th scope="row"&gt; for row headers</code>
        </div>
      </div>
    </section>

    <!-- Section 5: Color Contrast Panel -->
    <section id="contrast" class="demo-section" aria-labelledby="contrast-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">05</span>
        <h2 id="contrast-heading">Color Contrast Verification</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">All color pairs used in Jinki are validated against WCAG 2.1 AA contrast requirements (4.5:1 for text, 3:1 for large text and UI).</p>
        <div class="contrast-grid" id="contrast-grid">
          <!-- populated by JS -->
        </div>
        <div class="contrast-legend" style="margin-top:20px;display:flex;gap:24px;flex-wrap:wrap;">
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="contrast-badge pass">AA</span>
            <span style="color:var(--text-secondary);font-size:14px;">Passes AA (4.5:1+)</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="contrast-badge large">AA Large</span>
            <span style="color:var(--text-secondary);font-size:14px;">Passes for large text (3:1+)</span>
          </div>
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="contrast-badge fail">Fail</span>
            <span style="color:var(--text-secondary);font-size:14px;">Does not meet AA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 6: Keyboard Navigation Guide -->
    <section id="keyboard" class="demo-section" aria-labelledby="keyboard-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">06</span>
        <h2 id="keyboard-heading">Keyboard Navigation Guide</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">Every interactive element on Jinki is keyboard accessible. Try the shortcuts below.</p>
        <div class="keyboard-grid">
          <div class="key-item" tabindex="0" role="button" aria-label="Tab key: Move to next focusable element">
            <kbd>Tab</kbd>
            <span>Move to next focusable element</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="Shift+Tab: Move to previous focusable element">
            <kbd>Shift + Tab</kbd>
            <span>Move to previous element</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="Enter key: Activate links and buttons">
            <kbd>Enter</kbd>
            <span>Activate links &amp; buttons</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="Space key: Toggle checkboxes, scroll page">
            <kbd>Space</kbd>
            <span>Toggle checkboxes / scroll</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="Escape key: Close modals and popups">
            <kbd>Escape</kbd>
            <span>Close modals &amp; popups</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="Arrow keys: Navigate within components">
            <kbd>&uarr; &darr; &larr; &rarr;</kbd>
            <span>Navigate within components</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="Home key: Jump to first item">
            <kbd>Home</kbd>
            <span>Jump to first item</span>
          </div>
          <div class="key-item" tabindex="0" role="button" aria-label="End key: Jump to last item">
            <kbd>End</kbd>
            <span>Jump to last item</span>
          </div>
        </div>
        <div class="focus-indicator-demo" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Focus Indicator Demo</h3>
          <p style="color:var(--text-secondary);font-size:14px;margin-bottom:16px;">Tab through these elements to see the focus ring style:</p>
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a href="#keyboard" class="focus-demo-link">Link</a>
            <button class="focus-demo-btn">Button</button>
            <input type="text" class="focus-demo-input" placeholder="Input field" aria-label="Demo input field" />
            <select class="focus-demo-select" aria-label="Demo select field">
              <option>Option 1</option>
              <option>Option 2</option>
            </select>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 7: Reduced Motion -->
    <section id="reduced-motion" class="demo-section" aria-labelledby="motion-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">07</span>
        <h2 id="motion-heading">Reduced Motion Support</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">Users who prefer reduced motion see simplified transitions. Toggle to compare.</p>
        <div class="motion-toggle-row">
          <button class="btn-premium motion-toggle" id="motion-toggle" aria-pressed="false" style="background:var(--accent);color:#000;border:none;padding:12px 28px;border-radius:10px;font-family:var(--font-label);font-weight:600;cursor:pointer;font-size:15px;display:inline-flex;align-items:center;gap:8px;">
            <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">motion_photos_paused</span>
            Enable Reduced Motion
          </button>
          <span class="motion-status" id="motion-status" aria-live="polite" style="color:var(--text-tertiary);font-size:14px;">Motion: Full</span>
        </div>
        <div class="motion-comparison" style="margin-top:24px;">
          <div class="motion-box" id="motion-box-1">
            <div class="motion-orb" aria-hidden="true"></div>
            <span class="motion-label">Float Animation</span>
          </div>
          <div class="motion-box" id="motion-box-2">
            <div class="motion-pulse" aria-hidden="true"></div>
            <span class="motion-label">Pulse Animation</span>
          </div>
          <div class="motion-box" id="motion-box-3">
            <div class="motion-slide" aria-hidden="true">
              <div class="slide-bar"></div>
            </div>
            <span class="motion-label">Slide Animation</span>
          </div>
        </div>
        <div class="code-block" style="margin-top:20px;">
          <code>@media (prefers-reduced-motion: reduce) &#123; animation-duration: 0.01ms !important; &#125;</code>
        </div>
      </div>
    </section>

    <!-- Section 8: High Contrast Mode -->
    <section id="high-contrast" class="demo-section" aria-labelledby="hc-heading">
      <div class="section-header">
        <span class="section-number" aria-hidden="true">08</span>
        <h2 id="hc-heading">High Contrast Mode</h2>
      </div>
      <div class="demo-card glass-panel" style="border-radius:16px;">
        <p class="demo-desc">High contrast mode increases text contrast and border visibility for users with low vision.</p>
        <button class="btn-premium" id="hc-toggle" aria-pressed="false" style="background:var(--accent);color:#000;border:none;padding:12px 28px;border-radius:10px;font-family:var(--font-label);font-weight:600;cursor:pointer;font-size:15px;display:inline-flex;align-items:center;gap:8px;">
          <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">contrast</span>
          Toggle High Contrast
        </button>
        <div class="hc-preview" style="margin-top:24px;">
          <div class="hc-sample-card">
            <h3>Sample Card</h3>
            <p>This card demonstrates how high contrast mode enhances readability with stronger borders and text contrast.</p>
            <button class="hc-sample-btn">Sample Action</button>
          </div>
          <div class="hc-sample-card">
            <h3>Data Reading</h3>
            <p>Thermal anomaly detected at coordinates 34.052, -118.243. Severity level elevated.</p>
            <span class="hc-badge">Critical</span>
          </div>
        </div>
        <div class="code-block" style="margin-top:20px;">
          <code>@media (forced-colors: active) &#123; /* Windows High Contrast */ &#125;</code>
        </div>
      </div>
    </section>
  </main>

  <style>
    /* --- Page Structure --- */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 16px;
      z-index: 9999;
      padding: 12px 24px;
      background: var(--accent);
      color: #000;
      font-weight: 700;
      font-family: var(--font-label);
      border-radius: 0 0 10px 10px;
      text-decoration: none;
      transition: top 0.2s ease;
      font-size: 15px;
    }
    .skip-link:focus { top: 0; }

    .page-header {
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 16px 24px;
    }
    .header-inner {
      max-width: 1200px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
    }
    .page-title {
      font-size: clamp(18px, 3vw, 24px);
      line-height: 1.2;
    }
    .team-badge {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--accent);
      letter-spacing: 0.05em;
    }
    .section-nav {
      display: flex;
      gap: 4px;
      list-style: none;
      flex-wrap: wrap;
    }
    .section-nav a {
      display: block;
      padding: 6px 12px;
      border-radius: 8px;
      font-size: 13px;
      font-family: var(--font-label);
      color: var(--text-secondary);
      transition: all 0.2s;
      text-decoration: none;
    }
    .section-nav a:hover,
    .section-nav a:focus-visible {
      background: var(--accent-glow);
      color: var(--accent);
    }

    .demo-section { margin-bottom: 48px; }
    .section-header {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 20px;
    }
    .section-number {
      font-family: var(--font-mono);
      font-size: 48px;
      font-weight: 700;
      color: var(--accent);
      opacity: 0.25;
      line-height: 1;
    }
    .section-header h2 {
      font-size: clamp(22px, 4vw, 32px);
    }

    .demo-card { padding: 32px; position: relative; z-index: 0; }
    .demo-desc {
      color: var(--text-secondary);
      font-size: 15px;
      line-height: 1.7;
      margin-bottom: 24px;
    }
    .demo-desc code, .code-block code {
      font-family: var(--font-mono);
      font-size: 13px;
      background: var(--surface-container);
      padding: 2px 8px;
      border-radius: 4px;
      color: var(--accent);
    }
    .code-block {
      background: var(--surface-container-low);
      padding: 16px 20px;
      border-radius: 10px;
      overflow-x: auto;
      border: 1px solid var(--border);
    }
    .code-block code { background: transparent; padding: 0; display: block; line-height: 1.6; }

    .best-practices { margin-top: 20px; }
    .best-practices h3 {
      font-size: 16px;
      margin-bottom: 10px;
      color: var(--text-primary);
    }
    .best-practices ul {
      list-style: none;
      display: grid;
      gap: 8px;
    }
    .best-practices li {
      font-size: 14px;
      color: var(--text-secondary);
      padding-left: 24px;
      position: relative;
    }
    .best-practices li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 7px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.6;
    }

    /* Skip Nav Demo Visual */
    .skip-demo-box { margin-bottom: 20px; }
    .skip-visual {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 20px;
      position: relative;
      overflow: hidden;
    }
    .fake-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
      margin-bottom: 16px;
    }
    .fake-logo {
      width: 60px;
      height: 20px;
      border-radius: 4px;
      background: var(--accent);
      opacity: 0.3;
    }
    .fake-links { display: flex; gap: 8px; }
    .fake-link {
      width: 48px;
      height: 10px;
      border-radius: 3px;
      background: var(--text-tertiary);
      opacity: 0.3;
    }
    .skip-indicator {
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--accent);
      color: #000;
      padding: 6px 16px;
      border-radius: 0 0 8px 8px;
      font-size: 13px;
      font-weight: 600;
      font-family: var(--font-label);
      display: flex;
      align-items: center;
      gap: 6px;
      animation: skipBounce 2s ease-in-out infinite;
    }
    @keyframes skipBounce {
      0%, 100% { opacity: 1; transform: translateX(-50%) translateY(0); }
      50% { opacity: 0.7; transform: translateX(-50%) translateY(-4px); }
    }
    .fake-content { display: grid; gap: 8px; }
    .fake-h1 { width: 60%; height: 16px; border-radius: 4px; background: var(--text-tertiary); opacity: 0.2; }
    .fake-paragraph { width: 90%; height: 10px; border-radius: 3px; background: var(--text-tertiary); opacity: 0.15; }
    .fake-paragraph.short { width: 50%; }

    /* Focus Trap Modal */
    .focus-trap-demo {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .focus-trap-demo[hidden] { display: none; }
    .modal-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(4px);
    }
    .modal-content {
      position: relative;
      z-index: 1;
      max-width: 480px;
      width: 100%;
      padding: 28px;
    }
    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .modal-header h3 { font-size: 20px; }
    .modal-close {
      background: transparent;
      border: none;
      color: var(--text-secondary);
      cursor: pointer;
      padding: 4px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }
    .modal-close:hover { background: var(--surface-container-high); }
    .modal-fields label {
      font-family: var(--font-label);
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      letter-spacing: 0.02em;
    }

    /* Live Regions */
    .live-demo-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px;
    }
    .live-panel {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .live-panel h3 { font-size: 15px; }
    .live-output {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      border-radius: 8px;
      background: var(--surface-container-low);
      border: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 13px;
      color: var(--text-primary);
      min-height: 48px;
    }
    .log-output {
      flex-direction: column;
      align-items: flex-start;
      min-height: 80px;
    }
    .log-entries {
      font-family: var(--font-mono);
      font-size: 12px;
      color: var(--text-secondary);
      white-space: pre-line;
      line-height: 1.6;
    }

    /* Data Table */
    .table-wrapper {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid var(--border);
    }
    .a11y-table {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-body);
      font-size: 14px;
    }
    .a11y-table caption {
      padding: 16px 20px;
      font-family: var(--font-label);
      font-weight: 700;
      font-size: 16px;
      text-align: left;
      color: var(--text-primary);
      background: var(--surface-container);
      border-bottom: 1px solid var(--border);
    }
    .a11y-table thead th {
      text-align: left;
      padding: 12px 20px;
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 13px;
      color: var(--text-tertiary);
      background: var(--surface-container-low);
      border-bottom: 1px solid var(--border);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .a11y-table tbody td,
    .a11y-table tbody th {
      padding: 14px 20px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border);
    }
    .a11y-table tbody th {
      font-weight: 600;
      color: var(--text-primary);
    }
    .a11y-table tbody tr:last-child td,
    .a11y-table tbody tr:last-child th { border-bottom: none; }
    .a11y-table tbody tr:hover td,
    .a11y-table tbody tr:hover th { background: var(--accent-glow); }
    .severity {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      font-family: var(--font-label);
    }
    .severity.high { background: rgba(255,71,87,0.15); color: #ff4757; }
    .severity.medium { background: rgba(255,165,0,0.15); color: #ffa500; }
    .severity.low { background: rgba(0,229,255,0.15); color: var(--accent); }

    /* Contrast Grid */
    .contrast-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
    }
    .contrast-pair {
      border-radius: 10px;
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      border: 1px solid var(--border);
    }
    .contrast-pair-label {
      font-family: var(--font-label);
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      opacity: 0.7;
    }
    .contrast-pair-ratio {
      font-family: var(--font-mono);
      font-size: 24px;
      font-weight: 700;
    }
    .contrast-pair-names {
      font-size: 12px;
      font-family: var(--font-mono);
      opacity: 0.6;
    }
    .contrast-badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 700;
      font-family: var(--font-label);
    }
    .contrast-badge.pass { background: rgba(52,211,153,0.2); color: #34d399; }
    .contrast-badge.large { background: rgba(255,165,0,0.2); color: #ffa500; }
    .contrast-badge.fail { background: rgba(255,71,87,0.2); color: #ff4757; }

    /* Keyboard Guide */
    .keyboard-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 10px;
    }
    .key-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      border-radius: 10px;
      background: var(--surface-container);
      border: 1px solid var(--border);
      transition: all 0.2s;
      cursor: default;
    }
    .key-item:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      background: var(--accent-glow);
    }
    .key-item kbd {
      font-family: var(--font-mono);
      font-size: 13px;
      background: var(--surface-container-low);
      border: 1px solid var(--outline-variant);
      border-bottom-width: 2px;
      padding: 4px 10px;
      border-radius: 6px;
      color: var(--accent);
      white-space: nowrap;
      font-weight: 600;
    }
    .key-item span:last-child {
      font-size: 14px;
      color: var(--text-secondary);
    }

    .focus-demo-link,
    .focus-demo-btn,
    .focus-demo-input,
    .focus-demo-select {
      padding: 10px 20px;
      border-radius: 8px;
      font-family: var(--font-body);
      font-size: 14px;
      transition: all 0.2s;
    }
    .focus-demo-link {
      background: var(--surface-container);
      color: var(--accent);
      text-decoration: none;
      border: 1px solid var(--border);
      display: inline-block;
    }
    .focus-demo-btn {
      background: var(--accent);
      color: #000;
      border: none;
      font-weight: 600;
      cursor: pointer;
    }
    .focus-demo-input {
      background: var(--surface-container);
      border: 1px solid var(--outline-variant);
      color: var(--text-primary);
    }
    .focus-demo-select {
      background: var(--surface-container);
      border: 1px solid var(--outline-variant);
      color: var(--text-primary);
    }

    /* Motion Demo */
    .motion-toggle-row {
      display: flex;
      align-items: center;
      gap: 16px;
      flex-wrap: wrap;
    }
    .motion-comparison {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
    }
    .motion-box {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 32px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
      border: 1px solid var(--border);
    }
    .motion-label {
      font-family: var(--font-label);
      font-size: 13px;
      color: var(--text-tertiary);
    }
    .motion-orb {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--accent);
      animation: float 3s ease-in-out infinite;
    }
    .motion-pulse {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: var(--accent);
      animation: pulse 2s ease-in-out infinite;
    }
    .motion-slide { width: 100%; overflow: hidden; height: 8px; border-radius: 4px; background: var(--surface-container-low); }
    .slide-bar {
      width: 40%;
      height: 100%;
      border-radius: 4px;
      background: var(--accent);
      animation: slideAcross 2s ease-in-out infinite alternate;
    }
    @keyframes slideAcross {
      0% { transform: translateX(0); }
      100% { transform: translateX(150%); }
    }

    body.reduced-motion .motion-orb,
    body.reduced-motion .motion-pulse,
    body.reduced-motion .slide-bar,
    body.reduced-motion .skip-indicator {
      animation: none !important;
    }

    /* High Contrast */
    .hc-preview {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }
    .hc-sample-card {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 24px;
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 10px;
      transition: all 0.3s;
    }
    .hc-sample-card h3 { font-size: 17px; }
    .hc-sample-card p { font-size: 14px; color: var(--text-secondary); }
    .hc-sample-btn {
      align-self: flex-start;
      padding: 8px 20px;
      border-radius: 8px;
      border: 1px solid var(--accent);
      background: transparent;
      color: var(--accent);
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.2s;
    }
    .hc-sample-btn:hover { background: var(--accent); color: #000; }
    .hc-badge {
      display: inline-block;
      align-self: flex-start;
      padding: 4px 12px;
      border-radius: 6px;
      background: rgba(255,71,87,0.15);
      color: #ff4757;
      font-size: 12px;
      font-weight: 700;
      font-family: var(--font-label);
    }

    body.high-contrast .hc-sample-card {
      border-width: 2px;
      border-color: var(--text-primary);
    }
    body.high-contrast .hc-sample-card p { color: var(--text-primary); }
    body.high-contrast .hc-sample-btn {
      border-width: 2px;
      border-color: var(--text-primary);
      color: var(--text-primary);
    }
    body.high-contrast .hc-badge {
      background: #ff4757;
      color: #fff;
    }
    body.high-contrast .demo-card {
      border-width: 2px !important;
      border-color: var(--text-secondary) !important;
    }

    @media (forced-colors: active) {
      .demo-card { border: 2px solid CanvasText; }
      .hc-sample-btn { border: 2px solid ButtonText; }
    }

    /* Mobile */
    @media (max-width: 768px) {
      .header-inner { flex-direction: column; align-items: flex-start; }
      .section-nav { display: none; }
      .demo-card { padding: 20px; }
      .section-number { font-size: 36px; }
    }
  </style>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // --- Focus Trap ---
    var modal = document.getElementById('demo-modal');
    var openBtn = document.getElementById('open-modal-btn');
    var closeBtn = document.getElementById('close-modal-btn');
    var lastFocused = null;

    function openModal() {
      lastFocused = document.activeElement;
      modal.hidden = false;
      var firstInput = modal.querySelector('input, button:not(.modal-close)');
      if (firstInput) firstInput.focus();
    }
    function closeModal() {
      modal.hidden = true;
      if (lastFocused) lastFocused.focus();
    }

    openBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    modal.querySelectorAll('[data-close-modal]').forEach(function(el) {
      el.addEventListener('click', closeModal);
    });

    modal.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') { closeModal(); return; }
      if (e.key !== 'Tab') return;
      var focusable = modal.querySelectorAll('input, select, button, [tabindex]:not([tabindex="-1"])');
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });

    // --- Live Regions ---
    var alertCount = 0;
    var missionCount = 0;
    var logCount = 0;
    var alerts = [
      'Thermal anomaly detected in sector 4!',
      'Perimeter breach alert — zone C!',
      'High wind advisory — operations paused!',
      'Battery critical on unit Alpha-7!'
    ];
    var logEntries = [
      'Mission Alpha-3 launched.',
      'Thermal scan in progress...',
      'Anomaly detected at grid ref 34.05N.',
      'Data upload complete — 2.4 GB.',
      'Unit returning to base.'
    ];

    document.getElementById('trigger-alert').addEventListener('click', function() {
      alertCount = (alertCount + 1) % alerts.length;
      document.getElementById('alert-text').textContent = alerts[alertCount];
    });
    document.getElementById('trigger-status').addEventListener('click', function() {
      missionCount++;
      document.getElementById('status-text').textContent = 'Missions completed: ' + missionCount;
    });
    document.getElementById('trigger-log').addEventListener('click', function() {
      var entry = logEntries[logCount % logEntries.length];
      logCount++;
      var logEl = document.getElementById('log-text');
      logEl.textContent += '\n' + new Date().toLocaleTimeString() + ' — ' + entry;
      logEl.parentElement.scrollTop = logEl.parentElement.scrollHeight;
    });

    // --- Contrast Grid ---
    var colorPairs = [
      { fg: '#e2e2e5', bg: '#121416', fgName: 'on-surface', bgName: 'surface' },
      { fg: '#bac9cc', bg: '#121416', fgName: 'on-surface-variant', bgName: 'surface' },
      { fg: '#00e5ff', bg: '#121416', fgName: 'accent', bgName: 'surface' },
      { fg: '#849396', bg: '#121416', fgName: 'text-tertiary', bgName: 'surface' },
      { fg: '#e2e2e5', bg: '#1e2022', fgName: 'on-surface', bgName: 'card' },
      { fg: '#00e5ff', bg: '#1e2022', fgName: 'accent', bgName: 'card' },
      { fg: '#000000', bg: '#00e5ff', fgName: 'on-accent', bgName: 'accent' },
      { fg: '#1a1c1e', bg: '#fafbfc', fgName: 'on-surface (light)', bgName: 'bg (light)' },
      { fg: '#00838f', bg: '#fafbfc', fgName: 'accent (light)', bgName: 'bg (light)' },
      { fg: '#ff4757', bg: '#121416', fgName: 'error-red', bgName: 'surface' },
    ];

    function luminance(hex) {
      var r = parseInt(hex.slice(1, 3), 16) / 255;
      var g = parseInt(hex.slice(3, 5), 16) / 255;
      var b = parseInt(hex.slice(5, 7), 16) / 255;
      r = r <= 0.03928 ? r / 12.92 : Math.pow((r + 0.055) / 1.055, 2.4);
      g = g <= 0.03928 ? g / 12.92 : Math.pow((g + 0.055) / 1.055, 2.4);
      b = b <= 0.03928 ? b / 12.92 : Math.pow((b + 0.055) / 1.055, 2.4);
      return 0.2126 * r + 0.7152 * g + 0.0722 * b;
    }
    function contrastRatio(fg, bg) {
      var l1 = luminance(fg);
      var l2 = luminance(bg);
      var lighter = Math.max(l1, l2);
      var darker = Math.min(l1, l2);
      return (lighter + 0.05) / (darker + 0.05);
    }

    var grid = document.getElementById('contrast-grid');
    colorPairs.forEach(function(pair) {
      var ratio = contrastRatio(pair.fg, pair.bg);
      var level = ratio >= 4.5 ? 'pass' : (ratio >= 3 ? 'large' : 'fail');
      var levelLabel = ratio >= 4.5 ? 'AA' : (ratio >= 3 ? 'AA Large' : 'Fail');
      var card = document.createElement('div');
      card.className = 'contrast-pair';
      card.style.background = pair.bg;
      card.style.color = pair.fg;
      card.innerHTML =
        '<span class="contrast-pair-label" style="color:' + pair.fg + ';">' + levelLabel + '</span>' +
        '<span class="contrast-pair-ratio" style="color:' + pair.fg + ';">' + ratio.toFixed(1) + ':1</span>' +
        '<span class="contrast-pair-names" style="color:' + pair.fg + ';">' + pair.fgName + ' on ' + pair.bgName + '</span>' +
        '<span class="contrast-badge ' + level + '" style="align-self:flex-start;">' + levelLabel + '</span>';
      grid.appendChild(card);
    });

    // --- Reduced Motion Toggle ---
    var motionBtn = document.getElementById('motion-toggle');
    var motionStatus = document.getElementById('motion-status');
    var reduced = false;
    motionBtn.addEventListener('click', function() {
      reduced = !reduced;
      document.body.classList.toggle('reduced-motion', reduced);
      motionBtn.setAttribute('aria-pressed', String(reduced));
      motionBtn.innerHTML =
        '<span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">motion_photos_paused</span> ' +
        (reduced ? 'Disable Reduced Motion' : 'Enable Reduced Motion');
      motionStatus.textContent = 'Motion: ' + (reduced ? 'Reduced' : 'Full');
    });

    // --- High Contrast Toggle ---
    var hcBtn = document.getElementById('hc-toggle');
    var hcActive = false;
    hcBtn.addEventListener('click', function() {
      hcActive = !hcActive;
      document.body.classList.toggle('high-contrast', hcActive);
      hcBtn.setAttribute('aria-pressed', String(hcActive));
    });
  });
  </script>
</body>
</html>
