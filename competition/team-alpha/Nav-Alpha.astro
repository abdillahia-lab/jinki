  .mobile-action-card .material-symbols-outlined {
    font-size: 24px;
    color: var(--text-secondary);
  }

  .mobile-action-card__label {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
  }

  .mobile-action-card--primary {
    background: linear-gradient(135deg, rgba(0, 229, 255, 0.1), rgba(0, 229, 255, 0.02));
    border-color: rgba(0, 229, 255, 0.2);
  }

  .mobile-action-card--primary .material-symbols-outlined {
    color: var(--accent);
  }

  :global([data-theme="light"]) .mobile-action-card--primary {
    background: linear-gradient(135deg, rgba(0, 131, 143, 0.08), rgba(0, 131, 143, 0.02));
    border-color: rgba(0, 131, 143, 0.15);
  }

  .mobile-action-card:active {
    transform: scale(0.97);
  }

  /* ---- Reduced Motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .nav-scroll-progress,
    .command-deck,
    .nav-trigger__chevron,
    .nav-active-indicator,
    .dropdown-panel,
    .mega-panel,
    .spotlight,
    .spotlight__panel,
    .mobile-overlay,
    .mobile-accordion,
    .mobile-overlay__actions,
    .command-deck__logo-icon,
    .mega-card,
    .breadcrumb-trail__list {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }

    .command-deck__logo:hover .command-deck__logo-icon {
      transform: none;
    }
  }

  /* ---- Print ---- */
  @media print {
    .command-deck,
    .nav-scroll-progress,
    .spotlight,
    .mobile-overlay {
      display: none !important;
    }
  }
</style>

<script is:inline>
(function () {
  'use strict';

  /* ============================================================
     COMMAND DECK — Runtime Controller
     ============================================================ */

  var nav = document.getElementById('site-nav');
  var scrollProgress = document.getElementById('nav-scroll-progress');
  var mobileToggle = document.getElementById('mobile-toggle');
  var mobileMenu = document.getElementById('mobile-menu');
  var searchTrigger = document.getElementById('search-trigger');
  var searchOverlay = document.getElementById('search-overlay');
  var searchInput = document.getElementById('search-input');
  var activeIndicator = document.getElementById('nav-active-indicator');
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  /* ---- 1. Scroll: progress bar + nav background ---- */
  function onScroll() {
    var scrollTop = window.scrollY;
    var docHeight = document.documentElement.scrollHeight - window.innerHeight;
    var pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    scrollProgress.style.width = pct + '%';

    if (scrollTop > 40) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ---- 2. Desktop dropdown & mega-menu management ---- */
  var navGroups = nav.querySelectorAll('.nav-group');
  var openGroup = null;
  var closeTimer = null;

  function openDropdown(group) {
    if (openGroup && openGroup !== group) closeDropdown(openGroup);
    var panel = group.querySelector('.mega-panel, .dropdown-panel');
    var trigger = group.querySelector('.nav-trigger');
    if (panel) {
      clearTimeout(closeTimer);
      panel.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
      openGroup = group;
    }
  }

  function closeDropdown(group) {
    var panel = group.querySelector('.mega-panel, .dropdown-panel');
    var trigger = group.querySelector('.nav-trigger');
    if (panel) {
      panel.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    }
    if (openGroup === group) openGroup = null;
  }

  function closeAllDropdowns() {
    navGroups.forEach(function (g) { closeDropdown(g); });
    openGroup = null;
  }

  navGroups.forEach(function (group) {
    var trigger = group.querySelector('.nav-trigger');

    // Hover
    group.addEventListener('mouseenter', function () {
      clearTimeout(closeTimer);
      openDropdown(group);
    });

    group.addEventListener('mouseleave', function () {
      closeTimer = setTimeout(function () {
        closeDropdown(group);
      }, 200);
    });

    // Click toggle (for touch-screen laptops)
    trigger.addEventListener('click', function (e) {
      e.preventDefault();
      var panel = group.querySelector('.mega-panel, .dropdown-panel');
      if (panel && panel.classList.contains('open')) {
        closeDropdown(group);
      } else {
        openDropdown(group);
      }
    });

    // Keyboard: Enter / Space / ArrowDown opens, Escape closes
    trigger.addEventListener('keydown', function (e) {
      var panel = group.querySelector('.mega-panel, .dropdown-panel');
      var links = panel ? panel.querySelectorAll('a') : [];

      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        e.preventDefault();
        openDropdown(group);
        if (links.length) links[0].focus();
      }
      if (e.key === 'Escape') {
        closeDropdown(group);
        trigger.focus();
      }
    });

    // Arrow navigation within dropdown
    var panel = group.querySelector('.mega-panel, .dropdown-panel');
    if (panel) {
      var links = panel.querySelectorAll('a');
      links.forEach(function (link, idx) {
        link.addEventListener('keydown', function (e) {
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (idx < links.length - 1) links[idx + 1].focus();
          } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (idx > 0) links[idx - 1].focus();
            else trigger.focus();
          } else if (e.key === 'Escape') {
            closeDropdown(group);
            trigger.focus();
          } else if (e.key === 'ArrowRight' && group.dataset.hasMega === 'true') {
            // Navigate between mega columns
            e.preventDefault();
            if (idx < links.length - 1) links[idx + 1].focus();
          } else if (e.key === 'ArrowLeft' && group.dataset.hasMega === 'true') {
            e.preventDefault();
            if (idx > 0) links[idx - 1].focus();
          }
        });
      });

      // Close on focus leaving
      group.addEventListener('focusout', function (e) {
        setTimeout(function () {
          if (!group.contains(document.activeElement)) {
            closeDropdown(group);
          }
        }, 10);
      });
    }
  });

  // Left/Right arrow keys between top-level triggers
  var triggers = Array.from(nav.querySelectorAll('.nav-trigger'));
  triggers.forEach(function (trigger, idx) {
    trigger.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        closeAllDropdowns();
        var next = triggers[(idx + 1) % triggers.length];
        next.focus();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        closeAllDropdowns();
        var prev = triggers[(idx - 1 + triggers.length) % triggers.length];
        prev.focus();
      }
    });
  });

  // Close on outside click
  document.addEventListener('click', function (e) {
    if (openGroup && !nav.contains(e.target)) {
      closeAllDropdowns();
    }
  });

  /* ---- 3. Active page indicator (sliding underline) ---- */
  function updateActiveIndicator() {
    var path = window.location.pathname;
    var activeGroup = null;

    navGroups.forEach(function (group) {
      var links = group.querySelectorAll('a');
      var trigger = group.querySelector('.nav-trigger');
      var isActive = false;

      links.forEach(function (link) {
        if (path.startsWith(link.getAttribute('href'))) {
          isActive = true;
        }
      });

      if (isActive) {
        trigger.classList.add('is-active');
        activeGroup = group;
      } else {
        trigger.classList.remove('is-active');
      }
    });

    if (activeGroup && activeIndicator) {
      var trigger = activeGroup.querySelector('.nav-trigger');
      var navRect = nav.querySelector('.command-deck__nav').getBoundingClientRect();
      var triggerRect = trigger.getBoundingClientRect();
      activeIndicator.style.left = (triggerRect.left - navRect.left) + 'px';
      activeIndicator.style.width = triggerRect.width + 'px';
      activeIndicator.classList.add('visible');
    }
  }

  // Run after fonts settle
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(updateActiveIndicator);
  } else {
    setTimeout(updateActiveIndicator, 200);
  }

  /* ---- 4. Hover indicator tracking ---- */
  triggers.forEach(function (trigger) {
    trigger.addEventListener('mouseenter', function () {
      var navEl = nav.querySelector('.command-deck__nav');
      if (!navEl) return;
      var navRect = navEl.getBoundingClientRect();
      var rect = trigger.getBoundingClientRect();
      activeIndicator.style.left = (rect.left - navRect.left) + 'px';
      activeIndicator.style.width = rect.width + 'px';
      activeIndicator.classList.add('visible');
    });
  });

  var navEl = nav.querySelector('.command-deck__nav');
  if (navEl) {
    navEl.addEventListener('mouseleave', function () {
      // Snap back to active item or hide
      updateActiveIndicator();
    });
  }

  /* ---- 5. Theme toggle ---- */
  var themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', function () {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('jinki-theme', next);
      themeToggle.style.transform = 'rotate(180deg) scale(0.85)';
      setTimeout(function () {
        themeToggle.style.transform = '';
      }, 300);
    });
  }

  /* ---- 6. Spotlight Search ---- */
  function openSearch() {
    searchOverlay.classList.add('open');
    searchOverlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(function () { searchInput.focus(); }, 100);
    filterResults('');
  }

  function closeSearch() {
    searchOverlay.classList.remove('open');
    searchOverlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    searchInput.value = '';
    searchTrigger.focus();
  }

  if (searchTrigger) {
    searchTrigger.addEventListener('click', openSearch);
  }

  // Cmd/Ctrl + K shortcut
  document.addEventListener('keydown', function (e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (searchOverlay.classList.contains('open')) {
        closeSearch();
      } else {
        openSearch();
      }
    }
  });

  if (searchOverlay) {
    // Close on backdrop click
    searchOverlay.querySelector('.spotlight__backdrop').addEventListener('click', closeSearch);

    // Close on Escape
    searchOverlay.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        e.stopPropagation();
        closeSearch();
      }
    });

    // Filter search results
    var allResults = searchOverlay.querySelectorAll('.spotlight__result');
    var allCategories = searchOverlay.querySelectorAll('.spotlight__category');

    function filterResults(query) {
      var q = query.toLowerCase().trim();
      var highlightIdx = -1;

      allCategories.forEach(function (cat) {
        var results = cat.querySelectorAll('.spotlight__result');
        var anyVisible = false;

        results.forEach(function (r) {
          var text = r.textContent.toLowerCase();
          var show = !q || text.indexOf(q) !== -1;
          r.style.display = show ? 'flex' : 'none';
          r.classList.remove('highlighted');
          if (show) anyVisible = true;
        });

        cat.style.display = anyVisible ? 'block' : 'none';
      });

      // Highlight first visible result
      var visibleResults = searchOverlay.querySelectorAll('.spotlight__result[style*="flex"], .spotlight__result:not([style*="none"])');
      if (visibleResults.length > 0) {
        visibleResults[0].classList.add('highlighted');
      }
    }

    searchInput.addEventListener('input', function () {
      filterResults(this.value);
    });

    // Arrow key navigation in search results
    searchInput.addEventListener('keydown', function (e) {
      var visible = Array.from(allResults).filter(function (r) {
        return r.style.display !== 'none';
      });
      var currentIdx = visible.findIndex(function (r) {
        return r.classList.contains('highlighted');
      });

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        visible.forEach(function (r) { r.classList.remove('highlighted'); });
        var nextIdx = (currentIdx + 1) % visible.length;
        visible[nextIdx].classList.add('highlighted');
        visible[nextIdx].scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        visible.forEach(function (r) { r.classList.remove('highlighted'); });
        var prevIdx = (currentIdx - 1 + visible.length) % visible.length;
        visible[prevIdx].classList.add('highlighted');
        visible[prevIdx].scrollIntoView({ block: 'nearest' });
      } else if (e.key === 'Enter') {
        e.preventDefault();
        var highlighted = searchOverlay.querySelector('.spotlight__result.highlighted');
        if (highlighted) {
          closeSearch();
          window.location.href = highlighted.getAttribute('href');
        }
      }
    });
  }

  /* ---- 7. Mobile Menu ---- */
  var touchStartX = 0;
  var touchStartY = 0;
  var swipeThreshold = 80;

  function openMobile() {
    mobileMenu.classList.add('open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    mobileToggle.setAttribute('aria-expanded', 'true');
    mobileToggle.setAttribute('aria-label', 'Close menu');
    document.body.style.overflow = 'hidden';
    initNoiseCanvas();
  }

  function closeMobile() {
    mobileMenu.classList.remove('open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    mobileToggle.setAttribute('aria-expanded', 'false');
    mobileToggle.setAttribute('aria-label', 'Open menu');
    document.body.style.overflow = '';
    // Close all accordions
    document.querySelectorAll('.mobile-accordion__panel').forEach(function (p) {
      p.classList.remove('expanded');
    });
    document.querySelectorAll('.mobile-accordion__trigger').forEach(function (t) {
      t.setAttribute('aria-expanded', 'false');
    });
  }

  if (mobileToggle) {
    mobileToggle.addEventListener('click', function () {
      if (mobileToggle.getAttribute('aria-expanded') === 'true') {
        closeMobile();
      } else {
        openMobile();
      }
    });
  }

  // Swipe-to-close gesture
  if (mobileMenu) {
    mobileMenu.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    mobileMenu.addEventListener('touchend', function (e) {
      var deltaX = e.changedTouches[0].clientX - touchStartX;
      var deltaY = Math.abs(e.changedTouches[0].clientY - touchStartY);
      // Swipe right to close
      if (deltaX > swipeThreshold && deltaY < 100) {
        closeMobile();
      }
    }, { passive: true });
  }

  // Close mobile menu on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      if (mobileToggle.getAttribute('aria-expanded') === 'true') {
        closeMobile();
        mobileToggle.focus();
      }
    }
  });

  // Close mobile on link click
  if (mobileMenu) {
    mobileMenu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMobile);
    });
  }

  /* ---- 8. Mobile Accordion ---- */
  document.querySelectorAll('.mobile-accordion__trigger').forEach(function (trigger) {
    trigger.addEventListener('click', function () {
      var idx = trigger.dataset.accordionTrigger;
      var panel = document.querySelector('[data-accordion-panel="' + idx + '"]');
      var expanded = trigger.getAttribute('aria-expanded') === 'true';

      // Close other panels
      document.querySelectorAll('.mobile-accordion__trigger').forEach(function (t) {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          var otherPanel = document.querySelector('[data-accordion-panel="' + t.dataset.accordionTrigger + '"]');
          if (otherPanel) otherPanel.classList.remove('expanded');
        }
      });

      trigger.setAttribute('aria-expanded', !expanded);
      panel.classList.toggle('expanded');
    });
  });

  /* ---- 9. Animated noise background for mobile menu ---- */
  var noiseFrame = null;

  function initNoiseCanvas() {
    if (prefersReducedMotion.matches) return;
    var canvas = document.getElementById('mobile-noise-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    canvas.width = 200;
    canvas.height = 200;

    function drawNoise() {
      var imgData = ctx.createImageData(canvas.width, canvas.height);
      var data = imgData.data;
      for (var i = 0; i < data.length; i += 4) {
        var v = Math.random() * 255;
        data[i] = v;
        data[i + 1] = v;
        data[i + 2] = v;
        data[i + 3] = 12;
      }
      ctx.putImageData(imgData, 0, 0);
      if (mobileMenu.classList.contains('open')) {
        noiseFrame = requestAnimationFrame(drawNoise);
      }
    }

    cancelAnimationFrame(noiseFrame);
    drawNoise();
  }

})();
</script>
