  .mobile-overlay.open .mobile-accordion:nth-child(1) { transition-delay: 0.05s; }
  .mobile-overlay.open .mobile-accordion:nth-child(2) { transition-delay: 0.1s; }
  .mobile-overlay.open .mobile-accordion:nth-child(3) { transition-delay: 0.15s; }
  .mobile-overlay.open .mobile-accordion:nth-child(4) { transition-delay: 0.2s; }
  .mobile-overlay.open .mobile-accordion:nth-child(5) { transition-delay: 0.25s; }

  .mobile-accordion__trigger {
    display: flex;
    align-items: center;
