  .mobile-accordion__trigger[aria-expanded="true"] .mobile-accordion__chevron {
    transform: rotate(180deg);
  }

  .mobile-accordion__panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-accordion__panel.expanded {
    max-height: 400px;
  }

  .mobile-accordion__link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 10px;
    transition: all 0.2s ease;
  }

  .mobile-accordion__link:hover {
    color: var(--text-primary);
    background: var(--surface-container-high);
  }

  .mobile-accordion__link .material-symbols-outlined {
    font-size: 20px;
    color: var(--accent);
  }

  /* ---- Mobile Quick Action Cards ---- */
  .mobile-overlay__actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 32px;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.3s;
  }

  .mobile-overlay.open .mobile-overlay__actions {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-action-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 20px 16px;
    border-radius: 14px;
