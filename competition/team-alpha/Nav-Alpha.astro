---
/*
  COMMAND DECK NAVIGATION — Team Alpha
  Mega-menu, spotlight search, breadcrumbs, scroll progress,
  full-screen mobile with gestures, logo animation, active page indicator.
  Astro v5 + Tailwind CSS v4 + vanilla JS.
*/

const verticals = [
  {
    href: '/verticals/data-centers',
    label: 'Data Centers',
    icon: 'dns',
    accent: '#00E5FF',
    desc: 'Thermal monitoring and infrastructure intelligence for mission-critical facilities.',
  },
  {
    href: '/verticals/energy-grid',
    label: 'Energy Grid',
    icon: 'electric_bolt',
    accent: '#FF8C00',
    desc: 'Transmission line and substation inspection at grid scale.',
  },
  {
    href: '/verticals/security',
    label: 'Security',
    icon: 'shield',
    accent: '#7B61FF',
    desc: 'Autonomous perimeter surveillance and intrusion detection.',
  },
  {
    href: '/verticals/agriculture',
    label: 'Agriculture',
    icon: 'grass',
    accent: '#34D399',
    desc: 'NDVI crop health mapping and precision agriculture analytics.',
  },
];

const navItems = [
  {
    label: 'About Us',
    children: [
      { href: '/about', label: 'Our Mission', icon: 'flag' },
      { href: '/about/team', label: 'Team', icon: 'groups' },
    ],
  },
  {
    label: 'Verticals',
    mega: true,
    children: verticals,
  },
  {
    label: 'Services',
    children: [
      { href: '/services/audit', label: 'Facility Audit', icon: 'search_insights' },
      { href: '/services/deployment', label: 'Autonomous Deployment', icon: 'flight_takeoff' },
    ],
  },
  {
    label: 'Careers',
    children: [
      { href: '/careers', label: 'Open Roles', icon: 'work' },
    ],
  },
  {
    label: 'Blog',
    children: [
      { href: '/blog', label: 'Insights', icon: 'article' },
    ],
  },
];

/* Determine current path for breadcrumbs and active state */
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/' || currentPath === '';

/* Build breadcrumb segments */
const pathSegments = currentPath.split('/').filter(Boolean);
const breadcrumbs = pathSegments.map((seg, i) => {
  const href = '/' + pathSegments.slice(0, i + 1).join('/');
  const label = seg.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  return { href, label };
});
---

<!-- Scroll Progress Indicator -->
<div id="nav-scroll-progress" class="nav-scroll-progress" aria-hidden="true"></div>

<!-- Main Header -->
<header id="site-nav" class="command-deck" role="banner">
  <div class="command-deck__inner">

    <!-- Logo -->
    <a href="/" class="command-deck__logo" aria-label="Jinki — Home">
      <span class="command-deck__logo-icon material-symbols-outlined" aria-hidden="true">radar</span>
      <span class="command-deck__logo-text">Jinki</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="command-deck__nav" aria-label="Main navigation">
      <!-- Active indicator (slides between items) -->
      <div class="nav-active-indicator" id="nav-active-indicator" aria-hidden="true"></div>

      {navItems.map((item, idx) => (
        <div
          class="nav-group"
          data-nav-group={idx}
          data-has-mega={item.mega ? 'true' : 'false'}
        >
          <button
            type="button"
            class="nav-trigger"
            aria-haspopup="true"
            aria-expanded="false"
            data-nav-idx={idx}
          >
            <span class="nav-trigger__label">{item.label}</span>
            <span class="nav-trigger__chevron material-symbols-outlined" aria-hidden="true">expand_more</span>
          </button>

          {/* Mega menu for Verticals */}
          {item.mega ? (
            <div class="mega-panel" role="menu" aria-label={`${item.label} submenu`}>
              <div class="mega-panel__grid">
                {item.children.map((v) => (
                  <a
                    href={v.href}
                    class="mega-card"
                    role="menuitem"
                    style={`--card-accent: ${v.accent};`}
                  >
                    <span
                      class="mega-card__icon material-symbols-outlined"
                      aria-hidden="true"
                      style={`color: ${v.accent};`}
                    >{v.icon}</span>
                    <span class="mega-card__title">{v.label}</span>
                    <span class="mega-card__desc">{v.desc}</span>
                    <span class="mega-card__arrow material-symbols-outlined" aria-hidden="true">arrow_forward</span>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            /* Standard dropdown */
            <div class="dropdown-panel" role="menu" aria-label={`${item.label} submenu`}>
              {item.children.map((child) => (
                <a href={child.href} class="dropdown-item" role="menuitem">
                  <span class="dropdown-item__icon material-symbols-outlined" aria-hidden="true">{child.icon}</span>
                  <span class="dropdown-item__label">{child.label}</span>
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Actions cluster -->
    <div class="command-deck__actions">

      <!-- Search trigger -->
      <button
        id="search-trigger"
        class="action-btn"
        type="button"
        aria-label="Search (Cmd+K)"
      >
        <span class="material-symbols-outlined" aria-hidden="true">search</span>
        <kbd class="search-kbd">K</kbd>
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="action-btn action-btn--theme"
        type="button"
        aria-label="Toggle dark/light mode"
      >
        <span class="material-symbols-outlined icon-dark" aria-hidden="true">dark_mode</span>
        <span class="material-symbols-outlined icon-light" aria-hidden="true">light_mode</span>
      </button>

      <!-- CTA -->
      <a href="#lead-gen" class="command-deck__cta btn-premium">
        Get in Touch
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-toggle"
        class="mobile-hamburger"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Breadcrumb trail (inner pages only) -->
  {!isHome && breadcrumbs.length > 0 && (
    <nav class="breadcrumb-trail" aria-label="Breadcrumb">
      <ol class="breadcrumb-trail__list">
        <li class="breadcrumb-trail__item">
          <a href="/" class="breadcrumb-trail__link">
            <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 14px;">home</span>
          </a>
        </li>
        {breadcrumbs.map((crumb, i) => (
          <li class="breadcrumb-trail__item">
            <span class="breadcrumb-trail__sep" aria-hidden="true">/</span>
            {i === breadcrumbs.length - 1 ? (
              <span class="breadcrumb-trail__current" aria-current="page">{crumb.label}</span>
            ) : (
              <a href={crumb.href} class="breadcrumb-trail__link">{crumb.label}</a>
            )}
          </li>
        ))}
      </ol>
    </nav>
  )}
</header>

<!-- Spotlight Search Overlay -->
<div id="search-overlay" class="spotlight" role="dialog" aria-modal="true" aria-label="Site search" aria-hidden="true">
  <div class="spotlight__backdrop"></div>
  <div class="spotlight__panel">
    <div class="spotlight__input-row">
      <span class="material-symbols-outlined spotlight__icon" aria-hidden="true">search</span>
      <input
        id="search-input"
        class="spotlight__input"
        type="search"
        placeholder="Search Jinki..."
        autocomplete="off"
        aria-label="Search"
      />
      <kbd class="spotlight__esc">ESC</kbd>
    </div>
    <div id="search-suggestions" class="spotlight__suggestions" role="listbox">
      <div class="spotlight__category">
        <span class="spotlight__category-label">Quick Links</span>
        <a href="/verticals/data-centers" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">dns</span>
          <span>Data Centers</span>
          <span class="spotlight__result-type">Vertical</span>
        </a>
        <a href="/verticals/energy-grid" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">electric_bolt</span>
          <span>Energy Grid</span>
          <span class="spotlight__result-type">Vertical</span>
        </a>
        <a href="/verticals/security" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">shield</span>
          <span>Security</span>
          <span class="spotlight__result-type">Vertical</span>
        </a>
        <a href="/verticals/agriculture" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">grass</span>
          <span>Agriculture</span>
          <span class="spotlight__result-type">Vertical</span>
        </a>
      </div>
      <div class="spotlight__category">
        <span class="spotlight__category-label">Services</span>
        <a href="/services/audit" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">search_insights</span>
          <span>Facility Audit</span>
          <span class="spotlight__result-type">Service</span>
        </a>
        <a href="/services/deployment" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">flight_takeoff</span>
          <span>Autonomous Deployment</span>
          <span class="spotlight__result-type">Service</span>
        </a>
      </div>
      <div class="spotlight__category">
        <span class="spotlight__category-label">Company</span>
        <a href="/about" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">flag</span>
          <span>About / Mission</span>
          <span class="spotlight__result-type">Page</span>
        </a>
        <a href="/careers" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">work</span>
          <span>Careers</span>
          <span class="spotlight__result-type">Page</span>
        </a>
        <a href="/blog" class="spotlight__result" role="option">
          <span class="material-symbols-outlined" aria-hidden="true">article</span>
          <span>Blog</span>
          <span class="spotlight__result-type">Page</span>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Full-screen Mobile Menu -->
<div
  id="mobile-menu"
  class="mobile-overlay"
  aria-hidden="true"
  role="dialog"
  aria-label="Mobile navigation"
>
  <!-- Noise canvas for animated background -->
  <canvas id="mobile-noise-canvas" class="mobile-overlay__noise" aria-hidden="true"></canvas>

  <div class="mobile-overlay__content">
    <nav class="mobile-overlay__nav" aria-label="Mobile navigation">
      {navItems.map((item, idx) => (
        <div class="mobile-accordion" data-accordion={idx}>
          <button
            type="button"
            class="mobile-accordion__trigger"
            aria-expanded="false"
            data-accordion-trigger={idx}
          >
            <span class="mobile-accordion__label">{item.label}</span>
            <span class="mobile-accordion__chevron material-symbols-outlined" aria-hidden="true">expand_more</span>
          </button>
          <div class="mobile-accordion__panel" data-accordion-panel={idx}>
            {item.mega ? (
              item.children.map((v) => (
                <a href={v.href} class="mobile-accordion__link" style={`--link-accent: ${v.accent};`}>
                  <span class="material-symbols-outlined" aria-hidden="true" style={`color: ${v.accent};`}>{v.icon}</span>
                  <span>{v.label}</span>
                </a>
              ))
            ) : (
              item.children.map((child) => (
                <a href={child.href} class="mobile-accordion__link">
                  <span class="material-symbols-outlined" aria-hidden="true">{child.icon}</span>
                  <span>{child.label}</span>
                </a>
              ))
            )}
          </div>
        </div>
      ))}
    </nav>

    <!-- Quick action cards at bottom -->
    <div class="mobile-overlay__actions">
      <a href="#lead-gen" class="mobile-action-card mobile-action-card--primary">
        <span class="material-symbols-outlined" aria-hidden="true">mail</span>
        <span class="mobile-action-card__label">Get in Touch</span>
      </a>
      <a href="#lead-gen" class="mobile-action-card">
        <span class="material-symbols-outlined" aria-hidden="true">play_circle</span>
        <span class="mobile-action-card__label">Request Demo</span>
      </a>
    </div>
  </div>
</div>

<style>
  /* =============================================================
     COMMAND DECK NAVIGATION — Scoped Styles
     Tailwind v4 spacing utilities broken — all spacing is inline/CSS.
     ============================================================= */

  /* ---- Scroll Progress ---- */
  .nav-scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: linear-gradient(90deg, #00E5FF, #7B61FF);
    z-index: 1002;
    pointer-events: none;
    will-change: width;
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.4);
  }

  :global([data-theme="light"]) .nav-scroll-progress {
    background: linear-gradient(90deg, #00838f, #4F46E5);
    box-shadow: 0 0 8px rgba(0, 131, 143, 0.3);
  }

  /* ---- Header Shell ---- */
  .command-deck {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    border-bottom: 1px solid transparent;
    transition: background 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                backdrop-filter 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.3s ease;
  }

  .command-deck.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(24px) saturate(1.6);
    -webkit-backdrop-filter: blur(24px) saturate(1.6);
    border-bottom-color: var(--border);
  }

  .command-deck__inner {
    max-width: 1280px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-left: auto;
    margin-right: auto;
    padding: 1rem clamp(20px, 5vw, 80px);
  }

  /* ---- Logo ---- */
  .command-deck__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    z-index: 10;
    position: relative;
  }

  .command-deck__logo-icon {
    font-size: 30px;
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 28;
    color: var(--accent);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1), color 0.3s ease;
    display: inline-block;
  }

  .command-deck__logo:hover .command-deck__logo-icon {
    transform: rotate(90deg);
  }

  .command-deck__logo-text {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text-primary);
    transition: text-shadow 0.4s ease, color 0.3s ease;
  }

  .command-deck__logo:hover .command-deck__logo-text {
    text-shadow: 0 0 20px var(--accent-glow-strong), 0 0 40px var(--accent-glow);
  }

  :global([data-theme="light"]) .command-deck__logo-icon { color: var(--accent); }
  :global([data-theme="light"]) .command-deck__logo-text { color: var(--text-primary); }

  /* ---- Desktop Nav ---- */
  .command-deck__nav {
    display: none;
    align-items: center;
    gap: 4px;
    position: relative;
  }

  @media (min-width: 768px) {
    .command-deck__nav { display: flex; }
  }

  /* ---- Nav Group (each top-level item) ---- */
  .nav-group {
    position: relative;
  }

  .nav-trigger {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 0.5rem 0.75rem;
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-headline);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    position: relative;
    white-space: nowrap;
  }

  .nav-trigger:hover,
  .nav-trigger[aria-expanded="true"] {
    color: var(--text-primary);
  }

  .nav-trigger__chevron {
    font-size: 16px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-trigger[aria-expanded="true"] .nav-trigger__chevron {
    transform: rotate(180deg);
  }

  /* Active page highlight on trigger */
  .nav-trigger.is-active {
    color: var(--accent);
  }

  /* ---- Active Indicator (sliding underline) ---- */
  .nav-active-indicator {
    position: absolute;
    bottom: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
    transition: left 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease;
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 0 8px var(--accent-glow);
  }

  .nav-active-indicator.visible {
    opacity: 1;
  }

  /* ---- Standard Dropdown ---- */
  .dropdown-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 200px;
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
    border-radius: 12px;
    padding: 6px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.25s;
    z-index: 100;
  }

  .dropdown-panel.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0.625rem 1rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.15s ease;
  }

  .dropdown-item:hover,
  .dropdown-item:focus-visible {
    color: var(--text-primary);
    background: var(--surface-container-high);
    transform: translateX(2px);
  }

  .dropdown-item__icon {
    font-size: 18px;
    color: var(--accent);
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
  }

  /* ---- Mega Menu (Verticals) ---- */
  .mega-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    width: max-content;
    max-width: 780px;
    background: var(--glass-bg);
    backdrop-filter: blur(32px) saturate(1.8);
    -webkit-backdrop-filter: blur(32px) saturate(1.8);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
    border-radius: 16px;
    padding: 8px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.3s;
    z-index: 100;
  }

  .mega-panel.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .mega-panel__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 6px;
  }

  @media (max-width: 900px) {
    .mega-panel__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .mega-panel {
      max-width: 420px;
    }
  }

  .mega-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 14px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
    min-width: 170px;
  }

  .mega-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    background: radial-gradient(circle at 30% 30%, var(--card-accent), transparent 70%);
    transition: opacity 0.3s ease;
  }

  .mega-card:hover::before,
  .mega-card:focus-visible::before {
    opacity: 0.08;
  }

  .mega-card:hover,
  .mega-card:focus-visible {
    background: var(--surface-container-high);
    transform: translateY(-2px);
  }

  .mega-card__icon {
    font-size: 26px;
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24;
    position: relative;
    z-index: 1;
  }

  .mega-card__title {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }

  .mega-card__desc {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    line-height: 1.4;
    position: relative;
    z-index: 1;
  }

  .mega-card__arrow {
    font-size: 16px;
    color: var(--text-tertiary);
    transition: transform 0.2s ease, color 0.2s ease;
    position: relative;
    z-index: 1;
    align-self: flex-start;
  }

  .mega-card:hover .mega-card__arrow,
  .mega-card:focus-visible .mega-card__arrow {
    transform: translateX(4px);
    color: var(--card-accent);
  }

  /* ---- Actions cluster ---- */
  .command-deck__actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .action-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  .action-btn:active {
    transform: scale(0.92);
  }

  .action-btn .material-symbols-outlined {
    font-size: 18px;
  }

  /* Search kbd badge */
  .search-kbd {
    position: absolute;
    top: -6px;
    right: -6px;
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: 600;
    background: var(--surface-container-high);
    color: var(--text-tertiary);
    padding: 1px 4px;
    border-radius: 4px;
    border: 1px solid var(--border);
    line-height: 1.3;
    pointer-events: none;
  }

  /* Theme toggle icons */
  .icon-light { display: none; }
  :global([data-theme="light"]) .icon-dark { display: none; }
