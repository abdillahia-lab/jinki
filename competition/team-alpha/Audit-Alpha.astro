---
/*
  TEAM ALPHA — Facility Intelligence Audit | Jinki Aerial Intelligence

  Redesigned service page with:
  1. Blueprint grid hero with animated scan lines
  2. 6-step expandable process flow
  3. Deliverable mockup (report preview with TOC, thermal overlays, priority matrix)
  4. Pricing transparency card
  5. FAQ accordion
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

const process = [
  {
    step: '01',
    title: 'Planning',
    icon: 'architecture',
    summary: 'Site assessment, scope definition, and mission design.',
    details: 'We study your facility layout, identify priority zones, coordinate airspace authorization, and design a flight plan tailored to your geometry. Every engagement starts with a conversation about what matters to your operations team — not a generic questionnaire.',
  },
  {
    step: '02',
    title: 'Pre-flight',
    icon: 'checklist',
    summary: 'Regulatory compliance, safety protocols, equipment calibration.',
    details: 'Airspace coordination with local authorities, safety risk assessment, sensor calibration, and weather window selection. All regulatory paperwork handled by Jinki — your team provides site access, we handle everything else.',
  },
  {
    step: '03',
    title: 'Data Capture',
    icon: 'satellite_alt',
    summary: 'Multi-sensor aerial data collection across your entire facility.',
    details: 'Thermal, visual, and multispectral data capture covering every rooftop, mechanical system, perimeter section, and exterior surface. The H30T thermal sensor captures radiometric data at 640x512 resolution. Most facilities complete data capture in a single day.',
  },
  {
    step: '04',
    title: 'AI Analysis',
    icon: 'model_training',
    summary: 'Automated anomaly detection, classification, and severity ranking.',
    details: 'Raw data feeds our analytics pipeline: thermal anomaly detection identifies hot spots and insulation failures, computer vision classifies structural damage by severity, and pattern recognition flags trends across thousands of data points. Every finding is cross-referenced against industry baselines.',
  },
  {
    step: '05',
    title: 'Report Generation',
    icon: 'summarize',
    summary: 'Severity-ranked findings with visual evidence and cost estimates.',
    details: 'The Facility Intelligence Report is assembled: each finding includes thermal overlay imagery, severity classification, remediation recommendations, estimated repair costs, and suggested timelines. Compliance documentation for NFPA 70B, ASHRAE, and environmental requirements is generated automatically.',
  },
  {
    step: '06',
    title: 'Recommendations',
    icon: 'assignment_turned_in',
    summary: 'Walk-through review and prioritized action plan for your team.',
    details: 'We present every finding to your team in a live review session. Questions answered, priorities confirmed, and a clear remediation roadmap established. You get a work order, not a file drop. Optional: recurring assessment scheduling to track remediation progress over time.',
  },
];

const reportSections = [
  { icon: 'toc', label: 'Executive Summary', desc: 'Key findings, risk overview, and recommended priorities' },
  { icon: 'thermostat', label: 'Thermal Analysis', desc: 'Full radiometric mapping with anomaly classification' },
  { icon: 'roofing', label: 'Structural Assessment', desc: 'Damage inventory with visual and thermal evidence' },
  { icon: 'security', label: 'Security Evaluation', desc: 'Coverage gaps, blind spots, and vulnerability mapping' },
  { icon: 'priority_high', label: 'Priority Matrix', desc: 'Severity-ranked findings with remediation timelines' },
  { icon: 'attach_money', label: 'Cost Estimates', desc: 'Per-finding repair costs and total remediation budget' },
];

const pricingIncludes = [
  'Full-facility aerial data capture (thermal + visual + multispectral)',
  'AI-powered anomaly detection and severity classification',
  'Facility Intelligence Report with visual evidence',
  'Remediation priorities with cost estimates',
  'Compliance documentation (NFPA 70B, ASHRAE)',
  'Live walk-through review with your team',
  'Digital asset delivery (orthomosaics, 3D models)',
  'Post-engagement support for 30 days',
];

const faqs = [
  {
    q: 'How long does a Facility Intelligence Audit take?',
    a: 'Most facilities complete the entire process in two to three weeks. Aerial data capture is typically a single day on-site. AI analysis and report generation take 5-7 business days. The walk-through review is scheduled at your convenience.',
  },
  {
    q: 'What size facilities can you assess?',
    a: 'We audit facilities from 50,000 sq ft single buildings to multi-million sq ft campus environments. Larger sites may require multiple capture days but follow the same six-step process and pricing model.',
  },
  {
    q: 'Do we need to shut down operations during the audit?',
    a: 'No. Aerial operations are conducted above your facility with zero impact on ground-level operations. There is no scaffolding, no roof access, and no disruption to your team or tenants.',
  },
  {
    q: 'What sensors do you use?',
    a: 'Our primary platform carries the H30T thermal sensor (640x512 radiometric), a 40MP wide-angle visual camera, and optional LiDAR for volumetric mapping. Sensor selection is tailored to your assessment requirements.',
  },
  {
    q: 'Can we schedule recurring assessments?',
    a: 'Absolutely. Many clients move to quarterly or semi-annual assessments after their initial audit. Recurring engagements include trend analysis showing remediation progress and new findings over time.',
  },
  {
    q: 'How is this different from a traditional inspection?',
    a: 'Traditional inspections are manual, subjective, and limited by physical access. Our aerial approach covers every surface in hours (not weeks), uses calibrated sensors instead of human judgment, and delivers AI-ranked findings with cost estimates — not a checklist of observations.',
  },
];
---

<Layout title="Facility Intelligence Audit — Jinki Aerial Intelligence" description="Comprehensive aerial assessment of your facility's thermal health, structural condition, and security posture. Six-step process from scoping to actionable recommendations.">
  <Nav />
  <main id="main-content">

    <!-- ============ HERO ============ -->
    <section class="audit-hero" aria-label="Facility Intelligence Audit">
      <div class="blueprint-bg" aria-hidden="true">
        <div class="blueprint-grid"></div>
        <div class="blueprint-scan-h"></div>
        <div class="blueprint-scan-v"></div>
        <div class="blueprint-crosshair"></div>
        <div class="blueprint-corner tl"></div>
        <div class="blueprint-corner tr"></div>
        <div class="blueprint-corner bl"></div>
        <div class="blueprint-corner br"></div>
      </div>
      <div class="hero-inner">
        <div class="hero-content reveal">
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">Service</span>
          </div>
          <h1 class="hero-title">
            Facility<br/>
            <span class="gradient-text-cyan">Intelligence Audit</span>
          </h1>
          <p class="hero-subtitle">
            One engagement. Every surface, every system, every vulnerability — mapped,
            analyzed, and ranked. You get a prioritized work order with cost estimates,
            not raw data and another dashboard.
          </p>
          <div class="hero-actions">
            <a href="#lead-gen" class="btn-premium hero-cta">Schedule Your Audit</a>
            <a href="#process" class="hero-cta-secondary">
              <span class="material-symbols-outlined" style="font-size: 18px; font-variation-settings: 'FILL' 1;" aria-hidden="true">arrow_downward</span>
              See the Process
            </a>
          </div>
          <div class="hero-proof" aria-hidden="true">
            <div class="proof-item">
              <span class="proof-value">6</span>
              <span class="proof-label">Step Process</span>
            </div>
            <div class="proof-divider"></div>
            <div class="proof-item">
              <span class="proof-value">1 Day</span>
              <span class="proof-label">On-site Capture</span>
            </div>
            <div class="proof-divider"></div>
            <div class="proof-item">
              <span class="proof-value">2-3 Wks</span>
              <span class="proof-label">To Final Report</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 6-STEP PROCESS ============ -->
    <section id="process" class="section" aria-label="The Audit Process">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">The Process</span>
          </div>
          <h2>Six Steps to<br/>Actionable Intelligence</h2>
          <p class="section-subtitle">
            From initial scoping call to prioritized recommendations report.
            Click any step to see the full detail.
          </p>
        </div>

        <div class="process-flow">
          <div class="process-connector-line" aria-hidden="true"></div>
          {process.map((step, i) => (
            <div class={`process-step reveal reveal-delay-${(i % 4) + 1}`} data-step={step.step}>
              <button
                class="process-step-header"
                aria-expanded="false"
                aria-controls={`step-detail-${step.step}`}
              >
                <div class="step-marker">
                  <span class="step-number">{step.step}</span>
                </div>
                <div class="step-summary">
                  <div class="step-icon-title">
                    <span class="material-symbols-outlined step-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{step.icon}</span>
                    <h3>{step.title}</h3>
                  </div>
                  <p class="step-brief">{step.summary}</p>
                </div>
                <span class="material-symbols-outlined step-chevron" aria-hidden="true">expand_more</span>
              </button>
              <div class="process-step-detail" id={`step-detail-${step.step}`} role="region" aria-label={`${step.title} details`}>
                <div class="step-detail-inner">
                  <p>{step.details}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ DELIVERABLE MOCKUP ============ -->
    <section class="section" style="background: var(--surface-dim);" aria-label="The Deliverable">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">The Deliverable</span>
          </div>
          <h2>The Facility<br/>Intelligence Report</h2>
          <p class="section-subtitle">
            Your team receives a work order, not a file dump. Every finding is
            ranked by severity, costed for remediation, and scheduled for action.
          </p>
        </div>

        <div class="report-preview reveal">
          <div class="report-window">
            <div class="report-titlebar">
              <div class="report-dots">
                <span class="rdot" style="background: #FF6B35;"></span>
                <span class="rdot" style="background: #FFBD2E;"></span>
                <span class="rdot" style="background: #27C93F;"></span>
              </div>
              <span class="report-filename">Facility-Intelligence-Report_2026.pdf</span>
            </div>
            <div class="report-content">
              <!-- TOC Sidebar -->
              <div class="report-toc">
                <span class="toc-title">CONTENTS</span>
                {reportSections.map((sec, i) => (
                  <div class={`toc-item ${i === 0 ? 'active' : ''}`}>
                    <span class="material-symbols-outlined toc-icon" style="font-variation-settings: 'FILL' 1; font-size: 16px;" aria-hidden="true">{sec.icon}</span>
                    <span class="toc-label">{sec.label}</span>
                  </div>
                ))}
              </div>
              <!-- Report Body Preview -->
              <div class="report-body-preview">
                <!-- Priority Matrix Preview -->
                <div class="report-section-preview">
                  <span class="rsp-label">PRIORITY MATRIX</span>
                  <div class="priority-matrix">
                    <div class="matrix-row critical">
                      <span class="matrix-severity">CRITICAL</span>
                      <span class="matrix-finding">Cooling unit T-4 — thermal runaway risk</span>
                      <span class="matrix-cost">$12,400</span>
                      <span class="matrix-timeline">Immediate</span>
                    </div>
                    <div class="matrix-row high">
                      <span class="matrix-severity">HIGH</span>
                      <span class="matrix-finding">Roof membrane degradation — Bldg C</span>
                      <span class="matrix-cost">$34,200</span>
                      <span class="matrix-timeline">30 days</span>
                    </div>
                    <div class="matrix-row medium">
                      <span class="matrix-severity">MEDIUM</span>
                      <span class="matrix-finding">Camera blind spot — NE perimeter gate</span>
                      <span class="matrix-cost">$2,800</span>
                      <span class="matrix-timeline">60 days</span>
                    </div>
                    <div class="matrix-row low">
                      <span class="matrix-severity">LOW</span>
                      <span class="matrix-finding">Insulation gap — mechanical room 2</span>
                      <span class="matrix-cost">$1,600</span>
                      <span class="matrix-timeline">90 days</span>
                    </div>
                  </div>
                </div>
                <!-- Thermal Overlay Preview -->
                <div class="report-section-preview thermal-preview">
                  <span class="rsp-label">THERMAL OVERLAY</span>
                  <div class="thermal-mockup">
                    <div class="thermal-grid-bg"></div>
                    <div class="thermal-hotspot hs-1" aria-hidden="true">
                      <span class="hs-ring"></span>
                      <span class="hs-label">T-4: 89.2C</span>
                    </div>
                    <div class="thermal-hotspot hs-2" aria-hidden="true">
                      <span class="hs-ring"></span>
                      <span class="hs-label">R-C: 42.1C</span>
                    </div>
                    <div class="thermal-scale" aria-hidden="true">
                      <span>20C</span>
                      <div class="scale-bar"></div>
                      <span>95C</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Report Sections Grid -->
        <div class="report-sections-grid" style="margin-top: 48px;">
          {reportSections.map((sec, i) => (
            <div class={`report-section-card reveal reveal-delay-${(i % 3) + 1}`}>
              <span class="material-symbols-outlined rsc-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{sec.icon}</span>
              <h3>{sec.label}</h3>
              <p>{sec.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ PRICING ============ -->
    <section class="section" aria-label="Pricing">
      <div class="section-inner">
        <div class="pricing-layout reveal">
          <div class="pricing-text">
            <div class="eyebrow">
              <span class="eyebrow-line"></span>
              <span class="eyebrow-text">Pricing</span>
            </div>
            <h2>Transparent Pricing.<br/>No Hidden Fees.</h2>
            <p class="pricing-lead">
              Every audit includes the full six-step process, AI analysis, and
              the complete Facility Intelligence Report. Pricing scales with
              facility size — not with the number of findings.
            </p>
          </div>
          <div class="pricing-card">
            <div class="pricing-card-inner">
              <div class="pricing-badge">Most Popular</div>
              <span class="pricing-label">Facility Intelligence Audit</span>
              <div class="pricing-amount">
                <span class="pricing-from">Starting at</span>
                <span class="pricing-number">$4,500</span>
                <span class="pricing-per">per engagement</span>
              </div>
              <div class="pricing-divider"></div>
              <ul class="pricing-includes" role="list">
                {pricingIncludes.map(item => (
                  <li>
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; color: #00E5FF; font-size: 18px; flex-shrink: 0;" aria-hidden="true">check_circle</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#lead-gen" class="btn-premium pricing-cta">Get a Custom Quote</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Frequently Asked Questions">
      <div class="section-inner" style="max-width: 800px;">
        <div class="section-header reveal">
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">FAQ</span>
          </div>
          <h2>Common Questions</h2>
        </div>

        <div class="faq-list">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal reveal-delay-${(i % 3) + 1}`}>
              <button class="faq-trigger" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
                <span class="faq-question">{faq.q}</span>
                <span class="material-symbols-outlined faq-chevron" aria-hidden="true">expand_more</span>
              </button>
              <div class="faq-answer" id={`faq-answer-${i}`} role="region" aria-label={faq.q}>
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <LeadGen />
  </main>
  <Footer />
</Layout>

<script>
  // Process step expand/collapse
  document.querySelectorAll('.process-step-header').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const detail = btn.nextElementSibling as HTMLElement;

      // Close all others
      document.querySelectorAll('.process-step-header').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const otherDetail = other.nextElementSibling as HTMLElement;
          if (otherDetail) otherDetail.style.maxHeight = '0';
        }
      });

      btn.setAttribute('aria-expanded', String(!expanded));
      if (!expanded && detail) {
        detail.style.maxHeight = detail.scrollHeight + 'px';
      } else if (detail) {
        detail.style.maxHeight = '0';
      }
    });
  });

  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answer = btn.nextElementSibling as HTMLElement;

      document.querySelectorAll('.faq-trigger').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const otherAnswer = other.nextElementSibling as HTMLElement;
          if (otherAnswer) otherAnswer.style.maxHeight = '0';
        }
      });

      btn.setAttribute('aria-expanded', String(!expanded));
      if (!expanded && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
      } else if (answer) {
        answer.style.maxHeight = '0';
      }
    });
  });
</script>

<style>
  /* ============================================================
     HERO — Blueprint Grid Background
     ============================================================ */
  .audit-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 160px clamp(20px, 5vw, 80px) 80px;
    background: var(--surface-container-lowest);
    overflow: hidden;
  }

  .blueprint-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .blueprint-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px),
      linear-gradient(rgba(0, 229, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.015) 1px, transparent 1px);
    background-size: 120px 120px, 120px 120px, 24px 24px, 24px 24px;
    animation: grid-drift 40s linear infinite;
  }

  @keyframes grid-drift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(24px, 24px); }
  }

  .blueprint-scan-h {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(0, 229, 255, 0.4) 30%, rgba(0, 229, 255, 0.6) 50%, rgba(0, 229, 255, 0.4) 70%, transparent 100%);
    animation: scan-h 6s ease-in-out infinite;
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.2);
  }

  @keyframes scan-h {
    0%, 100% { top: 10%; opacity: 0.5; }
    50% { top: 85%; opacity: 0.8; }
  }

  .blueprint-scan-v {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 229, 255, 0.3) 30%, rgba(0, 229, 255, 0.5) 50%, rgba(0, 229, 255, 0.3) 70%, transparent 100%);
    animation: scan-v 8s ease-in-out infinite;
  }

  @keyframes scan-v {
    0%, 100% { left: 5%; opacity: 0.3; }
    50% { left: 90%; opacity: 0.5; }
  }

  .blueprint-crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60px;
    height: 60px;
    transform: translate(-50%, -50%);
    border: 1px solid rgba(0, 229, 255, 0.08);
    border-radius: 50%;
    animation: crosshair-pulse 4s ease-in-out infinite;
  }

  .blueprint-crosshair::before,
  .blueprint-crosshair::after {
    content: '';
    position: absolute;
    background: rgba(0, 229, 255, 0.06);
  }

  .blueprint-crosshair::before {
    top: 50%;
    left: -20px;
    right: -20px;
    height: 1px;
  }

  .blueprint-crosshair::after {
    left: 50%;
    top: -20px;
    bottom: -20px;
    width: 1px;
  }

  @keyframes crosshair-pulse {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -50%) scale(1.3); }
  }

  .blueprint-corner {
    position: absolute;
    width: 40px;
    height: 40px;
  }

  .blueprint-corner::before,
  .blueprint-corner::after {
    content: '';
    position: absolute;
    background: rgba(0, 229, 255, 0.15);
  }

  .blueprint-corner.tl { top: 40px; left: 40px; }
  .blueprint-corner.tl::before { top: 0; left: 0; width: 20px; height: 1px; }
  .blueprint-corner.tl::after { top: 0; left: 0; width: 1px; height: 20px; }

  .blueprint-corner.tr { top: 40px; right: 40px; }
  .blueprint-corner.tr::before { top: 0; right: 0; width: 20px; height: 1px; }
  .blueprint-corner.tr::after { top: 0; right: 0; width: 1px; height: 20px; }

  .blueprint-corner.bl { bottom: 40px; left: 40px; }
  .blueprint-corner.bl::before { bottom: 0; left: 0; width: 20px; height: 1px; }
  .blueprint-corner.bl::after { bottom: 0; left: 0; width: 1px; height: 20px; }

  .blueprint-corner.br { bottom: 40px; right: 40px; }
  .blueprint-corner.br::before { bottom: 0; right: 0; width: 20px; height: 1px; }
  .blueprint-corner.br::after { bottom: 0; right: 0; width: 1px; height: 20px; }

  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 720px;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
  }

  .hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 5vw + 0.5rem, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .gradient-text-cyan {
    background: linear-gradient(135deg, #00E5FF, #00a8b5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.1875rem);
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 580px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 48px;
  }

  .hero-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.875rem 2rem;
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
    background: linear-gradient(135deg, #00E5FF, #00a8b5);
  }

  .hero-cta:hover {
    box-shadow: 0 0 30px rgba(0, 229, 255, 0.3);
