---
/*
  Blog Post Page — Team Alpha Redesign
  Jinki Aerial Intelligence

  Features:
  - Reading progress bar (gradient, fixed top)
  - Side table of contents (highlights current section)
  - Drop caps on first paragraph
  - Beautiful article typography
  - Code block styling with syntax highlighting
  - Related posts section
  - Share buttons (Twitter, LinkedIn, copy link) with tooltips
  - Author card with avatar placeholder and bio
  - Estimated read time in header
  - Dark/light theme support
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Calculate read time
const wordCount = (post.body || '').split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 230));

// Get related posts (same tags, excluding current)
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const related = allPosts
  .filter(p => p.id !== post.id && p.data.tags.some(t => post.data.tags.includes(t)))
  .slice(0, 3);

// If not enough related by tag, fill with recent
const relatedPosts = related.length >= 2
  ? related
  : [...related, ...allPosts.filter(p => p.id !== post.id && !related.includes(p))].slice(0, 3);

// Tag color map
const tagColors: Record<string, string> = {
  'data centers': '#00E5FF',
  'thermal': '#FF6B35',
  'monitoring': '#FF8C00',
  'infrastructure': '#7B61FF',
  'AI': '#34D399',
  'inspection': '#10B981',
  'security': '#4F46E5',
  'agriculture': '#34D399',
  'energy': '#FF8C00',
};

function getTagColor(tag: string): string {
  return tagColors[tag.toLowerCase()] || '#00E5FF';
}

const shareUrl = `https://jinki.ai/blog/${post.id}`;
const shareTitle = post.data.title;
---

<Layout title={`${post.data.title} — Jinki Blog`} description={post.data.description}>
  <Nav />

  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="reading-progress" role="progressbar" aria-valuenow={0} aria-valuemin={0} aria-valuemax={100} aria-label="Reading progress"></div>

  <main id="main-content" class="post-page" style="padding-top: 100px;">
    <div class="post-layout section-inner">

      <!-- Side ToC (Desktop) -->
      {headings.length > 0 && (
        <aside class="toc-sidebar" aria-label="Table of contents">
          <div class="toc-container">
            <div class="toc-label" style="margin-bottom: 12px;">On this page</div>
            <nav class="toc-nav">
              <ul class="toc-list">
                {headings.filter(h => h.depth <= 3).map(heading => (
                  <li class={`toc-item toc-depth-${heading.depth}`}>
                    <a href={`#${heading.slug}`} class="toc-link" data-slug={heading.slug}>
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      )}

      <!-- Article -->
      <article class="post-article" itemscope itemtype="https://schema.org/BlogPosting">
        <!-- Breadcrumb -->
        <nav class="breadcrumb reveal" aria-label="Breadcrumb" style="margin-bottom: 32px;">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{post.data.title}</span>
        </nav>

        <!-- Header -->
        <header class="post-header reveal" style="margin-bottom: 48px;">
          <div class="post-tags-row" style="margin-bottom: 16px;">
            {post.data.tags.map(tag => (
              <span class="post-tag" style={`--tag-color: ${getTagColor(tag)}`}>{tag}</span>
            ))}
          </div>

          <h1 itemprop="headline" style="margin-bottom: 16px;">{post.data.title}</h1>
          <p class="post-desc" itemprop="description">{post.data.description}</p>

          <div class="post-meta-bar" style="margin-top: 24px;">
            <div class="author-inline">
              <div class="author-avatar-sm" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <span itemprop="author">{post.data.author}</span>
            </div>
            <span class="meta-divider" aria-hidden="true"></span>
            <time datetime={post.data.date.toISOString()} itemprop="datePublished">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="meta-divider" aria-hidden="true"></span>
            <span class="read-time-badge">{readTime} min read</span>
          </div>
        </header>

        <!-- Post Content -->
        <div class="post-content reveal reveal-delay-1" id="post-content" itemprop="articleBody">
          <Content />
        </div>

        <!-- Share Buttons -->
        <div class="share-bar" style="margin-top: 48px; padding-top: 32px;">
          <span class="share-label">Share this post</span>
          <div class="share-buttons" style="margin-top: 12px;">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareTitle)}&url=${encodeURIComponent(shareUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              aria-label="Share on X (Twitter)"
              title="Share on X"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn"
              aria-label="Share on LinkedIn"
              title="Share on LinkedIn"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <button
              class="share-btn copy-link-btn"
              aria-label="Copy link to clipboard"
              title="Copy link"
              data-url={shareUrl}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
              </svg>
              <span class="copy-tooltip">Copied!</span>
            </button>
          </div>
        </div>

        <!-- Author Card -->
        <div class="author-card glass-panel" style="margin-top: 48px; padding: 24px; border-radius: 12px;">
          <div class="author-card-inner">
            <div class="author-avatar" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <div class="author-info">
              <div class="author-name">{post.data.author}</div>
              <p class="author-bio">
                Jinki Aerial Intelligence delivers autonomous inspection, thermal monitoring, and predictive analytics for critical infrastructure.
              </p>
            </div>
          </div>
        </div>

        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <section class="related-section" style="margin-top: 64px;" aria-label="Related posts">
            <h2 class="related-heading" style="margin-bottom: 24px;">Related Posts</h2>
            <div class="related-grid">
              {relatedPosts.map(rp => (
                <a href={`/blog/${rp.id}`} class="related-card glass-panel">
                  <div class="related-card-inner" style="padding: 20px;">
                    <div class="related-meta" style="margin-bottom: 8px;">
                      <time datetime={rp.data.date.toISOString()}>
                        {rp.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                      </time>
                    </div>
                    <h3 class="related-title">{rp.data.title}</h3>
                    <p class="related-desc" style="margin-top: 8px;">{rp.data.description}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Back Link -->
        <div class="post-footer" style="margin-top: 48px; padding-top: 32px;">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="19" y1="12" x2="5" y2="12"/>
              <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Blog
          </a>
        </div>
      </article>
    </div>
  </main>
</Layout>

<style>
  /* ---- Reading Progress Bar ---- */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), #7B61FF, #FF6B35);
    z-index: 1100;
    transition: width 0.05s linear;
    box-shadow: 0 0 12px var(--accent-glow-strong);
  }

  /* ---- Page Layout ---- */
  .post-page {
    min-height: 100vh;
    background: var(--bg-primary);
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr minmax(0, 720px) 1fr;
    gap: 0;
    position: relative;
  }

  .post-article {
    grid-column: 2;
    padding-bottom: 80px;
  }

  /* ---- ToC Sidebar ---- */
  .toc-sidebar {
    grid-column: 3;
    grid-row: 1;
    position: relative;
  }

  .toc-container {
    position: sticky;
    top: 120px;
    padding-left: 48px;
    max-width: 220px;
  }

  .toc-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin-bottom: 4px;
  }

  .toc-depth-3 {
    padding-left: 16px;
  }

  .toc-link {
    display: block;
    font-size: 13px;
    line-height: 1.4;
    color: var(--text-tertiary);
    text-decoration: none;
    padding: 4px 0 4px 12px;
    border-left: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .toc-link:hover {
    color: var(--text-primary);
  }

  .toc-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  /* ---- Breadcrumb ---- */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-tertiary);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb [aria-current="page"] {
    color: var(--text-tertiary);
    max-width: 300px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ---- Post Header ---- */
  .post-tags-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-tag {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 12px;
    border-radius: 100px;
    background: color-mix(in srgb, var(--tag-color) 15%, transparent);
    color: var(--tag-color);
    border: 1px solid color-mix(in srgb, var(--tag-color) 25%, transparent);
  }

  .post-header h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.1;
  }

  .post-desc {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .post-meta-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    font-size: 14px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .author-inline {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    color: var(--text-secondary);
  }

  .author-avatar-sm {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
  }

  .meta-divider {
    width: 1px;
    height: 16px;
    background: var(--border-hover);
  }

  .read-time-badge {
    background: var(--accent-glow);
    color: var(--accent);
    padding: 2px 10px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 500;
  }

  /* ---- Post Content — Article Typography ---- */
  .post-content {
    font-size: 18px;
    line-height: 1.85;
    color: var(--text-secondary);
  }

  /* Drop cap on first paragraph */
  .post-content :global(> p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-headline);
    font-size: 3.5em;
    font-weight: 700;
    line-height: 0.8;
    padding-right: 8px;
    padding-top: 4px;
    color: var(--accent);
  }

  .post-content :global(h2) {
    font-size: 1.6rem;
    margin-top: 56px;
    margin-bottom: 16px;
    color: var(--text-primary);
    scroll-margin-top: 80px;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 40px;
    margin-bottom: 12px;
    color: var(--text-primary);
    scroll-margin-top: 80px;
  }

  .post-content :global(p) {
    margin-bottom: 24px;
    max-width: none;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
    color: var(--text-secondary);
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 0.2s ease;
  }

  .post-content :global(a:hover) {
    text-decoration-color: transparent;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 20px;
    margin: 32px 0;
    font-style: italic;
    color: var(--text-tertiary);
    font-size: 1.05em;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    padding: 2px 8px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--accent);
  }

  .post-content :global(pre) {
    background: var(--surface-container-lowest);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px 24px;
    margin: 24px 0;
    overflow-x: auto;
    font-size: 14px;
    line-height: 1.7;
  }

  .post-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: var(--text-secondary);
  }

  .post-content :global(img) {
    max-width: 100%;
    border-radius: 10px;
    margin: 32px 0;
  }

  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--border);
    margin: 48px 0;
  }

  .post-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* ---- Share Bar ---- */
  .share-bar {
    border-top: 1px solid var(--border);
  }

  .share-label {
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }

  .share-buttons {
    display: flex;
    gap: 10px;
  }

  .share-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--glass-bg);
    color: var(--text-secondary);
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .share-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
  }

  .copy-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    font-size: 12px;
    font-weight: 500;
    color: #fff;
    background: var(--accent);
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .copy-tooltip.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* ---- Author Card ---- */
  .author-card-inner {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    position: relative;
    z-index: 3;
  }

  .author-avatar {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
  }

  .author-name {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .author-bio {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  /* ---- Related Posts ---- */
  .related-heading {
    font-size: 1.3rem;
    color: var(--text-primary);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .related-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-glow);
  }

  .related-card:hover .related-title {
    color: var(--accent);
  }

  .related-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .related-title {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .related-desc {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ---- Back Link ---- */
  .post-footer {
    border-top: 1px solid var(--border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-label);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, gap 0.2s ease;
  }

  .back-link:hover {
    color: var(--accent);
    gap: 12px;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1100px) {
    .post-layout {
      grid-template-columns: 1fr minmax(0, 720px);
    }

    .toc-sidebar {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .post-layout {
      grid-template-columns: 1fr;
    }

    .post-header h1 {
      font-size: clamp(1.6rem, 5vw, 2.2rem);
    }

    .post-content {
      font-size: 16px;
    }

    .post-content :global(> p:first-of-type::first-letter) {
      font-size: 3em;
    }

    .post-meta-bar {
      gap: 8px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Reading progress bar
  function updateProgress() {
    const article = document.getElementById('post-content');
    const bar = document.getElementById('reading-progress');
    if (!article || !bar) return;

    const rect = article.getBoundingClientRect();
    const articleTop = rect.top + window.scrollY;
    const articleHeight = rect.height;
    const scrolled = window.scrollY - articleTop + window.innerHeight * 0.3;
    const progress = Math.min(100, Math.max(0, (scrolled / articleHeight) * 100));

    bar.style.width = progress + '%';
    bar.setAttribute('aria-valuenow', String(Math.round(progress)));
  }

  // ToC active section tracking
  function updateToC() {
    const headings = document.querySelectorAll('.post-content h2, .post-content h3');
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (headings.length === 0 || links.length === 0) return;

    let activeId = '';
    headings.forEach(h => {
      const rect = h.getBoundingClientRect();
      if (rect.top <= 100) {
        activeId = h.id;
      }
    });

    links.forEach(link => {
      if (link.dataset.slug === activeId) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
  }

  // Scroll handler
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        updateProgress();
        updateToC();
        ticking = false;
      });
      ticking = true;
    }
  });

  // Copy link button
  document.addEventListener('DOMContentLoaded', () => {
    const copyBtn = document.querySelector<HTMLButtonElement>('.copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const url = copyBtn.dataset.url || window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          const tooltip = copyBtn.querySelector('.copy-tooltip');
          tooltip?.classList.add('show');
          setTimeout(() => tooltip?.classList.remove('show'), 2000);
        } catch {
          // Fallback
          const input = document.createElement('input');
          input.value = url;
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          document.body.removeChild(input);
          const tooltip = copyBtn.querySelector('.copy-tooltip');
          tooltip?.classList.add('show');
          setTimeout(() => tooltip?.classList.remove('show'), 2000);
        }
      });
    }

    // Initial calls
    updateProgress();
    updateToC();
  });
</script>
