---
/*
  ThemeToggle-Alpha — Animated sun/moon morphing toggle
  3 themes: Dark (default), Light, Auto (follows system)
  Smooth circular reveal clip-path transition from toggle position.
  Persists choice in localStorage; preload script prevents flash.
*/
---

<!-- Preload script: runs before paint to prevent theme flash -->
<script is:inline>
(function() {
  const STORAGE_KEY = 'jinki-theme-alpha';
  const stored = localStorage.getItem(STORAGE_KEY);
  let theme = stored || 'dark';

  if (theme === 'auto') {
    theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', theme);
    document.documentElement.setAttribute('data-theme-mode', 'auto');
  } else {
    document.documentElement.setAttribute('data-theme', theme);
    document.documentElement.setAttribute('data-theme-mode', theme);
  }
})();
</script>

<div class="theme-toggle-alpha" role="group" aria-label="Theme selection">
  <button
    class="toggle-btn"
    id="theme-toggle-alpha"
    type="button"
    aria-label="Toggle theme"
    title="Switch theme"
  >
    <div class="toggle-track">
      <!-- Sun icon -->
      <svg class="icon icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="4" />
        <line class="ray ray-1" x1="12" y1="1"  x2="12" y2="4" />
        <line class="ray ray-2" x1="19.8" y1="4.2" x2="17.7" y2="6.3" />
        <line class="ray ray-3" x1="23" y1="12" x2="20" y2="12" />
        <line class="ray ray-4" x1="19.8" y1="19.8" x2="17.7" y2="17.7" />
        <line class="ray ray-5" x1="12" y1="23" x2="12" y2="20" />
        <line class="ray ray-6" x1="4.2" y1="19.8" x2="6.3" y2="17.7" />
        <line class="ray ray-7" x1="1"  y1="12" x2="4"  y2="12" />
        <line class="ray ray-8" x1="4.2" y1="4.2" x2="6.3" y2="6.3" />
      </svg>
      <!-- Moon icon -->
      <svg class="icon icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        <circle class="moon-star star-1" cx="18" cy="6" r="0.8" fill="currentColor" stroke="none" />
        <circle class="moon-star star-2" cx="20" cy="10" r="0.5" fill="currentColor" stroke="none" />
      </svg>
      <!-- Auto icon -->
      <svg class="icon icon-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 3a9 9 0 0 1 0 18" fill="currentColor" opacity="0.3" />
        <text x="12" y="15" text-anchor="middle" font-size="7" font-weight="700" fill="currentColor" stroke="none" font-family="var(--font-label)">A</text>
      </svg>
    </div>
    <span class="toggle-label" id="theme-label-alpha" aria-live="polite">Dark</span>
  </button>
</div>

<style>
  .theme-toggle-alpha {
    position: relative;
    z-index: 200;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface-container);
    border: 1px solid var(--glass-border);
    border-radius: 9999px;
    padding: 6px 14px 6px 8px;
    cursor: pointer;
    color: var(--text-secondary);
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 250ms ease, border-color 250ms ease, color 250ms ease, box-shadow 250ms ease;
    outline: none;
    position: relative;
    overflow: hidden;
  }

  .toggle-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
  }

  .toggle-btn:hover {
    background: var(--surface-container-high);
    border-color: var(--border-hover);
    color: var(--text-primary);
  }

  .toggle-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .toggle-btn:active {
    transform: scale(0.96);
  }

  .toggle-track {
    position: relative;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  .icon {
    position: absolute;
    inset: 0;
    width: 22px;
    height: 22px;
    transition: opacity 350ms ease, transform 350ms ease;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* States: show sun in light, moon in dark, auto in auto */
  .icon-sun {
    opacity: 0;
    transform: rotate(-45deg) scale(0.7);
  }

  .icon-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .icon-auto {
    opacity: 0;
    transform: rotate(45deg) scale(0.7);
  }

  /* Light mode active → show sun */
  :global([data-theme-mode="light"]) .icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  :global([data-theme-mode="light"]) .icon-moon {
    opacity: 0;
    transform: rotate(45deg) scale(0.7);
  }
  :global([data-theme-mode="light"]) .icon-auto {
    opacity: 0;
    transform: rotate(45deg) scale(0.7);
  }

  /* Auto mode active → show auto */
  :global([data-theme-mode="auto"]) .icon-auto {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }
  :global([data-theme-mode="auto"]) .icon-moon {
    opacity: 0;
    transform: rotate(-45deg) scale(0.7);
  }
  :global([data-theme-mode="auto"]) .icon-sun {
    opacity: 0;
    transform: rotate(-45deg) scale(0.7);
  }

  /* Orbital ray animation on sun */
  .ray {
    transform-origin: 12px 12px;
    transition: transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global([data-theme-mode="light"]) .ray {
    animation: ray-spin 12s linear infinite;
  }

  @keyframes ray-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Moon stars twinkle */
  .moon-star {
    animation: twinkle 3s ease-in-out infinite;
  }
  .star-2 { animation-delay: 1.2s; }

  @keyframes twinkle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .toggle-label {
    pointer-events: none;
    user-select: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .icon, .ray, .moon-star {
      transition-duration: 0ms !important;
      animation: none !important;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const STORAGE_KEY = 'jinki-theme-alpha';
    const btn = document.getElementById('theme-toggle-alpha');
    const label = document.getElementById('theme-label-alpha');
    if (!btn || !label) return;

    const MODES = ['dark', 'light', 'auto'] as const;
    type ThemeMode = typeof MODES[number];

    function getCurrentMode(): ThemeMode {
      const stored = localStorage.getItem(STORAGE_KEY) as ThemeMode | null;
      return (stored && MODES.includes(stored)) ? stored : 'dark';
    }

    function resolveTheme(mode: ThemeMode): 'dark' | 'light' {
      if (mode === 'auto') {
        return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      return mode;
    }

    function applyTheme(mode: ThemeMode, animate = false) {
      const resolved = resolveTheme(mode);

      if (animate && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        // Circular reveal animation from toggle button position
        const rect = btn!.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const maxRadius = Math.hypot(
          Math.max(cx, window.innerWidth - cx),
          Math.max(cy, window.innerHeight - cy)
        );

        if (document.startViewTransition) {
          document.startViewTransition(() => {
            document.documentElement.setAttribute('data-theme', resolved);
            document.documentElement.setAttribute('data-theme-mode', mode);
          });
        } else {
          // Fallback: clip-path animation
          document.documentElement.style.setProperty('--reveal-cx', `${cx}px`);
          document.documentElement.style.setProperty('--reveal-cy', `${cy}px`);
          document.documentElement.setAttribute('data-theme', resolved);
          document.documentElement.setAttribute('data-theme-mode', mode);
          document.documentElement.classList.add('theme-revealing');
          setTimeout(() => {
            document.documentElement.classList.remove('theme-revealing');
          }, 500);
        }
      } else {
        document.documentElement.setAttribute('data-theme', resolved);
        document.documentElement.setAttribute('data-theme-mode', mode);
      }

      localStorage.setItem(STORAGE_KEY, mode);
      label!.textContent = mode.charAt(0).toUpperCase() + mode.slice(1);
      btn!.setAttribute('aria-label', `Current theme: ${mode}. Click to switch.`);
    }

    // Cycle through modes on click
    btn.addEventListener('click', () => {
      const current = getCurrentMode();
      const nextIndex = (MODES.indexOf(current) + 1) % MODES.length;
      applyTheme(MODES[nextIndex], true);
    });

    // Keyboard support
    btn.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        btn.click();
      }
    });

    // Listen for system preference changes when in auto mode
    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
      if (getCurrentMode() === 'auto') {
        applyTheme('auto', false);
      }
    });

    // Initialize label
    const mode = getCurrentMode();
    label.textContent = mode.charAt(0).toUpperCase() + mode.slice(1);
    btn.setAttribute('aria-label', `Current theme: ${mode}. Click to switch.`);
  });
</script>
