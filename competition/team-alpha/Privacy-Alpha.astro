---
/*
  Privacy-Alpha — Jinki Aerial Intelligence
  Enhanced privacy policy with jump-to-section sidebar navigation,
  key points summary boxes, version history toggle, and print-friendly styles.
*/
import Layout from '../../src/layouts/Layout.astro';
import Nav from '../../src/components/Nav.astro';
import Footer from './Footer-Alpha.astro';

const lastUpdated = 'March 15, 2026';
const version = '2.1';

const versionHistory = [
  { version: '2.1', date: 'March 15, 2026', note: 'Updated data retention periods and added VCDPA section.' },
  { version: '2.0', date: 'January 10, 2026', note: 'Major rewrite for aerial intelligence service expansion.' },
  { version: '1.0', date: 'September 1, 2025', note: 'Initial privacy policy.' },
];

const sections = [
  {
    id: 'information-collection',
    title: 'Information We Collect',
    keyPoints: ['Contact info from forms', 'Technical browsing data', 'Geospatial and thermal imagery from engagements'],
    content: [
      'We collect information you provide directly when you request a consultation, submit a contact form, or communicate with our team. This includes your name, email address, phone number, company name, and details about your infrastructure or facility.',
      'When you visit our website, we automatically collect technical data such as your IP address, browser type, operating system, referring URL, pages viewed, and timestamps. This data helps us understand how visitors use our site and improve the experience.',
      'In the course of delivering aerial intelligence services, we collect geospatial data, thermal imagery, visual spectrum imagery, and derived analytics related to client facilities and infrastructure. This operational data is governed by individual client service agreements.',
    ],
  },
  {
    id: 'use-of-data',
    title: 'How We Use Your Data',
    keyPoints: ['Service delivery and communication', 'Site analytics and performance', 'Contracted scope only for operational data'],
    content: [
      'We use contact information to respond to inquiries, deliver requested services, provide project updates, and send relevant communications about our aerial intelligence capabilities.',
      'Website analytics data is used to monitor site performance, identify technical issues, understand visitor behavior, and improve our content and user experience.',
      'Aerial survey data and derived analytics are processed exclusively for the purposes outlined in each client engagement — such as infrastructure condition assessment, thermal anomaly detection, perimeter monitoring, and asset documentation. We do not use client operational data for any purpose beyond the contracted scope without explicit written consent.',
    ],
  },
  {
    id: 'data-sharing',
    title: 'Data Sharing',
    keyPoints: ['We never sell your data', 'Trusted service providers only', 'Client survey data never shared without authorization'],
    content: [
      'We do not sell, rent, or trade your personal information to third parties.',
      'We may share data with trusted service providers who assist in operating our website, conducting our business, or delivering services to you — provided those parties agree to keep your information confidential. These include cloud hosting providers, analytics platforms, and email delivery services.',
      'We may disclose information when required by law, regulation, or legal process, or when we believe disclosure is necessary to protect our rights, your safety, or the safety of others.',
      'Client aerial survey data is never shared with third parties unless explicitly authorized by the client in writing.',
    ],
  },
  {
    id: 'security',
    title: 'Security',
    keyPoints: ['AES-256 encryption at rest', 'TLS 1.3 in transit', 'CISSP/CCSP certified team'],
    content: [
      'We implement industry-standard technical and organizational measures to protect your data against unauthorized access, alteration, disclosure, or destruction. These measures include encryption in transit and at rest, access controls, regular security assessments, and secure data storage practices.',
      'Aerial survey data and client deliverables are stored in encrypted environments with role-based access controls. Our security practices reflect the sensitive nature of infrastructure intelligence — our founding team holds CISSP and CCSP certifications, and security is embedded in our operations from the ground up.',
      'No method of transmission or storage is completely secure. While we strive to protect your information, we cannot guarantee absolute security.',
    ],
  },
  {
    id: 'cookies',
    title: 'Cookies',
    keyPoints: ['Essential cookies for functionality', 'Analytics cookies (opt-out available)', 'No advertising or cross-site tracking'],
    content: [
      'Our website uses cookies and similar technologies to enhance your browsing experience, remember your preferences (such as theme selection), and collect aggregate analytics data.',
      'Essential cookies are required for basic site functionality. Analytics cookies help us understand traffic patterns and site usage. You can control cookie preferences through your browser settings.',
      'We do not use cookies for advertising or cross-site tracking purposes.',
    ],
  },
  {
    id: 'third-party-services',
    title: 'Third-Party Services',
    keyPoints: ['No control over third-party sites', 'Analytics and form processing tools used'],
    content: [
      'Our website may contain links to third-party websites or services that are not operated by us. We have no control over the content, privacy policies, or practices of third-party sites and accept no responsibility for them.',
      'We use third-party tools for website analytics, form processing, and email communications. These services have their own privacy policies governing their use of your data.',
    ],
  },
  {
    id: 'data-retention',
    title: 'Data Retention',
    keyPoints: ['Contact data retained up to 3 years', 'Survey data per service agreement', 'Secure deletion on completion'],
    content: [
      'We retain personal information for as long as necessary to fulfill the purposes described in this policy, comply with legal obligations, resolve disputes, and enforce our agreements.',
      'Contact form submissions and inquiry records are retained for up to three years unless you request earlier deletion.',
      'Client aerial survey data is retained according to the terms of each service agreement. Upon contract completion or termination, data is either returned to the client or securely destroyed, per the agreed-upon terms.',
    ],
  },
  {
    id: 'your-rights',
    title: 'Your Rights',
    keyPoints: ['Access, correct, delete, or port your data', '30-day response to verified requests', 'VCDPA rights for Virginia residents'],
    content: [
      'Depending on your jurisdiction, you may have the right to access, correct, delete, or port your personal data. You may also have the right to restrict or object to certain processing activities.',
      'To exercise any of these rights, contact us at the email address below. We will respond to verified requests within 30 days.',
      'If you are a Virginia resident, you have specific rights under the Virginia Consumer Data Protection Act (VCDPA), including the right to access, correct, delete, and obtain a copy of your personal data, as well as the right to opt out of targeted advertising and profiling.',
    ],
  },
  {
    id: 'contact',
    title: 'Contact',
    keyPoints: ['privacy@jinki.ai for all privacy inquiries'],
    content: [
      'If you have questions about this Privacy Policy or our data practices, contact us:',
    ],
  },
];
---

<Layout title="Privacy Policy — Jinki Aerial Intelligence" description="Privacy policy for Jinki Aerial Intelligence. How we collect, use, and protect your data.">
  <Nav />
  <main id="main-content">

    <!-- Hero -->
    <section class="legal-hero" aria-label="Privacy Policy">
      <div class="legal-hero-inner">
        <div class="vert-eyebrow reveal">
          <span class="vert-eyebrow-line"></span>
          <span class="vert-eyebrow-text">Legal</span>
        </div>
        <h1 class="reveal reveal-delay-1">Privacy Policy</h1>
        <p class="legal-hero-sub reveal reveal-delay-2">
          Effective {lastUpdated}. This policy describes how Jinki Aerial Intelligence
          collects, uses, and protects your information.
        </p>
        <div class="legal-meta reveal reveal-delay-3">
          <span class="legal-version-badge">v{version}</span>
          <button class="version-history-btn" id="version-toggle" aria-expanded="false">
            View version history
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
        </div>
        <!-- Version History Dropdown -->
        <div class="version-history-panel" id="version-panel" aria-hidden="true">
          <table class="version-table">
            <thead>
              <tr>
                <th>Version</th>
                <th>Date</th>
                <th>Changes</th>
              </tr>
            </thead>
            <tbody>
              {versionHistory.map(v => (
                <tr>
                  <td><span class="version-tag">v{v.version}</span></td>
                  <td>{v.date}</td>
                  <td>{v.note}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Policy Content with Sidebar -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Privacy Policy Details">
      <div class="legal-layout">

        <!-- Sidebar Navigation -->
        <nav class="legal-sidebar" aria-label="Policy sections">
          <div class="sidebar-sticky">
            <h3 class="sidebar-title">On this page</h3>
            <ul class="sidebar-links">
              {sections.map(s => (
                <li>
                  <a href={`#${s.id}`} class="sidebar-link" data-section={s.id}>{s.title}</a>
                </li>
              ))}
            </ul>
          </div>
        </nav>

        <!-- Main Content -->
        <div class="legal-content">
          {sections.map((section, i) => (
            <div id={section.id} class={`legal-section reveal reveal-delay-${(i % 3) + 1}`}>
              <h2>{section.title}</h2>

              {/* Key Points Summary */}
              <div class="key-points-box">
                <span class="key-points-label">Key Points</span>
                <ul class="key-points-list">
                  {section.keyPoints.map(kp => (
                    <li>{kp}</li>
                  ))}
                </ul>
              </div>

              {section.content.map((para) => (
                <p class="legal-paragraph">{para}</p>
              ))}

              {section.id === 'contact' && (
                <div class="contact-block">
                  <a href="mailto:privacy@jinki.ai" class="legal-email-btn">privacy@jinki.ai</a>
                  <p class="contact-address">Jinki Aerial Intelligence<br />Virginia, USA</p>
                </div>
              )}
            </div>
          ))}

          <div class="legal-footer-note reveal">
            <p>This policy may be updated periodically. Changes will be posted on this page with a revised effective date. Continued use of our website or services after changes constitutes acceptance of the updated policy.</p>
          </div>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* === HERO === */
  .legal-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px clamp(20px, 5vw, 80px) 64px;
    text-align: center;
    background: var(--surface-container-lowest);
    position: relative;
  }

  .legal-hero-inner {
    max-width: 720px;
  }

  .legal-hero h1 {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .legal-hero-sub {
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .vert-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    justify-content: center;
  }

  .vert-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .vert-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
  }

  /* === VERSION META === */
  .legal-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 24px;
  }

  .legal-version-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid rgba(0, 229, 255, 0.2);
  }

  .version-history-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .version-history-btn:hover { color: var(--accent); }

  .version-history-btn svg {
    transition: transform 0.3s ease;
  }

  .version-history-btn.open svg {
    transform: rotate(180deg);
  }

  .version-history-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), margin 0.4s ease;
    margin-top: 0;
  }

  .version-history-panel.open {
    max-height: 300px;
    margin-top: 20px;
  }

  .version-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    text-align: left;
  }

  .version-table th {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
    padding: 8px 12px;
    border-bottom: 1px solid var(--glass-border);
  }

  .version-table td {
    padding: 10px 12px;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--glass-border);
  }

  .version-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
  }

  /* === LAYOUT === */
  .section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .section { padding: 6rem clamp(20px, 5vw, 80px); }
  }

  .legal-layout {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 64px;
  }

  @media (max-width: 1024px) {
    .legal-layout { grid-template-columns: 1fr; gap: 0; }
  }

  /* === SIDEBAR === */
  .legal-sidebar {
    display: block;
  }

  @media (max-width: 1024px) {
    .legal-sidebar { display: none; }
  }

  .sidebar-sticky {
    position: sticky;
    top: 120px;
  }

  .sidebar-title {
    font-family: var(--font-headline);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-tertiary);
    margin-bottom: 16px;
  }

  .sidebar-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 6px 12px;
    border-left: 2px solid transparent;
    border-radius: 0 6px 6px 0;
    display: block;
    transition: all 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--text-primary);
    background: var(--accent-glow);
    border-left-color: var(--accent);
  }

  .sidebar-link.active {
    color: var(--accent);
    background: var(--accent-glow);
    border-left-color: var(--accent);
    font-weight: 600;
  }

  /* === CONTENT === */
  .legal-content {
    max-width: 800px;
  }

  .legal-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .legal-section:first-child { padding-top: 0; }
  .legal-section:last-of-type { border-bottom: none; }

  .legal-section h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.25rem, 2vw + 0.25rem, 1.5rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 20px;
  }

  /* === KEY POINTS BOX === */
  .key-points-box {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-left: 3px solid var(--accent);
    border-radius: 0 12px 12px 0;
    padding: 16px 20px;
    margin-bottom: 24px;
    position: relative;
    overflow: hidden;
  }

  .key-points-box::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .key-points-label {
    font-family: var(--font-headline);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    display: block;
    margin-bottom: 8px;
  }

  .key-points-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .key-points-list li {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-primary);
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }

  .key-points-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.6;
  }

  /* === PARAGRAPHS === */
  .legal-paragraph {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 14px;
  }

  .legal-paragraph:last-of-type { margin-bottom: 0; }

  /* === CONTACT === */
  .contact-block { margin-top: 20px; }

  .legal-email-btn {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--accent);
    text-decoration: none;
    padding: 10px 20px;
    border: 1px solid var(--accent);
    border-radius: 12px;
    display: inline-block;
    transition: all 0.3s ease;
  }

  .legal-email-btn:hover {
    background: var(--accent-glow);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .contact-address {
    margin-top: 16px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-tertiary);
    line-height: 1.7;
  }

  /* === FOOTER NOTE === */
  .legal-footer-note {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--glass-border);
  }

  .legal-footer-note p {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    line-height: 1.8;
  }

  /* === PRINT === */
  @media print {
    .legal-sidebar { display: none !important; }
    .legal-layout { grid-template-columns: 1fr !important; }
    .legal-hero { min-height: auto; padding: 40px 20px; }
    .legal-section { break-inside: avoid; }
    .key-points-box { background: #f5f5f5 !important; border-color: #ddd !important; }
    .key-points-label { color: #333 !important; }
    .key-points-list li { color: #333 !important; }
    .legal-paragraph { color: #333 !important; }
    .version-history-panel { display: none !important; }
  }
</style>

<script>
  // Version history toggle
  const versionToggle = document.getElementById('version-toggle');
  const versionPanel = document.getElementById('version-panel');

  if (versionToggle && versionPanel) {
    versionToggle.addEventListener('click', () => {
      const isOpen = versionPanel.classList.contains('open');
      versionPanel.classList.toggle('open');
      versionToggle.classList.toggle('open');
      versionToggle.setAttribute('aria-expanded', String(!isOpen));
      versionPanel.setAttribute('aria-hidden', String(isOpen));
    });
  }

  // Sidebar active state tracking
  const sidebarLinks = document.querySelectorAll('.sidebar-link');
  const legalSections = document.querySelectorAll('.legal-section');

  if (sidebarLinks.length > 0 && legalSections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            sidebarLinks.forEach((link) => {
              link.classList.toggle('active', link.getAttribute('data-section') === id);
            });
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
    );

    legalSections.forEach((section) => observer.observe(section));
  }
</script>
