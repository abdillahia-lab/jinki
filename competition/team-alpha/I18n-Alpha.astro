---
/*  I18n-Alpha.astro — Internationalization framework showcase
    Team Alpha | Rounds 19+20
    Jinki Aerial Intelligence  */
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>i18n Framework — Alpha | Jinki Aerial Intelligence</title>
  <style>
    :root{
      --surface:#121416;--bg-primary:#121416;--bg-elevated:#1a1c1e;--bg-card:#1e2022;
      --bg-card-hover:#282a2c;
      --text-primary:#e2e2e5;--text-secondary:#bac9cc;--text-tertiary:#849396;
      --accent:#00e5ff;--accent-soft:#c3f5ff;--accent-glow:rgba(0,229,255,.15);
      --border:rgba(59,73,76,.2);--border-hover:rgba(59,73,76,.4);
      --glass-bg:rgba(30,32,34,.6);--glass-border:rgba(255,255,255,.06);
      --glass-shadow:0 8px 32px rgba(0,0,0,.3),0 2px 8px rgba(0,0,0,.2);
      --glossy-shine:linear-gradient(135deg,rgba(255,255,255,.12) 0%,rgba(255,255,255,0) 40%,rgba(255,255,255,.04) 100%);
      --font-headline:'Space Grotesk',system-ui,sans-serif;
      --font-body:'Inter',system-ui,sans-serif;
      --font-mono:'JetBrains Mono','SF Mono',monospace;
    }
    [data-theme="light"]{
      --surface:#fff;--bg-primary:#fafbfc;--bg-elevated:#fff;--bg-card:#f0f1f3;
      --bg-card-hover:#e8e9eb;
      --text-primary:#1a1c1e;--text-secondary:#3b494c;--text-tertiary:#6f7979;
      --accent:#00838f;--accent-soft:#004f58;--accent-glow:rgba(0,131,143,.1);
      --border:rgba(0,0,0,.08);--border-hover:rgba(0,0,0,.15);
      --glass-bg:rgba(255,255,255,.7);--glass-border:rgba(0,0,0,.06);
      --glass-shadow:0 8px 32px rgba(0,0,0,.08),0 2px 8px rgba(0,0,0,.04);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;font-family:var(--font-body);color:var(--text-primary);background:var(--bg-primary)}
    body{min-height:100vh;line-height:1.7}

    .page{max-width:1120px;margin:0 auto;padding:48px 24px 80px}
    .page-title{font-family:var(--font-headline);font-size:clamp(28px,4vw,40px);font-weight:700;text-align:center;margin:0 0 8px}
    .page-subtitle{font-family:var(--font-body);font-size:16px;color:var(--text-tertiary);text-align:center;margin:0 0 56px}

    .section{margin:0 0 64px}
    .section-label{font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin:0 0 8px}
    .section-title{font-family:var(--font-headline);font-size:clamp(20px,3vw,28px);font-weight:700;margin:0 0 24px}

    .theme-toggle{
      position:fixed;top:16px;right:16px;z-index:100;
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:10px;padding:10px 14px;cursor:pointer;
      color:var(--text-primary);font-size:18px;
      backdrop-filter:blur(12px);transition:border-color .2s;
    }
    .theme-toggle:hover{border-color:var(--accent)}

    /* ════════════════════════════════════
       1. LANGUAGE SWITCHER
    ════════════════════════════════════ */
    .switcher-demo{display:flex;align-items:flex-start;gap:32px;flex-wrap:wrap}

    .lang-switcher{position:relative;width:280px}
    .lang-trigger{
      display:flex;align-items:center;gap:12px;width:100%;
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:12px;padding:14px 16px;cursor:pointer;
      color:var(--text-primary);font-family:var(--font-headline);
      font-size:15px;font-weight:600;transition:border-color .2s;
      backdrop-filter:blur(12px);
    }
    .lang-trigger:hover,.lang-trigger[aria-expanded="true"]{border-color:var(--accent)}
    .lang-trigger .flag{font-size:22px;line-height:1}
    .lang-trigger .chevron{
      margin-left:auto;transition:transform .2s;color:var(--text-tertiary);
    }
    .lang-trigger[aria-expanded="true"] .chevron{transform:rotate(180deg)}

    .lang-dropdown{
      position:absolute;top:calc(100% + 8px);left:0;right:0;
      background:var(--bg-elevated);border:1px solid var(--glass-border);
      border-radius:12px;overflow:hidden;z-index:50;
      box-shadow:var(--glass-shadow);
      display:none;animation:dropIn .2s ease;
    }
    .lang-dropdown.open{display:block}
    @keyframes dropIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}

    .lang-option{
      display:flex;align-items:center;gap:12px;
      padding:12px 16px;cursor:pointer;
      font-family:var(--font-body);font-size:14px;color:var(--text-secondary);
      transition:background .15s,color .15s;border:none;background:none;width:100%;
      text-align:left;
    }
    .lang-option:hover{background:var(--accent-glow);color:var(--text-primary)}
    .lang-option.active{color:var(--accent);font-weight:600}
    .lang-option .flag{font-size:20px}
    .lang-option .check{margin-left:auto;opacity:0;color:var(--accent)}
    .lang-option.active .check{opacity:1}

    .switcher-info{flex:1;min-width:260px}
    .switcher-info p{font-size:14px;color:var(--text-tertiary);line-height:1.7;margin:0 0 12px}

    /* ════════════════════════════════════
       2. RTL SUPPORT
    ════════════════════════════════════ */
    .rtl-demo{
      display:grid;grid-template-columns:1fr 1fr;gap:16px;
    }
    @media(max-width:700px){.rtl-demo{grid-template-columns:1fr}}

    .rtl-card{
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:12px;padding:24px;position:relative;overflow:hidden;
    }
    .rtl-card::before{
      content:'';position:absolute;inset:0;border-radius:inherit;
      background:var(--glossy-shine);pointer-events:none;
    }
    .rtl-card-label{
      font-family:var(--font-mono);font-size:10px;text-transform:uppercase;
      letter-spacing:.1em;color:var(--accent);margin:0 0 12px;
    }
    .rtl-card h3{font-family:var(--font-headline);font-size:18px;font-weight:700;margin:0 0 8px}
    .rtl-card p{font-family:var(--font-body);font-size:14px;color:var(--text-secondary);line-height:1.6}
    .rtl-card .btn-sample{
      display:inline-flex;align-items:center;gap:8px;margin:16px 0 0;
      background:var(--accent);color:#000;border:none;border-radius:8px;
      font-family:var(--font-headline);font-size:13px;font-weight:600;
      padding:10px 20px;cursor:pointer;
    }

    /* ════════════════════════════════════
       3. TRANSLATION KEY STRUCTURE
    ════════════════════════════════════ */
    .code-block{
      background:var(--bg-card);border:1px solid var(--glass-border);
      border-radius:12px;overflow:hidden;
    }
    .code-header{
      display:flex;align-items:center;justify-content:space-between;
      padding:12px 16px;border-bottom:1px solid var(--border);
    }
    .code-filename{font-family:var(--font-mono);font-size:12px;color:var(--text-tertiary)}
    .code-copy{
      background:none;border:1px solid var(--border);border-radius:6px;
      padding:4px 10px;font-family:var(--font-mono);font-size:11px;
      color:var(--text-tertiary);cursor:pointer;transition:all .2s;
    }
    .code-copy:hover{border-color:var(--accent);color:var(--accent)}
    .code-body{
      padding:20px;overflow-x:auto;
      font-family:var(--font-mono);font-size:13px;line-height:1.8;
      color:var(--text-secondary);
    }
    .code-body .key{color:var(--accent)}
    .code-body .str{color:#a5d6ff}
    [data-theme="light"] .code-body .str{color:#0550ae}
    .code-body .comment{color:var(--text-tertiary);font-style:italic}
    .code-body .bracket{color:var(--text-tertiary)}

    /* ════════════════════════════════════
       4. DATE / NUMBER FORMATTING
    ════════════════════════════════════ */
    .format-grid{
      display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;
    }
    .format-card{
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:12px;padding:20px;position:relative;overflow:hidden;
      transition:border-color .2s;
    }
    .format-card:hover{border-color:var(--accent)}
    .format-card::before{
      content:'';position:absolute;inset:0;border-radius:inherit;
      background:var(--glossy-shine);pointer-events:none;
    }
    .format-locale{
      font-family:var(--font-mono);font-size:11px;color:var(--accent);
      margin:0 0 12px;text-transform:uppercase;letter-spacing:.08em;
    }
    .format-row{
      display:flex;justify-content:space-between;align-items:baseline;
      margin:0 0 8px;
    }
    .format-label{font-family:var(--font-body);font-size:12px;color:var(--text-tertiary)}
    .format-value{
      font-family:var(--font-mono);font-size:14px;color:var(--text-primary);
      font-weight:600;
    }

    /* ── Responsive / a11y ── */
    @media(prefers-reduced-motion:reduce){
      *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}
    }
    :focus-visible{outline:2px solid var(--accent);outline-offset:2px}
  </style>
</head>
<body>
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme"><span id="themeIcon">&#9790;</span></button>

  <div class="page">
    <h1 class="page-title">i18n Framework</h1>
    <p class="page-subtitle">Team Alpha &mdash; multi-language, multi-locale, fully accessible</p>

    <!-- ─── 1. LANGUAGE SWITCHER ─── -->
    <section class="section" aria-labelledby="switcher-heading">
      <p class="section-label">01</p>
      <h2 class="section-title" id="switcher-heading">Language Switcher</h2>
      <div class="switcher-demo">
        <div class="lang-switcher">
          <button class="lang-trigger" id="langTrigger" aria-expanded="false" aria-haspopup="listbox" aria-label="Select language">
            <span class="flag" id="currentFlag">&#127482;&#127480;</span>
            <span id="currentLang">English</span>
            <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="lang-dropdown" id="langDropdown" role="listbox" aria-label="Available languages">
            <button class="lang-option active" role="option" aria-selected="true" data-lang="en" data-flag="&#127482;&#127480;" data-name="English">
              <span class="flag">&#127482;&#127480;</span> English
              <span class="check">&#10003;</span>
            </button>
            <button class="lang-option" role="option" aria-selected="false" data-lang="es" data-flag="&#127466;&#127480;" data-name="Espa&ntilde;ol">
              <span class="flag">&#127466;&#127480;</span> Espa&ntilde;ol
              <span class="check">&#10003;</span>
            </button>
            <button class="lang-option" role="option" aria-selected="false" data-lang="fr" data-flag="&#127467;&#127479;" data-name="Fran&ccedil;ais">
              <span class="flag">&#127467;&#127479;</span> Fran&ccedil;ais
              <span class="check">&#10003;</span>
            </button>
            <button class="lang-option" role="option" aria-selected="false" data-lang="de" data-flag="&#127465;&#127466;" data-name="Deutsch">
              <span class="flag">&#127465;&#127466;</span> Deutsch
              <span class="check">&#10003;</span>
            </button>
            <button class="lang-option" role="option" aria-selected="false" data-lang="ja" data-flag="&#127471;&#127477;" data-name="&#26085;&#26412;&#35486;">
              <span class="flag">&#127471;&#127477;</span> &#26085;&#26412;&#35486;
              <span class="check">&#10003;</span>
            </button>
          </div>
        </div>
        <div class="switcher-info">
          <p>The language switcher uses a dropdown pattern with keyboard navigation support. Press <kbd style="font-family:var(--font-mono);font-size:12px;background:var(--bg-card);padding:2px 6px;border-radius:4px;border:1px solid var(--border)">Enter</kbd> or <kbd style="font-family:var(--font-mono);font-size:12px;background:var(--bg-card);padding:2px 6px;border-radius:4px;border:1px solid var(--border)">Space</kbd> to open, arrow keys to navigate, and <kbd style="font-family:var(--font-mono);font-size:12px;background:var(--bg-card);padding:2px 6px;border-radius:4px;border:1px solid var(--border)">Escape</kbd> to close.</p>
          <p>Selected language is persisted in <code style="font-family:var(--font-mono);font-size:13px;color:var(--accent)">localStorage</code> and applied via the <code style="font-family:var(--font-mono);font-size:13px;color:var(--accent)">lang</code> attribute on <code style="font-family:var(--font-mono);font-size:13px;color:var(--accent)">&lt;html&gt;</code>.</p>
        </div>
      </div>
    </section>

    <!-- ─── 2. RTL SUPPORT ─── -->
    <section class="section" aria-labelledby="rtl-heading">
      <p class="section-label">02</p>
      <h2 class="section-title" id="rtl-heading">RTL Support</h2>
      <div class="rtl-demo">
        <div class="rtl-card">
          <div class="rtl-card-label">LTR &mdash; English</div>
          <h3>Aerial Intelligence</h3>
          <p>Advanced autonomous inspection systems providing actionable facility data. Real-time thermal monitoring, structural analysis, and predictive maintenance.</p>
          <button class="btn-sample">Get Started &rarr;</button>
        </div>
        <div class="rtl-card" dir="rtl" lang="ar">
          <div class="rtl-card-label">RTL &mdash; &#1575;&#1604;&#1593;&#1585;&#1576;&#1610;&#1577;</div>
          <h3>&#1575;&#1604;&#1584;&#1603;&#1575;&#1569; &#1575;&#1604;&#1580;&#1608;&#1610;</h3>
          <p>&#1571;&#1606;&#1592;&#1605;&#1577; &#1601;&#1581;&#1589; &#1584;&#1575;&#1578;&#1610;&#1577; &#1605;&#1578;&#1602;&#1583;&#1605;&#1577; &#1578;&#1608;&#1601;&#1585; &#1576;&#1610;&#1575;&#1606;&#1575;&#1578; &#1605;&#1606;&#1588;&#1570;&#1578; &#1602;&#1575;&#1576;&#1604;&#1577; &#1604;&#1604;&#1578;&#1606;&#1601;&#1610;&#1584;. &#1605;&#1585;&#1575;&#1602;&#1576;&#1577; &#1581;&#1585;&#1575;&#1585;&#1610;&#1577; &#1601;&#1608;&#1585;&#1610;&#1577; &#1608;&#1578;&#1581;&#1604;&#1610;&#1604; &#1607;&#1610;&#1603;&#1604;&#1610;.</p>
          <button class="btn-sample">&larr; &#1575;&#1576;&#1583;&#1571; &#1575;&#1604;&#1570;&#1606;</button>
        </div>
      </div>
    </section>

    <!-- ─── 3. TRANSLATION KEY STRUCTURE ─── -->
    <section class="section" aria-labelledby="keys-heading">
      <p class="section-label">03</p>
      <h2 class="section-title" id="keys-heading">Translation Key Structure</h2>
      <div class="code-block">
        <div class="code-header">
          <span class="code-filename">src/i18n/en.json</span>
          <button class="code-copy" id="copyBtn" aria-label="Copy code">Copy</button>
        </div>
        <pre class="code-body"><span class="bracket">{</span>
  <span class="comment">// Namespaced by feature area</span>
  <span class="key">"nav"</span>: <span class="bracket">{</span>
    <span class="key">"home"</span>: <span class="str">"Home"</span>,
    <span class="key">"verticals"</span>: <span class="str">"Industries"</span>,
    <span class="key">"services"</span>: <span class="str">"Services"</span>,
    <span class="key">"about"</span>: <span class="str">"About"</span>,
    <span class="key">"contact"</span>: <span class="str">"Get in Touch"</span>
  <span class="bracket">}</span>,
  <span class="key">"hero"</span>: <span class="bracket">{</span>
    <span class="key">"headline"</span>: <span class="str">"Aerial Intelligence for Critical Infrastructure"</span>,
    <span class="key">"subheadline"</span>: <span class="str">"Autonomous inspection systems that deliver actionable data"</span>,
    <span class="key">"cta_primary"</span>: <span class="str">"Get in Touch"</span>,
    <span class="key">"cta_secondary"</span>: <span class="str">"Watch Demo"</span>
  <span class="bracket">}</span>,
  <span class="key">"stats"</span>: <span class="bracket">{</span>
    <span class="key">"missions"</span>: <span class="str">"{{count}} Missions Completed"</span>,
    <span class="key">"uptime"</span>: <span class="str">"{{percent}}% Uptime"</span>,
    <span class="key">"facilities"</span>: <span class="str">"{{count}} Facilities Monitored"</span>
  <span class="bracket">}</span>,
  <span class="key">"errors"</span>: <span class="bracket">{</span>
    <span class="key">"required"</span>: <span class="str">"This field is required"</span>,
    <span class="key">"email_invalid"</span>: <span class="str">"Please enter a valid email"</span>,
    <span class="key">"network"</span>: <span class="str">"Connection lost. Retrying..."</span>
  <span class="bracket">}</span>
<span class="bracket">}</span></pre>
      </div>
    </section>

    <!-- ─── 4. DATE/NUMBER FORMATTING ─── -->
    <section class="section" aria-labelledby="format-heading">
      <p class="section-label">04</p>
      <h2 class="section-title" id="format-heading">Date &amp; Number Formatting</h2>
      <div class="format-grid" id="formatGrid">
        <!-- Populated by JS -->
      </div>
    </section>
  </div>

  <script>
    // Theme toggle
    const toggle = document.getElementById('themeToggle');
    const icon = document.getElementById('themeIcon');
    function setTheme(t) {
      document.documentElement.setAttribute('data-theme', t);
      icon.textContent = t === 'light' ? '\u2600' : '\u263E';
      localStorage.setItem('theme', t);
    }
    toggle.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      setTheme(next);
    });
    const saved = localStorage.getItem('theme');
    if (saved) setTheme(saved);

    // Language switcher
    const trigger = document.getElementById('langTrigger');
    const dropdown = document.getElementById('langDropdown');
    const options = dropdown.querySelectorAll('.lang-option');
    const currentFlag = document.getElementById('currentFlag');
    const currentLang = document.getElementById('currentLang');

    trigger.addEventListener('click', () => {
      const open = dropdown.classList.toggle('open');
      trigger.setAttribute('aria-expanded', open);
    });
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.lang-switcher')) {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
        trigger.focus();
      }
    });

    options.forEach(opt => {
      opt.addEventListener('click', () => {
        options.forEach(o => { o.classList.remove('active'); o.setAttribute('aria-selected', 'false'); });
        opt.classList.add('active');
        opt.setAttribute('aria-selected', 'true');
        currentFlag.innerHTML = opt.dataset.flag;
        currentLang.textContent = opt.dataset.name;
        document.documentElement.setAttribute('lang', opt.dataset.lang);
        dropdown.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
        renderFormats(opt.dataset.lang);
      });
    });

    // Copy button
    document.getElementById('copyBtn').addEventListener('click', function() {
      const code = document.querySelector('.code-body').textContent;
      navigator.clipboard.writeText(code).then(() => {
        this.textContent = 'Copied!';
        setTimeout(() => { this.textContent = 'Copy'; }, 2000);
      });
    });

    // Date/Number formatting
    const locales = {
      en: { locale: 'en-US', label: 'EN-US', currency: 'USD' },
      es: { locale: 'es-ES', label: 'ES-ES', currency: 'EUR' },
      fr: { locale: 'fr-FR', label: 'FR-FR', currency: 'EUR' },
      de: { locale: 'de-DE', label: 'DE-DE', currency: 'EUR' },
      ja: { locale: 'ja-JP', label: 'JA-JP', currency: 'JPY' },
    };
    const sampleDate = new Date(2026, 2, 20, 14, 30);
    const sampleNumber = 1284567.89;

    function renderFormats(activeLang) {
      const grid = document.getElementById('formatGrid');
      grid.innerHTML = '';
      Object.entries(locales).forEach(([key, cfg]) => {
        const isActive = key === activeLang;
        const card = document.createElement('div');
        card.className = 'format-card';
        if (isActive) card.style.borderColor = 'var(--accent)';
        card.innerHTML = `
          <div class="format-locale">${cfg.label}${isActive ? ' &bull; Active' : ''}</div>
          <div class="format-row"><span class="format-label">Date</span><span class="format-value">${new Intl.DateTimeFormat(cfg.locale, { dateStyle: 'long' }).format(sampleDate)}</span></div>
          <div class="format-row"><span class="format-label">Time</span><span class="format-value">${new Intl.DateTimeFormat(cfg.locale, { timeStyle: 'short' }).format(sampleDate)}</span></div>
          <div class="format-row"><span class="format-label">Number</span><span class="format-value">${new Intl.NumberFormat(cfg.locale).format(sampleNumber)}</span></div>
          <div class="format-row"><span class="format-label">Currency</span><span class="format-value">${new Intl.NumberFormat(cfg.locale, { style: 'currency', currency: cfg.currency }).format(sampleNumber)}</span></div>
        `;
        grid.appendChild(card);
      });
    }
    renderFormats('en');
  </script>
</body>
</html>
