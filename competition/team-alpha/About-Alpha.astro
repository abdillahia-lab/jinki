---
/*
  About Page — Team Alpha, Round 11
  Jinki Aerial Intelligence

  Sections:
  1. Mission hero with animated topographic background
  2. Timeline — company journey milestones
  3. Values grid — 4 core values with glass cards
  4. Leadership team — 2x2 grid with perspective tilt
  5. Technology stack — sensor > AI > cloud > dashboard flow
  6. Stats bar
  7. Partners / certifications trust strip
*/
import Layout from '../../src/layouts/Layout.astro';
import Nav from '../../src/components/Nav.astro';
import Footer from '../../src/components/Footer.astro';

const values = [
  {
    icon: 'target',
    title: 'Precision',
    desc: 'Every data point verified, every recommendation auditable. We hold ourselves to the accuracy standards that critical infrastructure demands.',
    color: '#00E5FF',
  },
  {
    icon: 'lightbulb',
    title: 'Innovation',
    desc: 'We push the boundary of what autonomous aerial systems can perceive, interpret, and recommend — turning raw sensor data into operational advantage.',
    color: '#7B61FF',
  },
  {
    icon: 'shield',
    title: 'Safety',
    desc: 'Zero incidents is not aspirational — it is the minimum. Every mission is planned, reviewed, and executed with redundant safety protocols.',
    color: '#34D399',
  },
  {
    icon: 'trending_up',
    title: 'Impact',
    desc: 'We measure success by decisions improved, not hours flown. If our intelligence does not change an outcome, we have not delivered value.',
    color: '#FF8C00',
  },
];

const milestones = [
  { year: '2024', quarter: 'Q3', title: 'Company Founded', desc: 'Jinki Aerial Intelligence established in Northern Virginia with a mission to transform facility monitoring.' },
  { year: '2024', quarter: 'Q4', title: 'First Client Engagement', desc: 'Delivered inaugural thermal intelligence audit for a hyperscale data center campus.' },
  { year: '2025', quarter: 'Q1', title: 'AI Analytics Platform', desc: 'Launched proprietary computer vision pipeline for automated anomaly detection and severity classification.' },
  { year: '2025', quarter: 'Q3', title: 'Autonomous Operations', desc: 'Deployed DJI Dock 3 persistent monitoring, enabling 150+ autonomous missions per month per site.' },
  { year: '2026', quarter: 'Q1', title: 'Multi-Vertical Expansion', desc: 'Extended operations to energy grid, perimeter security, and precision agriculture verticals.' },
  { year: '2026', quarter: 'Q3', title: 'National Coverage', desc: 'Scaling operations across the eastern United States with regional deployment teams.' },
];

const team = [
  { name: 'Adnan Abdillahi', title: 'Founder & CEO', bio: 'Security-credentialed technologist (CISSP, CCSP, AIGP, PMP) who built Jinki to bring enterprise-grade intelligence to aerial operations.' },
  { name: 'Open Position', title: 'VP of Engineering', bio: 'We are seeking a technical leader to scale our AI analytics platform and autonomous flight operations software.' },
  { name: 'Open Position', title: 'Head of Operations', bio: 'Looking for an operations executive to lead field deployment teams and establish SOPs across all verticals.' },
  { name: 'Open Position', title: 'Director of Sales', bio: 'Seeking a strategic seller who understands infrastructure, technology, and consultative sales.' },
];

const techStack = [
  { icon: 'sensors', label: 'Sensor Suite', desc: 'Thermal, RGB, LiDAR, multispectral', sublabel: 'H30T + L3 + S1' },
  { icon: 'psychology', label: 'AI Engine', desc: 'Computer vision, anomaly detection, severity scoring', sublabel: 'Manifold 3 Edge AI' },
  { icon: 'cloud_sync', label: 'Cloud Analytics', desc: 'Geospatial processing, historical trending, predictive models', sublabel: 'Secure Cloud Pipeline' },
  { icon: 'dashboard', label: 'Intelligence Dashboard', desc: 'Prioritized findings, export-ready reports, API integrations', sublabel: 'Client Portal' },
];

const stats = [
  { value: '50+', label: 'Facilities Served' },
  { value: '4', label: 'Industry Verticals' },
  { value: '99.7%', label: 'System Uptime' },
  { value: '0', label: 'Safety Incidents' },
];

const certifications = [
  { name: 'FAA Part 107', desc: 'Commercial UAS Operations', icon: 'flight_takeoff' },
  { name: 'SOC 2 Type II', desc: 'In Progress', icon: 'verified_user' },
  { name: '$5M Liability', desc: 'Commercial Insurance', icon: 'security' },
  { name: 'CISSP / CCSP', desc: 'ISC2 Certified Team', icon: 'shield' },
  { name: 'AIGP', desc: 'IAPP AI Governance', icon: 'smart_toy' },
  { name: 'PMP', desc: 'PMI Project Management', icon: 'task_alt' },
];
---

<Layout title="About — Jinki Aerial Intelligence" description="Learn about Jinki's mission, values, leadership, and the technology platform behind our aerial intelligence.">
  <Nav />
  <main id="main-content">

    <!-- ============ 1. MISSION HERO ============ -->
    <section class="alpha-about-hero" aria-label="About Jinki">
      <div class="alpha-about-hero__topo" aria-hidden="true">
        <svg class="alpha-topo-svg" viewBox="0 0 800 400" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <g class="alpha-topo-lines" opacity="0.15">
            <ellipse cx="400" cy="200" rx="380" ry="180" fill="none" stroke="var(--accent)" stroke-width="0.5"/>
            <ellipse cx="400" cy="200" rx="320" ry="150" fill="none" stroke="var(--accent)" stroke-width="0.5"/>
            <ellipse cx="400" cy="200" rx="260" ry="120" fill="none" stroke="var(--accent)" stroke-width="0.6"/>
            <ellipse cx="400" cy="200" rx="200" ry="90" fill="none" stroke="var(--accent)" stroke-width="0.6"/>
            <ellipse cx="400" cy="200" rx="140" ry="60" fill="none" stroke="var(--accent)" stroke-width="0.7"/>
            <ellipse cx="400" cy="200" rx="80" ry="30" fill="none" stroke="var(--accent)" stroke-width="0.8"/>
            <ellipse cx="400" cy="200" rx="30" ry="10" fill="none" stroke="var(--accent)" stroke-width="1"/>
          </g>
          <g class="alpha-topo-lines-offset" opacity="0.08">
            <ellipse cx="250" cy="150" rx="200" ry="100" fill="none" stroke="var(--accent)" stroke-width="0.4"/>
            <ellipse cx="250" cy="150" rx="140" ry="70" fill="none" stroke="var(--accent)" stroke-width="0.5"/>
            <ellipse cx="550" cy="250" rx="180" ry="90" fill="none" stroke="var(--accent)" stroke-width="0.4"/>
            <ellipse cx="550" cy="250" rx="120" ry="60" fill="none" stroke="var(--accent)" stroke-width="0.5"/>
          </g>
        </svg>
      </div>
      <div class="alpha-about-hero__content">
        <span class="label reveal">About Jinki</span>
        <h1 class="reveal reveal-delay-1">Turning Aerial Data Into<br/><span class="alpha-gradient-text">Actionable Intelligence</span></h1>
        <p class="alpha-about-hero__sub reveal reveal-delay-2">
          We exist to give organizations a decisive informational advantage over the
          critical assets they protect, maintain, and grow — delivering verified
          intelligence, not raw footage.
        </p>
      </div>
    </section>

    <!-- ============ 2. TIMELINE ============ -->
    <section class="alpha-section" style="background: var(--bg-elevated);" aria-label="Company Timeline">
      <div class="alpha-section__inner">
        <div class="alpha-section__header reveal" style="text-align: center; margin-bottom: 64px;">
          <span class="label">Our Journey</span>
          <h2 style="margin-top: 8px;">From Founding to Scale</h2>
        </div>
        <div class="alpha-timeline">
          <div class="alpha-timeline__line" aria-hidden="true"></div>
          {milestones.map((m, i) => (
            <div class={`alpha-timeline__item ${i % 2 === 0 ? 'alpha-timeline__item--left' : 'alpha-timeline__item--right'} reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="alpha-timeline__dot" aria-hidden="true"></div>
              <div class="alpha-timeline__card">
                <span class="alpha-timeline__date">{m.year} {m.quarter}</span>
                <h3 class="alpha-timeline__title">{m.title}</h3>
                <p class="alpha-timeline__desc">{m.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 3. VALUES GRID ============ -->
    <section class="alpha-section" aria-label="Core Values">
      <div class="alpha-section__inner">
        <div class="alpha-section__header reveal" style="text-align: center; margin-bottom: 64px;">
          <span class="label">Core Values</span>
          <h2 style="margin-top: 8px;">What Drives Every Mission</h2>
          <p style="max-width: 580px; margin: 16px auto 0; color: var(--text-secondary); line-height: 1.7;">
            These are not aspirational statements. They are operational commitments
            embedded in how we build, fly, and deliver.
          </p>
        </div>
        <div class="alpha-values-grid">
          {values.map((v, i) => (
            <div class={`alpha-value-card reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="alpha-value-card__icon" style={`background: ${v.color}15; border-color: ${v.color}30;`}>
                <span class="material-symbols-outlined" style={`color: ${v.color}; font-size: 28px; font-variation-settings: 'FILL' 1;`} aria-hidden="true">{v.icon}</span>
              </div>
              <h3 class="alpha-value-card__title">{v.title}</h3>
              <p class="alpha-value-card__desc">{v.desc}</p>
              <div class="alpha-value-card__bar" style={`background: ${v.color};`} aria-hidden="true"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 4. LEADERSHIP TEAM ============ -->
    <section class="alpha-section" style="background: var(--bg-elevated);" aria-label="Leadership Team">
      <div class="alpha-section__inner">
        <div class="alpha-section__header reveal" style="text-align: center; margin-bottom: 64px;">
          <span class="label">Leadership</span>
          <h2 style="margin-top: 8px;">The Team Behind the Intelligence</h2>
        </div>
        <div class="alpha-team-grid">
          {team.map((member, i) => (
            <div class={`alpha-team-card reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="alpha-team-card__photo">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
              <div class="alpha-team-card__info">
                <h3 class="alpha-team-card__name">{member.name}</h3>
                <span class="alpha-team-card__role">{member.title}</span>
                <p class="alpha-team-card__bio">{member.bio}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ 5. TECHNOLOGY STACK ============ -->
    <section class="alpha-section" aria-label="Technology Platform">
      <div class="alpha-section__inner">
        <div class="alpha-section__header reveal" style="text-align: center; margin-bottom: 64px;">
          <span class="label">Platform</span>
          <h2 style="margin-top: 8px;">End-to-End Intelligence Pipeline</h2>
          <p style="max-width: 580px; margin: 16px auto 0; color: var(--text-secondary); line-height: 1.7;">
            From sensor capture to actionable report — every stage is purpose-built
            for critical infrastructure intelligence.
          </p>
        </div>
        <div class="alpha-tech-flow">
          {techStack.map((tech, i) => (
            <Fragment key={i}>
              <div class={`alpha-tech-card reveal reveal-delay-${(i % 4) + 1}`}>
                <div class="alpha-tech-card__icon">
                  <span class="material-symbols-outlined" style="font-size: 32px; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">{tech.icon}</span>
                </div>
                <h3 class="alpha-tech-card__label">{tech.label}</h3>
                <p class="alpha-tech-card__desc">{tech.desc}</p>
                <span class="alpha-tech-card__sublabel">{tech.sublabel}</span>
              </div>
              {i < techStack.length - 1 && (
                <div class="alpha-tech-arrow reveal" aria-hidden="true">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              )}
            </Fragment>
          ))}
        </div>
        <!-- Mobile: vertical arrow layout described via CSS -->
      </div>
    </section>

    <!-- ============ 6. STATS BAR ============ -->
    <section class="alpha-stats-section" aria-label="Key Metrics">
      <div class="alpha-stats-inner">
        {stats.map((s, i) => (
          <div class={`alpha-stat reveal reveal-delay-${(i % 4) + 1}`}>
            <span class="alpha-stat__value">{s.value}</span>
            <span class="alpha-stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ 7. CERTIFICATIONS / TRUST ============ -->
    <section class="alpha-section" style="background: var(--bg-elevated);" aria-label="Certifications and Partnerships">
      <div class="alpha-section__inner">
        <div class="alpha-section__header reveal" style="text-align: center; margin-bottom: 48px;">
          <span class="label">Trust & Compliance</span>
          <h2 style="margin-top: 8px;">Certifications & Credentials</h2>
        </div>
        <div class="alpha-certs-grid">
          {certifications.map((cert, i) => (
            <div class={`alpha-cert-card reveal reveal-delay-${(i % 4) + 1}`}>
              <span class="material-symbols-outlined alpha-cert-card__icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{cert.icon}</span>
              <span class="alpha-cert-card__name">{cert.name}</span>
              <span class="alpha-cert-card__desc">{cert.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* =============================================
     ABOUT PAGE — TEAM ALPHA
     ============================================= */

  /* --- 1. Mission Hero --- */
  .alpha-about-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 160px clamp(20px, 5vw, 80px) 100px;
    text-align: center;
    overflow: hidden;
    background: var(--surface-container-lowest);
  }

  .alpha-about-hero__topo {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .alpha-topo-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .alpha-topo-lines {
    animation: alpha-topo-breathe 8s ease-in-out infinite;
  }

  .alpha-topo-lines-offset {
    animation: alpha-topo-breathe 8s ease-in-out infinite 4s;
  }

  @keyframes alpha-topo-breathe {
    0%, 100% { opacity: 0.15; transform: scale(1); }
    50% { opacity: 0.25; transform: scale(1.02); }
  }

  .alpha-about-hero__content {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .alpha-about-hero__content h1 {
    font-size: clamp(2.2rem, 4.5vw + 0.5rem, 3.5rem);
    line-height: 1.08;
    margin-bottom: 24px;
  }

  .alpha-gradient-text {
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .alpha-about-hero__sub {
    font-size: clamp(1rem, 1.3vw + 0.5rem, 1.15rem);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  /* --- Shared Section --- */
  .alpha-section {
    padding: 100px clamp(20px, 5vw, 80px);
  }

  .alpha-section__inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .alpha-section__header h2 {
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    line-height: 1.12;
  }

  /* --- 2. Timeline --- */
  .alpha-timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .alpha-timeline__line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    transform: translateX(-50%);
    opacity: 0.3;
  }

  .alpha-timeline__item {
    position: relative;
    display: flex;
    margin-bottom: 48px;
  }

  .alpha-timeline__item--left {
    justify-content: flex-start;
    padding-right: calc(50% + 32px);
    text-align: right;
  }

  .alpha-timeline__item--right {
    justify-content: flex-end;
    padding-left: calc(50% + 32px);
    text-align: left;
  }

  .alpha-timeline__dot {
    position: absolute;
    left: 50%;
    top: 8px;
    width: 14px;
    height: 14px;
    background: var(--accent);
    border-radius: 50%;
    transform: translateX(-50%);
    box-shadow: 0 0 12px var(--accent-glow-strong);
    z-index: 2;
  }

  .alpha-timeline__card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 24px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .alpha-timeline__card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
  }

  .alpha-timeline__date {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .alpha-timeline__title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 6px;
    margin-bottom: 8px;
  }

  .alpha-timeline__desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* --- 3. Values Grid --- */
  .alpha-values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .alpha-value-card {
    position: relative;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 36px 32px 32px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .alpha-value-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .alpha-value-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
  }

  .alpha-value-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: transform 0.3s ease;
  }

  .alpha-value-card:hover .alpha-value-card__icon {
    transform: scale(1.08);
  }

  .alpha-value-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  .alpha-value-card__desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .alpha-value-card__bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0.5;
    transition: opacity 0.3s ease;
  }

  .alpha-value-card:hover .alpha-value-card__bar {
    opacity: 1;
  }

  /* --- 4. Leadership Team --- */
  .alpha-team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 960px;
    margin: 0 auto;
  }

  .alpha-team-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 32px;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    perspective: 800px;
    position: relative;
    overflow: hidden;
  }

  .alpha-team-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .alpha-team-card:hover {
    transform: perspective(800px) rotateY(-2deg) rotateX(1deg) translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25), 0 0 30px var(--accent-glow);
  }

  .alpha-team-card__photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: border-color 0.3s ease;
  }

  .alpha-team-card:hover .alpha-team-card__photo {
    border-color: var(--accent);
  }

  .alpha-team-card__name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .alpha-team-card__role {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 14px;
  }

  .alpha-team-card__bio {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* --- 5. Technology Stack --- */
  .alpha-tech-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .alpha-tech-card {
    flex: 1;
    max-width: 260px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .alpha-tech-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .alpha-tech-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 229, 255, 0.2);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2), 0 0 20px var(--accent-glow);
  }

  .alpha-tech-card__icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }

  .alpha-tech-card__label {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .alpha-tech-card__desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .alpha-tech-card__sublabel {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .alpha-tech-arrow {
    flex-shrink: 0;
    display: flex;
