---
/*
  Blog Index — Team Alpha Redesign
  Jinki Aerial Intelligence

  Features:
  - Featured post hero (latest post, full-width with gradient overlay)
  - Tag filter bar (horizontal scrolling pills)
  - 2-column masonry-style grid with glass cards
  - Staggered scroll-reveal entrances
  - Card design: image placeholder, gradient accent bar, title, excerpt, date, read time
  - Dark/light theme support
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featured = posts[0];
const remaining = posts.slice(1);

// Collect all unique tags
const allTags = [...new Set(posts.flatMap(p => p.data.tags))];

// Tag color map
const tagColors: Record<string, string> = {
  'data centers': '#00E5FF',
  'thermal': '#FF6B35',
  'monitoring': '#FF8C00',
  'infrastructure': '#7B61FF',
  'AI': '#34D399',
  'inspection': '#10B981',
  'security': '#4F46E5',
  'agriculture': '#34D399',
  'energy': '#FF8C00',
};

function getTagColor(tag: string): string {
  return tagColors[tag.toLowerCase()] || '#00E5FF';
}

function estimateReadTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 230));
}
---

<Layout title="Blog — Jinki Aerial Intelligence" description="Insights on aerial intelligence, autonomous systems, thermal monitoring, and industry trends.">
  <Nav />

  <main id="main-content" class="blog-index">
    <!-- Featured Post Hero -->
    {featured && (
      <section class="featured-hero" style="padding-top: 100px;">
        <a href={`/blog/${featured.id}`} class="featured-link" aria-label={`Read featured post: ${featured.data.title}`}>
          <div class="featured-image-wrap">
            {featured.data.image ? (
              <img src={featured.data.image} alt="" class="featured-img" loading="eager" />
            ) : (
              <div class="featured-img-placeholder">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.3;">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
              </div>
            )}
            <div class="featured-overlay"></div>
            <div class="featured-content">
              <div class="featured-badge">
                <span class="featured-badge-dot"></span>
                Featured
              </div>
              <div class="featured-meta" style="margin-bottom: 12px;">
                <time datetime={featured.data.date.toISOString()}>
                  {featured.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="meta-sep" aria-hidden="true">|</span>
                <span>{estimateReadTime(featured.body || '')} min read</span>
              </div>
              <h1 class="featured-title">{featured.data.title}</h1>
              <p class="featured-desc">{featured.data.description}</p>
              <div class="featured-tags" style="margin-top: 16px;">
                {featured.data.tags.map(tag => (
                  <span class="tag-pill" style={`--tag-color: ${getTagColor(tag)}`}>{tag}</span>
                ))}
              </div>
            </div>
          </div>
        </a>
      </section>
    )}

    <div class="blog-body section-inner">
      <!-- Header + Tag Filter Bar -->
      <div class="blog-controls reveal" style="margin-bottom: 40px;">
        <div class="blog-heading-row" style="margin-bottom: 24px;">
          <span class="label" style="margin-bottom: 8px; display: block;">Blog</span>
          <h2 style="font-size: clamp(1.5rem, 3vw, 2rem);">All Posts</h2>
        </div>

        <div class="tag-filter-bar" role="tablist" aria-label="Filter posts by tag">
          <button
            class="tag-filter-pill active"
            data-tag="all"
            role="tab"
            aria-selected="true"
          >
            All
          </button>
          {allTags.map(tag => (
            <button
              class="tag-filter-pill"
              data-tag={tag}
              role="tab"
              aria-selected="false"
              style={`--pill-color: ${getTagColor(tag)}`}
            >
              {tag}
            </button>
          ))}
        </div>
      </div>

      <!-- Post Grid -->
      <div class="post-grid" id="post-grid">
        {remaining.length === 0 && posts.length <= 1 && (
          <p class="blog-empty" style="grid-column: 1 / -1; text-align: center; padding: 80px 0; color: var(--text-tertiary);">
            More posts coming soon.
          </p>
        )}

        {(remaining.length > 0 ? remaining : posts.length > 1 ? posts.slice(1) : posts).map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class={`post-card glass-panel reveal`}
            style={`--card-delay: ${i * 0.08}s; --accent-bar: ${getTagColor(post.data.tags[0] || '')}`}
            data-tags={post.data.tags.join(',')}
          >
            <div class="card-image-wrap">
              {post.data.image ? (
                <img src={post.data.image} alt="" class="card-img" loading="lazy" />
              ) : (
                <div class="card-img-placeholder">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.2;">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <polyline points="21 15 16 10 5 21"/>
                  </svg>
                </div>
              )}
              <div class="card-accent-bar"></div>
            </div>
            <div class="card-body" style="padding: 20px 20px 24px;">
              <div class="card-meta" style="margin-bottom: 10px;">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <span class="meta-dot" aria-hidden="true"></span>
                <span>{estimateReadTime(post.body || '')} min read</span>
              </div>
              <h3 class="card-title" style="margin-bottom: 8px;">{post.data.title}</h3>
              <p class="card-excerpt">{post.data.description}</p>
              <div class="card-footer" style="margin-top: 16px;">
                <div class="card-tags">
                  {post.data.tags.slice(0, 2).map(tag => (
                    <span class="card-tag" style={`--tag-color: ${getTagColor(tag)}`}>{tag}</span>
                  ))}
                </div>
                <span class="card-read-arrow" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<style>
  /* ---- Page ---- */
  .blog-index {
    min-height: 100vh;
    background: var(--bg-primary);
  }

  /* ---- Featured Hero ---- */
  .featured-hero {
    position: relative;
    overflow: hidden;
  }

  .featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .featured-image-wrap {
    position: relative;
    width: 100%;
    min-height: 480px;
    max-height: 600px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .featured-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-img-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-elevated) 100%);
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(5, 5, 8, 0.95) 0%,
      rgba(5, 5, 8, 0.7) 40%,
      rgba(5, 5, 8, 0.2) 100%
    );
    z-index: 1;
  }

  :global([data-theme="light"]) .featured-overlay {
    background: linear-gradient(
      to top,
      rgba(250, 251, 252, 0.97) 0%,
      rgba(250, 251, 252, 0.75) 40%,
      rgba(250, 251, 252, 0.15) 100%
    );
  }

  .featured-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 24px 48px;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid var(--accent-glow-strong);
    border-radius: 100px;
    padding: 4px 14px;
    margin-bottom: 16px;
  }

  .featured-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  .featured-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .meta-sep {
    opacity: 0.4;
  }

  .featured-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    line-height: 1.1;
    color: var(--text-primary);
    max-width: 700px;
    margin-bottom: 12px;
  }

  .featured-desc {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 600px;
  }

  .featured-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag-pill {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 12px;
    border-radius: 100px;
    background: color-mix(in srgb, var(--tag-color) 15%, transparent);
    color: var(--tag-color);
    border: 1px solid color-mix(in srgb, var(--tag-color) 25%, transparent);
  }

  .featured-link:hover .featured-title {
    color: var(--accent);
  }

  .featured-link:hover .featured-img,
  .featured-link:hover .featured-img-placeholder {
    transform: scale(1.02);
    transition: transform 0.6s ease;
  }

  /* ---- Blog Body ---- */
  .blog-body {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  .blog-heading-row h2 {
    color: var(--text-primary);
  }

  /* ---- Tag Filter Bar ---- */
  .tag-filter-bar {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
  }

  .tag-filter-bar::-webkit-scrollbar {
    display: none;
  }

  .tag-filter-pill {
    flex-shrink: 0;
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 18px;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .tag-filter-pill:hover {
    border-color: var(--text-tertiary);
    color: var(--text-primary);
  }

  .tag-filter-pill.active {
    background: var(--accent);
    color: #050508;
    border-color: var(--accent);
    font-weight: 600;
  }

  :global([data-theme="light"]) .tag-filter-pill.active {
    color: #fff;
  }

  /* ---- Post Grid ---- */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  /* ---- Post Card ---- */
  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.35s ease;
    transition-delay: var(--card-delay, 0s);
  }

  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-glow);
  }

  .post-card:hover .card-read-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  .post-card:hover .card-title {
    color: var(--accent);
  }

  .card-image-wrap {
    position: relative;
    width: 100%;
    height: 180px;
    overflow: hidden;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-card:hover .card-img {
    transform: scale(1.05);
  }

  .card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-elevated) 100%);
  }

  .card-accent-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent-bar, var(--accent)), transparent);
    z-index: 3;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-tertiary);
  }

  .card-title {
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .card-excerpt {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-tags {
    display: flex;
    gap: 6px;
  }

  .card-tag {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tag-color, var(--accent)) 12%, transparent);
    color: var(--tag-color, var(--accent));
  }

  .card-read-arrow {
    color: var(--text-tertiary);
    transition: transform 0.25s ease, color 0.25s ease;
    display: flex;
  }

  /* ---- Staggered Reveal for Cards ---- */
  .post-card.reveal {
    transition-delay: var(--card-delay, 0s);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .featured-image-wrap {
      min-height: 360px;
    }

    .featured-title {
      font-size: clamp(1.4rem, 5vw, 2rem);
    }

    .post-grid {
      grid-template-columns: 1fr;
    }

    .blog-body {
      padding-top: 32px;
    }
  }

  @media (max-width: 480px) {
    .featured-content {
      padding: 0 16px 32px;
    }

    .card-image-wrap {
      height: 140px;
    }
  }
</style>

<script>
  // Tag filter interactivity
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll<HTMLButtonElement>('.tag-filter-pill');
    const cards = document.querySelectorAll<HTMLAnchorElement>('.post-card');

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        // Update active state
        pills.forEach(p => {
          p.classList.remove('active');
          p.setAttribute('aria-selected', 'false');
        });
        pill.classList.add('active');
        pill.setAttribute('aria-selected', 'true');

        const tag = pill.dataset.tag;

        cards.forEach(card => {
          const cardTags = card.dataset.tags?.toLowerCase() || '';
          if (tag === 'all' || cardTags.includes(tag!.toLowerCase())) {
            card.style.display = '';
            card.style.opacity = '0';
            card.style.transform = 'translateY(16px)';
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                card.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
              });
            });
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  });
</script>
