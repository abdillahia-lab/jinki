    .process-connector-fill {
      transition: none;
      height: 100% !important;
    }
  }
</style>

<script is:inline>
  (function() {
    /* ================================================================
       HOTSPOT INTERACTIONS
       ================================================================ */
    var hotspotData = {
      'hs-1': { temp: '72.4\u00B0C', label: 'CRAH Unit #7', desc: 'Failing compressor bearing \u2014 estimated 14 days to failure. Replacement cost: $8,200 vs $340K unplanned outage.', severity: 'critical' },
      'hs-2': { temp: '54.1\u00B0C', label: 'Roof Section B3', desc: 'Moisture intrusion beneath membrane \u2014 12 sq ft affected area. Schedule repair before next rain event.', severity: 'warning' },
      'hs-3': { temp: '61.8\u00B0C', label: 'Generator Exhaust', desc: 'Elevated exhaust temperature indicating fuel injection timing drift. Service within 30 days.', severity: 'warning' },
      'hs-4': { temp: '83.2\u00B0C', label: 'Transformer T-4', desc: 'Hot spot on bushing connection \u2014 loose connection risk. Immediate inspection recommended per NFPA 70B.', severity: 'critical' },
      'hs-5': { temp: '47.6\u00B0C', label: 'Cooling Tower #2', desc: 'Fill media degradation reducing efficiency by ~18%. Schedule replacement during next maintenance window.', severity: 'moderate' },
    };

    var tooltip = document.getElementById('heatmap-tooltip');
    var tooltipLabel = document.getElementById('tooltip-label');
    var tooltipTemp = document.getElementById('tooltip-temp');
    var tooltipDesc = document.getElementById('tooltip-desc');
    var tooltipSeverity = document.getElementById('tooltip-severity');

    if (!tooltip) return;

    var hotspotBtns = document.querySelectorAll('.heatmap-hotspot');
    var heatmapEl = document.querySelector('.alpha-heatmap');
    var activeHotspot = null;

    hotspotBtns.forEach(function(btn) {
      btn.addEventListener('mouseenter', function() { showTooltip(btn); });
      btn.addEventListener('mouseleave', function() { hideTooltip(); });
      btn.addEventListener('focus', function() { showTooltip(btn); });
      btn.addEventListener('blur', function() { hideTooltip(); });
      btn.addEventListener('click', function() {
        if (activeHotspot === btn) {
          hideTooltip();
          activeHotspot = null;
        } else {
          showTooltip(btn);
          activeHotspot = btn;
        }
      });
    });

    function showTooltip(btn) {
      var id = btn.getAttribute('data-hotspot-id');
      var data = hotspotData[id];
      if (!data) return;

      tooltipLabel.textContent = data.label;
      tooltipTemp.textContent = data.temp;
      tooltipDesc.textContent = data.desc;
      tooltipSeverity.className = 'tooltip-severity severity-' + data.severity;

      // Position tooltip
      var heatmapRect = heatmapEl.getBoundingClientRect();
      var btnRect = btn.getBoundingClientRect();
      var tooltipWidth = 280;

      var left = btnRect.left - heatmapRect.left + btnRect.width / 2;
      var top = btnRect.top - heatmapRect.top - 10;

      // Keep within bounds
      if (left + tooltipWidth / 2 > heatmapRect.width) {
        left = heatmapRect.width - tooltipWidth - 10;
      } else if (left - tooltipWidth / 2 < 0) {
        left = 10;
      } else {
        left = left - tooltipWidth / 2;
      }

      // Show above or below
      if (top > 200) {
        tooltip.style.top = 'auto';
        tooltip.style.bottom = (heatmapRect.height - btnRect.top + heatmapRect.top + 10) + 'px';
      } else {
        tooltip.style.top = (btnRect.bottom - heatmapRect.top + 10) + 'px';
        tooltip.style.bottom = 'auto';
      }
      tooltip.style.left = left + 'px';

      tooltip.classList.add('visible');
      tooltip.setAttribute('aria-hidden', 'false');
    }

    function hideTooltip() {
      if (activeHotspot) return;
      tooltip.classList.remove('visible');
      tooltip.setAttribute('aria-hidden', 'true');
    }

    // Close tooltip on outside click
    document.addEventListener('click', function(e) {
      if (activeHotspot && !e.target.closest('.heatmap-hotspot')) {
        activeHotspot = null;
        tooltip.classList.remove('visible');
        tooltip.setAttribute('aria-hidden', 'true');
      }
    });

    /* ================================================================
       BEFORE/AFTER SLIDER
       ================================================================ */
    var slider = document.getElementById('comparison-slider');
    var handle = document.getElementById('slider-handle');
    if (!slider || !handle) return;

    var beforeLayer = slider.querySelector('.slider-before');
    var isDragging = false;

    function updateSliderPosition(clientX) {
      var rect = slider.getBoundingClientRect();
      var x = Math.max(0, Math.min(clientX - rect.left, rect.width));
      var pct = (x / rect.width) * 100;

      beforeLayer.style.clipPath = 'inset(0 ' + (100 - pct) + '% 0 0)';
      handle.style.left = pct + '%';
      handle.setAttribute('aria-valuenow', Math.round(pct));
    }

    slider.addEventListener('mousedown', function(e) {
      isDragging = true;
      updateSliderPosition(e.clientX);
      e.preventDefault();
    });

    slider.addEventListener('touchstart', function(e) {
      isDragging = true;
      updateSliderPosition(e.touches[0].clientX);
    }, { passive: true });

    document.addEventListener('mousemove', function(e) {
      if (isDragging) updateSliderPosition(e.clientX);
    });

    document.addEventListener('touchmove', function(e) {
      if (isDragging) updateSliderPosition(e.touches[0].clientX);
    }, { passive: true });

    document.addEventListener('mouseup', function() { isDragging = false; });
    document.addEventListener('touchend', function() { isDragging = false; });

    // Keyboard support
    handle.addEventListener('keydown', function(e) {
      var current = parseInt(handle.getAttribute('aria-valuenow') || '50', 10);
      if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') {
        e.preventDefault();
        current = Math.max(0, current - 2);
      } else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') {
        e.preventDefault();
        current = Math.min(100, current + 2);
      }
      beforeLayer.style.clipPath = 'inset(0 ' + (100 - current) + '% 0 0)';
      handle.style.left = current + '%';
      handle.setAttribute('aria-valuenow', current);
    });

    /* ================================================================
       PROCESS FLOW ANIMATION
       ================================================================ */
    var processFlow = document.getElementById('process-flow');
    var connectorFill = document.getElementById('process-connector-fill');
    if (processFlow && connectorFill) {
      var processSteps = processFlow.querySelectorAll('.process-step');

      var processObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var idx = parseInt(entry.target.getAttribute('data-step-index'), 10);
            entry.target.classList.add('step-active');
            var pct = Math.min(100, ((idx + 1) / processSteps.length) * 100);
            connectorFill.style.height = pct + '%';
          }
        });
      }, { threshold: 0.5, rootMargin: '0px 0px -20% 0px' });

      processSteps.forEach(function(step) {
        processObserver.observe(step);
      });
    }

    /* ================================================================
       ROI CALCULATOR
       ================================================================ */
    var roiSqft = document.getElementById('roi-sqft');
    var roiBuildings = document.getElementById('roi-buildings');
    var roiTier = document.getElementById('roi-tier');
    var roiSqftVal = document.getElementById('roi-sqft-val');
    var roiBuildingsVal = document.getElementById('roi-buildings-val');
    var roiSavings = document.getElementById('roi-savings');
    var roiTime = document.getElementById('roi-time');
    var roiRisk = document.getElementById('roi-risk');
    var roiReturn = document.getElementById('roi-return');

    if (roiSqft && roiBuildings && roiTier) {
      function formatCurrency(val) {
        if (val >= 1000000) return '$' + (val / 1000000).toFixed(1) + 'M';
        if (val >= 1000) return '$' + Math.round(val / 1000) + 'K';
        return '$' + Math.round(val);
      }

      function calculateROI() {
        var sqft = parseInt(roiSqft.value, 10);
        var buildings = parseInt(roiBuildings.value, 10);
        var tier = parseInt(roiTier.value, 10);

        // Display current values
        roiSqftVal.textContent = sqft.toLocaleString() + ' sq ft';
        roiBuildingsVal.textContent = buildings + ' building' + (buildings > 1 ? 's' : '');

        // Tier multipliers
        var tierMultiplier = tier === 4 ? 2.2 : (tier === 3 ? 1.5 : 1.0);
        var downtimeCostPerMin = tier === 4 ? 15000 : (tier === 3 ? 9000 : 5000);

        // Estimated savings: based on typical 2 prevented incidents per year
        var baseSavings = downtimeCostPerMin * 45 * 2; // 45 min avg outage, 2 incidents
        var facilitySizeMultiplier = sqft / 500000;
        var buildingMultiplier = Math.log2(buildings + 1);
        var totalSavings = Math.round(baseSavings * facilitySizeMultiplier * buildingMultiplier * tierMultiplier);

        // Time reduction: aerial vs manual
        var manualWeeksPerBuilding = 2.5;
        var aerialHoursPerBuilding = 0.75;
        var totalManualWeeks = manualWeeksPerBuilding * buildings;
        var totalAerialHours = aerialHoursPerBuilding * buildings;
        var timeReduction = Math.min(95, Math.round((1 - (totalAerialHours / (totalManualWeeks * 40))) * 100));

        // Risk reduction
        var riskReduction = Math.min(85, Math.round(55 + (buildings * 2) + (tier * 3)));

        // ROI multiplier
        var assessmentCost = 15000 + (buildings * 5000);
        var roiMultiplier = Math.round(totalSavings / assessmentCost);

        // Update display
        roiSavings.textContent = formatCurrency(totalSavings);
        roiTime.textContent = timeReduction + '%';
        roiRisk.textContent = riskReduction + '%';
        roiReturn.textContent = roiMultiplier + 'x';
      }

      roiSqft.addEventListener('input', calculateROI);
      roiBuildings.addEventListener('input', calculateROI);
      roiTier.addEventListener('change', calculateROI);

      // Initial calculation
      calculateROI();
    }

    /* ================================================================
       COUNTER ANIMATION (for stats)
       ================================================================ */
    var statValues = document.querySelectorAll('.alpha-stat-value[data-count]');
    if (statValues.length) {
      var counterObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            animateCounter(entry.target);
            counterObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });
      statValues.forEach(function(el) { counterObserver.observe(el); });
    }

    function animateCounter(el) {
      var target = el.getAttribute('data-count');
      var suffix = el.getAttribute('data-suffix') || '';
      var num = parseFloat(target);
      var isDecimal = target.indexOf('.') !== -1;
      var duration = 1800;
      var start = performance.now();

      // Check reduced motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.textContent = (isDecimal ? num.toFixed(1) : Math.round(num)) + suffix;
        return;
      }

      function update(now) {
        var elapsed = now - start;
        var progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        var eased = 1 - Math.pow(1 - progress, 3);
        var current = num * eased;
        el.textContent = (isDecimal ? current.toFixed(1) : Math.round(current)) + suffix;
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }
  })();
</script>
