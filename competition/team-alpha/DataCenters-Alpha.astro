    box-shadow: 0 4px 20px rgba(0, 131, 143, 0.4);
  }

  /* ================================================================
     REDUCED MOTION
     ================================================================ */
  @media (prefers-reduced-motion: reduce) {
    .heatmap-scanline,
    .hotspot-pulse,
    .thermal-anomaly {
      animation: none;
    }

    .heatmap-scanline {
      display: none;
    }

    .hotspot-pulse {
