---
/*
  TEAM ALPHA — Data Centers Vertical Page Redesign
  Round 3 Competitive Web Design Challenge

  Features:
  1. Interactive thermal heatmap hero with hoverable hotspots
  2. Before/After comparison slider
  3. ROI Calculator
  4. Animated process flow timeline
  5. Counter-animated stats
  6. Glass-morphism case study card
  7. Service comparison table (Jinki vs Traditional)
*/
import Layout from '../../src/layouts/Layout.astro';
import Nav from '../../src/components/Nav.astro';
import LeadGen from '../../src/components/LeadGen.astro';
import Footer from '../../src/components/Footer.astro';

const hotspots = [
  { id: 'hs-1', x: 22, y: 28, temp: '72.4', label: 'CRAH Unit #7', desc: 'Failing compressor bearing — estimated 14 days to failure. Replacement cost: $8,200 vs $340K unplanned outage.', severity: 'critical' },
  { id: 'hs-2', x: 58, y: 35, temp: '54.1', label: 'Roof Section B3', desc: 'Moisture intrusion beneath membrane — 12 sq ft affected area. Schedule repair before next rain event.', severity: 'warning' },
  { id: 'hs-3', x: 75, y: 55, temp: '61.8', label: 'Generator Exhaust', desc: 'Elevated exhaust temperature indicating fuel injection timing drift. Service within 30 days.', severity: 'warning' },
  { id: 'hs-4', x: 38, y: 62, temp: '83.2', label: 'Transformer T-4', desc: 'Hot spot on bushing connection — loose connection risk. Immediate inspection recommended per NFPA 70B.', severity: 'critical' },
  { id: 'hs-5', x: 85, y: 25, temp: '47.6', label: 'Cooling Tower #2', desc: 'Fill media degradation reducing efficiency by ~18%. Schedule replacement during next maintenance window.', severity: 'moderate' },
];

const processSteps = [
  { icon: 'rocket_launch', title: 'Deploy', desc: 'Aerial platform arrives on-site and begins pre-flight calibration. Zero disruption to your operations.' },
  { icon: 'radar', title: 'Scan', desc: 'Full-campus thermal and visual survey — every rooftop, mechanical system, and perimeter section in under 4 hours.' },
  { icon: 'psychology', title: 'Analyze', desc: 'AI-assisted thermal analysis cross-references findings against equipment baselines and failure pattern databases.' },
  { icon: 'verified_user', title: 'Report', desc: 'Severity-ranked report with remediation priorities, cost estimates, and suggested maintenance timelines delivered within 48 hours.' },
  { icon: 'speed', title: 'Act', desc: 'Your facilities team receives a work order — not a data dump. Every finding is actionable and quantified.' },
];

const stats = [
  { value: '47', suffix: '%', label: 'Average cost reduction in unplanned maintenance', icon: 'trending_down' },
  { value: '4', prefix: '<', suffix: 'hr', label: 'Full facility scan completion time', icon: 'speed' },
  { value: '99.2', suffix: '%', label: 'Thermal defect detection accuracy rate', icon: 'thermostat' },
  { value: '2.3', prefix: '$', suffix: 'M', label: 'Average prevented downtime costs per year', icon: 'shield' },
];

const comparisonRows = [
  { feature: 'Full campus coverage in one engagement', jinki: true, traditional: false },
  { feature: 'AI-prioritized severity rankings', jinki: true, traditional: false },
  { feature: 'Remediation cost estimates included', jinki: true, traditional: false },
  { feature: 'No roof access permits required', jinki: true, traditional: false },
  { feature: 'NFPA 70B compliance documentation', jinki: true, traditional: true },
  { feature: 'Sub-4-hour facility scan time', jinki: true, traditional: false },
  { feature: 'Thermal + visual + LiDAR fusion', jinki: true, traditional: false },
  { feature: 'Persistent autonomous monitoring option', jinki: true, traditional: false },
  { feature: 'Available same-day in Virginia market', jinki: true, traditional: false },
];
---

<Layout title="Data Centers — Jinki Aerial Intelligence" description="Interactive thermal intelligence for data center operations. Explore our thermal heatmap, ROI calculator, and see how Jinki transforms facility maintenance.">
  <Nav />
  <main id="main-content">

    <!-- ============================================================
         SECTION 1: Interactive Thermal Heatmap Hero
         ============================================================ -->
    <section class="alpha-hero" aria-label="Data Center Thermal Intelligence">
      <div class="alpha-hero-inner">
        <div class="alpha-hero-content reveal">
          <div class="alpha-eyebrow">
            <span class="alpha-eyebrow-line"></span>
            <span class="alpha-eyebrow-text">Data Centers</span>
          </div>
          <h1 class="alpha-hero-title">
            See What Your<br/>
            <span class="gradient-text-cyan">Facilities Team Can't</span>
          </h1>
          <p class="alpha-hero-subtitle">
            Every hotspot on this map is a real-world failure pattern found during
            aerial thermal inspections. Hover to explore what our sensors detect —
            and what goes unnoticed until it costs you millions.
          </p>
          <div class="alpha-hero-actions">
            <a href="#lead-gen" class="btn-premium alpha-cta">Schedule Assessment</a>
            <a href="#roi-calculator" class="alpha-cta-secondary">Calculate Your ROI</a>
          </div>
        </div>

        <!-- Interactive Thermal Heatmap -->
        <div class="alpha-heatmap-wrap reveal reveal-delay-1" role="img" aria-label="Interactive thermal heatmap of a data center rooftop showing detected anomalies">
          <div class="alpha-heatmap">
            <div class="heatmap-grid"></div>
            <div class="heatmap-scanline" aria-hidden="true"></div>

            <!-- Thermal gradient overlay -->
            <div class="heatmap-thermal-layer" aria-hidden="true"></div>

            <!-- Building outlines -->
            <svg class="heatmap-buildings" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="10" y="15" width="35" height="50" rx="1" stroke="rgba(0,229,255,0.2)" stroke-width="0.3" fill="rgba(0,229,255,0.03)"/>
              <rect x="50" y="20" width="40" height="40" rx="1" stroke="rgba(0,229,255,0.2)" stroke-width="0.3" fill="rgba(0,229,255,0.03)"/>
              <rect x="55" y="65" width="30" height="20" rx="1" stroke="rgba(0,229,255,0.15)" stroke-width="0.3" fill="rgba(0,229,255,0.02)"/>
              <line x1="45" y1="40" x2="50" y2="40" stroke="rgba(0,229,255,0.1)" stroke-width="0.2" stroke-dasharray="1,1"/>
            </svg>

            {hotspots.map(hs => (
              <button
                class={`heatmap-hotspot hotspot-${hs.severity}`}
                style={`left: ${hs.x}%; top: ${hs.y}%;`}
                data-hotspot-id={hs.id}
                aria-label={`${hs.label}: ${hs.temp} degrees Celsius — ${hs.severity} severity`}
                type="button"
              >
                <span class="hotspot-pulse" aria-hidden="true"></span>
                <span class="hotspot-core" aria-hidden="true"></span>
              </button>
            ))}

            <!-- Hotspot tooltip (positioned via JS) -->
            <div class="heatmap-tooltip" id="heatmap-tooltip" role="tooltip" aria-hidden="true">
              <div class="tooltip-header">
                <span class="tooltip-severity" id="tooltip-severity"></span>
                <span class="tooltip-label" id="tooltip-label"></span>
              </div>
              <div class="tooltip-temp" id="tooltip-temp"></div>
              <p class="tooltip-desc" id="tooltip-desc"></p>
            </div>

            <!-- HUD readout -->
            <div class="heatmap-hud" aria-hidden="true">
              <div class="hud-line"><span class="hud-key">MODE</span><span class="hud-val">THERMAL IR</span></div>
              <div class="hud-line"><span class="hud-key">ALT</span><span class="hud-val">120m AGL</span></div>
              <div class="hud-line"><span class="hud-key">SENSOR</span><span class="hud-val">H30T</span></div>
              <div class="hud-line"><span class="hud-key">DETECTIONS</span><span class="hud-val hud-val-accent">5 ANOMALIES</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 2: Animated Stats Counters
         ============================================================ -->
    <section class="alpha-stats reveal" aria-label="Key Performance Metrics">
      <div class="alpha-stats-inner">
        {stats.map((stat, i) => (
          <div class={`alpha-stat-item reveal reveal-delay-${i + 1}`}>
            <span class="material-symbols-outlined alpha-stat-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{stat.icon}</span>
            <div class="alpha-stat-value-wrap">
              {stat.prefix && <span class="alpha-stat-prefix">{stat.prefix}</span>}
              <span class="alpha-stat-value" data-count={stat.value} data-suffix={stat.suffix}>{stat.prefix === '<' ? '< ' : ''}{stat.value}{stat.suffix}</span>
            </div>
            <span class="alpha-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ============================================================
         SECTION 3: Before / After Comparison Slider
         ============================================================ -->
    <section class="alpha-section" aria-label="Before and After Comparison" id="comparison">
      <div class="alpha-section-inner">
        <div class="alpha-section-header reveal">
          <div class="alpha-eyebrow">
            <span class="alpha-eyebrow-line"></span>
            <span class="alpha-eyebrow-text">Visual Intelligence</span>
          </div>
          <h2>Standard Aerial View vs.<br/>Thermal Analysis</h2>
          <p class="alpha-section-subtitle">
            Drag the slider to see the difference between a standard visual inspection
            and Jinki's thermal intelligence layer. What looks normal to the eye hides
            critical failures visible only in the thermal spectrum.
          </p>
        </div>

        <div class="alpha-slider-container reveal reveal-delay-1" role="group" aria-label="Comparison slider between standard and thermal views">
          <div class="alpha-slider" id="comparison-slider">
            <!-- "Before" layer (standard view) -->
            <div class="slider-layer slider-before" aria-label="Standard aerial view">
              <div class="slider-scene slider-scene-normal">
                <div class="scene-grid" aria-hidden="true"></div>
                <svg class="scene-buildings" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="10" y="15" width="35" height="50" rx="1" stroke="rgba(150,160,170,0.4)" stroke-width="0.5" fill="rgba(150,160,170,0.08)"/>
                  <rect x="50" y="20" width="40" height="40" rx="1" stroke="rgba(150,160,170,0.4)" stroke-width="0.5" fill="rgba(150,160,170,0.08)"/>
                  <rect x="55" y="65" width="30" height="20" rx="1" stroke="rgba(150,160,170,0.3)" stroke-width="0.5" fill="rgba(150,160,170,0.05)"/>
                  <!-- HVAC units -->
                  <rect x="15" y="20" width="6" height="6" fill="rgba(150,160,170,0.15)"/>
                  <rect x="25" y="20" width="6" height="6" fill="rgba(150,160,170,0.15)"/>
                  <rect x="35" y="20" width="6" height="6" fill="rgba(150,160,170,0.15)"/>
                  <rect x="55" y="25" width="8" height="8" fill="rgba(150,160,170,0.15)"/>
                  <rect x="72" y="25" width="8" height="8" fill="rgba(150,160,170,0.15)"/>
                </svg>
                <div class="scene-label">STANDARD VIEW</div>
                <div class="scene-caption">Everything looks operational</div>
              </div>
            </div>

            <!-- "After" layer (thermal view) -->
            <div class="slider-layer slider-after" aria-label="Thermal analysis view">
              <div class="slider-scene slider-scene-thermal">
                <div class="scene-grid scene-grid-thermal" aria-hidden="true"></div>
                <svg class="scene-buildings" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="10" y="15" width="35" height="50" rx="1" stroke="rgba(0,229,255,0.3)" stroke-width="0.5" fill="rgba(0,100,200,0.05)"/>
                  <rect x="50" y="20" width="40" height="40" rx="1" stroke="rgba(0,229,255,0.3)" stroke-width="0.5" fill="rgba(0,100,200,0.05)"/>
                  <rect x="55" y="65" width="30" height="20" rx="1" stroke="rgba(0,229,255,0.2)" stroke-width="0.5" fill="rgba(0,100,200,0.03)"/>
                </svg>
                <!-- Thermal anomalies -->
                <div class="thermal-anomaly anomaly-critical" style="left: 22%; top: 28%; width: 50px; height: 50px;"></div>
                <div class="thermal-anomaly anomaly-warning" style="left: 58%; top: 35%; width: 40px; height: 40px;"></div>
                <div class="thermal-anomaly anomaly-critical" style="left: 38%; top: 62%; width: 45px; height: 45px;"></div>
                <div class="thermal-anomaly anomaly-warning" style="left: 75%; top: 55%; width: 35px; height: 35px;"></div>
                <div class="thermal-anomaly anomaly-moderate" style="left: 85%; top: 25%; width: 30px; height: 30px;"></div>
                <div class="scene-label scene-label-thermal">THERMAL ANALYSIS</div>
                <div class="scene-caption scene-caption-thermal">5 anomalies detected — 2 critical</div>
              </div>
            </div>

            <!-- Slider handle -->
            <div class="slider-handle" id="slider-handle" role="slider" aria-label="Drag to compare standard and thermal views" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
              <div class="slider-handle-line"></div>
              <div class="slider-handle-grip">
                <span class="material-symbols-outlined" style="font-size: 20px; font-variation-settings: 'FILL' 1;" aria-hidden="true">drag_indicator</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 4: Animated Process Flow
         ============================================================ -->
    <section class="alpha-section alpha-section-dim" aria-label="Our Process" id="process">
      <div class="alpha-section-inner">
        <div class="alpha-section-header reveal">
          <div class="alpha-eyebrow">
            <span class="alpha-eyebrow-line"></span>
            <span class="alpha-eyebrow-text">How It Works</span>
          </div>
          <h2>From Deployment to<br/>Actionable Intelligence</h2>
          <p class="alpha-section-subtitle">
            A complete facility assessment in five steps. No platforms to learn,
            no data to interpret, no guesswork involved.
          </p>
        </div>

        <div class="alpha-process" id="process-flow">
          <div class="process-connector" aria-hidden="true">
            <div class="process-connector-fill" id="process-connector-fill"></div>
          </div>
          {processSteps.map((step, i) => (
            <div class={`process-step reveal reveal-delay-${i + 1}`} data-step-index={i}>
              <div class="process-step-marker">
                <span class="process-step-number">{String(i + 1).padStart(2, '0')}</span>
                <div class="process-step-dot">
                  <span class="material-symbols-outlined" style="font-size: 24px; font-variation-settings: 'FILL' 1;" aria-hidden="true">{step.icon}</span>
                </div>
              </div>
              <div class="process-step-content">
                <h3 class="process-step-title">{step.title}</h3>
                <p class="process-step-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 5: ROI Calculator
         ============================================================ -->
    <section class="alpha-section" aria-label="ROI Calculator" id="roi-calculator">
      <div class="alpha-section-inner">
        <div class="alpha-section-header reveal">
          <div class="alpha-eyebrow">
            <span class="alpha-eyebrow-line"></span>
            <span class="alpha-eyebrow-text">ROI Calculator</span>
          </div>
          <h2>Quantify Your<br/>Risk Reduction</h2>
          <p class="alpha-section-subtitle">
            Input your facility details and see estimated savings from proactive
            aerial thermal intelligence versus reactive maintenance.
          </p>
        </div>

        <div class="alpha-roi-container reveal reveal-delay-1">
          <div class="alpha-roi-inputs glass-panel" style="border-radius: 16px;">
            <h3 class="roi-input-title">Your Facility</h3>

            <div class="roi-field">
              <label for="roi-sqft" class="roi-label">Total Facility Size (sq ft)</label>
              <input type="range" id="roi-sqft" min="50000" max="2000000" step="50000" value="500000" class="roi-range" aria-describedby="roi-sqft-val"/>
              <div class="roi-range-labels">
                <span>50K</span>
                <span class="roi-range-current" id="roi-sqft-val">500,000 sq ft</span>
                <span>2M</span>
              </div>
            </div>

            <div class="roi-field">
              <label for="roi-buildings" class="roi-label">Number of Buildings</label>
              <input type="range" id="roi-buildings" min="1" max="20" step="1" value="4" class="roi-range" aria-describedby="roi-buildings-val"/>
              <div class="roi-range-labels">
                <span>1</span>
                <span class="roi-range-current" id="roi-buildings-val">4 buildings</span>
                <span>20</span>
              </div>
            </div>

            <div class="roi-field">
              <label for="roi-tier" class="roi-label">Tier Classification</label>
              <select id="roi-tier" class="roi-select">
                <option value="2">Tier II</option>
                <option value="3" selected>Tier III</option>
                <option value="4">Tier IV</option>
              </select>
            </div>
          </div>

          <div class="alpha-roi-results" id="roi-results">
            <h3 class="roi-results-title">Estimated Annual Impact</h3>

            <div class="roi-result-card roi-result-savings">
              <span class="material-symbols-outlined roi-result-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">trending_down</span>
              <div class="roi-result-data">
                <span class="roi-result-value" id="roi-savings">$1.2M</span>
                <span class="roi-result-label">Estimated Prevented Downtime Costs</span>
              </div>
            </div>

            <div class="roi-result-card roi-result-time">
              <span class="material-symbols-outlined roi-result-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">speed</span>
              <div class="roi-result-data">
                <span class="roi-result-value" id="roi-time">87%</span>
                <span class="roi-result-label">Inspection Time Reduction</span>
              </div>
            </div>

            <div class="roi-result-card roi-result-risk">
              <span class="material-symbols-outlined roi-result-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">shield</span>
              <div class="roi-result-data">
                <span class="roi-result-value" id="roi-risk">73%</span>
                <span class="roi-result-label">Unplanned Outage Risk Reduction</span>
              </div>
            </div>

            <div class="roi-result-card roi-result-roi">
              <span class="material-symbols-outlined roi-result-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">trending_up</span>
              <div class="roi-result-data">
                <span class="roi-result-value" id="roi-return">14x</span>
                <span class="roi-result-label">Return on Assessment Investment</span>
              </div>
            </div>

            <p class="roi-disclaimer">Estimates based on industry benchmarks and Jinki engagement data. Actual results vary by facility condition and operational profile.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 6: Case Study Card
         ============================================================ -->
    <section class="alpha-section alpha-section-dim" aria-label="Case Study" id="case-study">
      <div class="alpha-section-inner">
        <div class="alpha-section-header reveal">
          <div class="alpha-eyebrow">
            <span class="alpha-eyebrow-line"></span>
            <span class="alpha-eyebrow-text">Case Study</span>
          </div>
          <h2>From Reactive to Proactive</h2>
        </div>

        <div class="alpha-case-study glass-panel reveal reveal-delay-1" style="border-radius: 16px;">
          <div class="case-study-badge">Featured Engagement</div>

          <div class="case-study-grid">
            <div class="case-study-main">
              <h3 class="case-study-title">Fortune 100 Cloud Provider — Northern Virginia Campus</h3>
              <p class="case-study-context">
                A hyperscale operator with 6 buildings across 1.2 million square feet
                was experiencing recurring HVAC failures and unexpected roof leaks.
                Manual inspections were taking 3 weeks per building and missing
                subsurface defects entirely.
              </p>

              <div class="case-study-challenge">
                <h4>Challenge</h4>
                <p>
                  After two unplanned outages in Q3 — one caused by a failed CRAH unit,
                  another by storm water ingress through an undetected membrane breach —
                  the facilities team needed a systematic way to identify every thermal
                  and structural risk across the campus before winter.
                </p>
              </div>

              <div class="case-study-solution">
                <h4>Jinki's Approach</h4>
                <p>
                  A single-day aerial thermal and visual survey covered all six buildings,
                  every rooftop mechanical system, and the full perimeter. AI-assisted
                  analysis cross-referenced 47,000+ thermal data points against equipment
                  baselines, producing a severity-ranked report within 48 hours.
                </p>
              </div>
            </div>

            <div class="case-study-results">
              <h4>Results</h4>
              <div class="case-result-item">
                <span class="case-result-number">23</span>
                <span class="case-result-text">Thermal anomalies identified (3 critical)</span>
              </div>
              <div class="case-result-item">
                <span class="case-result-number">$4.1M</span>
                <span class="case-result-text">Estimated prevented downtime costs</span>
              </div>
              <div class="case-result-item">
                <span class="case-result-number">1 day</span>
                <span class="case-result-text">vs. 18 weeks traditional inspection</span>
              </div>
              <div class="case-result-item">
                <span class="case-result-number">100%</span>
                <span class="case-result-text">Campus coverage including inaccessible areas</span>
              </div>

              <blockquote class="case-study-quote">
                "For the first time, we had a complete picture of every thermal and structural risk across our campus — ranked by severity with clear remediation steps."
                <cite>— VP of Facilities Engineering</cite>
              </blockquote>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 7: Service Comparison Table
         ============================================================ -->
    <section class="alpha-section" aria-label="Service Comparison" id="comparison-table">
      <div class="alpha-section-inner">
        <div class="alpha-section-header reveal">
          <div class="alpha-eyebrow">
            <span class="alpha-eyebrow-line"></span>
            <span class="alpha-eyebrow-text">Why Jinki</span>
          </div>
          <h2>Aerial Intelligence vs.<br/>Traditional Inspection</h2>
          <p class="alpha-section-subtitle">
            Manual roof walks and spot-check thermography cover a fraction of your
            campus. Jinki delivers complete coverage with prioritized intelligence.
          </p>
        </div>

        <div class="alpha-comparison-table-wrap reveal reveal-delay-1">
          <table class="alpha-comparison-table" role="table">
            <thead>
              <tr>
                <th scope="col" class="comp-th-feature">Capability</th>
                <th scope="col" class="comp-th-jinki">
                  <span class="comp-brand">Jinki</span>
                  <span class="comp-brand-sub">Aerial Intelligence</span>
                </th>
                <th scope="col" class="comp-th-trad">
                  <span class="comp-brand">Traditional</span>
                  <span class="comp-brand-sub">Manual Inspection</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map(row => (
                <tr>
                  <td class="comp-feature">{row.feature}</td>
                  <td class="comp-cell comp-cell-jinki">
                    {row.jinki ? (
                      <span class="comp-check" aria-label="Yes">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="rgba(0,229,255,0.15)"/><path d="M6 10l3 3 5-6" stroke="#00E5FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    ) : (
                      <span class="comp-x" aria-label="No">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="rgba(255,75,75,0.1)"/><path d="M7 7l6 6M13 7l-6 6" stroke="#FF4B4B" stroke-width="2" stroke-linecap="round"/></svg>
                      </span>
                    )}
                  </td>
                  <td class="comp-cell comp-cell-trad">
                    {row.traditional ? (
                      <span class="comp-check-dim" aria-label="Yes">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="rgba(150,160,170,0.1)"/><path d="M6 10l3 3 5-6" stroke="rgba(150,160,170,0.5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      </span>
                    ) : (
                      <span class="comp-x" aria-label="No">
