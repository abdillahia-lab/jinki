---
/*
  Hero-Omega — "Topographic Intelligence Map"
  Team Omega competitive redesign for Jinki Aerial Intelligence.
  Pure CSS + vanilla JS. No external dependencies.
*/
---

<section id="hero" class="omega-hero" aria-label="Hero — Aerial Intelligence Platform">

  <!-- ============ BACKGROUND LAYERS ============ -->
  <div class="omega-bg" aria-hidden="true">

    <!-- Topographic SVG Map -->
    <svg class="topo-map" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <filter id="topoGlow">
          <feGaussianBlur stdDeviation="2" result="blur"/>
          <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <linearGradient id="contourGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.4"/>
          <stop offset="100%" stop-color="#7B61FF" stop-opacity="0.15"/>
        </linearGradient>
      </defs>
      <g class="topo-contours" filter="url(#topoGlow)">
        <!-- Contour rings — drawn on load via stroke-dashoffset -->
        <ellipse class="contour c1" cx="750" cy="400" rx="380" ry="220" />
        <ellipse class="contour c2" cx="720" cy="390" rx="310" ry="180" />
        <ellipse class="contour c3" cx="700" cy="380" rx="240" ry="140" />
        <ellipse class="contour c4" cx="690" cy="375" rx="170" ry="100" />
        <ellipse class="contour c5" cx="685" cy="370" rx="110" ry="65"  />
        <ellipse class="contour c6" cx="682" cy="368" rx="60"  ry="35"  />
        <!-- Secondary cluster -->
        <ellipse class="contour c7" cx="350" cy="550" rx="200" ry="120" />
        <ellipse class="contour c8" cx="340" cy="545" rx="140" ry="80"  />
        <ellipse class="contour c9" cx="335" cy="540" rx="80"  ry="45"  />
        <!-- Upper cluster -->
        <ellipse class="contour c10" cx="500" cy="200" rx="160" ry="90"  />
        <ellipse class="contour c11" cx="495" cy="195" rx="100" ry="55"  />
        <ellipse class="contour c12" cx="492" cy="192" rx="50"  ry="28"  />
      </g>
      <!-- Grid lines -->
      <g class="topo-grid" opacity="0.06">
        <line x1="0" y1="0" x2="0" y2="800" class="grid-v"/>
        <line x1="120" y1="0" x2="120" y2="800" class="grid-v"/>
        <line x1="240" y1="0" x2="240" y2="800" class="grid-v"/>
        <line x1="360" y1="0" x2="360" y2="800" class="grid-v"/>
        <line x1="480" y1="0" x2="480" y2="800" class="grid-v"/>
        <line x1="600" y1="0" x2="600" y2="800" class="grid-v"/>
        <line x1="720" y1="0" x2="720" y2="800" class="grid-v"/>
        <line x1="840" y1="0" x2="840" y2="800" class="grid-v"/>
        <line x1="960" y1="0" x2="960" y2="800" class="grid-v"/>
        <line x1="1080" y1="0" x2="1080" y2="800" class="grid-v"/>
        <line x1="1200" y1="0" x2="1200" y2="800" class="grid-v"/>
        <line x1="0" y1="0" x2="1200" y2="0" class="grid-h"/>
        <line x1="0" y1="100" x2="1200" y2="100" class="grid-h"/>
        <line x1="0" y1="200" x2="1200" y2="200" class="grid-h"/>
        <line x1="0" y1="300" x2="1200" y2="300" class="grid-h"/>
        <line x1="0" y1="400" x2="1200" y2="400" class="grid-h"/>
        <line x1="0" y1="500" x2="1200" y2="500" class="grid-h"/>
        <line x1="0" y1="600" x2="1200" y2="600" class="grid-h"/>
        <line x1="0" y1="700" x2="1200" y2="700" class="grid-h"/>
        <line x1="0" y1="800" x2="1200" y2="800" class="grid-h"/>
      </g>
    </svg>

    <!-- Scan line -->
    <div class="scan-line"></div>

    <!-- Ambient particles container -->
    <canvas class="particle-canvas" aria-hidden="true"></canvas>

    <!-- Split reveal overlay -->
    <div class="split-reveal">
      <div class="split-left"></div>
      <div class="split-right"></div>
    </div>
  </div>

  <!-- ============ CONTENT ============ -->
  <div class="omega-content">
    <div class="omega-text">

      <!-- Eyebrow -->
      <div class="omega-eyebrow reveal">
        <span class="eyebrow-pip"></span>
        <span class="eyebrow-line-el"></span>
        <span class="eyebrow-label">Aerial Intelligence Platform</span>
      </div>

      <!-- Headline -->
      <h1 class="omega-headline reveal reveal-delay-1">
        <span class="headline-static">See What You <span class="headline-accent">Can't.</span></span>
        <span class="headline-swap-wrapper" aria-live="polite" aria-label="Act Before It Fails.">
          <span class="headline-swap-track">
            <span class="swap-phrase active">Act Before It <span class="headline-accent">Fails.</span></span>
            <span class="swap-phrase">Know Before It <span class="headline-accent">Breaks.</span></span>
            <span class="swap-phrase">Fix Before It <span class="headline-accent">Costs.</span></span>
          </span>
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="omega-subtitle reveal reveal-delay-2">
        Jinki turns aerial data into prioritized maintenance recommendations
        for infrastructure you can't easily reach — power lines, rooftops,
        data centers, and farmland.
      </p>

      <!-- CTAs -->
      <div class="omega-actions reveal reveal-delay-3">
        <a href="#lead-gen" class="omega-cta-primary btn-premium">
          <span class="cta-glow"></span>
          Get a Free Assessment
        </a>
        <a href="#verticals" class="omega-cta-secondary btn-premium">
          See How It Works
          <svg class="cta-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Floating Metric Cards -->
    <div class="omega-metrics reveal reveal-delay-2">
      <div class="metric-card mc-1" data-tilt>
        <span class="metric-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="metric-value" data-count="99.7">0</span><span class="metric-unit">%</span>
        <span class="metric-label">Detection Accuracy</span>
      </div>
      <div class="metric-card mc-2" data-tilt>
        <span class="metric-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </span>
        <span class="metric-value" data-count="24">0</span><span class="metric-unit">hr</span>
        <span class="metric-label">Turnaround Time</span>
      </div>
      <div class="metric-card mc-3" data-tilt>
        <span class="metric-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="metric-value" data-count="10">0</span><span class="metric-unit">x</span>
        <span class="metric-label">Faster Than Manual</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="omega-scroll-indicator reveal reveal-delay-4" aria-hidden="true">
    <div class="scroll-track">
      <div class="scroll-thumb"></div>
    </div>
    <span class="scroll-text">Scroll</span>
  </div>
</section>

<style>
  /* ================================================================
     OMEGA HERO — Topographic Intelligence Map
     ================================================================ */

  .omega-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 6rem;
    padding-bottom: 3rem;
    overflow: hidden;
    background: var(--bg-primary);
  }

  /* ---- Background Layer ---- */
  .omega-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  /* ---- Topographic SVG ---- */
  .topo-map {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.7;
  }

  .contour {
    fill: none;
    stroke: url(#contourGrad);
    stroke-width: 1;
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: drawContour 3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  .c1  { animation-delay: 0.0s; stroke-opacity: 0.5; }
  .c2  { animation-delay: 0.15s; stroke-opacity: 0.45; }
  .c3  { animation-delay: 0.3s; stroke-opacity: 0.4; }
  .c4  { animation-delay: 0.45s; stroke-opacity: 0.35; }
  .c5  { animation-delay: 0.6s; stroke-opacity: 0.3; }
  .c6  { animation-delay: 0.75s; stroke-opacity: 0.25; }
  .c7  { animation-delay: 0.5s; stroke-opacity: 0.35; }
  .c8  { animation-delay: 0.65s; stroke-opacity: 0.3; }
  .c9  { animation-delay: 0.8s; stroke-opacity: 0.25; }
  .c10 { animation-delay: 0.35s; stroke-opacity: 0.35; }
  .c11 { animation-delay: 0.55s; stroke-opacity: 0.3; }
  .c12 { animation-delay: 0.7s; stroke-opacity: 0.25; }

  @keyframes drawContour {
    to { stroke-dashoffset: 0; }
  }

  /* Contour pulse after draw */
  .contour {
    animation: drawContour 3s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards,
               contourPulse 6s ease-in-out 3.5s infinite;
  }

  @keyframes contourPulse {
    0%, 100% { stroke-opacity: var(--base-opacity, 0.35); }
    50%      { stroke-opacity: calc(var(--base-opacity, 0.35) + 0.15); }
  }

  .c1  { --base-opacity: 0.5; }
  .c2  { --base-opacity: 0.45; }
  .c3  { --base-opacity: 0.4; }
  .c4  { --base-opacity: 0.35; }
  .c5  { --base-opacity: 0.3; }
  .c6  { --base-opacity: 0.25; }
  .c7  { --base-opacity: 0.35; }
  .c8  { --base-opacity: 0.3; }
  .c9  { --base-opacity: 0.25; }
  .c10 { --base-opacity: 0.35; }
  .c11 { --base-opacity: 0.3; }
  .c12 { --base-opacity: 0.25; }

  .topo-grid line {
    stroke: var(--accent);
    stroke-width: 0.5;
  }

  /* ---- Scan Line ---- */
  .scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--accent) 20%, var(--accent) 80%, transparent 100%);
    opacity: 0.5;
    top: -2px;
    animation: scanDown 6s cubic-bezier(0.4, 0, 0.6, 1) 2s infinite;
    box-shadow: 0 0 20px var(--accent), 0 0 60px var(--accent-glow);
    z-index: 3;
  }

  .scan-line::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: 80px;
    background: linear-gradient(to bottom, var(--accent-glow), transparent);
    pointer-events: none;
  }

  @keyframes scanDown {
    0%   { top: -2px; opacity: 0; }
    5%   { opacity: 0.6; }
    90%  { opacity: 0.3; }
    100% { top: 100%; opacity: 0; }
  }

  /* ---- Particle Canvas ---- */
  .particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  /* ---- Split Reveal ---- */
  .split-reveal {
    position: absolute;
    inset: 0;
    display: flex;
    z-index: 0;
    pointer-events: none;
  }

  .split-left {
    flex: 1;
    background: linear-gradient(135deg, rgba(5, 5, 8, 0.4) 0%, transparent 100%);
    transform: translateX(-100%);
    animation: splitLeftIn 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.2s forwards;
  }

  .split-right {
    flex: 1;
    background: linear-gradient(225deg, rgba(0, 229, 255, 0.03) 0%, transparent 60%);
    transform: translateX(100%);
    animation: splitRightIn 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.2s forwards;
  }

  @keyframes splitLeftIn {
    to { transform: translateX(0); }
  }
  @keyframes splitRightIn {
    to { transform: translateX(0); }
  }

  /* ---- Content Layout ---- */
  .omega-content {
    position: relative;
    z-index: 10;
    max-width: 80rem;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 768px) {
    .omega-content {
      padding-left: 3rem;
      padding-right: 3rem;
    }
  }

  @media (min-width: 1024px) {
    .omega-content {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 3rem;
      padding-left: 5rem;
      padding-right: 5rem;
    }
  }

  /* ---- Eyebrow ---- */
  .omega-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow-pip {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: pipPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pipPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 12px var(--accent); }
    50%      { opacity: 0.5; box-shadow: 0 0 4px var(--accent); }
  }

  .eyebrow-line-el {
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--accent);
    opacity: 0.5;
    flex-shrink: 0;
  }

  .eyebrow-label {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.7rem;
    color: var(--accent);
    white-space: nowrap;
  }

  /* ---- Headline ---- */
  .omega-headline {
    font-family: var(--font-headline);
    font-size: clamp(2.4rem, 4.5vw + 0.5rem, 5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.75rem;
  }

  .headline-static {
    display: block;
  }

  .headline-accent {
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  :global([data-theme="light"]) .headline-accent {
    background: linear-gradient(135deg, #00838f, #5B4BC9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Word swap */
  .headline-swap-wrapper {
    display: block;
    overflow: hidden;
    height: 1.1em;
    position: relative;
  }

  .headline-swap-track {
    display: flex;
    flex-direction: column;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }

  .swap-phrase {
    flex-shrink: 0;
    height: 1.1em;
    display: flex;
    align-items: center;
    opacity: 0.3;
    transition: opacity 0.4s ease;
  }

  .swap-phrase.active {
    opacity: 1;
  }

  /* ---- Subtitle ---- */
  .omega-subtitle {
    font-size: clamp(1.05rem, 1.3vw + 0.4rem, 1.35rem);
    color: var(--on-surface-variant);
    font-weight: 300;
    max-width: 34rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  /* ---- CTAs ---- */
  .omega-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .omega-cta-primary,
  .omega-cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    padding: 1rem 2.25rem;
    border-radius: 12px;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  /* Primary CTA — animated border gradient + inner glow */
  .omega-cta-primary {
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    color: #fff;
    box-shadow:
      0 4px 20px rgba(0, 229, 255, 0.35),
      0 8px 40px rgba(0, 229, 255, 0.15),
      inset 0 1px 0 rgba(255,255,255,0.25),
      inset 0 0 20px rgba(0, 229, 255, 0.15);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
    border: none;
  }

  .cta-glow {
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: conic-gradient(from 0deg, #00E5FF, #7B61FF, #00E5FF);
    z-index: -1;
    animation: glowSpin 4s linear infinite;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .omega-cta-primary:hover .cta-glow {
    opacity: 0.6;
  }

  @keyframes glowSpin {
    to { transform: rotate(360deg); }
  }

  .omega-cta-primary:hover {
    background: linear-gradient(135deg, #33ecff 0%, #00c4d4 50%, #007a8a 100%);
    box-shadow:
      0 6px 30px rgba(0, 229, 255, 0.5),
      0 12px 50px rgba(0, 229, 255, 0.2),
      inset 0 1px 0 rgba(255,255,255,0.3),
      inset 0 0 30px rgba(0, 229, 255, 0.2);
    transform: translateY(-2px);
  }

  .omega-cta-primary:active {
    transform: translateY(0);
  }

  /* Secondary CTA — glass */
  .omega-cta-secondary {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-primary);
    border: 1.5px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(16px) saturate(1.8);
    -webkit-backdrop-filter: blur(16px) saturate(1.8);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
    gap: 0.5rem;
  }

  .omega-cta-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.25);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.12), 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .omega-cta-secondary:active {
    transform: translateY(0);
  }

  .cta-arrow {
    transition: transform 0.3s ease;
  }

  .omega-cta-secondary:hover .cta-arrow {
    transform: translateX(3px);
  }

  /* ---- Floating Metric Cards ---- */
  .omega-metrics {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  @media (min-width: 1024px) {
    .omega-metrics {
      margin-top: 0;
      gap: 1.25rem;
    }
  }

  .metric-card {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 1.25rem 1.5rem;
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    box-shadow: var(--glass-shadow);
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s ease;
    cursor: default;
    /* Stagger offset for parallax feel on desktop */
    transform-style: preserve-3d;
    perspective: 800px;
  }

  .metric-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
    z-index: 1;
  }

  .mc-1 { animation: floatCard 7s ease-in-out 0.5s infinite; }
  .mc-2 { animation: floatCard 8s ease-in-out 1.2s infinite; }
  .mc-3 { animation: floatCard 6s ease-in-out 0.8s infinite; }

  @media (min-width: 1024px) {
    .mc-1 { transform: translateX(0); }
    .mc-2 { transform: translateX(2rem); }
    .mc-3 { transform: translateX(0.5rem); }
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  /* On desktop preserve the X offset */
  @media (min-width: 1024px) {
    @keyframes floatCard1 { 0%, 100% { transform: translateX(0) translateY(0); } 50% { transform: translateX(0) translateY(-6px); } }
    @keyframes floatCard2 { 0%, 100% { transform: translateX(2rem) translateY(0); } 50% { transform: translateX(2rem) translateY(-8px); } }
    @keyframes floatCard3 { 0%, 100% { transform: translateX(0.5rem) translateY(0); } 50% { transform: translateX(0.5rem) translateY(-5px); } }
    .mc-1 { animation-name: floatCard1; }
    .mc-2 { animation-name: floatCard2; }
    .mc-3 { animation-name: floatCard3; }
  }

  .metric-card:hover {
    box-shadow: var(--glass-shadow), 0 0 30px var(--accent-glow);
  }

  .metric-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }

  .metric-unit {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--accent);
    font-weight: 400;
    margin-left: 2px;
  }

  .metric-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-left: auto;
    text-align: right;
    white-space: nowrap;
  }

  /* ---- Scroll Indicator ---- */
  .omega-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .scroll-track {
    width: 2px;
    height: 32px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 1px;
    position: relative;
    overflow: hidden;
  }

  .scroll-thumb {
    width: 2px;
    height: 10px;
    background: var(--accent);
    border-radius: 1px;
    animation: scrollThumb 2.5s ease-in-out infinite;
    box-shadow: 0 0 6px var(--accent);
  }

  @keyframes scrollThumb {
    0%   { transform: translateY(0); opacity: 1; }
    70%  { transform: translateY(22px); opacity: 0.3; }
    100% { transform: translateY(0); opacity: 1; }
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-tertiary);
    opacity: 0.5;
  }

  /* ================================================================
     LIGHT MODE OVERRIDES
     ================================================================ */

  :global([data-theme="light"]) .omega-hero {
    background: var(--bg-primary);
  }

  :global([data-theme="light"]) .contour {
    stroke: var(--accent);
  }

  :global([data-theme="light"]) .topo-grid line {
    stroke: var(--accent);
  }

  :global([data-theme="light"]) .scan-line {
    background: linear-gradient(90deg, transparent 0%, var(--accent) 20%, var(--accent) 80%, transparent 100%);
    opacity: 0.3;
    box-shadow: 0 0 15px var(--accent-glow), 0 0 40px var(--accent-glow);
  }

  :global([data-theme="light"]) .split-left {
    background: linear-gradient(135deg, rgba(250, 251, 252, 0.4) 0%, transparent 100%);
  }

  :global([data-theme="light"]) .split-right {
    background: linear-gradient(225deg, rgba(0, 131, 143, 0.04) 0%, transparent 60%);
  }

  :global([data-theme="light"]) .omega-headline {
    color: var(--text-primary);
    text-shadow: none;
  }

  :global([data-theme="light"]) .omega-subtitle {
    color: var(--text-secondary);
  }

  :global([data-theme="light"]) .omega-cta-primary {
    background: var(--accent);
    box-shadow: 0 10px 30px rgba(0, 131, 143, 0.2), inset 0 0 20px rgba(255, 255, 255, 0.1);
  }

  :global([data-theme="light"]) .omega-cta-primary:hover {
    background: #00969e;
    box-shadow: 0 14px 40px rgba(0, 131, 143, 0.3), inset 0 0 25px rgba(255, 255, 255, 0.15);
  }

  :global([data-theme="light"]) .omega-cta-secondary {
    background: rgba(0, 0, 0, 0.03);
    color: var(--text-primary);
    border-color: rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(8px);
  }

  :global([data-theme="light"]) .omega-cta-secondary:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
  }

  :global([data-theme="light"]) .scroll-track {
    background: rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="light"]) .eyebrow-pip {
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }

  :global([data-theme="light"]) .metric-card {
    background: var(--glass-bg);
    border-color: var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  /* Frosted backdrop behind text for light mode */
  :global([data-theme="light"]) .omega-text::before {
    content: '';
    position: absolute;
    inset: -2rem;
    border-radius: 1.5rem;
    background: radial-gradient(ellipse at 30% 50%, rgba(255,255,255,0.85) 0%, rgba(255,255,255,0.6) 50%, transparent 80%);
    backdrop-filter: blur(8px);
    z-index: -1;
    pointer-events: none;
  }

  :global([data-theme="light"]) .omega-text {
    position: relative;
  }

  /* ================================================================
     RESPONSIVE
     ================================================================ */

  @media (max-width: 767px) {
    .omega-hero {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }

    .omega-actions {
      flex-direction: column;
    }

    .omega-cta-primary,
    .omega-cta-secondary {
      width: 100%;
      max-width: 320px;
    }

    .omega-metrics {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .metric-card {
      flex: 1 1 calc(50% - 0.75rem);
      min-width: 0;
      flex-direction: column;
      text-align: center;
      padding: 1rem;
      gap: 0.5rem;
    }

    .metric-label {
      margin-left: 0;
      text-align: center;
      font-size: 0.65rem;
    }

    .omega-scroll-indicator {
      bottom: 1rem;
    }

    .mc-1, .mc-2, .mc-3 {
      animation: none;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .omega-metrics {
      flex-direction: row;
      gap: 1rem;
      margin-top: 2rem;
    }

    .metric-card {
      flex: 1;
    }
  }

  /* ================================================================
     REDUCED MOTION
     ================================================================ */

  @media (prefers-reduced-motion: reduce) {
    .contour {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }

    .scan-line {
      animation: none !important;
      display: none;
    }

    .split-left,
    .split-right {
      transform: none !important;
      animation: none !important;
    }

    .mc-1, .mc-2, .mc-3 {
      animation: none !important;
    }

    .eyebrow-pip {
      animation: none !important;
    }

    .scroll-thumb {
      animation: none !important;
    }

    .headline-swap-track {
      transition: none !important;
    }

    .swap-phrase {
      transition: none !important;
    }

    .particle-canvas {
      display: none !important;
    }

    .cta-glow {
      animation: none !important;
      display: none;
    }
  }

  /* ================================================================
     PRINT
     ================================================================ */

  @media print {
    .omega-bg,
    .omega-scroll-indicator,
    .cta-glow,
    .particle-canvas,
    .scan-line,
    .split-reveal {
      display: none !important;
    }
  }
</style>

<script is:inline>
(function() {
  'use strict';

  /* ---- Reduced-motion guard ---- */
  var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ==============================================================
     1. Word-swap headline animation
     ============================================================== */
  var track = document.querySelector('.headline-swap-track');
  var phrases = document.querySelectorAll('.swap-phrase');
  var swapWrapper = document.querySelector('.headline-swap-wrapper');
  if (track && phrases.length > 1) {
    var idx = 0;
    var total = phrases.length;

    function swapWord() {
      phrases[idx].classList.remove('active');
      idx = (idx + 1) % total;
      track.style.transform = 'translateY(-' + (idx * 1.1) + 'em)';
      phrases[idx].classList.add('active');
      /* Update aria-label */
      if (swapWrapper) swapWrapper.setAttribute('aria-label', phrases[idx].textContent.trim());
    }

    if (!prefersReduced) {
      setInterval(swapWord, 3000);
    }
  }

  /* ==============================================================
     2. Ambient particles (thermal signatures)
     ============================================================== */
  var canvas = document.querySelector('.particle-canvas');
  if (canvas && !prefersReduced) {
    var ctx = canvas.getContext('2d');
    var particles = [];
    var PARTICLE_COUNT = 40;
    var raf;

    function resizeCanvas() {
      var rect = canvas.parentElement.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }

    function createParticle() {
      return {
        x: Math.random() * canvas.width,
        y: canvas.height + Math.random() * 20,
        size: Math.random() * 2 + 0.5,
        speedY: -(Math.random() * 0.5 + 0.2),
        speedX: (Math.random() - 0.5) * 0.3,
        opacity: Math.random() * 0.4 + 0.1,
        life: 0,
        maxLife: Math.random() * 300 + 200
      };
    }

    function initParticles() {
      particles = [];
      for (var i = 0; i < PARTICLE_COUNT; i++) {
        var p = createParticle();
        p.y = Math.random() * canvas.height;
        p.life = Math.random() * p.maxLife;
        particles.push(p);
      }
    }

    function drawParticles() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      /* Detect theme */
      var isLight = document.documentElement.getAttribute('data-theme') === 'light';
      var baseColor = isLight ? '0, 131, 143' : '0, 229, 255';

      for (var i = 0; i < particles.length; i++) {
        var p = particles[i];
        p.x += p.speedX;
        p.y += p.speedY;
        p.life++;

        /* Fade in/out */
        var lifeRatio = p.life / p.maxLife;
        var alpha = p.opacity;
        if (lifeRatio < 0.1) alpha *= lifeRatio / 0.1;
        else if (lifeRatio > 0.8) alpha *= (1 - lifeRatio) / 0.2;

        if (p.life >= p.maxLife || p.y < -10) {
          particles[i] = createParticle();
          continue;
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + baseColor + ',' + alpha + ')';
        ctx.fill();
      }

      raf = requestAnimationFrame(drawParticles);
    }

    resizeCanvas();
    initParticles();
    drawParticles();

    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        resizeCanvas();
        initParticles();
      }, 200);
    });

    /* Pause when out of viewport */
    var heroEl = document.querySelector('.omega-hero');
    if (heroEl && 'IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          if (!raf) drawParticles();
        } else {
          if (raf) { cancelAnimationFrame(raf); raf = null; }
        }
      }, { threshold: 0.1 });
      obs.observe(heroEl);
    }
  }

  /* ==============================================================
     3. Metric counter animation
     ============================================================== */
  var metricEls = document.querySelectorAll('.metric-value[data-count]');
  if (metricEls.length && 'IntersectionObserver' in window) {
    var counted = false;
    var metricObs = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting && !counted) {
        counted = true;
        metricEls.forEach(function(el) {
          var target = parseFloat(el.getAttribute('data-count'));
          var isFloat = target % 1 !== 0;
          var duration = 1800;
          var start = performance.now();

          function tick(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            /* Ease out cubic */
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = eased * target;
            el.textContent = isFloat ? current.toFixed(1) : Math.round(current);
            if (progress < 1) requestAnimationFrame(tick);
          }

          if (prefersReduced) {
            el.textContent = isFloat ? target.toFixed(1) : Math.round(target);
          } else {
            requestAnimationFrame(tick);
          }
        });
        metricObs.disconnect();
      }
    }, { threshold: 0.3 });
    metricObs.observe(document.querySelector('.omega-metrics'));
  }

  /* ==============================================================
     4. Card tilt on hover (desktop only)
     ============================================================== */
  if (!prefersReduced && window.matchMedia('(hover: hover) and (min-width: 1024px)').matches) {
    var cards = document.querySelectorAll('.metric-card[data-tilt]');
    cards.forEach(function(card) {
      card.addEventListener('mousemove', function(e) {
        var rect = card.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = 'perspective(800px) rotateY(' + (x * 8) + 'deg) rotateX(' + (-y * 8) + 'deg) translateZ(8px)';
      });

      card.addEventListener('mouseleave', function() {
        card.style.transform = '';
      });
    });
  }

  /* ==============================================================
     5. Parallax on topo map (desktop only)
     ============================================================== */
  if (!prefersReduced && window.matchMedia('(hover: hover) and (min-width: 1024px)').matches) {
    var hero = document.querySelector('.omega-hero');
    var topoMap = hero && hero.querySelector('.topo-map');
    if (hero && topoMap) {
      hero.addEventListener('mousemove', function(e) {
        var rect = hero.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        topoMap.style.transform = 'translate(' + (x * 15) + 'px, ' + (y * 10) + 'px) scale(1.05)';
      });

      hero.addEventListener('mouseleave', function() {
        topoMap.style.transform = '';
      });
    }
  }

})();
</script>
