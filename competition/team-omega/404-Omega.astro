---
/*  404-Omega.astro — Night sky + flyable platform 404 page
    Team Omega | Rounds 19+20
    Jinki Aerial Intelligence  */
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — Page Not Found | Jinki Aerial Intelligence</title>
  <style>
    :root{
      --surface:#121416;--bg-primary:#121416;--bg-elevated:#1a1c1e;--bg-card:#1e2022;
      --text-primary:#e2e2e5;--text-secondary:#bac9cc;--text-tertiary:#849396;
      --accent:#00e5ff;--accent-soft:#c3f5ff;--accent-glow:rgba(0,229,255,.15);
      --error:#ffb4ab;--border:rgba(59,73,76,.2);
      --glass-bg:rgba(30,32,34,.6);--glass-border:rgba(255,255,255,.06);
      --glass-shadow:0 8px 32px rgba(0,0,0,.3),0 2px 8px rgba(0,0,0,.2);
      --glossy-shine:linear-gradient(135deg,rgba(255,255,255,.12) 0%,rgba(255,255,255,0) 40%,rgba(255,255,255,.04) 100%);
      --font-headline:'Space Grotesk',system-ui,sans-serif;
      --font-body:'Inter',system-ui,sans-serif;
      --font-mono:'JetBrains Mono','SF Mono',monospace;
    }
    [data-theme="light"]{
      --surface:#fff;--bg-primary:#fafbfc;--bg-elevated:#fff;--bg-card:#f0f1f3;
      --text-primary:#1a1c1e;--text-secondary:#3b494c;--text-tertiary:#6f7979;
      --accent:#00838f;--accent-soft:#004f58;--accent-glow:rgba(0,131,143,.1);
      --error:#ba1a1a;--border:rgba(0,0,0,.08);
      --glass-bg:rgba(255,255,255,.7);--glass-border:rgba(0,0,0,.06);
      --glass-shadow:0 8px 32px rgba(0,0,0,.08),0 2px 8px rgba(0,0,0,.04);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;font-family:var(--font-body);color:var(--text-primary);background:var(--bg-primary)}
    body{min-height:100vh;overflow:hidden;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center}

    /* ── Night sky ── */
    .sky{position:fixed;inset:0;z-index:0;background:radial-gradient(ellipse at 50% 0%,#0a1628 0%,var(--bg-primary) 70%)}
    [data-theme="light"] .sky{background:radial-gradient(ellipse at 50% 0%,#e0f0ff 0%,var(--bg-primary) 70%)}

    /* Stars */
    .stars{position:fixed;inset:0;z-index:1}
    .star{
      position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;
      animation:twinkle var(--dur) ease-in-out infinite;
      opacity:var(--o);
    }
    [data-theme="light"] .star{background:var(--accent);opacity:.15}
    @keyframes twinkle{0%,100%{opacity:var(--o)}50%{opacity:.1}}

    /* Floating satellites (CSS dots) */
    .satellite{
      position:absolute;z-index:2;
      width:4px;height:4px;background:var(--accent);border-radius:50%;
      box-shadow:0 0 8px var(--accent),0 0 20px var(--accent-glow);
    }
    .sat-1{animation:satOrbit1 25s linear infinite}
    .sat-2{animation:satOrbit2 35s linear infinite}
    .sat-3{animation:satOrbit3 18s linear infinite}
    @keyframes satOrbit1{
      0%{top:15%;left:-5%}25%{top:5%;left:50%}50%{top:20%;left:105%}75%{top:35%;left:50%}100%{top:15%;left:-5%}
    }
    @keyframes satOrbit2{
      0%{top:80%;left:105%}25%{top:60%;left:40%}50%{top:75%;left:-5%}75%{top:90%;left:40%}100%{top:80%;left:105%}
    }
    @keyframes satOrbit3{
      0%{top:50%;left:-5%}33%{top:10%;left:60%}66%{top:70%;left:80%}100%{top:50%;left:-5%}
    }

    /* Satellite trail */
    .satellite::after{
      content:'';position:absolute;top:50%;right:100%;
      width:40px;height:1px;
      background:linear-gradient(90deg,transparent,var(--accent));
      opacity:.4;transform:translateY(-50%);
    }

    /* ── Main content ── */
    .content{position:relative;z-index:10;text-align:center;max-width:600px;padding:0 24px}

    /* Typewriter heading */
    .heading-404{
      font-family:var(--font-headline);font-size:clamp(72px,14vw,140px);
      font-weight:700;color:var(--text-primary);line-height:1;
      margin:0 0 8px;opacity:.08;
    }
    .typewriter-wrap{margin:0 0 16px;min-height:44px}
    .typewriter{
      font-family:var(--font-headline);font-size:clamp(24px,4vw,40px);
      font-weight:700;color:var(--text-primary);
      display:inline;
    }
    .cursor{
      display:inline-block;width:3px;height:1em;
      background:var(--accent);margin-left:2px;
      vertical-align:text-bottom;
      animation:blink .8s step-end infinite;
    }
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

    .desc{
      font-family:var(--font-body);font-size:clamp(14px,1.8vw,17px);
      color:var(--text-tertiary);line-height:1.7;margin:0 0 32px;
    }

    /* ── Flyable platform ── */
    .fly-zone{
      position:fixed;inset:0;z-index:5;pointer-events:none;
    }
    .platform{
      position:absolute;width:32px;height:32px;
      transition:transform .05s linear;
      filter:drop-shadow(0 0 12px var(--accent)) drop-shadow(0 0 24px var(--accent-glow));
    }
    .platform svg{width:100%;height:100%}
    .platform-trail{
      position:absolute;width:6px;height:6px;border-radius:50%;
      background:var(--accent);opacity:0;pointer-events:none;
    }

    .fly-hint{
      font-family:var(--font-mono);font-size:12px;color:var(--text-tertiary);
      display:inline-flex;align-items:center;gap:8px;
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:8px;padding:8px 14px;margin:0 0 32px;
      backdrop-filter:blur(8px);
    }
    .fly-hint kbd{
      font-family:var(--font-mono);font-size:11px;
      background:var(--bg-card);border:1px solid var(--border);
      border-radius:4px;padding:2px 8px;color:var(--accent);
    }

    /* ── Did you mean ── */
    .suggestions{
      margin:0 0 32px;
    }
    .suggestions-label{
      font-family:var(--font-mono);font-size:11px;text-transform:uppercase;
      letter-spacing:.1em;color:var(--text-tertiary);margin:0 0 12px;
    }
    .suggestion-chips{display:flex;flex-wrap:wrap;gap:8px;justify-content:center}
    .chip{
      display:inline-flex;align-items:center;gap:6px;
      font-family:var(--font-headline);font-size:13px;font-weight:600;
      color:var(--text-secondary);background:var(--glass-bg);
      border:1px solid var(--glass-border);border-radius:20px;
      padding:8px 16px;text-decoration:none;transition:all .2s;
      backdrop-filter:blur(8px);
    }
    .chip:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-1px)}

    /* ── Actions ── */
    .actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin:0 0 24px}
    .btn{
      display:inline-flex;align-items:center;gap:8px;
      font-family:var(--font-headline);font-size:14px;font-weight:600;
      padding:12px 24px;border-radius:10px;cursor:pointer;
      text-decoration:none;transition:all .25s;border:none;
    }
    .btn-primary{background:var(--accent);color:#000;box-shadow:0 0 20px var(--accent-glow)}
    .btn-primary:hover{box-shadow:0 0 30px var(--accent-glow),0 0 60px var(--accent-glow)}
    .btn-ghost{background:transparent;color:var(--text-primary);border:1px solid var(--border)}
    .btn-ghost:hover{border-color:var(--accent);color:var(--accent)}

    /* ── Redirect countdown ── */
    .redirect-bar{
      display:flex;align-items:center;justify-content:center;gap:12px;
      font-family:var(--font-mono);font-size:12px;color:var(--text-tertiary);
    }
    .redirect-track{
      width:120px;height:4px;background:var(--border);border-radius:2px;overflow:hidden;
    }
    .redirect-fill{
      height:100%;background:var(--accent);border-radius:2px;
      width:0%;transition:width 1s linear;
    }
    .redirect-cancel{
      background:none;border:none;color:var(--accent);
      font-family:var(--font-mono);font-size:12px;cursor:pointer;
      text-decoration:underline;text-underline-offset:2px;
    }

    /* ── Reduced motion ── */
    @media(prefers-reduced-motion:reduce){
      *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}
    }
    :focus-visible{outline:2px solid var(--accent);outline-offset:2px}
  </style>
</head>
<body>
  <!-- Night sky -->
  <div class="sky" aria-hidden="true"></div>
  <div class="stars" aria-hidden="true" id="starsContainer"></div>

  <!-- Floating satellites -->
  <div class="satellite sat-1" aria-hidden="true"></div>
  <div class="satellite sat-2" aria-hidden="true"></div>
  <div class="satellite sat-3" aria-hidden="true"></div>

  <!-- Flyable platform -->
  <div class="fly-zone" id="flyZone" aria-hidden="true">
    <div class="platform" id="platform" style="top:50%;left:50%;transform:translate(-50%,-50%)">
      <svg viewBox="0 0 32 32" fill="none">
        <!-- Simple aerial platform icon -->
        <circle cx="16" cy="16" r="6" fill="var(--accent)" opacity=".3"/>
        <circle cx="16" cy="16" r="3" fill="var(--accent)"/>
        <line x1="16" y1="10" x2="16" y2="4" stroke="var(--accent)" stroke-width="1.5" opacity=".6"/>
        <line x1="16" y1="22" x2="16" y2="28" stroke="var(--accent)" stroke-width="1.5" opacity=".6"/>
        <line x1="10" y1="16" x2="4" y2="16" stroke="var(--accent)" stroke-width="1.5" opacity=".6"/>
        <line x1="22" y1="16" x2="28" y2="16" stroke="var(--accent)" stroke-width="1.5" opacity=".6"/>
        <circle cx="16" cy="4" r="2" fill="var(--accent)" opacity=".5"/>
        <circle cx="16" cy="28" r="2" fill="var(--accent)" opacity=".5"/>
        <circle cx="4" cy="16" r="2" fill="var(--accent)" opacity=".5"/>
        <circle cx="28" cy="16" r="2" fill="var(--accent)" opacity=".5"/>
      </svg>
    </div>
  </div>

  <!-- Main content -->
  <div class="content">
    <div class="heading-404" aria-hidden="true">404</div>
    <div class="typewriter-wrap" aria-live="polite">
      <span class="typewriter" id="typewriterText"></span><span class="cursor" aria-hidden="true"></span>
    </div>
    <p class="desc" id="pageDesc">
      The coordinates you entered lead to uncharted space. This page does not exist or may have been moved.
    </p>

    <div class="fly-hint" id="flyHint">
      Use <kbd>&uarr;</kbd><kbd>&darr;</kbd><kbd>&larr;</kbd><kbd>&rarr;</kbd> to fly the platform
    </div>

    <!-- Smart suggestions -->
    <div class="suggestions" id="suggestions">
      <p class="suggestions-label">Did you mean...</p>
      <div class="suggestion-chips" id="suggestionChips">
        <a href="/verticals/data-centers" class="chip">/verticals/data-centers</a>
        <a href="/verticals/energy-grid" class="chip">/verticals/energy-grid</a>
        <a href="/services/audit" class="chip">/services/audit</a>
        <a href="/about" class="chip">/about</a>
      </div>
    </div>

    <nav class="actions" aria-label="Error page navigation">
      <a href="/" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Return Home
      </a>
      <a href="/blog" class="btn btn-ghost">Read Blog</a>
    </nav>

    <!-- Auto-redirect -->
    <div class="redirect-bar" id="redirectBar">
      <span>Redirecting in <strong id="countdownNum">15</strong>s</span>
      <div class="redirect-track"><div class="redirect-fill" id="redirectFill"></div></div>
      <button class="redirect-cancel" id="cancelRedirect">Cancel</button>
    </div>
  </div>

  <script>
    // ── Generate stars ──
    const starsContainer = document.getElementById('starsContainer');
    for (let i = 0; i < 150; i++) {
      const star = document.createElement('div');
      star.className = 'star';
      star.style.cssText = `top:${Math.random()*100}%;left:${Math.random()*100}%;--dur:${2+Math.random()*4}s;--o:${.2+Math.random()*.6}`;
      starsContainer.appendChild(star);
    }

    // ── Typewriter ──
    const typewriterEl = document.getElementById('typewriterText');
    const phrases = ['Page Not Found', 'Signal Not Acquired', 'Target Unresolved'];
    let phraseIdx = 0, charIdx = 0, deleting = false;
    function typeStep() {
      const phrase = phrases[phraseIdx];
      if (!deleting) {
        typewriterEl.textContent = phrase.slice(0, ++charIdx);
        if (charIdx === phrase.length) { setTimeout(() => { deleting = true; typeStep(); }, 2000); return; }
      } else {
        typewriterEl.textContent = phrase.slice(0, --charIdx);
        if (charIdx === 0) { deleting = false; phraseIdx = (phraseIdx + 1) % phrases.length; }
      }
      setTimeout(typeStep, deleting ? 40 : 80);
    }
    typeStep();

    // ── Flyable platform ──
    const platform = document.getElementById('platform');
    let px = window.innerWidth / 2, py = window.innerHeight / 2;
    const speed = 5;
    const keys = {};
    const trails = [];

    document.addEventListener('keydown', (e) => {
      if (['ArrowUp','ArrowDown','ArrowLeft','ArrowRight'].includes(e.key)) {
        e.preventDefault();
        keys[e.key] = true;
      }
    });
    document.addEventListener('keyup', (e) => { keys[e.key] = false; });

    function spawnTrail(x, y) {
      const t = document.createElement('div');
      t.className = 'platform-trail';
      t.style.cssText = `left:${x+12}px;top:${y+12}px;opacity:.5;transition:opacity .6s`;
      document.getElementById('flyZone').appendChild(t);
      requestAnimationFrame(() => { t.style.opacity = '0'; });
      setTimeout(() => t.remove(), 600);
    }

    let frame = 0;
    function gameLoop() {
      let moved = false;
      if (keys['ArrowUp']) { py = Math.max(0, py - speed); moved = true; }
      if (keys['ArrowDown']) { py = Math.min(window.innerHeight - 32, py + speed); moved = true; }
      if (keys['ArrowLeft']) { px = Math.max(0, px - speed); moved = true; }
      if (keys['ArrowRight']) { px = Math.min(window.innerWidth - 32, px + speed); moved = true; }
      if (moved) {
        platform.style.left = px + 'px';
        platform.style.top = py + 'px';
        platform.style.transform = 'none';
        if (frame % 3 === 0) spawnTrail(px, py);
      }
      frame++;
      requestAnimationFrame(gameLoop);
    }
    gameLoop();

    // ── Smart URL suggestions ──
    const routes = [
      '/verticals/data-centers', '/verticals/energy-grid', '/verticals/security',
      '/verticals/agriculture', '/services/audit', '/services/deployment',
      '/about', '/careers', '/blog', '/security', '/privacy', '/terms'
    ];
    const path = window.location.pathname.toLowerCase();
    if (path && path !== '/') {
      const scored = routes.map(r => {
        const parts = r.split('/').filter(Boolean);
        const pathParts = path.split('/').filter(Boolean);
        let score = 0;
        pathParts.forEach(pp => { parts.forEach(rp => {
          if (rp.includes(pp) || pp.includes(rp)) score += 3;
          else {
            // Levenshtein-ish: shared prefix
            let shared = 0;
            for (let i = 0; i < Math.min(pp.length, rp.length); i++) {
              if (pp[i] === rp[i]) shared++; else break;
            }
            if (shared >= 3) score += 1;
          }
        });});
        return { route: r, score };
      }).sort((a, b) => b.score - a.score).slice(0, 4);

      if (scored[0].score > 0) {
        const chips = document.getElementById('suggestionChips');
        chips.innerHTML = scored.map(s =>
          `<a href="${s.route}" class="chip">${s.route}</a>`
        ).join('');
      }
    }

    // ── Auto-redirect countdown (15s) ──
    let countdown = 15;
    let redirectCancelled = false;
    const countdownEl = document.getElementById('countdownNum');
    const fill = document.getElementById('redirectFill');
    const bar = document.getElementById('redirectBar');

    document.getElementById('cancelRedirect').addEventListener('click', () => {
      redirectCancelled = true;
      bar.style.opacity = '0';
      setTimeout(() => { bar.style.display = 'none'; }, 300);
    });

    const cdInterval = setInterval(() => {
      if (redirectCancelled) { clearInterval(cdInterval); return; }
      countdown--;
      countdownEl.textContent = countdown;
      fill.style.width = ((15 - countdown) / 15 * 100) + '%';
      if (countdown <= 0) {
        clearInterval(cdInterval);
        window.location.href = '/';
      }
    }, 1000);
  </script>
</body>
</html>
