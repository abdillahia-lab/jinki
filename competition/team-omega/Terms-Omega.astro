---
/*
  Terms-Omega — Jinki Aerial Intelligence
  Team Omega, Round 24.
  Dual-pane layout: plain language left, legal text right.
  Highlight changes, print/PDF buttons, cookie preference toggle.
*/
import Layout from '../../src/layouts/Layout.astro';
import Nav from '../../src/components/Nav.astro';
import Footer from '../../src/components/Footer.astro';

const lastUpdated = 'March 2026';
const previousVersion = 'January 2026';

const sections = [
  {
    id: 'acceptance',
    title: '1. Acceptance of Terms',
    plain: 'By using Jinki services or our website, you agree to these terms. If you do not agree, please do not use our services.',
    legal: 'By accessing or using the services provided by Jinki Aerial Intelligence ("Jinki," "we," "us," or "our"), including the website at jinki.ai and all related aerial intelligence services, you agree to be bound by these Terms of Service. If you do not agree to these terms, you must not access or use our services.',
    changed: false,
  },
  {
    id: 'services',
    title: '2. Description of Services',
    plain: 'Jinki provides aerial intelligence for infrastructure: inspections, thermal analysis, monitoring, security assessment, and agriculture surveying. We deliver data insights and recommendations, not hardware.',
    legal: 'Jinki provides aerial intelligence services for critical infrastructure, including but not limited to: infrastructure inspection, thermal imaging and analysis, data center monitoring, perimeter security assessment, and agricultural surveying. Our deliverables consist of data products, analytical reports, and actionable recommendations derived from aerial operations. Jinki is an aerial intelligence firm — we provide data-driven insights, not hardware.',
    changed: false,
  },
  {
    id: 'responsibilities',
    title: '3. User Responsibilities',
    plain: 'Provide accurate info, follow the law, do not interfere with our systems, and use our deliverables only for their intended lawful purpose.',
    legal: 'You agree to: (a) provide accurate and complete information when engaging our services; (b) comply with all applicable local, state, and federal laws and regulations; (c) not interfere with or disrupt the integrity or performance of our services; (d) not attempt to gain unauthorized access to our systems or data; and (e) use all deliverables, reports, and data products solely for their intended lawful purpose.',
    changed: false,
  },
  {
    id: 'ip',
    title: '4. Intellectual Property',
    plain: 'Our technology, methods, and materials are our IP. You get a license to use deliverables for your internal business. Do not redistribute our proprietary work without written permission.',
    legal: 'All content, methodologies, software, analytical frameworks, reports, and materials provided by Jinki are protected by intellectual property laws. Jinki retains all rights, title, and interest in its proprietary technology, processes, and analytical methods. Clients receive a limited, non-exclusive, non-transferable license to use deliverables for their internal business purposes only. You may not reproduce, distribute, or create derivative works from our proprietary materials without prior written consent.',
    changed: true,
    changeNote: 'Clarified license scope for client deliverables.',
  },
  {
    id: 'confidentiality',
    title: '5. Confidentiality',
    plain: 'Both sides keep sensitive info confidential. Facility data, inspection findings, and security assessments stay private unless required by law. This obligation continues even after our engagement ends.',
    legal: 'Both parties agree to maintain the confidentiality of any proprietary or sensitive information exchanged during the course of engagement. This includes, but is not limited to, facility data, inspection findings, security assessments, and infrastructure details. Confidential information shall not be disclosed to third parties without prior written consent, except as required by law. This obligation survives the termination of any service agreement.',
    changed: false,
  },
  {
    id: 'liability',
    title: '6. Limitation of Liability',
    plain: 'We are not liable for indirect or consequential damages. Our maximum liability is limited to the fees you paid for the specific service. Operational decisions based on our recommendations remain your responsibility.',
    legal: 'To the maximum extent permitted by applicable law, Jinki shall not be liable for any indirect, incidental, special, consequential, or punitive damages, including but not limited to loss of profits, data, or business opportunities, arising out of or related to your use of our services. Our total liability for any claim arising from these terms or our services shall not exceed the fees paid by you for the specific service giving rise to the claim. Our services provide intelligence and recommendations — operational decisions remain the sole responsibility of the client.',
    changed: true,
    changeNote: 'Added explicit client responsibility for operational decisions.',
  },
  {
    id: 'indemnification',
    title: '7. Indemnification',
    plain: 'You agree to protect us from claims arising from your use of our services, your violation of these terms, or operational decisions you make based on our deliverables.',
    legal: 'You agree to indemnify, defend, and hold harmless Jinki Aerial Intelligence, its officers, directors, employees, and agents from and against any claims, liabilities, damages, losses, and expenses (including reasonable attorneys\' fees) arising out of or in any way connected with: (a) your use of our services; (b) your violation of these terms; (c) your violation of any third-party rights; or (d) any operational decisions made based on our deliverables or recommendations.',
    changed: false,
  },
  {
    id: 'governing-law',
    title: '8. Governing Law',
    plain: 'Virginia law applies. Disputes go to Virginia courts.',
    legal: 'These Terms of Service shall be governed by and construed in accordance with the laws of the Commonwealth of Virginia, United States, without regard to its conflict of law provisions. Any disputes arising under or in connection with these terms shall be subject to the exclusive jurisdiction of the state and federal courts located in Virginia.',
    changed: false,
  },
  {
    id: 'termination',
    title: '9. Termination',
    plain: 'We can suspend or end your access with reasonable notice. Key provisions (IP, confidentiality, liability) survive termination.',
    legal: 'Jinki reserves the right to suspend or terminate your access to our services at any time, with or without cause, upon reasonable notice. Upon termination, your right to use our services ceases immediately. Provisions that by their nature should survive termination — including intellectual property, confidentiality, limitation of liability, indemnification, and governing law — shall remain in effect.',
    changed: false,
  },
  {
    id: 'changes',
    title: '10. Changes to Terms',
    plain: 'We may update these terms. Major changes will be communicated on this page or directly. Continuing to use our services means you accept the new terms.',
    legal: 'We reserve the right to modify these Terms of Service at any time. Material changes will be communicated through our website or via direct notice to active clients. Your continued use of our services following any modifications constitutes acceptance of the revised terms. We encourage you to review these terms periodically.',
    changed: false,
  },
];
---

<Layout title="Terms of Service — Jinki Aerial Intelligence" description="Terms of Service governing the use of Jinki Aerial Intelligence services and website.">
  <Nav />
  <main id="main-content">

    <!-- Hero -->
    <section class="terms-hero" aria-label="Terms of Service">
      <div class="terms-hero-inner" style="max-width: 800px; margin: 0 auto; text-align: center;">
        <div class="vert-eyebrow reveal">
          <span class="vert-eyebrow-line"></span>
          <span class="vert-eyebrow-text">Legal</span>
        </div>
        <h1 class="reveal reveal-delay-1">Terms of Service</h1>
        <p class="terms-subtitle reveal reveal-delay-2" style="font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem); max-width: 560px; margin: 16px auto 0; line-height: 1.75; color: var(--text-secondary);">
          Effective {lastUpdated}
        </p>
        <!-- Action Buttons -->
        <div class="hero-actions reveal reveal-delay-3" style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 32px; flex-wrap: wrap;">
          <button class="action-btn" onclick="window.print()" aria-label="Print this page">
            <span class="material-symbols-outlined" style="font-size: 18px;" aria-hidden="true">print</span>
            Print
          </button>
          <button class="action-btn" onclick="window.print()" aria-label="Download as PDF">
            <span class="material-symbols-outlined" style="font-size: 18px;" aria-hidden="true">download</span>
            Download PDF
          </button>
          <span class="version-badge">
            Updated from {previousVersion}
          </span>
        </div>
      </div>
    </section>

    <!-- Dual-Pane Terms Content -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Terms of Service Details">
      <div style="max-width: 1280px; margin: 0 auto;">

        <!-- View Toggle -->
        <div class="view-toggle reveal" style="display: flex; align-items: center; gap: 16px; margin-bottom: 48px; flex-wrap: wrap;">
          <span style="font-family: var(--font-label); font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.2em; color: var(--text-tertiary);">View:</span>
          <button class="toggle-btn active" data-view="dual" aria-pressed="true">Dual Pane</button>
          <button class="toggle-btn" data-view="plain" aria-pressed="false">Plain Language</button>
          <button class="toggle-btn" data-view="legal" aria-pressed="false">Full Legal</button>
        </div>

        <!-- Terms Sections -->
        {sections.map((section, i) => (
          <div id={section.id} class={`terms-row reveal reveal-delay-${(i % 3) + 1}`} data-changed={section.changed ? 'true' : 'false'}>
            {section.changed && (
              <div class="change-indicator">
                <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">edit_note</span>
                <span>{section.changeNote}</span>
              </div>
            )}
            <h2 style="font-family: var(--font-headline); font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.375rem); font-weight: 700; color: var(--text-primary); margin-bottom: 20px;">
              {section.title}
            </h2>
            <div class="dual-pane">
              <div class="pane-plain">
                <div class="pane-label">
                  <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">translate</span>
                  Plain Language
                </div>
                <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.8;">{section.plain}</p>
              </div>
              <div class="pane-legal">
                <div class="pane-label">
                  <span class="material-symbols-outlined" style="font-size: 14px;" aria-hidden="true">gavel</span>
                  Legal Text
                </div>
                <p style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.8;">{section.legal}</p>
              </div>
            </div>
          </div>
        ))}

        <!-- Contact -->
        <div class="terms-row" style="border-bottom: none;">
          <h2 style="font-family: var(--font-headline); font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.375rem); font-weight: 700; color: var(--text-primary); margin-bottom: 20px;">
            11. Contact
          </h2>
          <p style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.8; margin-bottom: 20px;">
            Questions about these Terms of Service? Contact us:
          </p>
          <div class="contact-card">
            <p style="font-size: 0.9375rem; font-weight: 600; color: var(--text-primary); margin-bottom: 4px;">Jinki Aerial Intelligence</p>
            <p style="font-size: 0.875rem; color: var(--text-secondary); margin-bottom: 12px;">Virginia, United States</p>
            <a href="mailto:legal@jinki.ai" class="terms-email-link">legal@jinki.ai</a>
          </div>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  // View toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtns = document.querySelectorAll('.toggle-btn');
    const termsRows = document.querySelectorAll('.terms-row');

    toggleBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        toggleBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');

        const view = btn.dataset.view;
        termsRows.forEach(row => {
          const plain = row.querySelector('.pane-plain') as HTMLElement;
          const legal = row.querySelector('.pane-legal') as HTMLElement;
          if (!plain || !legal) return;

          if (view === 'dual') {
            plain.style.display = '';
            legal.style.display = '';
          } else if (view === 'plain') {
            plain.style.display = '';
            legal.style.display = 'none';
          } else if (view === 'legal') {
            plain.style.display = 'none';
            legal.style.display = '';
          }
        });
      });
    });
  });
</script>

<style>
  .terms-hero {
    min-height: 45vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px clamp(20px, 5vw, 80px) 60px;
    text-align: center;
    background: var(--surface-container-lowest);
    position: relative;
  }

  .terms-hero h1 {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .vert-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    justify-content: center;
  }

  .vert-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .vert-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
  }

  .section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .section { padding: 6rem clamp(20px, 5vw, 80px); }
  }

  /* Action Buttons */
  .action-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    padding: 10px 18px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .action-btn:hover {
    color: var(--accent);
    border-color: rgba(0, 229, 255, 0.15);
    transform: translateY(-1px);
  }

  .version-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 6px 14px;
    border-radius: 100px;
  }

  /* View Toggle */
  .toggle-btn {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    background: transparent;
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    padding: 8px 16px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .toggle-btn:hover {
    color: var(--text-secondary);
    border-color: var(--text-tertiary);
  }

  .toggle-btn.active {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  /* Terms Rows */
  .terms-row {
    padding: 40px 0;
    border-bottom: 1px solid var(--glass-border);
    position: relative;
  }

  .terms-row[data-changed="true"] {
    border-left: 3px solid var(--accent);
    padding-left: 24px;
  }

  .change-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 4px 12px;
    border-radius: 100px;
    margin-bottom: 16px;
  }

  /* Dual Pane */
  .dual-pane {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  @media (max-width: 768px) {
    .dual-pane { grid-template-columns: 1fr; gap: 20px; }
  }

  .pane-plain,
  .pane-legal {
    padding: 24px;
    border-radius: 12px;
    position: relative;
  }

  .pane-plain {
    background: var(--accent-glow);
    border: 1px solid rgba(0, 229, 255, 0.1);
  }

  .pane-legal {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
  }

  .pane-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-tertiary);
    margin-bottom: 12px;
  }

  /* Contact */
  .contact-card {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 24px;
    display: inline-block;
  }

  .terms-email-link {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--accent);
    text-decoration: none;
    display: inline-block;
    padding: 8px 20px;
    border: 1px solid var(--accent);
    border-radius: 10px;
    transition: all 0.3s ease;
  }

  .terms-email-link:hover {
    background: var(--accent-glow);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  /* Print styles */
  @media print {
    .hero-actions,
    .view-toggle { display: none !important; }

    .dual-pane { grid-template-columns: 1fr; }
    .pane-plain { display: none; }

    .terms-row[data-changed="true"] {
      border-left-color: #000;
    }
  }
</style>
