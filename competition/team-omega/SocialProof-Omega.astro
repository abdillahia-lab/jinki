---
/*
  SocialProof-Omega — Full social proof section
  1. Wall of Love: Masonry grid of testimonial quotes (varied card sizes)
  2. Metric Dashboard: 4 large metrics with CSS-only sparkline charts
  3. Industry Recognition: "Featured in" press badges
  4. NPS Score Visualizer: Animated gauge
  5. Client Map: Dot map showing regional client locations
*/

const wallOfLove = [
  { quote: "Thermal anomaly detection prevented two critical failures in our first month.", author: "VP of Operations", company: "Tier-1 Data Center", size: "large" },
  { quote: "48-hour turnaround on a full facility audit. Exceptional.", author: "Facilities Director", company: "Cloud Infrastructure Co.", size: "small" },
  { quote: "The persistent monitoring caught a breach attempt our fixed cameras missed entirely.", author: "Security Director", company: "National Logistics Campus", size: "medium" },
  { quote: "Replaced annual aerial surveys with continuous intelligence. ROI in the first quarter.", author: "Head of AgTech", company: "Regional Ag Cooperative", size: "small" },
  { quote: "AI-powered defect classification eliminated 80% of false positives from manual review. Our maintenance teams now execute directly from prioritized action matrices.", author: "Grid Reliability Manager", company: "Midwest Energy Utility", size: "large" },
  { quote: "Not just imagery — actionable intelligence with every flight.", author: "COO", company: "Industrial Services Group", size: "small" },
  { quote: "12-mile transmission corridor covered weekly with zero operational disruption.", author: "Infrastructure VP", company: "Regional Power Authority", size: "medium" },
  { quote: "Saved over 2 million gallons of water identifying irrigation inefficiencies.", author: "Operations Lead", company: "Agricultural Enterprise", size: "medium" },
  { quote: "The deliverable quality sets a new standard for the industry.", author: "CTO", company: "Enterprise Data Services", size: "small" },
];

const metrics = [
  { value: '15,000+', label: 'Inspections Completed', sparkline: [20, 35, 28, 45, 52, 60, 55, 72, 80, 85, 92, 100] },
  { value: '99.7%', label: 'Platform Uptime', sparkline: [95, 97, 98, 99, 98, 99, 100, 99, 100, 99, 100, 100] },
  { value: '340+', label: 'Facilities Monitored', sparkline: [10, 18, 30, 45, 60, 80, 120, 160, 200, 250, 300, 340] },
  { value: '98%', label: 'Client Satisfaction', sparkline: [88, 90, 91, 93, 94, 95, 96, 96, 97, 97, 98, 98] },
];

const pressLogos = [
  { name: 'TechCrunch', width: 130 },
  { name: 'Bloomberg', width: 120 },
  { name: 'Forbes', width: 90 },
  { name: 'Wired', width: 80 },
  { name: 'MIT Tech Review', width: 140 },
  { name: 'The Verge', width: 110 },
];

const npsScore = 82;

const clientRegions = [
  // US regions — approximate relative positions (percentage-based)
  { x: 18, y: 35, label: 'Pacific Northwest', count: 12 },
  { x: 12, y: 52, label: 'California', count: 28 },
  { x: 28, y: 42, label: 'Mountain West', count: 8 },
  { x: 38, y: 38, label: 'Northern Plains', count: 5 },
  { x: 45, y: 55, label: 'Central', count: 15 },
  { x: 55, y: 42, label: 'Great Lakes', count: 18 },
  { x: 65, y: 48, label: 'Mid-Atlantic', count: 22 },
  { x: 72, y: 40, label: 'Northeast', count: 30 },
  { x: 52, y: 62, label: 'Southeast', count: 20 },
  { x: 35, y: 68, label: 'Gulf Coast', count: 14 },
  { x: 22, y: 62, label: 'Southwest', count: 10 },
];
---

<section class="social-proof-omega" aria-label="Social proof and client metrics">

  <!-- ── Metric Dashboard ── -->
  <div class="metrics-section reveal">
    <div class="metrics-grid">
      {metrics.map((m) => (
        <div class="metric-card glass-panel">
          <div class="metric-sparkline" aria-hidden="true">
            <svg viewBox="0 0 120 40" preserveAspectRatio="none" class="sparkline-svg">
              <defs>
                <linearGradient id={`spark-grad-${m.label.replace(/\s/g,'')}`} x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.3" />
                  <stop offset="100%" stop-color="var(--accent)" stop-opacity="0" />
                </linearGradient>
              </defs>
              {/* Area fill */}
              <path
                d={`M0,${40 - (m.sparkline[0] / 100) * 36} ${m.sparkline.map((v, i) => `L${(i / (m.sparkline.length - 1)) * 120},${40 - (v / 100) * 36}`).join(' ')} L120,40 L0,40 Z`}
                fill={`url(#spark-grad-${m.label.replace(/\s/g,'')})`}
              />
              {/* Line */}
              <polyline
                points={m.sparkline.map((v, i) => `${(i / (m.sparkline.length - 1)) * 120},${40 - (v / 100) * 36}`).join(' ')}
                fill="none"
                stroke="var(--accent)"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
              {/* End dot */}
              <circle
                cx="120"
                cy={40 - (m.sparkline[m.sparkline.length - 1] / 100) * 36}
                r="2.5"
                fill="var(--accent)"
              />
            </svg>
          </div>
          <span class="metric-value">{m.value}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── NPS Score Gauge ── -->
  <div class="nps-section reveal">
    <div class="nps-container">
      <div class="nps-gauge" id="omega-nps-gauge" data-score={npsScore}>
        <svg viewBox="0 0 200 120" class="gauge-svg">
          {/* Background arc */}
          <path
            d="M20,100 A80,80 0 0,1 180,100"
            fill="none"
            stroke="var(--surface-container-high)"
            stroke-width="12"
            stroke-linecap="round"
          />
          {/* Colored arc — animated via CSS */}
          <path
            d="M20,100 A80,80 0 0,1 180,100"
            fill="none"
            stroke="var(--accent)"
            stroke-width="12"
            stroke-linecap="round"
            class="gauge-fill"
            stroke-dasharray="251"
            stroke-dashoffset="251"
          />
          {/* Score label */}
          <text x="100" y="88" text-anchor="middle" class="gauge-score-text" fill="var(--text-primary)" font-family="var(--font-headline)" font-size="32" font-weight="700">{npsScore}</text>
          <text x="100" y="108" text-anchor="middle" fill="var(--text-tertiary)" font-family="var(--font-label)" font-size="10" font-weight="600" letter-spacing="0.08em">NPS SCORE</text>
        </svg>
        <div class="gauge-labels">
          <span class="gauge-label-min">0</span>
          <span class="gauge-label-mid">50</span>
          <span class="gauge-label-max">100</span>
        </div>
      </div>
      <p class="nps-descriptor">
        <span class="nps-badge">Excellent</span>
        Industry average: 34
      </p>
    </div>
  </div>

  <!-- ── Wall of Love ── -->
  <div class="wall-section reveal">
    <h2 class="section-heading">What Our Clients Say</h2>
    <div class="wall-grid">
      {wallOfLove.map((t) => (
        <div class={`wall-card glass-panel wall-${t.size}`}>
          <blockquote class="wall-quote">{t.quote}</blockquote>
          <div class="wall-author">
            <span class="wall-author-name">{t.author}</span>
            <span class="wall-author-company">{t.company}</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Industry Recognition ── -->
  <div class="press-section reveal">
    <p class="press-heading">Featured In</p>
    <div class="press-grid">
      {pressLogos.map((p) => (
        <div class="press-badge" style={`width: ${p.width}px`}>
          <span class="press-name">{p.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Client Map ── -->
  <div class="map-section reveal">
    <h2 class="section-heading">Nationwide Coverage</h2>
    <p class="map-subtitle">Serving facilities across every major region</p>
    <div class="map-container" aria-label="Client locations across the United States">
      <div class="map-canvas" id="omega-client-map">
        {/* US outline placeholder — simplified rectangle with rounded corners */}
        <svg viewBox="0 0 100 80" class="map-outline" aria-hidden="true">
          <rect x="2" y="8" width="96" height="64" rx="4" ry="4" fill="none" stroke="var(--outline-variant)" stroke-width="0.5" opacity="0.3" />
          {/* Approximate US landmass shape */}
          <path
            d="M10,20 L25,15 L40,18 L55,14 L70,16 L82,18 L90,22 L88,35 L92,45 L85,55 L75,58 L65,60 L50,62 L40,65 L30,60 L20,55 L15,48 L12,40 L8,30 Z"
            fill="var(--surface-container)"
            stroke="var(--outline-variant)"
            stroke-width="0.5"
            opacity="0.5"
          />
        </svg>
        {/* Client dots */}
        {clientRegions.map((r) => (
          <div
            class="map-dot"
            style={`left: ${r.x}%; top: ${r.y}%; --dot-scale: ${0.6 + (r.count / 30) * 0.8};`}
            data-label={r.label}
            data-count={r.count}
            aria-label={`${r.label}: ${r.count} facilities`}
          >
            <span class="dot-ping"></span>
            <span class="dot-core"></span>
            <div class="dot-tooltip">
              <strong>{r.label}</strong>
              <span>{r.count} facilities</span>
            </div>
          </div>
        ))}
      </div>
      <div class="map-legend">
        <div class="legend-item">
          <span class="legend-dot small"></span>
          <span>1-10 facilities</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot medium"></span>
          <span>11-20 facilities</span>
        </div>
        <div class="legend-item">
          <span class="legend-dot large"></span>
          <span>21+ facilities</span>
        </div>
      </div>
    </div>
  </div>

</section>

<style>
  .social-proof-omega {
    display: flex;
    flex-direction: column;
  }

  .section-heading {
    font-family: var(--font-headline);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    letter-spacing: -0.02em;
  }

  /* ─── Metric Dashboard ─── */
  .metrics-section {
    padding: 80px 24px;
    background: var(--surface-container-lowest);
    border-bottom: 1px solid var(--glass-border);
  }

  .metrics-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .metric-card {
    position: relative;
    text-align: center;
    padding: 24px 16px;
    border-radius: 12px;
    overflow: hidden;
  }

  .metric-sparkline {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
    opacity: 0.6;
  }

  .sparkline-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .metric-value {
    display: block;
    position: relative;
    z-index: 3;
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .metric-label {
    display: block;
    position: relative;
    z-index: 3;
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-top: 6px;
  }

  /* ─── NPS Gauge ─── */
  .nps-section {
    padding: 64px 24px;
    text-align: center;
    border-bottom: 1px solid var(--glass-border);
  }

  .nps-container {
    max-width: 320px;
    margin: 0 auto;
  }

  .nps-gauge {
    position: relative;
  }

  .gauge-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .gauge-fill {
    transition: stroke-dashoffset 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gauge-labels {
    display: flex;
    justify-content: space-between;
    padding: 0 16px;
    margin-top: -4px;
  }

  .gauge-labels span {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-tertiary);
  }

  .gauge-label-mid {
    margin-left: auto;
    margin-right: auto;
  }

  .nps-descriptor {
    margin-top: 16px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .nps-badge {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 3px 10px;
    border-radius: 9999px;
  }

  /* ─── Wall of Love ─── */
  .wall-section {
    padding: 80px 24px;
  }

  .wall-grid {
    max-width: 1100px;
    margin: 40px auto 0;
    columns: 3;
    column-gap: 20px;
  }

  .wall-card {
    break-inside: avoid;
    margin-bottom: 20px;
    padding: 24px;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .wall-quote {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
  }

  .wall-large .wall-quote {
    font-size: 1rem;
  }

  .wall-small .wall-quote {
    font-size: 0.875rem;
  }

  .wall-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 8px;
    border-top: 1px solid var(--glass-border);
  }

  .wall-author-name {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .wall-author-company {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  /* ─── Press / Recognition ─── */
  .press-section {
    padding: 48px 24px;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    text-align: center;
  }

  .press-heading {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    margin-bottom: 24px;
  }

  .press-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .press-badge {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    padding: 0 16px;
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    background: var(--surface-container);
    transition: background 250ms ease, border-color 250ms ease;
  }

  .press-badge:hover {
    background: var(--surface-container-high);
    border-color: var(--border-hover);
  }

  .press-name {
    font-family: var(--font-label);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  /* ─── Client Map ─── */
  .map-section {
    padding: 80px 24px;
  }

  .map-subtitle {
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-tertiary);
    margin-top: 8px;
  }

  .map-container {
    max-width: 800px;
    margin: 40px auto 0;
  }

  .map-canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 100 / 80;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    background: var(--surface-container-lowest);
    overflow: hidden;
  }

  .map-outline {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .map-dot {
    position: absolute;
    transform: translate(-50%, -50%);
    cursor: default;
    z-index: 5;
  }

  .dot-core {
    display: block;
    width: calc(8px * var(--dot-scale, 1));
    height: calc(8px * var(--dot-scale, 1));
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow-strong, rgba(0, 229, 255, 0.3));
    position: relative;
    z-index: 2;
    transition: transform 250ms ease;
  }

  .map-dot:hover .dot-core {
    transform: scale(1.4);
  }

  .dot-ping {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--accent);
    opacity: 0;
    animation: dot-ping 3s ease-out infinite;
    z-index: 1;
  }

  @keyframes dot-ping {
    0% { transform: scale(0.8); opacity: 0.6; }
    100% { transform: scale(2.5); opacity: 0; }
  }

  .dot-tooltip {
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: var(--surface-container-highest);
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    padding: 8px 12px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease, transform 200ms ease;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dot-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 5px solid transparent;
    border-top-color: var(--surface-container-highest);
  }

  .dot-tooltip strong {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .dot-tooltip span {
    font-family: var(--font-body);
    font-size: 0.625rem;
    color: var(--text-tertiary);
  }

  .map-dot:hover .dot-tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .map-legend {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    margin-top: 16px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  .legend-dot {
    display: block;
    border-radius: 50%;
    background: var(--accent);
  }

  .legend-dot.small  { width: 6px; height: 6px; }
  .legend-dot.medium { width: 9px; height: 9px; }
  .legend-dot.large  { width: 12px; height: 12px; }

  /* ─── Responsive ─── */
  @media (max-width: 1023px) {
    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .wall-grid {
      columns: 2;
    }
  }

  @media (max-width: 767px) {
    .metrics-section,
    .wall-section,
    .map-section {
      padding: 56px 16px;
    }

    .metrics-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .wall-grid {
      columns: 1;
    }

    .press-grid {
      gap: 10px 16px;
    }

    .map-legend {
      flex-wrap: wrap;
      gap: 12px;
    }

    .dot-tooltip {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot-ping {
      animation: none !important;
    }
    .gauge-fill {
      transition-duration: 0ms !important;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // ── NPS Gauge Animation ──
    const gauge = document.getElementById('omega-nps-gauge');
    if (gauge) {
      const score = parseInt(gauge.dataset.score || '0', 10);
      const fill = gauge.querySelector('.gauge-fill') as SVGPathElement | null;
      if (fill) {
        // Arc length = pi * radius = pi * 80 ~ 251
        const totalLength = 251;
        const targetOffset = totalLength - (score / 100) * totalLength;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Respect reduced motion
              if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                fill.style.strokeDashoffset = `${targetOffset}`;
              } else {
                requestAnimationFrame(() => {
                  fill.style.strokeDashoffset = `${targetOffset}`;
                });
              }
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });

        observer.observe(gauge);
      }
    }

    // ── Stagger dot animations ──
    const dots = document.querySelectorAll('.map-dot .dot-ping');
    dots.forEach((dot, i) => {
      (dot as HTMLElement).style.animationDelay = `${(i * 400) % 3000}ms`;
    });
  });
</script>
