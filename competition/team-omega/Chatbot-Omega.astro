---
/*
  Chatbot-Omega.astro — Aerial Intelligence Concierge
  Team Omega, Round 8

  A dock-style chatbot with conversation trees, rich message types,
  command palette, session persistence, and mobile bottom-sheet behavior.
*/
---

<!-- Launcher + Chat Panel -->
<div id="jinki-chatbot" class="jinki-chatbot" role="complementary" aria-label="Jinki Intelligence Concierge">

  <!-- Pill Launcher -->
  <button
    id="jinki-launcher"
    class="jinki-launcher"
    aria-label="Open Jinki Concierge chat"
    aria-expanded="false"
    aria-controls="jinki-panel"
    type="button"
  >
    <span class="launcher-icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2L2 7l10 5 10-5-10-5z"/>
        <path d="M2 17l10 5 10-5"/>
        <path d="M2 12l10 5 10-5"/>
      </svg>
    </span>
    <span class="launcher-label">Ask Jinki</span>
    <span class="launcher-glow" aria-hidden="true"></span>
  </button>

  <!-- Tooltip Preview -->
  <div id="jinki-tooltip" class="jinki-tooltip" role="tooltip" aria-hidden="true">
    <span class="tooltip-text">Have a question about aerial intelligence?</span>
  </div>

  <!-- Chat Panel -->
  <div
    id="jinki-panel"
    class="jinki-panel"
    role="dialog"
    aria-label="Jinki Concierge Chat"
    aria-hidden="true"
  >
    <!-- Drag Handle (mobile) -->
    <div class="panel-drag-handle" aria-hidden="true">
      <span class="drag-bar"></span>
    </div>

    <!-- Top Bar -->
    <header class="panel-header">
      <div class="header-left">
        <span class="header-status" aria-hidden="true"></span>
        <span class="header-title">Jinki Concierge</span>
      </div>
      <div class="header-actions">
        <button
          id="jinki-minimize"
          class="header-btn"
          aria-label="Minimize chat"
          type="button"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
        </button>
        <button
          id="jinki-close"
          class="header-btn"
          aria-label="Close chat"
          type="button"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
        </button>
      </div>
    </header>

    <!-- Conversation Canvas -->
    <div id="jinki-messages" class="panel-messages" role="log" aria-live="polite" aria-label="Chat messages">
      <!-- Messages injected here by JS -->
    </div>

    <!-- Command Palette -->
    <div id="jinki-commands" class="command-palette" aria-hidden="true" role="listbox" aria-label="Available commands">
      <!-- Commands injected by JS -->
    </div>

    <!-- Input Area -->
    <div class="panel-input-area">
      <div class="input-wrapper">
        <input
          id="jinki-input"
          type="text"
          class="chat-input"
          placeholder="Type a message or / for commands..."
          aria-label="Chat message input"
          autocomplete="off"
        />
        <button
          id="jinki-send"
          class="send-btn"
          aria-label="Send message"
          type="button"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/>
          </svg>
        </button>
      </div>
      <div class="input-hint">
        <kbd>/</kbd> commands &middot; Press Enter to send
      </div>
    </div>
  </div>
</div>

<style>
  /* ======= LAYOUT & POSITIONING ======= */
  .jinki-chatbot {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9990;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-primary);
  }

  /* ======= LAUNCHER ======= */
  .jinki-launcher {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px 12px 16px;
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    color: var(--text-primary);
    font-family: var(--font-label);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--glass-shadow), 0 0 20px rgba(0, 229, 255, 0.1);
  }

  .jinki-launcher:hover {
    border-color: var(--accent);
    box-shadow: var(--glass-shadow), 0 0 30px rgba(0, 229, 255, 0.2);
    transform: translateY(-2px);
  }

  .jinki-launcher:active {
    transform: translateY(0) scale(0.98);
  }

  .jinki-launcher[aria-expanded="true"] {
    opacity: 0;
    pointer-events: none;
    transform: translateY(10px) scale(0.9);
  }

  .launcher-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }

  .launcher-label {
    white-space: nowrap;
  }

  .launcher-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    pointer-events: none;
    animation: launcher-breathe 4s ease-in-out infinite;
    border: 1px solid transparent;
  }

  @keyframes launcher-breathe {
    0%, 100% {
      box-shadow: 0 0 12px rgba(0, 229, 255, 0.08), inset 0 0 12px rgba(0, 229, 255, 0.03);
    }
    50% {
      box-shadow: 0 0 24px rgba(0, 229, 255, 0.18), inset 0 0 20px rgba(0, 229, 255, 0.06);
    }
  }

  /* ======= TOOLTIP ======= */
  .jinki-tooltip {
    position: absolute;
    bottom: calc(100% + 12px);
    right: 0;
    padding: 10px 16px;
    background: var(--surface-container-high);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    font-size: 13px;
    color: var(--text-secondary);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: var(--glass-shadow);
  }

  .jinki-launcher:hover ~ .jinki-tooltip,
  .jinki-launcher:focus-visible ~ .jinki-tooltip {
    opacity: 1;
    transform: translateY(0);
  }

  .jinki-launcher[aria-expanded="true"] ~ .jinki-tooltip {
    opacity: 0 !important;
    pointer-events: none !important;
  }

  /* ======= CHAT PANEL ======= */
  .jinki-panel {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 400px;
    height: 560px;
    max-height: calc(100vh - 48px);
    display: flex;
    flex-direction: column;
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    box-shadow: var(--glass-shadow), 0 0 60px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px) scale(0.95);
    transform-origin: bottom right;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .jinki-panel[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  /* Topo background inside panel */
  .jinki-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/topo-dark.svg');
    background-size: 600px 600px;
    background-repeat: repeat;
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }

  :global([data-theme="light"]) .jinki-panel::before {
    background-image: url('/images/topo-light.svg');
    opacity: 0.06;
  }

  :global([data-theme="light"]) .jinki-panel {
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.12), 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  /* Drag handle (mobile only) */
  .panel-drag-handle {
    display: none;
    justify-content: center;
    padding: 10px 0 2px;
    cursor: grab;
    position: relative;
    z-index: 5;
  }

  .drag-bar {
    width: 36px;
    height: 4px;
    border-radius: 2px;
    background: var(--text-tertiary);
    opacity: 0.5;
  }

  /* ======= HEADER ======= */
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--surface-container);
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .header-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #34d399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    flex-shrink: 0;
  }

  .header-title {
    font-family: var(--font-label);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.01em;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .header-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .header-btn:hover {
    background: var(--surface-container-high);
    color: var(--text-primary);
  }

  /* ======= MESSAGES ======= */
  .panel-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    position: relative;
    z-index: 1;
    scroll-behavior: smooth;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .panel-messages::-webkit-scrollbar { width: 4px; }
  .panel-messages::-webkit-scrollbar-track { background: transparent; }
  .panel-messages::-webkit-scrollbar-thumb { background: var(--text-tertiary); border-radius: 2px; opacity: 0.3; }

  /* Message Bubbles */
  .jinki-chatbot .msg {
    display: flex;
    flex-direction: column;
    max-width: 85%;
    animation: msg-in 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    opacity: 0;
  }

  @keyframes msg-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .jinki-chatbot .msg-bot {
    align-self: flex-start;
  }

  .jinki-chatbot .msg-user {
    align-self: flex-end;
  }

  .jinki-chatbot .msg-bubble {
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.55;
    position: relative;
  }

  .jinki-chatbot .msg-bot .msg-bubble {
    background: var(--surface-container);
    border: 1px solid var(--border);
    border-bottom-left-radius: 4px;
    color: var(--text-primary);
  }

  .jinki-chatbot .msg-user .msg-bubble {
    background: var(--accent);
    color: #000;
    border-bottom-right-radius: 4px;
    font-weight: 500;
  }

  :global([data-theme="light"]) .jinki-chatbot .msg-user .msg-bubble {
    background: var(--accent);
    color: #fff;
  }

  /* Markdown-like formatting inside bubbles */
  .jinki-chatbot .msg-bubble strong {
    font-weight: 700;
    color: inherit;
  }

  .jinki-chatbot .msg-bubble code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: rgba(0,0,0,0.15);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* ======= OPTION CARDS ======= */
  .jinki-chatbot .option-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin: 4px 0 0;
    max-width: 100%;
  }

  .jinki-chatbot .option-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px;
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    text-align: left;
    font-family: inherit;
    color: var(--text-primary);
    position: relative;
    overflow: hidden;
  }

  .jinki-chatbot .option-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
  }

  .jinki-chatbot .option-card:hover {
    border-color: var(--accent);
    background: var(--accent-glow);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 229, 255, 0.1);
  }

  .jinki-chatbot .option-card:active {
    transform: translateY(0) scale(0.98);
  }

  .jinki-chatbot .option-card-icon {
    font-size: 20px;
    color: var(--accent);
    font-family: 'Material Symbols Rounded';
    font-weight: normal;
    line-height: 1;
  }

  .jinki-chatbot .option-card-title {
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .jinki-chatbot .option-card-sub {
    font-size: 11px;
    color: var(--text-tertiary);
    line-height: 1.3;
  }

  /* ======= IMAGE CARD ======= */
  .jinki-chatbot .img-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    margin: 4px 0 0;
  }

  .jinki-chatbot .img-card-visual {
    width: 100%;
    height: 120px;
    background: linear-gradient(135deg, var(--surface-container) 0%, var(--surface-container-high) 50%, rgba(0, 229, 255, 0.08) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .jinki-chatbot .img-card-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 229, 255, 0.03) 3px,
      rgba(0, 229, 255, 0.03) 4px
    );
    pointer-events: none;
  }

  .jinki-chatbot .img-card-visual .material-symbols-rounded {
    font-size: 36px;
    color: var(--accent);
    opacity: 0.5;
  }

  .jinki-chatbot .img-card-body {
    padding: 10px 12px;
    background: var(--surface-container);
  }

  .jinki-chatbot .img-card-title {
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .jinki-chatbot .img-card-desc {
    font-size: 12px;
    color: var(--text-tertiary);
    margin: 2px 0 0;
  }

  /* ======= STATS CARD ======= */
  .jinki-chatbot .stats-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin: 4px 0 0;
  }

  .jinki-chatbot .stat-item {
    padding: 10px 12px;
    background: var(--surface-container);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-align: center;
  }

  .jinki-chatbot .stat-value {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 700;
    color: var(--accent);
    line-height: 1.2;
  }

  .jinki-chatbot .stat-label {
    font-size: 11px;
    color: var(--text-tertiary);
    margin: 2px 0 0;
  }

  /* ======= CTA BUTTON IN MESSAGES ======= */
  .jinki-chatbot .msg-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 8px 0 0;
    padding: 8px 16px;
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 8px;
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .jinki-chatbot .msg-cta:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  :global([data-theme="light"]) .jinki-chatbot .msg-cta {
    color: #fff;
  }

  /* ======= THINKING STATE ======= */
  .jinki-chatbot .thinking {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: var(--surface-container);
    border: 1px solid var(--border);
    border-radius: 12px;
    border-bottom-left-radius: 4px;
    align-self: flex-start;
  }

  .jinki-chatbot .scan-line {
    width: 80px;
    height: 3px;
    background: var(--surface-container-high);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .jinki-chatbot .scan-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: -40%;
    width: 40%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: scan-sweep 1.2s ease-in-out infinite;
    border-radius: inherit;
  }

  @keyframes scan-sweep {
    0% { left: -40%; }
    100% { left: 100%; }
  }

  .jinki-chatbot .thinking-label {
    font-size: 12px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    letter-spacing: 0.05em;
  }

  /* ======= COMMAND PALETTE ======= */
  .command-palette {
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    max-height: 200px;
    overflow-y: auto;
    background: var(--surface-container);
    border-top: 1px solid var(--border);
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: all 0.2s ease;
    z-index: 10;
  }

  .command-palette[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .jinki-chatbot .cmd-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    cursor: pointer;
    transition: background 0.15s ease;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
    color: var(--text-primary);
  }

  .jinki-chatbot .cmd-item:hover,
  .jinki-chatbot .cmd-item[aria-selected="true"] {
    background: var(--accent-glow);
  }

  .jinki-chatbot .cmd-name {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    font-weight: 600;
  }

  .jinki-chatbot .cmd-desc {
    font-size: 12px;
    color: var(--text-tertiary);
  }

  /* ======= INPUT AREA ======= */
  .panel-input-area {
    padding: 12px 16px 14px;
    border-top: 1px solid var(--border);
    background: var(--surface-container);
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  .input-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface-container-low);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 4px 4px 4px 14px;
    transition: border-color 0.2s ease;
  }

  .input-wrapper:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }

  .chat-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14px;
    outline: none;
    min-width: 0;
  }

  .chat-input::placeholder {
    color: var(--text-tertiary);
  }

  .send-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 10px;
    background: var(--accent);
    color: #000;
    cursor: pointer;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .send-btn:hover {
    filter: brightness(1.1);
    transform: scale(1.05);
  }

  .send-btn:active {
    transform: scale(0.95);
  }

  :global([data-theme="light"]) .send-btn {
    color: #fff;
  }

  .input-hint {
    font-size: 11px;
    color: var(--text-tertiary);
    margin: 6px 0 0;
    text-align: center;
    opacity: 0.7;
  }

  .input-hint kbd {
    display: inline-block;
    padding: 1px 5px;
    font-family: var(--font-mono);
    font-size: 10px;
    background: var(--surface-container-high);
    border: 1px solid var(--border);
    border-radius: 4px;
    line-height: 1.4;
  }

  /* ======= MOBILE ======= */
  @media (max-width: 640px) {
    .jinki-chatbot {
      bottom: 16px;
      right: 16px;
    }

    .jinki-panel {
      position: fixed;
      bottom: 0;
      right: 0;
      left: 0;
      width: 100%;
      height: 60vh;
      max-height: none;
      border-radius: 20px 20px 0 0;
      transform-origin: bottom center;
    }

    .jinki-panel[aria-hidden="false"] {
      transform: translateY(0);
    }

    .jinki-panel.panel-expanded {
      height: 100vh;
      height: 100dvh;
      border-radius: 0;
    }

    .panel-drag-handle {
      display: flex;
    }

    .jinki-tooltip {
      display: none;
    }

    .jinki-chatbot .option-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ======= PRINT ======= */
  @media print {
    .jinki-chatbot { display: none !important; }
  }

  /* ======= REDUCED MOTION ======= */
  @media (prefers-reduced-motion: reduce) {
    .jinki-panel,
    .jinki-launcher,
    .jinki-chatbot .msg,
    .jinki-chatbot .option-card,
    .command-palette {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>

<script>
(function() {
  'use strict';

  // ---- DOM refs ----
  const root       = document.getElementById('jinki-chatbot');
  const launcher   = document.getElementById('jinki-launcher');
  const tooltip    = document.getElementById('jinki-tooltip');
  const panel      = document.getElementById('jinki-panel');
  const msgArea    = document.getElementById('jinki-messages');
  const input      = document.getElementById('jinki-input');
  const sendBtn    = document.getElementById('jinki-send');
  const closeBtn   = document.getElementById('jinki-close');
  const minimizeBtn = document.getElementById('jinki-minimize');
  const cmdPalette = document.getElementById('jinki-commands');

  if (!root || !launcher || !panel || !msgArea || !input) return;

  // ---- State ----
  const SESSION_KEY = 'jinki-chat-session';
  let isOpen = false;
  let messages = [];
  let cmdIndex = -1;

  // ---- Commands ----
  const commands = [
    { name: '/services',  desc: 'View our service offerings',  action: 'services' },
    { name: '/contact',   desc: 'Connect with an expert',      action: 'contact' },
    { name: '/pricing',   desc: 'Learn about service plans',   action: 'pricing' },
    { name: '/verticals', desc: 'Explore industry solutions',  action: 'verticals' },
    { name: '/audit',     desc: 'Facility intelligence audit',  action: 'audit' },
    { name: '/deploy',    desc: 'Autonomous deployment info',  action: 'deploy' },
  ];

  // ---- Conversation Trees ----
  const welcomeOptions = [
    { icon: 'radar',         title: 'Facility Assessment',  sub: 'One-time aerial audit',          action: 'audit' },
    { icon: 'layers',        title: 'Service Plans',         sub: 'Ongoing monitoring solutions',   action: 'services' },
    { icon: 'category',      title: 'Industry Solutions',    sub: 'Verticals we serve',             action: 'verticals' },
    { icon: 'support_agent', title: 'Connect with Expert',   sub: 'Talk to our team',               action: 'contact' },
  ];

  const responses = {
    audit: {
      text: 'Our <strong>Facility Intelligence Audit</strong> is a comprehensive one-time assessment. We deploy advanced aerial sensors to capture thermal, visual, and LiDAR data across your entire facility.',
      followUp: 'image',
      imageData: { icon: 'thermal_camera', title: 'Thermal Scan Preview', desc: 'Multi-spectral facility assessment' },
      stats: [
        { value: '6', label: 'Step Process' },
        { value: '48h', label: 'Turnaround' },
        { value: '99.2%', label: 'Detection Rate' },
        { value: '40%', label: 'Cost Reduction' },
      ],
      cta: { label: 'Request an Audit', href: '/services/audit' },
    },
    services: {
      text: 'Jinki offers two core service tiers designed for different operational needs:',
      followUp: 'options',
      options: [
        { icon: 'search_insights', title: 'Intelligence Audit', sub: 'One-time deep assessment', action: 'audit' },
        { icon: 'hub',             title: 'Autonomous Deployment', sub: 'Persistent monitoring',  action: 'deploy' },
      ],
    },
    verticals: {
      text: 'We deliver aerial intelligence across <strong>four key industries</strong>, each with tailored analytics and reporting:',
      followUp: 'options',
      options: [
        { icon: 'dns',        title: 'Data Centers',    sub: 'Thermal & infrastructure', action: 'vertical_dc' },
        { icon: 'bolt',       title: 'Energy & Grid',   sub: 'Transmission & solar',     action: 'vertical_energy' },
        { icon: 'shield',     title: 'Security',        sub: 'Perimeter intelligence',   action: 'vertical_security' },
        { icon: 'eco',        title: 'Agriculture',     sub: 'Crop health & NDVI',       action: 'vertical_ag' },
      ],
    },
    contact: {
      text: 'Our aerial intelligence specialists are ready to discuss your specific requirements. We typically respond within one business day.',
      cta: { label: 'Get in Touch', href: '/#leadgen' },
    },
    deploy: {
      text: 'Our <strong>Autonomous Deployment</strong> service provides persistent, scheduled aerial monitoring using dock-based systems. Up to <strong>200 missions per month</strong> with zero manual intervention.',
      stats: [
        { value: '200', label: 'Missions/Month' },
        { value: '24/7', label: 'Coverage' },
        { value: '0', label: 'Pilot Required' },
        { value: '15min', label: 'Alert Response' },
      ],
      cta: { label: 'Learn More', href: '/services/deployment' },
    },
    pricing: {
      text: 'Our pricing is tailored to your facility size, frequency needs, and analytics requirements. We offer both <strong>one-time audits</strong> and <strong>subscription-based monitoring</strong>.',
      cta: { label: 'Request a Quote', href: '/#leadgen' },
    },
    vertical_dc: {
      text: 'For <strong>data centers</strong>, we provide thermal anomaly detection, roof integrity monitoring, and cooling efficiency analytics. Our sensors detect hotspots invisible to ground-level inspection.',
      cta: { label: 'Explore Data Centers', href: '/verticals/data-centers' },
    },
    vertical_energy: {
      text: 'Our <strong>energy & grid</strong> solutions cover transmission line inspection, solar panel diagnostics, and substation thermal monitoring at scale.',
      cta: { label: 'Explore Energy', href: '/verticals/energy-grid' },
    },
    vertical_security: {
      text: 'Jinki provides <strong>perimeter security</strong> intelligence with autonomous patrol routes, intrusion detection analytics, and real-time alerting for critical infrastructure.',
      cta: { label: 'Explore Security', href: '/verticals/security' },
    },
    vertical_ag: {
      text: 'Our <strong>agriculture</strong> platform delivers NDVI analysis, crop health mapping, irrigation optimization, and yield prediction using multi-spectral aerial data.',
      cta: { label: 'Explore Agriculture', href: '/verticals/agriculture' },
    },
    fallback: {
      text: "I appreciate the question. I'm best at helping with our aerial intelligence services, facility assessments, and industry solutions. Here are some topics I can help with:",
      followUp: 'options',
      options: welcomeOptions,
    },
  };

  // ---- Context-aware welcome ----
  function getWelcomeText() {
    const path = window.location.pathname;
    if (path.includes('/verticals/data-centers')) return 'Welcome! I see you\'re exploring our data center solutions. How can I help?';
    if (path.includes('/verticals/energy'))       return 'Welcome! Looking into energy grid intelligence? I can help you learn more.';
    if (path.includes('/verticals/security'))      return 'Welcome! Interested in perimeter security solutions? Let me assist you.';
    if (path.includes('/verticals/agriculture'))    return 'Welcome! Exploring agricultural intelligence? I\'m here to help.';
    if (path.includes('/services/audit'))           return 'Welcome! Interested in a facility intelligence audit? Let me walk you through it.';
    if (path.includes('/services/deployment'))      return 'Welcome! Curious about autonomous deployment? I can explain our capabilities.';
    return 'Welcome to Jinki Intelligence. What can I help you explore?';
  }

  // ---- Session persistence ----
  function saveSession() {
    try {
      sessionStorage.setItem(SESSION_KEY, JSON.stringify(messages));
    } catch(e) { /* quota exceeded, ignore */ }
  }

  function loadSession() {
    try {
      const data = sessionStorage.getItem(SESSION_KEY);
      if (data) {
        messages = JSON.parse(data);
        return true;
      }
    } catch(e) { /* parse error, ignore */ }
    return false;
  }

  // ---- Render helpers ----
  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function createMsgEl(role, html) {
    const wrapper = document.createElement('div');
    wrapper.className = 'msg msg-' + role;
    wrapper.setAttribute('role', 'article');
    wrapper.setAttribute('aria-label', role === 'bot' ? 'Jinki' : 'You');
    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';
    bubble.innerHTML = html;
    wrapper.appendChild(bubble);
    return wrapper;
  }

  function createOptionGrid(options) {
    const grid = document.createElement('div');
    grid.className = 'option-grid';
    options.forEach(function(opt) {
      const card = document.createElement('button');
      card.className = 'option-card';
      card.type = 'button';
      card.setAttribute('aria-label', opt.title + ': ' + opt.sub);
      card.innerHTML =
        '<span class="option-card-icon material-symbols-rounded" aria-hidden="true">' + opt.icon + '</span>' +
        '<span class="option-card-title">' + opt.title + '</span>' +
        '<span class="option-card-sub">' + opt.sub + '</span>';
      card.addEventListener('click', function() {
        handleAction(opt.action, opt.title);
      });
      grid.appendChild(card);
    });
    return grid;
  }

  function createImageCard(data) {
    const card = document.createElement('div');
    card.className = 'img-card';
    card.innerHTML =
      '<div class="img-card-visual"><span class="material-symbols-rounded" aria-hidden="true">' + data.icon + '</span></div>' +
      '<div class="img-card-body"><div class="img-card-title">' + data.title + '</div><div class="img-card-desc">' + data.desc + '</div></div>';
    return card;
  }

  function createStatsCard(stats) {
    const card = document.createElement('div');
    card.className = 'stats-card';
    stats.forEach(function(s) {
      const item = document.createElement('div');
      item.className = 'stat-item';
      item.innerHTML = '<div class="stat-value">' + s.value + '</div><div class="stat-label">' + s.label + '</div>';
      card.appendChild(item);
    });
    return card;
  }

  function createCTA(cta) {
    const a = document.createElement('a');
    a.className = 'msg-cta';
    a.href = cta.href;
    a.textContent = cta.label;
    a.innerHTML += ' <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>';
    return a;
  }

  function createThinking() {
    const el = document.createElement('div');
    el.className = 'thinking';
    el.setAttribute('role', 'status');
    el.setAttribute('aria-label', 'Jinki is thinking');
    el.innerHTML = '<div class="scan-line"></div><span class="thinking-label">analyzing</span>';
    return el;
  }

  // ---- Typewriter effect ----
  function typewriter(bubble, html, callback) {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion) {
      bubble.innerHTML = html;
      if (callback) callback();
      return;
    }
    // Parse HTML into text nodes for a simulated typewriter
    bubble.innerHTML = '';
    const tempDiv = document.createElement('div');
    tempDiv.innerHTML = html;
    const fullText = tempDiv.textContent || '';
    let i = 0;
    const speed = Math.max(12, Math.min(30, 600 / fullText.length));
    function type() {
      if (i < fullText.length) {
        // Once we've typed enough, just reveal the rest with HTML
        if (i > 30 || i >= fullText.length - 1) {
          bubble.innerHTML = html;
          if (callback) callback();
          return;
        }
        bubble.textContent = fullText.substring(0, i + 1);
        i++;
        setTimeout(type, speed);
      } else {
        bubble.innerHTML = html;
        if (callback) callback();
      }
    }
    type();
  }

  // ---- Scroll to bottom ----
  function scrollToBottom() {
    requestAnimationFrame(function() {
      msgArea.scrollTop = msgArea.scrollHeight;
    });
  }

  // ---- Add messages ----
  function addUserMessage(text) {
    messages.push({ role: 'user', text: text });
    saveSession();
    const el = createMsgEl('user', escapeHtml(text));
    msgArea.appendChild(el);
    scrollToBottom();
  }

  function addBotResponse(responseKey) {
    const data = responses[responseKey] || responses.fallback;

    // Show thinking
    const thinking = createThinking();
    msgArea.appendChild(thinking);
    scrollToBottom();

    const delay = 600 + Math.random() * 400;
    setTimeout(function() {
      thinking.remove();

      // Text bubble with typewriter
      messages.push({ role: 'bot', key: responseKey });
      saveSession();

      const wrapper = document.createElement('div');
      wrapper.className = 'msg msg-bot';
      wrapper.setAttribute('role', 'article');
      wrapper.setAttribute('aria-label', 'Jinki');

      const bubble = document.createElement('div');
      bubble.className = 'msg-bubble';
      wrapper.appendChild(bubble);
      msgArea.appendChild(wrapper);

      typewriter(bubble, data.text, function() {
        // Follow-up content
        if (data.followUp === 'image' && data.imageData) {
          wrapper.appendChild(createImageCard(data.imageData));
        }
        if (data.stats) {
          wrapper.appendChild(createStatsCard(data.stats));
        }
        if (data.followUp === 'options' && data.options) {
          wrapper.appendChild(createOptionGrid(data.options));
        }
        if (data.cta) {
          wrapper.appendChild(createCTA(data.cta));
        }
        scrollToBottom();
      });

      scrollToBottom();
    }, delay);
  }

  function showWelcome() {
    const welcomeText = getWelcomeText();
    messages.push({ role: 'bot', key: '_welcome' });
    saveSession();

    const wrapper = document.createElement('div');
    wrapper.className = 'msg msg-bot';
    wrapper.setAttribute('role', 'article');
    wrapper.setAttribute('aria-label', 'Jinki');

    const bubble = document.createElement('div');
    bubble.className = 'msg-bubble';
    wrapper.appendChild(bubble);
    msgArea.appendChild(wrapper);

    typewriter(bubble, welcomeText, function() {
      wrapper.appendChild(createOptionGrid(welcomeOptions));
      scrollToBottom();
    });
  }

  // Restore session messages (no animation)
  function restoreSession() {
    messages.forEach(function(msg) {
      if (msg.role === 'user') {
        const el = createMsgEl('user', escapeHtml(msg.text));
        el.style.animation = 'none';
        el.style.opacity = '1';
        msgArea.appendChild(el);
      } else if (msg.role === 'bot') {
        const data = msg.key === '_welcome' ? null : (responses[msg.key] || responses.fallback);
        const wrapper = document.createElement('div');
        wrapper.className = 'msg msg-bot';
        wrapper.style.animation = 'none';
        wrapper.style.opacity = '1';
        wrapper.setAttribute('role', 'article');
        wrapper.setAttribute('aria-label', 'Jinki');

        const bubble = document.createElement('div');
        bubble.className = 'msg-bubble';

        if (msg.key === '_welcome') {
          bubble.innerHTML = getWelcomeText();
          wrapper.appendChild(bubble);
          wrapper.appendChild(createOptionGrid(welcomeOptions));
        } else if (data) {
          bubble.innerHTML = data.text;
          wrapper.appendChild(bubble);
          if (data.followUp === 'image' && data.imageData) wrapper.appendChild(createImageCard(data.imageData));
          if (data.stats) wrapper.appendChild(createStatsCard(data.stats));
          if (data.followUp === 'options' && data.options) wrapper.appendChild(createOptionGrid(data.options));
          if (data.cta) wrapper.appendChild(createCTA(data.cta));
        }

        msgArea.appendChild(wrapper);
      }
    });
    scrollToBottom();
  }

  // ---- Actions ----
  function handleAction(action, displayText) {
    if (displayText) {
      addUserMessage(displayText);
    }
    addBotResponse(action);
  }

  function handleUserInput() {
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    hideCommands();

    // Check if it's a command
    if (text.startsWith('/')) {
      const cmd = commands.find(function(c) { return c.name === text.toLowerCase(); });
      if (cmd) {
        addUserMessage(text);
        addBotResponse(cmd.action);
        return;
      }
    }

    addUserMessage(text);

    // Simple keyword matching
    const lower = text.toLowerCase();
    if (lower.includes('audit') || lower.includes('assessment') || lower.includes('inspect'))   { addBotResponse('audit'); return; }
    if (lower.includes('deploy') || lower.includes('autonomous') || lower.includes('dock'))     { addBotResponse('deploy'); return; }
    if (lower.includes('service') || lower.includes('plan') || lower.includes('offer'))          { addBotResponse('services'); return; }
    if (lower.includes('vertical') || lower.includes('industry') || lower.includes('sector'))    { addBotResponse('verticals'); return; }
    if (lower.includes('contact') || lower.includes('expert') || lower.includes('talk') || lower.includes('speak')) { addBotResponse('contact'); return; }
    if (lower.includes('price') || lower.includes('pricing') || lower.includes('cost') || lower.includes('quote')) { addBotResponse('pricing'); return; }
    if (lower.includes('data center') || lower.includes('datacenter'))  { addBotResponse('vertical_dc'); return; }
    if (lower.includes('energy') || lower.includes('grid') || lower.includes('solar'))           { addBotResponse('vertical_energy'); return; }
    if (lower.includes('security') || lower.includes('perimeter'))                               { addBotResponse('vertical_security'); return; }
    if (lower.includes('agri') || lower.includes('crop') || lower.includes('farm') || lower.includes('ndvi')) { addBotResponse('vertical_ag'); return; }

    addBotResponse('fallback');
  }

  // ---- Command palette ----
  function showCommands(filter) {
    const filtered = commands.filter(function(c) {
      return !filter || c.name.includes(filter.toLowerCase());
    });
    if (filtered.length === 0) { hideCommands(); return; }

    cmdPalette.innerHTML = '';
    filtered.forEach(function(cmd, i) {
      const item = document.createElement('button');
      item.className = 'cmd-item';
      item.type = 'button';
      item.setAttribute('role', 'option');
      item.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
      item.innerHTML = '<span class="cmd-name">' + cmd.name + '</span><span class="cmd-desc">' + cmd.desc + '</span>';
      item.addEventListener('click', function() {
        input.value = cmd.name;
        hideCommands();
        handleUserInput();
      });
      cmdPalette.appendChild(item);
    });
    cmdPalette.setAttribute('aria-hidden', 'false');
    cmdIndex = 0;
  }

  function hideCommands() {
    cmdPalette.setAttribute('aria-hidden', 'true');
    cmdPalette.innerHTML = '';
    cmdIndex = -1;
  }

  // ---- Open / Close ----
  function openPanel() {
    isOpen = true;
    launcher.setAttribute('aria-expanded', 'true');
    panel.setAttribute('aria-hidden', 'false');
    input.focus();

    if (msgArea.children.length === 0) {
      const hasSession = loadSession();
      if (hasSession && messages.length > 0) {
        restoreSession();
      } else {
        messages = [];
        showWelcome();
      }
    }
  }

  function closePanel() {
    isOpen = false;
    launcher.setAttribute('aria-expanded', 'false');
    panel.setAttribute('aria-hidden', 'true');
    hideCommands();
    launcher.focus();
  }

  // ---- Event listeners ----
  launcher.addEventListener('click', function() {
    if (!isOpen) openPanel();
  });

  closeBtn.addEventListener('click', closePanel);
  minimizeBtn.addEventListener('click', closePanel);

  sendBtn.addEventListener('click', handleUserInput);

  input.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      handleUserInput();
    }
    if (e.key === 'Escape') {
      if (cmdPalette.getAttribute('aria-hidden') === 'false') {
        hideCommands();
      } else {
        closePanel();
      }
    }
    // Navigate command palette
    if (cmdPalette.getAttribute('aria-hidden') === 'false') {
      const items = cmdPalette.querySelectorAll('.cmd-item');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        cmdIndex = Math.min(cmdIndex + 1, items.length - 1);
        items.forEach(function(it, i) { it.setAttribute('aria-selected', i === cmdIndex ? 'true' : 'false'); });
      }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        cmdIndex = Math.max(cmdIndex - 1, 0);
        items.forEach(function(it, i) { it.setAttribute('aria-selected', i === cmdIndex ? 'true' : 'false'); });
      }
      if (e.key === 'Tab' || (e.key === 'Enter' && cmdIndex >= 0)) {
        e.preventDefault();
        if (items[cmdIndex]) items[cmdIndex].click();
      }
    }
  });

  input.addEventListener('input', function() {
    const val = input.value;
    if (val.startsWith('/')) {
      showCommands(val);
    } else {
      hideCommands();
    }
  });

  // Keyboard: close on Escape from panel
  panel.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closePanel();
    }
  });

  // Mobile drag handle
  (function() {
    const handle = panel.querySelector('.panel-drag-handle');
    if (!handle) return;
    let startY = 0;
    let startHeight = 0;

    handle.addEventListener('touchstart', function(e) {
      startY = e.touches[0].clientY;
      startHeight = panel.offsetHeight;
      handle.style.cursor = 'grabbing';
    }, { passive: true });

    handle.addEventListener('touchmove', function(e) {
      const diff = startY - e.touches[0].clientY;
      const newH = Math.max(200, startHeight + diff);
      const vh = window.innerHeight;
      if (newH > vh * 0.85) {
        panel.classList.add('panel-expanded');
      } else {
        panel.classList.remove('panel-expanded');
        panel.style.height = newH + 'px';
      }
    }, { passive: true });

    handle.addEventListener('touchend', function() {
      handle.style.cursor = 'grab';
      const vh = window.innerHeight;
      const h = panel.offsetHeight;
      // Snap logic
      if (h < vh * 0.3) {
        closePanel();
        panel.style.height = '';
      } else if (h > vh * 0.85) {
        panel.classList.add('panel-expanded');
        panel.style.height = '';
      } else {
        panel.classList.remove('panel-expanded');
        panel.style.height = '60vh';
      }
    }, { passive: true });
  })();

  // Click outside to close (desktop)
  document.addEventListener('click', function(e) {
    if (isOpen && !root.contains(e.target)) {
      closePanel();
    }
  });

})();
</script>
