    <LeadGen />
  </main>
  <Footer />
</Layout>

<script>
  // --- Crop card expand/collapse ---
  document.querySelectorAll('[data-crop-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const targetId = btn.getAttribute('aria-controls');
      const target = document.getElementById(targetId!);
      if (!target) return;

      // Close all others
      document.querySelectorAll('[data-crop-toggle]').forEach(other => {
        if (other !== btn) {
          other.setAttribute('aria-expanded', 'false');
          const otherId = other.getAttribute('aria-controls');
          const otherTarget = document.getElementById(otherId!);
          if (otherTarget) otherTarget.hidden = true;
        }
      });

      btn.setAttribute('aria-expanded', String(!expanded));
      target.hidden = expanded;
    });
  });

  // --- Particle system ---
  function createParticles() {
    const container = document.getElementById('ag-particles');
    if (!container) return;
    for (let i = 0; i < 20; i++) {
      const p = document.createElement('div');
      p.className = 'ag-particle';
      p.style.left = `${Math.random() * 100}%`;
      p.style.animationDelay = `${Math.random() * 6}s`;
      p.style.animationDuration = `${4 + Math.random() * 4}s`;
      p.style.opacity = `${0.2 + Math.random() * 0.5}`;
      p.style.width = p.style.height = `${2 + Math.random() * 3}px`;
      container.appendChild(p);
    }
  }

  // --- Water savings counter animation ---
  function animateCounter(el: HTMLElement, target: number, duration: number) {
    const start = performance.now();
    const initial = 0;
    function update(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(initial + (target - initial) * eased).toLocaleString();
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  // --- Yield chart line animation ---
  function animateYieldChart() {
    const line = document.querySelector('.yield-line') as SVGPathElement | null;
    const band = document.querySelector('.yield-band') as SVGPathElement | null;
    if (line) {
      const len = line.getTotalLength();
      line.style.strokeDasharray = `${len}`;
      line.style.strokeDashoffset = `${len}`;
      line.style.transition = 'stroke-dashoffset 2s cubic-bezier(0.4, 0, 0.2, 1)';
      requestAnimationFrame(() => { line.style.strokeDashoffset = '0'; });
    }
    if (band) {
      band.style.opacity = '0';
      band.style.transition = 'opacity 1.5s ease 0.5s';
      requestAnimationFrame(() => { band.style.opacity = '1'; });
    }
    document.querySelectorAll('.yield-dot').forEach((dot, i) => {
      (dot as SVGElement).style.opacity = '0';
      (dot as SVGElement).style.transition = `opacity 0.3s ease ${0.3 + i * 0.3}s`;
      requestAnimationFrame(() => { (dot as SVGElement).style.opacity = '1'; });
    });
  }

  // --- IntersectionObserver triggers ---
  const waterObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const tradEl = document.getElementById('water-trad');
        const jinkiEl = document.getElementById('water-jinki');
        const savedEl = document.getElementById('water-saved');
        if (tradEl) animateCounter(tradEl, 325000, 2000);
        if (jinkiEl) animateCounter(jinkiEl, 221000, 2000);
        if (savedEl) animateCounter(savedEl, 104000, 2500);
        waterObs.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const yieldObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        animateYieldChart();
        yieldObs.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const waterViz = document.querySelector('.water-viz');
  const yieldChart = document.querySelector('.yield-chart-wrap');
  if (waterViz) waterObs.observe(waterViz);
  if (yieldChart) yieldObs.observe(yieldChart);

  createParticles();
</script>

