---

<Layout title="Agriculture — Jinki Aerial Intelligence" description="Precision agriculture intelligence: crop health mapping, irrigation optimization, disease detection, and yield forecasting. Aerial multispectral analysis for every acre.">
  <Nav />
  <main id="main-content">

    <!-- ====== LIVING FIELD HERO ====== -->
    <section class="ag-hero" aria-label="Agriculture Intelligence">
      <div class="ag-hero-bg" aria-hidden="true">
        <div class="field-row field-row-1"></div>
        <div class="field-row field-row-2"></div>
        <div class="field-row field-row-3"></div>
        <div class="field-row field-row-4"></div>
        <div class="field-row field-row-5"></div>
        <div class="field-row field-row-6"></div>
        <div class="field-row field-row-7"></div>
        <div class="field-row field-row-8"></div>
        <div class="ag-particles" id="ag-particles"></div>
        <div class="ag-glow"></div>
      </div>

      <div class="ag-hero-inner">
        <div class="ag-hero-content reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Precision Agriculture</span>
          </div>
          <h1 class="ag-hero-title">
            Every Acre, Every Season,<br/>
            <span class="gradient-text-green">Intelligent Growth</span>
          </h1>
          <p class="ag-hero-subtitle">
            Multispectral crop analysis, irrigation optimization, and yield
            forecasting that transforms agronomic decision-making. Jinki's
            aerial intelligence replaces guesswork with field-level precision
            across your entire operation.
          </p>
          <div class="ag-hero-actions">
            <a href="#lead-gen" class="btn-premium ag-cta">Schedule Assessment</a>
            <a href="#crop-analysis" class="ag-cta-secondary">Explore Capabilities</a>
          </div>
        </div>

        <div class="ag-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <div class="ndvi-hud">
            <div class="ndvi-hud-grid"></div>
            <div class="ndvi-scan-line"></div>
            <div class="ndvi-zone-a"></div>
            <div class="ndvi-zone-b"></div>
            <div class="ndvi-zone-c"></div>
            <div class="ndvi-hud-readout">
              <div class="hud-row">
                <span class="hud-label">NDVI</span>
                <span class="hud-val" id="ndvi-val">0.84</span>
              </div>
              <div class="hud-row">
                <span class="hud-label">MOISTURE</span>
                <span class="hud-val hud-val-blue">68%</span>
              </div>
              <div class="hud-row">
                <span class="hud-label">HEALTH</span>
                <span class="hud-val hud-val-green">OPTIMAL</span>
              </div>
            </div>
            <div class="ndvi-hud-corner ndvi-corner-tl"></div>
            <div class="ndvi-hud-corner ndvi-corner-tr"></div>
            <div class="ndvi-hud-corner ndvi-corner-bl"></div>
            <div class="ndvi-hud-corner ndvi-corner-br"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== STATS BAR ====== -->
    <div class="ag-stats-bar reveal">
      <div class="ag-stats-inner">
        <div class="ag-stat">
          <span class="ag-stat-value">$6.1B</span>
          <span class="ag-stat-label">Agricultural aerial services market (2025)</span>
        </div>
        <div class="ag-stat">
          <span class="ag-stat-value">26%</span>
          <span class="ag-stat-label">Annual market growth rate</span>
        </div>
        <div class="ag-stat">
          <span class="ag-stat-value">1,000+</span>
          <span class="ag-stat-label">Acres covered per flight session</span>
        </div>
        <div class="ag-stat">
          <span class="ag-stat-value">15</span>
          <span class="ag-stat-label">Spectral bands captured simultaneously</span>
        </div>
      </div>
    </div>

    <!-- ====== INTERACTIVE CROP ANALYSIS ====== -->
    <section id="crop-analysis" class="ag-section" aria-label="Crop Analysis Capabilities">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Crop Intelligence</span>
          </div>
          <h2>Analysis Tailored to<br/><span class="gradient-text-green">Every Crop Type</span></h2>
          <p class="ag-section-subtitle">
            Each crop presents unique challenges. Our multispectral analysis is
            calibrated for the specific physiological signatures, disease vectors,
            and growth patterns of every major crop type.
          </p>
        </div>

        <div class="crop-grid">
          {cropTypes.map((crop, i) => (
            <div class={`crop-card reveal reveal-delay-${(i % 3) + 1}`}>
              <button
                class="crop-card-header"
                aria-expanded="false"
                aria-controls={`crop-detail-${i}`}
