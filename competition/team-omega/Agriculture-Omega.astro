              >
                <div class="crop-card-left">
                  <div class="crop-icon-wrap">
                    <span class="material-symbols-outlined crop-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{crop.icon}</span>
                  </div>
                  <div>
                    <h3 class="crop-name">{crop.name}</h3>
                    <span class="crop-acreage">{crop.acreage}</span>
                  </div>
                </div>
                <span class="crop-expand-icon material-symbols-outlined" aria-hidden="true">expand_more</span>
              </button>
              <div class="crop-card-body" id={`crop-detail-${i}`} hidden>
                <ul class="crop-capabilities" role="list">
                  {crop.capabilities.map(cap => (
                    <li>
                      <span class="cap-check material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
