                <!-- Main prediction line -->
                <path class="yield-line" d="M0,285 C100,268 150,245 250,200 C350,155 450,128 550,100 C600,85 650,78 700,75" />
                <!-- Actual yield dots -->
                <circle class="yield-dot yd-1" cx="0" cy="285" r="5" />
                <circle class="yield-dot yd-2" cx="140" cy="248" r="5" />
                <circle class="yield-dot yd-3" cx="280" cy="195" r="5" />
                <circle class="yield-dot yd-4" cx="420" cy="140" r="5" />
                <circle class="yield-dot yd-5" cx="560" cy="98" r="5" />
                <circle class="yield-dot yd-6" cx="700" cy="75" r="5" />
              </svg>
              <div class="yield-x-labels" aria-hidden="true">
                <span>Apr</span>
                <span>May</span>
                <span>Jun</span>
                <span>Jul</span>
                <span>Aug</span>
                <span>Sep</span>
              </div>
            </div>
          </div>
          <div class="yield-legend" aria-hidden="true">
            <div class="yield-legend-item">
              <span class="yield-legend-line"></span>
              <span>Predicted Yield (bu/acre)</span>
            </div>
            <div class="yield-legend-item">
              <span class="yield-legend-band"></span>
              <span>Confidence Interval</span>
            </div>
            <div class="yield-legend-item">
              <span class="yield-legend-dot"></span>
              <span>Aerial Assessment Points</span>
            </div>
          </div>
          <div class="yield-insight reveal reveal-delay-1">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; color: #34D399; font-size: 20px;" aria-hidden="true">insights</span>
            <p>Yield prediction accuracy improves from <strong>72%</strong> at planting to <strong>96%</strong> by late season with 6+ aerial assessments per growing cycle.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== FARMER TESTIMONIALS ====== -->
    <section class="ag-section" aria-label="Farmer Testimonials">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Results in the Field</span>
          </div>
          <h2>Trusted by Operations<br/><span class="gradient-text-green">That Feed the Region</span></h2>
        </div>

        <div class="testimonial-grid">
          {testimonials.map((t, i) => (
            <div class={`testimonial-card metallic-gloss reveal reveal-delay-${i + 1}`}>
              <div class="testimonial-quote-icon" aria-hidden="true">&ldquo;</div>
              <blockquote class="testimonial-quote">{t.quote}</blockquote>
              <div class="testimonial-divider"></div>
              <div class="testimonial-meta">
                <div class="testimonial-person">
                  <span class="testimonial-name">{t.name}</span>
                  <span class="testimonial-farm">{t.farm}</span>
                </div>
                <div class="testimonial-details">
                  <div class="testimonial-detail">
                    <span class="td-label">Location</span>
                    <span class="td-value">{t.location}</span>
                  </div>
                  <div class="testimonial-detail">
                    <span class="td-label">Operation</span>
                    <span class="td-value">{t.size}</span>
                  </div>
                  <div class="testimonial-detail">
                    <span class="td-label">Crops</span>
                    <span class="td-value">{t.crop}</span>
                  </div>
                </div>
              </div>
              <div class="testimonial-metric">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; color: #34D399; font-size: 18px;" aria-hidden="true">trending_up</span>
                <span class="testimonial-metric-text">{t.metric}</span>
              </div>
            </div>
          ))}
