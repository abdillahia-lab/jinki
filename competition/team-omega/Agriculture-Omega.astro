              <span class="water-vs-text">VS</span>
              <div class="water-vs-line"></div>
            </div>

            <div class="water-col water-col-jinki">
              <div class="water-col-header">
                <span class="water-col-label water-col-label-green">Jinki-Optimized</span>
              </div>
              <div class="water-droplet-area" aria-hidden="true">
                <div class="water-drops-jinki">
                  {Array.from({ length: 14 }).map((_, i) => (
                    <div class={`water-drop wd-jinki wd-j-${i}`} style={`animation-delay: ${(i * 0.2).toFixed(2)}s;`}></div>
