    <!-- ====== WATER SAVINGS VISUALIZER ====== -->
    <section class="ag-section ag-section-alt" aria-label="Water Savings">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Irrigation Optimization</span>
          </div>
