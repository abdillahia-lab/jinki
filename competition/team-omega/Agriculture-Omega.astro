            </div>
          </div>

          <div class="water-savings-banner reveal reveal-delay-1">
            <div class="water-savings-icon-wrap" aria-hidden="true">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 32px; color: #34D399;">water_drop</span>
            </div>
            <div class="water-savings-text">
              <span class="water-savings-number" id="water-saved">104,000</span>
              <span class="water-savings-label">gallons saved per 100 acres per season</span>
            </div>
            <div class="water-savings-pct">
              <span class="water-pct-val">32%</span>
              <span class="water-pct-label">Reduction</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ====== DISEASE DETECTION SHOWCASE ====== -->
    <section class="ag-section" aria-label="Disease Detection">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Early Warning System</span>
          </div>
          <h2>Detect Threats Before<br/><span class="gradient-text-green">They Cost You Yield</span></h2>
          <p class="ag-section-subtitle">
            Multispectral imaging detects disease onset, pest damage, and nutrient
            deficiencies days to weeks before they become visible to the naked eye.
          </p>
        </div>

        <div class="disease-grid">
          {diseases.map((d, i) => (
            <div class={`disease-card reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="disease-card-top">
                <div class="disease-name-row">
                  <h3 class="disease-name">{d.name}</h3>
                  <span class={`disease-severity sev-${d.severity.toLowerCase()}`}>{d.severity}</span>
                </div>
                <span class="disease-crop">{d.crop}</span>
              </div>
              <div class="disease-card-body">
                <div class="disease-confidence">
                  <div class="confidence-bar-bg">
                    <div class="confidence-bar-fill" style={`width: ${d.confidence}%;`} role="progressbar" aria-valuenow={d.confidence} aria-valuemin={0} aria-valuemax={100} aria-label={`Detection confidence ${d.confidence}%`}></div>
                  </div>
                  <span class="confidence-val">{d.confidence}%</span>
                </div>
                <p class="disease-indicator">{d.indicator}</p>
                {d.early && (
                  <div class="early-badge">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 14px;" aria-hidden="true">notifications_active</span>
                    <span>Early Warning Available</span>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ====== YIELD FORECAST CHART ====== -->
    <section class="ag-section ag-section-alt" aria-label="Yield Forecasting">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Yield Intelligence</span>
          </div>
          <h2>Predictions That Improve<br/><span class="gradient-text-green">With Every Flight</span></h2>
