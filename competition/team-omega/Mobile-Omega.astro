---
import '../../styles/global.css';
const title = 'Mobile — Progressive Enhancement — Team Omega | Jinki';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content="Team Omega progressive enhancement and adaptive mobile strategies for Jinki Aerial Intelligence" />
  <meta name="color-scheme" content="dark light" />
  <title>{title}</title>
  <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=dark_mode,devices,grid_view,light_mode,phone_android,phone_iphone,responsive_layout,tablet,text_fields,tune,vibration,view_quilt&display=swap" rel="stylesheet" />
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('jinki-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <style is:inline>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <header class="omm-header" role="banner">
    <div class="omm-header-inner">
      <div style="display:flex;align-items:center;gap:12px;">
        <span class="material-symbols-outlined" style="font-size:32px;color:#7B61FF;" aria-hidden="true">devices</span>
        <div>
          <h1 style="font-size:clamp(18px,3vw,24px);line-height:1.2;">Mobile &mdash; Progressive Enhancement</h1>
          <p style="font-family:var(--font-mono);font-size:12px;color:#7B61FF;letter-spacing:0.05em;">Team Omega &mdash; Round 16</p>
        </div>
      </div>
    </div>
  </header>

  <main id="main-content" role="main" style="max-width:1200px;margin:0 auto;padding:32px 24px 80px;">

    <!-- Section 1: Progressive Enhancement -->
    <section id="progressive" class="omm-section" aria-labelledby="pe-heading">
      <div class="omm-section-header">
        <span class="sec-num" aria-hidden="true">01</span>
        <h2 id="pe-heading">Progressive Enhancement</h2>
      </div>
      <div class="omm-card glass-panel" style="border-radius:16px;">
        <p class="omm-desc">Jinki works without JavaScript. Every layer adds capability without breaking the foundation.</p>

        <div class="pe-layers">
          <div class="pe-layer layer-1">
            <div class="pe-layer-header">
              <span class="pe-layer-num">Layer 1</span>
              <h3>Semantic HTML</h3>
            </div>
            <p>Content is fully accessible with zero CSS or JS. Proper heading hierarchy, landmark roles, link destinations, and form structure.</p>
            <div class="pe-check-list">
              <span class="pe-check">All content readable</span>
              <span class="pe-check">Navigation functional</span>
              <span class="pe-check">Forms submittable</span>
            </div>
          </div>
          <div class="pe-layer layer-2">
            <div class="pe-layer-header">
              <span class="pe-layer-num">Layer 2</span>
              <h3>CSS Presentation</h3>
            </div>
            <p>Visual design, responsive layout, dark/light themes, glass effects, and animations. Uses <code>@supports</code> for progressive features.</p>
            <div class="pe-check-list">
              <span class="pe-check">Responsive grid layout</span>
              <span class="pe-check">Theme support</span>
              <span class="pe-check">Reduced motion respected</span>
            </div>
          </div>
          <div class="pe-layer layer-3">
            <div class="pe-layer-header">
              <span class="pe-layer-num">Layer 3</span>
              <h3>JavaScript Enhancement</h3>
            </div>
            <p>Interactive features: theme toggle, scroll animations, counter animations, form validation, intersection observers.</p>
            <div class="pe-check-list">
              <span class="pe-check">Theme toggle</span>
              <span class="pe-check">Scroll reveals</span>
              <span class="pe-check">Counter animations</span>
            </div>
          </div>
          <div class="pe-layer layer-4">
            <div class="pe-layer-header">
              <span class="pe-layer-num">Layer 4</span>
              <h3>Platform APIs</h3>
            </div>
            <p>Service worker, push notifications, haptic feedback, share API, orientation lock. Only when supported.</p>
            <div class="pe-check-list">
              <span class="pe-check">Offline support</span>
              <span class="pe-check">Push notifications</span>
              <span class="pe-check">Haptic feedback</span>
            </div>
          </div>
        </div>

        <div class="pe-code" style="margin-top:24px;">
          <div class="code-block">
            <pre><code>/* Progressive CSS with @supports */
.glass-panel {
  background: var(--surface-container); /* base */
}

@supports (backdrop-filter: blur(24px)) {
  .glass-panel {
    backdrop-filter: blur(24px) saturate(1.8);
    background: var(--glass-bg); /* enhanced */
  }
}

/* noscript fallback */
&lt;noscript&gt;
  &lt;style&gt;.reveal { opacity: 1 !important; transform: none !important; }&lt;/style&gt;
&lt;/noscript&gt;</code></pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Responsive Typography -->
    <section id="typography" class="omm-section" aria-labelledby="typo-heading">
      <div class="omm-section-header">
        <span class="sec-num" aria-hidden="true">02</span>
        <h2 id="typo-heading">Responsive Typography Scale</h2>
      </div>
      <div class="omm-card glass-panel" style="border-radius:16px;">
        <p class="omm-desc">Fluid typography using <code>clamp()</code> ensures readable text at every viewport width without media query breakpoints.</p>

        <div class="type-scale-demo">
          <div class="type-row">
            <div class="type-meta">
              <span class="type-name">Display</span>
              <span class="type-spec">clamp(32px, 5vw + 12px, 64px)</span>
            </div>
            <div class="type-sample display-sample">Aerial Intelligence</div>
          </div>
          <div class="type-row">
            <div class="type-meta">
              <span class="type-name">H1</span>
              <span class="type-spec">clamp(28px, 4vw + 8px, 48px)</span>
            </div>
            <div class="type-sample h1-sample">Critical Infrastructure</div>
          </div>
          <div class="type-row">
            <div class="type-meta">
              <span class="type-name">H2</span>
              <span class="type-spec">clamp(22px, 3vw + 6px, 36px)</span>
            </div>
            <div class="type-sample h2-sample">Thermal Detection</div>
          </div>
          <div class="type-row">
            <div class="type-meta">
              <span class="type-name">H3</span>
              <span class="type-spec">clamp(18px, 2vw + 4px, 24px)</span>
            </div>
            <div class="type-sample h3-sample">Predictive Analytics</div>
          </div>
          <div class="type-row">
            <div class="type-meta">
              <span class="type-name">Body</span>
              <span class="type-spec">clamp(15px, 1vw + 10px, 18px)</span>
            </div>
            <div class="type-sample body-sample" style="font-family:var(--font-body);font-weight:400;line-height:1.7;">Jinki transforms aerial sensor data into prioritized maintenance recommendations for infrastructure you cannot easily reach.</div>
          </div>
          <div class="type-row">
            <div class="type-meta">
              <span class="type-name">Caption</span>
              <span class="type-spec">clamp(12px, 0.5vw + 9px, 14px)</span>
            </div>
            <div class="type-sample caption-sample" style="font-family:var(--font-mono);color:var(--text-tertiary);">DATA-CENTER-A3 // 2026-03-20 14:32 UTC</div>
          </div>
        </div>

        <div class="type-principles" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Typography Principles</h3>
          <div class="principle-grid">
            <div class="principle-card">
              <h4>Line Length</h4>
              <p>Max <code>65ch</code> for body text. Prevents eye fatigue on wide screens.</p>
            </div>
            <div class="principle-card">
              <h4>Line Height</h4>
              <p>Body: 1.7. Headings: 1.05-1.15. Tighter for large text, looser for small.</p>
            </div>
            <div class="principle-card">
              <h4>Letter Spacing</h4>
              <p>Headings: -0.02em. Labels: 0.02-0.05em. Body: default.</p>
            </div>
            <div class="principle-card">
              <h4>Minimum Size</h4>
              <p>16px body minimum prevents iOS auto-zoom. 12px absolute floor for captions.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Adaptive Layouts -->
    <section id="adaptive" class="omm-section" aria-labelledby="adapt-heading">
      <div class="omm-section-header">
        <span class="sec-num" aria-hidden="true">03</span>
        <h2 id="adapt-heading">Adaptive Layouts</h2>
      </div>
      <div class="omm-card glass-panel" style="border-radius:16px;">
        <p class="omm-desc">Not just responsive — truly adaptive. Different layout patterns for phone, tablet, and desktop.</p>

        <div class="adaptive-showcase">
          <div class="device-preview phone-preview">
            <div class="device-frame phone-frame-demo">
              <div class="device-label">
                <span class="material-symbols-outlined" style="font-size:16px;" aria-hidden="true">phone_iphone</span>
                Phone (375px)
              </div>
              <div class="device-screen">
                <div class="layout-block nav-block">Nav (hamburger)</div>
                <div class="layout-block hero-block full">Hero (stacked)</div>
                <div class="layout-block card-block full">Card</div>
                <div class="layout-block card-block full">Card</div>
                <div class="layout-block card-block full">Card</div>
                <div class="layout-block cta-block full">CTA (full width)</div>
              </div>
            </div>
          </div>

          <div class="device-preview tablet-preview">
            <div class="device-frame tablet-frame-demo">
              <div class="device-label">
                <span class="material-symbols-outlined" style="font-size:16px;" aria-hidden="true">tablet</span>
                Tablet (768px)
              </div>
              <div class="device-screen">
                <div class="layout-block nav-block">Nav (full)</div>
                <div class="layout-block hero-block full">Hero (side-by-side)</div>
                <div class="layout-row">
                  <div class="layout-block card-block">Card</div>
                  <div class="layout-block card-block">Card</div>
                </div>
                <div class="layout-row">
                  <div class="layout-block card-block">Card</div>
                  <div class="layout-block card-block">Card</div>
                </div>
                <div class="layout-block cta-block full">CTA (centered)</div>
              </div>
            </div>
          </div>

          <div class="device-preview desktop-preview">
            <div class="device-frame desktop-frame-demo">
              <div class="device-label">
                <span class="material-symbols-outlined" style="font-size:16px;" aria-hidden="true">responsive_layout</span>
                Desktop (1280px)
              </div>
              <div class="device-screen">
                <div class="layout-block nav-block">Nav (full + CTA)</div>
                <div class="layout-block hero-block full">Hero (two columns with visual)</div>
                <div class="layout-row">
                  <div class="layout-block card-block">Card</div>
                  <div class="layout-block card-block">Card</div>
                  <div class="layout-block card-block">Card</div>
                  <div class="layout-block card-block">Card</div>
                </div>
                <div class="layout-block cta-block full">CTA (contained)</div>
              </div>
            </div>
          </div>
        </div>

        <div class="breakpoint-table" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Breakpoint Strategy</h3>
          <div class="bp-table-wrap" tabindex="0" role="region" aria-label="Breakpoints table">
            <table class="bp-table">
              <thead>
                <tr>
                  <th scope="col">Breakpoint</th>
                  <th scope="col">Width</th>
                  <th scope="col">Columns</th>
                  <th scope="col">Layout</th>
                  <th scope="col">Nav Style</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Phone</td>
                  <td><code>&lt; 640px</code></td>
                  <td>1</td>
                  <td>Stacked</td>
                  <td>Hamburger</td>
                </tr>
                <tr>
                  <td>Tablet</td>
                  <td><code>640-1024px</code></td>
                  <td>2</td>
                  <td>Grid</td>
                  <td>Full nav</td>
                </tr>
                <tr>
                  <td>Desktop</td>
                  <td><code>1024-1440px</code></td>
                  <td>3-4</td>
                  <td>Multi-column</td>
                  <td>Full + CTA</td>
                </tr>
                <tr>
                  <td>Wide</td>
                  <td><code>&gt; 1440px</code></td>
                  <td>4</td>
                  <td>Max-width contained</td>
                  <td>Full + CTA</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Haptic Feedback -->
    <section id="haptics" class="omm-section" aria-labelledby="haptic-heading">
      <div class="omm-section-header">
        <span class="sec-num" aria-hidden="true">04</span>
        <h2 id="haptic-heading">Haptic Feedback Simulation</h2>
      </div>
      <div class="omm-card glass-panel" style="border-radius:16px;">
        <p class="omm-desc">Haptic feedback adds a tactile dimension to mobile interactions. Uses the Vibration API where available.</p>

        <div class="haptic-grid">
          <button class="haptic-btn" data-pattern="light" aria-label="Light tap haptic feedback">
            <span class="material-symbols-outlined" style="font-size:28px;" aria-hidden="true">vibration</span>
            <span class="haptic-name">Light Tap</span>
            <span class="haptic-pattern">[10ms]</span>
            <span class="haptic-use">Button press, toggle</span>
          </button>
          <button class="haptic-btn" data-pattern="medium" aria-label="Medium impact haptic feedback">
            <span class="material-symbols-outlined" style="font-size:28px;" aria-hidden="true">vibration</span>
            <span class="haptic-name">Medium Impact</span>
            <span class="haptic-pattern">[30ms]</span>
            <span class="haptic-use">Selection, confirm</span>
          </button>
          <button class="haptic-btn" data-pattern="heavy" aria-label="Heavy impact haptic feedback">
            <span class="material-symbols-outlined" style="font-size:28px;" aria-hidden="true">vibration</span>
            <span class="haptic-name">Heavy Impact</span>
            <span class="haptic-pattern">[50ms]</span>
            <span class="haptic-use">Error, alert</span>
          </button>
          <button class="haptic-btn" data-pattern="success" aria-label="Success pattern haptic feedback">
            <span class="material-symbols-outlined" style="font-size:28px;" aria-hidden="true">vibration</span>
            <span class="haptic-name">Success</span>
            <span class="haptic-pattern">[10, 50, 20]ms</span>
            <span class="haptic-use">Form submit, mission complete</span>
          </button>
          <button class="haptic-btn" data-pattern="warning" aria-label="Warning pattern haptic feedback">
            <span class="material-symbols-outlined" style="font-size:28px;" aria-hidden="true">vibration</span>
            <span class="haptic-name">Warning</span>
            <span class="haptic-pattern">[30, 100, 30, 100, 30]ms</span>
            <span class="haptic-use">Anomaly detected</span>
          </button>
          <button class="haptic-btn" data-pattern="error" aria-label="Error pattern haptic feedback">
            <span class="material-symbols-outlined" style="font-size:28px;" aria-hidden="true">vibration</span>
            <span class="haptic-name">Error</span>
            <span class="haptic-pattern">[50, 100, 50, 100, 50]ms</span>
            <span class="haptic-use">Validation fail, connection lost</span>
          </button>
        </div>

        <div class="haptic-status" id="haptic-status" aria-live="polite" style="margin-top:16px;font-family:var(--font-mono);font-size:13px;color:var(--text-tertiary);text-align:center;">
          Tap a button to trigger haptic feedback (requires mobile device with Vibration API)
        </div>

        <div class="code-block" style="margin-top:20px;">
          <pre><code>// Haptic feedback helper
function haptic(pattern) {
  if ('vibrate' in navigator) {
    navigator.vibrate(pattern);
  }
}

// Usage
button.addEventListener('click', () => {
  haptic([10]); // light tap
  // ... perform action
});</code></pre>
        </div>
      </div>
    </section>

    <!-- Section 5: Dark Mode Auto-Detection -->
    <section id="dark-mode" class="omm-section" aria-labelledby="dm-heading">
      <div class="omm-section-header">
        <span class="sec-num" aria-hidden="true">05</span>
        <h2 id="dm-heading">Dark Mode Auto-Detection</h2>
      </div>
      <div class="omm-card glass-panel" style="border-radius:16px;">
        <p class="omm-desc">Jinki automatically matches the user's OS preference and remembers manual overrides.</p>

        <div class="dm-flow">
          <div class="dm-step">
            <span class="dm-step-num">1</span>
            <h3>Check localStorage</h3>
            <p>If user has previously set a preference, use it immediately.</p>
          </div>
          <div class="dm-step">
            <span class="dm-step-num">2</span>
            <h3>Check OS Preference</h3>
            <p>Query <code>prefers-color-scheme</code> media feature to match system setting.</p>
          </div>
          <div class="dm-step">
            <span class="dm-step-num">3</span>
            <h3>Default to Dark</h3>
            <p>If no preference detected, default to dark theme (brand identity).</p>
          </div>
          <div class="dm-step">
            <span class="dm-step-num">4</span>
            <h3>Listen for Changes</h3>
            <p>Watch for OS-level theme changes and update in real time.</p>
          </div>
        </div>

        <div class="dm-demo" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Current State</h3>
          <div class="dm-state-grid">
            <div class="dm-state-card">
              <span class="dm-state-label">OS Preference</span>
              <span class="dm-state-value" id="dm-os-pref">Detecting...</span>
            </div>
            <div class="dm-state-card">
              <span class="dm-state-label">localStorage</span>
              <span class="dm-state-value" id="dm-local">Detecting...</span>
            </div>
            <div class="dm-state-card">
              <span class="dm-state-label">Active Theme</span>
              <span class="dm-state-value" id="dm-active">Detecting...</span>
            </div>
          </div>
        </div>

        <div class="dm-toggle-demo" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Theme Toggle (with OS sync)</h3>
          <div style="display:flex;gap:12px;align-items:center;">
            <button class="dm-btn" id="dm-light" aria-label="Switch to light mode">
              <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">light_mode</span>
              Light
            </button>
            <button class="dm-btn" id="dm-system" aria-label="Use system preference">
              <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">tune</span>
              System
            </button>
            <button class="dm-btn" id="dm-dark" aria-label="Switch to dark mode">
              <span class="material-symbols-outlined" style="font-size:20px;" aria-hidden="true">dark_mode</span>
              Dark
            </button>
          </div>
        </div>

        <div class="code-block" style="margin-top:24px;">
          <pre><code>// Theme initialization (runs before render)
(function() {
  var saved = localStorage.getItem('jinki-theme');
  if (saved) {
    document.documentElement.setAttribute('data-theme', saved);
  } else {
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
  }
})();

// Listen for OS changes
window.matchMedia('(prefers-color-scheme: dark)')
  .addEventListener('change', (e) => {
    if (!localStorage.getItem('jinki-theme')) {
      document.documentElement.setAttribute('data-theme',
        e.matches ? 'dark' : 'light');
    }
  });</code></pre>
        </div>
      </div>
    </section>
  </main>

  <style>
    .omm-header {
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 16px 24px;
    }
    .omm-header-inner { max-width: 1200px; margin: 0 auto; }
    .omm-section { margin-bottom: 48px; }
    .omm-section-header {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 20px;
    }
    .sec-num {
      font-family: var(--font-mono);
      font-size: 48px;
      font-weight: 700;
      color: #7B61FF;
      opacity: 0.25;
      line-height: 1;
    }
    .omm-section-header h2 { font-size: clamp(22px, 4vw, 32px); }
    .omm-card { padding: 32px; position: relative; z-index: 0; }
    .omm-desc {
      color: var(--text-secondary);
      font-size: 15px;
      line-height: 1.7;
      margin-bottom: 24px;
    }
    .omm-desc code {
      font-family: var(--font-mono);
      font-size: 13px;
      background: var(--surface-container);
      padding: 2px 8px;
      border-radius: 4px;
      color: #7B61FF;
    }
    .code-block {
      background: var(--surface-container-low);
      padding: 16px 20px;
      border-radius: 10px;
      overflow-x: auto;
      border: 1px solid var(--border);
    }
    .code-block pre { margin: 0; }
    .code-block code {
      font-family: var(--font-mono);
      font-size: 13px;
      color: #7B61FF;
      line-height: 1.6;
      background: transparent;
    }

    /* Progressive Enhancement */
    .pe-layers { display: grid; gap: 12px; }
    .pe-layer {
      border-radius: 12px;
      padding: 24px;
      border: 1px solid var(--border);
      position: relative;
    }
    .layer-1 { background: var(--surface-container); border-left: 3px solid var(--text-tertiary); }
    .layer-2 { background: var(--surface-container); border-left: 3px solid #ffa500; }
    .layer-3 { background: var(--surface-container); border-left: 3px solid #7B61FF; }
    .layer-4 { background: var(--surface-container); border-left: 3px solid #34d399; }
    .pe-layer-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .pe-layer-num {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      padding: 2px 8px;
      border-radius: 4px;
      background: var(--surface-container-high);
      color: var(--text-tertiary);
    }
    .pe-layer h3 { font-size: 17px; }
    .pe-layer p { font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
    .pe-layer code { font-family: var(--font-mono); font-size: 12px; color: #7B61FF; }
    .pe-check-list { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 10px; }
    .pe-check {
      font-size: 12px;
      font-family: var(--font-label);
      color: #34d399;
      background: rgba(52,211,153,0.1);
      padding: 4px 10px;
      border-radius: 6px;
    }

    /* Typography Scale */
    .type-scale-demo { display: grid; gap: 16px; }
    .type-row {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 20px;
      border: 1px solid var(--border);
    }
    .type-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .type-name {
      font-family: var(--font-label);
      font-size: 12px;
      font-weight: 700;
      color: #7B61FF;
      background: rgba(123,97,255,0.1);
      padding: 2px 8px;
      border-radius: 4px;
    }
    .type-spec { font-family: var(--font-mono); font-size: 11px; color: var(--text-tertiary); }
    .type-sample {
      font-family: var(--font-headline);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .display-sample { font-size: clamp(32px, 5vw + 12px, 64px); }
    .h1-sample { font-size: clamp(28px, 4vw + 8px, 48px); }
    .h2-sample { font-size: clamp(22px, 3vw + 6px, 36px); }
    .h3-sample { font-size: clamp(18px, 2vw + 4px, 24px); }
    .body-sample { font-size: clamp(15px, 1vw + 10px, 18px); white-space: normal; }
    .caption-sample { font-size: clamp(12px, 0.5vw + 9px, 14px); }

    .principle-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 12px;
    }
    .principle-card {
      background: var(--surface-container);
      border-radius: 10px;
      padding: 16px;
      border: 1px solid var(--border);
    }
    .principle-card h4 { font-size: 14px; margin-bottom: 4px; }
    .principle-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
    .principle-card code { font-family: var(--font-mono); font-size: 12px; color: #7B61FF; }

    /* Adaptive Layouts */
    .adaptive-showcase {
      display: grid;
      grid-template-columns: 1fr 1.5fr 2fr;
      gap: 16px;
      align-items: start;
    }
    @media (max-width: 900px) {
      .adaptive-showcase { grid-template-columns: 1fr; }
    }
    .device-frame {
      border-radius: 12px;
      border: 1px solid var(--border);
      overflow: hidden;
      background: var(--surface-container);
    }
    .device-label {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      font-family: var(--font-label);
      font-size: 12px;
      font-weight: 600;
      color: var(--text-tertiary);
      border-bottom: 1px solid var(--border);
    }
    .device-screen { padding: 10px; display: flex; flex-direction: column; gap: 6px; }
    .layout-block {
      padding: 10px 12px;
      border-radius: 6px;
      font-family: var(--font-mono);
      font-size: 10px;
      text-align: center;
      color: var(--text-tertiary);
    }
    .nav-block { background: rgba(123,97,255,0.1); border: 1px dashed rgba(123,97,255,0.3); }
    .hero-block { background: rgba(0,229,255,0.08); border: 1px dashed rgba(0,229,255,0.25); }
    .card-block { background: var(--surface-container-low); border: 1px dashed var(--border); flex: 1; }
    .cta-block { background: rgba(52,211,153,0.08); border: 1px dashed rgba(52,211,153,0.25); }
    .layout-row { display: flex; gap: 6px; }
    .layout-block.full { width: 100%; }

    .bp-table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
    .bp-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .bp-table thead th {
      text-align: left;
      padding: 12px 14px;
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-tertiary);
      background: var(--surface-container-low);
      border-bottom: 1px solid var(--border);
    }
    .bp-table td { padding: 10px 14px; color: var(--text-secondary); border-bottom: 1px solid var(--border); }
    .bp-table code { font-family: var(--font-mono); font-size: 12px; color: #7B61FF; }
    .bp-table tbody tr:last-child td { border-bottom: none; }

    /* Haptic */
    .haptic-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
    }
    .haptic-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      padding: 20px 16px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--surface-container);
      color: var(--text-primary);
      cursor: pointer;
      transition: all 0.2s;
      text-align: center;
    }
    .haptic-btn:hover { background: var(--surface-container-high); border-color: #7B61FF; }
    .haptic-btn:active { transform: scale(0.97); }
    .haptic-name { font-family: var(--font-label); font-size: 14px; font-weight: 600; }
    .haptic-pattern { font-family: var(--font-mono); font-size: 11px; color: #7B61FF; }
    .haptic-use { font-size: 11px; color: var(--text-tertiary); }

    /* Dark Mode */
    .dm-flow {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
    }
    .dm-step {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 20px;
      border: 1px solid var(--border);
    }
    .dm-step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: #7B61FF;
      color: #fff;
      font-family: var(--font-mono);
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .dm-step h3 { font-size: 15px; margin-bottom: 4px; }
    .dm-step p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; }
    .dm-step code { font-family: var(--font-mono); font-size: 12px; color: #7B61FF; }

    .dm-state-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
    }
    .dm-state-card {
      background: var(--surface-container);
      border-radius: 10px;
      padding: 16px;
      border: 1px solid var(--border);
      text-align: center;
    }
    .dm-state-label { display: block; font-family: var(--font-label); font-size: 11px; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 6px; }
    .dm-state-value { font-family: var(--font-mono); font-size: 15px; font-weight: 600; color: var(--text-primary); }

    .dm-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 18px;
      border-radius: 10px;
      border: 1px solid var(--outline-variant);
      background: var(--surface-container);
      color: var(--text-primary);
      font-family: var(--font-label);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .dm-btn:hover { background: var(--surface-container-high); }
    .dm-btn.active { background: #7B61FF; color: #fff; border-color: #7B61FF; }

    @media (max-width: 768px) {
      .omm-card { padding: 20px; }
      .sec-num { font-size: 36px; }
    }
  </style>

  <script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Haptic feedback
    var hapticBtns = document.querySelectorAll('.haptic-btn');
    var hapticStatus = document.getElementById('haptic-status');
    var patterns = {
      light: [10],
      medium: [30],
      heavy: [50],
      success: [10, 50, 20],
      warning: [30, 100, 30, 100, 30],
      error: [50, 100, 50, 100, 50]
    };

    hapticBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var name = btn.getAttribute('data-pattern');
        var pattern = patterns[name];
        if ('vibrate' in navigator) {
          navigator.vibrate(pattern);
          hapticStatus.textContent = 'Triggered: ' + name + ' [' + pattern.join(', ') + ']ms';
        } else {
          hapticStatus.textContent = 'Vibration API not supported on this device. Pattern: [' + pattern.join(', ') + ']ms';
        }
      });
    });

    // Dark mode detection
    var osPref = document.getElementById('dm-os-pref');
    var localPref = document.getElementById('dm-local');
    var activePref = document.getElementById('dm-active');

    function updateDMState() {
      var osIsDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      osPref.textContent = osIsDark ? 'Dark' : 'Light';
      localPref.textContent = localStorage.getItem('jinki-theme') || '(none)';
      activePref.textContent = document.documentElement.getAttribute('data-theme') || 'dark';
    }
    updateDMState();

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateDMState);

    // Theme buttons
    var dmBtns = [
      document.getElementById('dm-light'),
      document.getElementById('dm-system'),
      document.getElementById('dm-dark')
    ];

    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('jinki-theme', theme);
      updateDMState();
      dmBtns.forEach(function(b) { b.classList.remove('active'); });
    }

    document.getElementById('dm-light').addEventListener('click', function() {
      setTheme('light');
      this.classList.add('active');
    });
    document.getElementById('dm-dark').addEventListener('click', function() {
      setTheme('dark');
      this.classList.add('active');
    });
    document.getElementById('dm-system').addEventListener('click', function() {
      localStorage.removeItem('jinki-theme');
      var osTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', osTheme);
      updateDMState();
      this.classList.add('active');
    });
  });
  </script>
</body>
</html>
