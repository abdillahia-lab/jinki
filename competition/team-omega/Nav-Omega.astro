---
/*
  TEAM OMEGA — Orbital Navigation System
  Floating pill nav with radial mega-menu, command palette,
  mobile dock, morphing CTA, context-aware scroll tracking,
  and micro-animations. Full a11y + dark/light theme support.
*/

const navItems = [
  {
    label: 'About Us',
    icon: 'info',
    children: [
      { href: '/about/mission', label: 'Our Mission', icon: 'flag' },
      { href: '/about/team', label: 'Team', icon: 'groups' },
    ],
  },
  {
    label: 'Verticals',
    icon: 'category',
    children: [
      { href: '/verticals/data-centers', label: 'Data Centers', icon: 'dns', color: '#00E5FF' },
      { href: '/verticals/energy-grid', label: 'Energy Grid', icon: 'bolt', color: '#FF8C00' },
      { href: '/verticals/security', label: 'Security', icon: 'shield', color: '#7B61FF' },
      { href: '/verticals/agriculture', label: 'Agriculture', icon: 'eco', color: '#34D399' },
    ],
  },
  {
    label: 'Services',
    icon: 'build',
    children: [
      { href: '/services/audit', label: 'Audit', icon: 'assessment' },
      { href: '/services/deployment', label: 'Deployment', icon: 'rocket_launch' },
    ],
  },
  {
    label: 'Careers',
    icon: 'work',
    children: [
      { href: '/careers', label: 'Open Roles', icon: 'badge' },
    ],
  },
  {
    label: 'Blog',
    icon: 'article',
    badge: true,
    children: [
      { href: '/blog', label: 'Insights', icon: 'auto_stories' },
    ],
  },
];

/* All searchable pages for command palette */
const allPages = [
  { href: '/', label: 'Home', section: 'Pages' },
  { href: '/about/mission', label: 'Our Mission', section: 'About' },
  { href: '/about/team', label: 'Team', section: 'About' },
  { href: '/verticals/data-centers', label: 'Data Centers', section: 'Verticals' },
  { href: '/verticals/energy-grid', label: 'Energy Grid', section: 'Verticals' },
  { href: '/verticals/security', label: 'Security', section: 'Verticals' },
  { href: '/verticals/agriculture', label: 'Agriculture', section: 'Verticals' },
  { href: '/services/audit', label: 'Facility Intelligence Audit', section: 'Services' },
  { href: '/services/deployment', label: 'Autonomous Deployment', section: 'Services' },
  { href: '/careers', label: 'Careers', section: 'Pages' },
  { href: '/blog', label: 'Blog', section: 'Pages' },
  { href: '/privacy', label: 'Privacy Policy', section: 'Legal' },
  { href: '/terms', label: 'Terms of Service', section: 'Legal' },
  { href: '/security', label: 'Security Architecture', section: 'Legal' },
  { href: '#lead-gen', label: 'Get in Touch', section: 'Actions' },
];

/* Mobile dock items (5 main + More) */
const dockItems = [
  { label: 'Home', icon: 'home', href: '/' },
  { label: 'Verticals', icon: 'category', href: null },
  { label: 'Services', icon: 'build', href: null },
  { label: 'Blog', icon: 'article', href: '/blog', badge: true },
  { label: 'More', icon: 'more_horiz', href: null },
];
---

<!-- Floating Pill Nav -->
<header id="orbital-nav" role="banner">
  <div class="orbital-pill" id="orbital-pill">

    <!-- Logo -->
    <a href="/" class="orbital-logo" aria-label="Jinki — Home">
      <span class="material-symbols-outlined orbital-logo-icon" aria-hidden="true">radar</span>
      <span class="orbital-logo-text">Jinki</span>
    </a>

    <!-- Desktop Nav Items -->
    <nav class="orbital-links" aria-label="Main navigation" id="desktop-nav">
      {navItems.map((item, idx) => (
        <div class="orbital-item" data-nav-group={idx}>
          <button
            type="button"
            class="orbital-nav-btn"
            aria-haspopup="true"
            aria-expanded="false"
            data-dropdown-trigger={idx}
          >
            <span class="orbital-nav-label">{item.label}</span>
            {item.badge && <span class="orbital-badge" aria-label="New content"></span>}
            <span class="orbital-underline"></span>
          </button>

          {/* Radial menu for Verticals, standard dropdown for others */}
          {item.label === 'Verticals' ? (
            <div
              class="orbital-radial-menu"
              role="menu"
              aria-label={`${item.label} submenu`}
              data-dropdown-panel={idx}
            >
              <div class="radial-container">
                {item.children.map((child, ci) => (
                  <a
                    href={child.href}
                    class="radial-item"
                    role="menuitem"
                    style={`--radial-index: ${ci}; --radial-total: ${item.children.length}; --radial-color: ${child.color};`}
                    tabindex="-1"
                  >
                    <span class="radial-glow" aria-hidden="true"></span>
                    <span class="material-symbols-outlined radial-icon" aria-hidden="true">{child.icon}</span>
                    <span class="radial-label">{child.label}</span>
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <div
              class="orbital-dropdown"
              role="menu"
              aria-label={`${item.label} submenu`}
              data-dropdown-panel={idx}
            >
              {item.children.map(child => (
                <a href={child.href} class="orbital-dropdown-link" role="menuitem" tabindex="-1">
                  <span class="material-symbols-outlined orbital-dropdown-icon" aria-hidden="true">{child.icon}</span>
                  <span>{child.label}</span>
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- Actions -->
    <div class="orbital-actions">
      <!-- Cmd+K trigger -->
      <button
        type="button"
        class="orbital-search-btn"
        id="cmd-k-trigger"
        aria-label="Search (Cmd+K)"
        title="Search (Cmd+K)"
      >
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 18px;">search</span>
        <kbd class="orbital-kbd">K</kbd>
      </button>

      <!-- Theme Toggle -->
      <button
        id="orbital-theme-toggle"
        class="orbital-theme-btn"
        aria-label="Toggle dark/light mode"
        type="button"
      >
        <span class="material-symbols-outlined icon-dark" aria-hidden="true" style="font-size: 18px;">dark_mode</span>
        <span class="material-symbols-outlined icon-light" aria-hidden="true" style="font-size: 18px;">light_mode</span>
      </button>

      <!-- Morphing CTA -->
      <a href="#lead-gen" class="orbital-cta" id="orbital-cta">
        <span class="orbital-cta-text">Get in Touch</span>
      </a>
    </div>
  </div>
</header>

<!-- Command Palette -->
<div id="command-palette" class="cmd-palette-overlay" role="dialog" aria-modal="true" aria-label="Search pages" aria-hidden="true">
  <div class="cmd-palette-backdrop"></div>
  <div class="cmd-palette-container">
    <div class="cmd-palette-input-row">
      <span class="material-symbols-outlined cmd-palette-search-icon" aria-hidden="true" style="font-size: 20px;">search</span>
      <input
        type="text"
        id="cmd-palette-input"
        class="cmd-palette-input"
        placeholder="Search pages..."
        autocomplete="off"
        spellcheck="false"
        aria-label="Search pages"
      />
      <kbd class="cmd-palette-esc">Esc</kbd>
    </div>
    <div class="cmd-palette-results" id="cmd-palette-results" role="listbox" aria-label="Search results">
      <!-- Populated by JS -->
    </div>
  </div>
</div>

<!-- Mobile Bottom Dock -->
<nav class="mobile-dock" id="mobile-dock" aria-label="Mobile navigation">
  {dockItems.map((item, i) => (
    item.href ? (
      <a href={item.href} class="dock-item" data-dock-idx={i}>
        <span class="material-symbols-outlined dock-icon" aria-hidden="true">{item.icon}</span>
        <span class="dock-label">{item.label}</span>
        {item.badge && <span class="dock-badge" aria-label="New content"></span>}
      </a>
    ) : (
      <button type="button" class="dock-item" data-dock-idx={i} data-dock-trigger={item.label.toLowerCase()} aria-haspopup="true" aria-expanded="false">
        <span class="material-symbols-outlined dock-icon" aria-hidden="true">{item.icon}</span>
        <span class="dock-label">{item.label}</span>
      </button>
    )
  ))}
</nav>

<!-- Mobile Bottom Sheet -->
<div id="mobile-sheet" class="mobile-sheet" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div class="mobile-sheet-backdrop"></div>
  <div class="mobile-sheet-panel">
    <div class="mobile-sheet-handle" aria-hidden="true"><span></span></div>
    <div class="mobile-sheet-content" id="mobile-sheet-content">
      <!-- Populated by JS -->
    </div>
  </div>
</div>

<style>
  /* ================================================================
     ORBITAL NAV — SCOPED STYLES
     ================================================================ */

  /* ---- Floating Pill ---- */
  #orbital-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    pointer-events: none;
    padding: 16px 20px 0;
  }

  .orbital-pill {
    display: flex;
    align-items: center;
    pointer-events: auto;
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border: 1px solid var(--glass-border);
    border-radius: 9999px;
    box-shadow: var(--glass-shadow), 0 0 0 0 rgba(0, 229, 255, 0);
    padding: 8px 12px 8px 16px;
    transition: box-shadow 0.4s ease, border-color 0.4s ease, padding 0.3s ease, background 0.5s ease;
    max-width: 820px;
    width: auto;
    position: relative;
    overflow: visible;
  }

  .orbital-pill::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
    z-index: 1;
  }

  .orbital-pill:hover {
    box-shadow: var(--glass-shadow), 0 0 30px rgba(0, 229, 255, 0.08);
    border-color: rgba(0, 229, 255, 0.15);
  }

  :global([data-theme="light"]) .orbital-pill:hover {
    box-shadow: var(--glass-shadow), 0 0 30px rgba(0, 131, 143, 0.06);
    border-color: rgba(0, 131, 143, 0.15);
  }

  /* Scrolled state */
  .orbital-pill.scrolled {
    background: var(--nav-bg);
  }

  /* ---- Logo ---- */
  .orbital-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
    position: relative;
    z-index: 2;
  }

  .orbital-logo-icon {
    font-size: 24px;
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24;
    color: var(--accent);
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .orbital-logo:hover .orbital-logo-icon {
    transform: rotate(20deg);
  }

  .orbital-logo-text {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }

  /* ---- Desktop Nav Links ---- */
  .orbital-links {
    display: none;
    align-items: center;
    gap: 2px;
    margin: 0 8px 0 16px;
    position: relative;
    z-index: 2;
  }

  @media (min-width: 768px) {
    .orbital-links {
      display: flex;
    }
  }

  .orbital-item {
    position: relative;
  }

  .orbital-nav-btn {
    font-family: var(--font-headline);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px 12px;
    position: relative;
    transition: color 0.2s ease, transform 0.15s ease;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 9999px;
  }

  .orbital-nav-btn:hover {
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  /* Bounce micro-animation on hover */
  @media (prefers-reduced-motion: no-preference) {
    .orbital-nav-btn:hover {
      animation: orbital-bounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
  }

  @keyframes orbital-bounce {
    0% { transform: translateY(0); }
    40% { transform: translateY(-3px); }
    70% { transform: translateY(-1px); }
    100% { transform: translateY(-1px); }
  }

  /* Sliding underline for active state */
  .orbital-underline {
    position: absolute;
    bottom: 2px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 60%;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
  }

  .orbital-nav-btn.active .orbital-underline,
  .orbital-nav-btn[aria-expanded="true"] .orbital-underline {
    transform: translateX(-50%) scaleX(1);
  }

  /* Notification badge */
  .orbital-badge {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FF4444;
    display: inline-block;
    position: relative;
    top: -4px;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .orbital-badge {
      animation: badge-pulse 2s ease-in-out infinite;
    }
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.3); }
  }

  /* ---- Standard Dropdown ---- */
  .orbital-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    min-width: 180px;
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
    padding: 6px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 100;
  }

  .orbital-dropdown.open {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .orbital-dropdown-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.15s ease;
  }

  .orbital-dropdown-link:hover,
  .orbital-dropdown-link:focus-visible {
    color: var(--text-primary);
    background: var(--surface-container-high);
    transform: translateX(2px);
    outline: none;
  }

  .orbital-dropdown-icon {
    font-size: 18px;
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 18;
    opacity: 0.6;
  }

  /* ---- Radial Menu (Verticals) ---- */
  .orbital-radial-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%);
    width: 340px;
    height: 200px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    z-index: 100;
    pointer-events: none;
  }

  .orbital-radial-menu.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .radial-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .radial-item {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 14px;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    opacity: 0;
    transform: scale(0.7) translateY(10px);
    overflow: hidden;
  }

  .orbital-radial-menu.open .radial-item {
    opacity: 1;
    transform: scale(1) translateY(0);
  }

  /* Position items in a semi-arc layout */
  .radial-item:nth-child(1) { left: 0; top: 10px; transition-delay: 0.05s; }
  .radial-item:nth-child(2) { left: 85px; top: 0; transition-delay: 0.1s; }
  .radial-item:nth-child(3) { left: 170px; top: 0; transition-delay: 0.15s; }
  .radial-item:nth-child(4) { left: 255px; top: 10px; transition-delay: 0.2s; }

  .orbital-radial-menu.open .radial-item:nth-child(1) { transition-delay: 0.05s; }
  .orbital-radial-menu.open .radial-item:nth-child(2) { transition-delay: 0.1s; }
  .orbital-radial-menu.open .radial-item:nth-child(3) { transition-delay: 0.15s; }
  .orbital-radial-menu.open .radial-item:nth-child(4) { transition-delay: 0.2s; }

  .radial-glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(circle at center, var(--radial-color), transparent 70%);
    z-index: 0;
  }

  .radial-item:hover .radial-glow,
  .radial-item:focus-visible .radial-glow {
    opacity: 0.15;
  }

  .radial-item:hover,
  .radial-item:focus-visible {
    border-color: var(--radial-color);
    box-shadow: 0 0 20px color-mix(in srgb, var(--radial-color) 25%, transparent);
    transform: scale(1.05) translateY(-2px);
    outline: none;
  }

  .radial-icon {
    font-size: 22px;
    color: var(--radial-color);
    position: relative;
    z-index: 1;
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 22;
  }

  .radial-label {
    font-family: var(--font-headline);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    white-space: nowrap;
    position: relative;
    z-index: 1;
  }

  /* ---- Actions area ---- */
  .orbital-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }

  /* Search / Cmd+K button */
  .orbital-search-btn {
    display: none;
    align-items: center;
    gap: 4px;
    padding: 6px 10px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: var(--font-body);
  }

  @media (min-width: 768px) {
    .orbital-search-btn {
      display: flex;
    }
  }

  .orbital-search-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }

  .orbital-kbd {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    padding: 1px 5px;
    background: var(--surface-container-high);
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--text-tertiary);
    line-height: 1.4;
  }

  /* Theme toggle */
  .orbital-theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 9999px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .orbital-theme-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  .orbital-theme-btn:active {
    transform: scale(0.9);
  }

  .icon-light { display: none; }
  :global([data-theme="light"]) .icon-dark { display: none; }
  :global([data-theme="light"]) .icon-light { display: inline-block; }

  /* ---- Morphing CTA ---- */
  .orbital-cta {
    display: none;
    align-items: center;
    padding: 8px 20px;
    font-family: var(--font-headline);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    border-radius: 9999px;
    position: relative;
    overflow: hidden;
    transition:
      border-radius 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.2s ease;
    box-shadow: 0 2px 12px rgba(0, 229, 255, 0.3), inset 0 1px 0 rgba(255,255,255,0.2);
  }

  @media (min-width: 1024px) {
    .orbital-cta {
      display: inline-flex;
    }
  }

  /* Morph: pill -> rounded square on hover */
  .orbital-cta:hover {
    border-radius: 12px;
    background: linear-gradient(135deg, #33ecff 0%, #00c4d4 50%, #007a8a 100%);
    box-shadow: 0 4px 24px rgba(0, 229, 255, 0.4), 0 0 60px rgba(0, 229, 255, 0.12), inset 0 1px 0 rgba(255,255,255,0.25);
    transform: translateY(-1px);
  }

  .orbital-cta::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 50%;
    background: linear-gradient(to bottom, rgba(255,255,255,0.15), transparent);
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
  }

  .orbital-cta:active {
    transform: scale(0.97);
  }

  :global([data-theme="light"]) .orbital-cta {
    background: #00838f;
    box-shadow: 0 0 20px rgba(0, 131, 143, 0.2);
  }

  :global([data-theme="light"]) .orbital-cta:hover {
    background: #00969e;
    box-shadow: 0 0 30px rgba(0, 131, 143, 0.3);
  }

  .orbital-cta-text {
    position: relative;
    z-index: 2;
  }

  /* ================================================================
     COMMAND PALETTE
     ================================================================ */
  .cmd-palette-overlay {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 80px 20px 20px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
  }

  .cmd-palette-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .cmd-palette-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  :global([data-theme="light"]) .cmd-palette-backdrop {
    background: rgba(0, 0, 0, 0.3);
  }

  .cmd-palette-container {
    position: relative;
    width: 100%;
    max-width: 520px;
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    box-shadow: var(--glass-shadow), 0 0 60px rgba(0, 229, 255, 0.08);
    overflow: hidden;
    transform: translateY(-8px) scale(0.98);
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .cmd-palette-overlay.open .cmd-palette-container {
    transform: translateY(0) scale(1);
  }

  .cmd-palette-input-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
  }

  .cmd-palette-search-icon {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .cmd-palette-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-primary);
    caret-color: var(--accent);
  }

  .cmd-palette-input::placeholder {
    color: var(--text-tertiary);
  }

  .cmd-palette-esc {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    padding: 2px 6px;
    background: var(--surface-container-high);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .cmd-palette-results {
    max-height: 320px;
    overflow-y: auto;
    padding: 6px;
  }

  .cmd-palette-results:empty::before {
    content: 'Type to search...';
    display: block;
    padding: 24px 16px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  .cmd-result-section {
    font-family: var(--font-headline);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    padding: 10px 12px 4px;
  }

  .cmd-result-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.1s ease;
  }

  .cmd-result-item:hover,
  .cmd-result-item.active {
    background: var(--surface-container-high);
    color: var(--text-primary);
  }

  .cmd-result-item.active {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  /* ================================================================
     MOBILE DOCK (shown < 768px)
     ================================================================ */
  .mobile-dock {
    display: flex;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border-top: 1px solid var(--glass-border);
    justify-content: space-around;
    align-items: center;
    padding: 6px 0 env(safe-area-inset-bottom, 6px);
  }

  @media (min-width: 768px) {
    .mobile-dock {
      display: none;
    }
  }

  .dock-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 8px 12px;
    background: transparent;
    border: none;
    color: var(--text-tertiary);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.2s ease, transform 0.15s ease;
    position: relative;
    font-family: var(--font-body);
    -webkit-tap-highlight-color: transparent;
  }

  .dock-item:active {
    transform: scale(0.9);
  }

  .dock-item.active {
    color: var(--accent);
  }

  .dock-icon {
    font-size: 22px;
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 22;
    transition: font-variation-settings 0.2s ease;
  }

  .dock-item.active .dock-icon {
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 22;
  }

  .dock-label {
    font-size: 0.5625rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .dock-badge {
    position: absolute;
    top: 4px;
    right: 8px;
    width: 6px;
    height: 6px;
    background: #FF4444;
    border-radius: 50%;
  }

  /* ================================================================
     MOBILE SHEET
     ================================================================ */
  .mobile-sheet {
    position: fixed;
    inset: 0;
    z-index: 1001;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0.25s ease;
  }

  .mobile-sheet.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-sheet-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .mobile-sheet-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg-elevated);
    border-radius: 20px 20px 0 0;
    max-height: 70vh;
    overflow-y: auto;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    padding: 0 16px 16px;
    padding-bottom: calc(16px + env(safe-area-inset-bottom, 0px));
  }

  .mobile-sheet.open .mobile-sheet-panel {
    transform: translateY(0);
  }

  .mobile-sheet-handle {
    display: flex;
    justify-content: center;
    padding: 10px 0 6px;
  }

  .mobile-sheet-handle span {
    display: block;
    width: 36px;
    height: 4px;
    background: var(--text-tertiary);
    border-radius: 2px;
    opacity: 0.4;
  }

  .mobile-sheet-content {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sheet-section-title {
    font-family: var(--font-headline);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    padding: 14px 12px 6px;
  }

  .sheet-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 12px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    border-radius: 12px;
    transition: background 0.15s ease;
  }

  .sheet-link:hover,
  .sheet-link:active {
    background: var(--surface-container-high);
  }

  .sheet-link-icon {
    font-size: 20px;
    color: var(--accent);
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 20;
  }

  .sheet-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 24px;
    margin: 8px 0 0;
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    color: #fff;
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    border-radius: 14px;
    box-shadow: 0 2px 12px rgba(0, 229, 255, 0.3);
  }

  /* ---- Hide desktop pill items on mobile ---- */
  @media (max-width: 767px) {
    .orbital-pill {
      padding: 8px 12px;
    }

    .orbital-cta,
    .orbital-search-btn {
      display: none !important;
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .orbital-nav-btn:hover {
      animation: none;
      transform: none;
    }
    .orbital-badge {
      animation: none;
    }
    .orbital-cta {
      transition: none;
    }
    .radial-item {
      transition-duration: 0.01ms;
    }
    .cmd-palette-container {
      transition: none;
    }
    .mobile-sheet-panel {
      transition: none;
    }
  }
</style>

<script is:inline>
(function () {
  /* ================================================================
     ORBITAL NAV — Runtime Script
     ================================================================ */

  var pill = document.getElementById('orbital-pill');
  var desktopNav = document.getElementById('desktop-nav');
  var allPages = [
    { href: '/', label: 'Home', section: 'Pages' },
    { href: '/about/mission', label: 'Our Mission', section: 'About' },
    { href: '/about/team', label: 'Team', section: 'About' },
    { href: '/verticals/data-centers', label: 'Data Centers', section: 'Verticals' },
    { href: '/verticals/energy-grid', label: 'Energy Grid', section: 'Verticals' },
    { href: '/verticals/security', label: 'Security', section: 'Verticals' },
    { href: '/verticals/agriculture', label: 'Agriculture', section: 'Verticals' },
    { href: '/services/audit', label: 'Facility Intelligence Audit', section: 'Services' },
    { href: '/services/deployment', label: 'Autonomous Deployment', section: 'Services' },
    { href: '/careers', label: 'Careers', section: 'Pages' },
    { href: '/blog', label: 'Blog', section: 'Pages' },
    { href: '/privacy', label: 'Privacy Policy', section: 'Legal' },
    { href: '/terms', label: 'Terms of Service', section: 'Legal' },
    { href: '/security', label: 'Security Architecture', section: 'Legal' },
    { href: '#lead-gen', label: 'Get in Touch', section: 'Actions' }
  ];

  var navItemData = [
    {
      label: 'About Us',
      children: [
        { href: '/about/mission', label: 'Our Mission', icon: 'flag' },
        { href: '/about/team', label: 'Team', icon: 'groups' }
      ]
    },
    {
      label: 'Verticals',
      children: [
        { href: '/verticals/data-centers', label: 'Data Centers', icon: 'dns', color: '#00E5FF' },
        { href: '/verticals/energy-grid', label: 'Energy Grid', icon: 'bolt', color: '#FF8C00' },
        { href: '/verticals/security', label: 'Security', icon: 'shield', color: '#7B61FF' },
        { href: '/verticals/agriculture', label: 'Agriculture', icon: 'eco', color: '#34D399' }
      ]
    },
    {
      label: 'Services',
      children: [
        { href: '/services/audit', label: 'Audit', icon: 'assessment' },
        { href: '/services/deployment', label: 'Deployment', icon: 'rocket_launch' }
      ]
    },
    {
      label: 'Careers',
      children: [
        { href: '/careers', label: 'Open Roles', icon: 'badge' }
      ]
    },
    {
      label: 'Blog',
      children: [
        { href: '/blog', label: 'Insights', icon: 'auto_stories' }
      ]
    }
  ];

  /* ---- Scroll: solid pill on scroll ---- */
  function updateScroll() {
    if (window.scrollY > 50) {
      pill.classList.add('scrolled');
    } else {
      pill.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();

  /* ---- Context-aware: track scroll position ---- */
  var sectionIds = ['hero', 'verticals', 'services', 'about', 'blog', 'lead-gen', 'careers'];
  var navBtns = desktopNav ? desktopNav.querySelectorAll('.orbital-nav-btn') : [];

  function updateActiveSection() {
    var scrollY = window.scrollY + 200;
    var activeIdx = -1;

    sectionIds.forEach(function (id) {
      var el = document.getElementById(id);
      if (el && el.offsetTop <= scrollY) {
        // Map section IDs to nav indices
        if (id === 'about') activeIdx = 0;
        else if (id === 'verticals') activeIdx = 1;
        else if (id === 'services') activeIdx = 2;
        else if (id === 'careers') activeIdx = 3;
        else if (id === 'blog') activeIdx = 4;
      }
    });

    navBtns.forEach(function (btn, i) {
      if (i === activeIdx) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });

    // Also update mobile dock
    var dockItems = document.querySelectorAll('.dock-item');
    dockItems.forEach(function (item) { item.classList.remove('active'); });
    var path = window.location.pathname;
    dockItems.forEach(function (item) {
      var href = item.getAttribute('href');
      if (href === path || (href === '/' && path === '/')) {
        item.classList.add('active');
      }
    });
  }

  window.addEventListener('scroll', updateActiveSection, { passive: true });
  updateActiveSection();

  /* ---- Desktop Dropdowns ---- */
  var openDropdown = null;

  function closeAllDropdowns() {
    document.querySelectorAll('[data-dropdown-panel]').forEach(function (p) {
      p.classList.remove('open');
    });
    document.querySelectorAll('[data-dropdown-trigger]').forEach(function (t) {
      t.setAttribute('aria-expanded', 'false');
    });
    openDropdown = null;
  }

  document.querySelectorAll('[data-dropdown-trigger]').forEach(function (trigger) {
    var idx = trigger.getAttribute('data-dropdown-trigger');
    var panel = document.querySelector('[data-dropdown-panel="' + idx + '"]');
    if (!panel) return;

    var parentItem = trigger.closest('.orbital-item');

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = panel.classList.contains('open');
      closeAllDropdowns();
      if (!isOpen) {
        panel.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
        openDropdown = panel;
        // Focus first link
        var firstLink = panel.querySelector('a');
        if (firstLink) firstLink.focus();
      }
    });

    // Hover open/close on desktop
    var hoverTimeout;
    parentItem.addEventListener('mouseenter', function () {
      clearTimeout(hoverTimeout);
      closeAllDropdowns();
      panel.classList.add('open');
      trigger.setAttribute('aria-expanded', 'true');
      openDropdown = panel;
    });

    parentItem.addEventListener('mouseleave', function () {
      hoverTimeout = setTimeout(function () {
        panel.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
        if (openDropdown === panel) openDropdown = null;
      }, 150);
    });
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', function (e) {
    if (openDropdown && !e.target.closest('.orbital-item')) {
      closeAllDropdowns();
    }
  });

  /* ---- Keyboard Navigation for Dropdowns ---- */
  document.querySelectorAll('[data-dropdown-trigger]').forEach(function (trigger) {
    var idx = trigger.getAttribute('data-dropdown-trigger');
    var panel = document.querySelector('[data-dropdown-panel="' + idx + '"]');
    if (!panel) return;

    trigger.addEventListener('keydown', function (e) {
      var links = panel.querySelectorAll('a');
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
        e.preventDefault();
        closeAllDropdowns();
        panel.classList.add('open');
        trigger.setAttribute('aria-expanded', 'true');
        openDropdown = panel;
        if (links.length) links[0].focus();
      }
      if (e.key === 'Escape') {
        closeAllDropdowns();
        trigger.focus();
      }
      // Arrow left/right to move between nav items
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        var allTriggers = Array.from(document.querySelectorAll('[data-dropdown-trigger]'));
        var curIdx = allTriggers.indexOf(trigger);
        if (curIdx < allTriggers.length - 1) {
          closeAllDropdowns();
          allTriggers[curIdx + 1].focus();
        }
      }
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        var allTriggers2 = Array.from(document.querySelectorAll('[data-dropdown-trigger]'));
        var curIdx2 = allTriggers2.indexOf(trigger);
        if (curIdx2 > 0) {
          closeAllDropdowns();
          allTriggers2[curIdx2 - 1].focus();
        }
      }
    });

    var links = panel.querySelectorAll('a');
    links.forEach(function (link, i) {
      link.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (i < links.length - 1) links[i + 1].focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          if (i > 0) links[i - 1].focus();
          else trigger.focus();
        } else if (e.key === 'Escape') {
          closeAllDropdowns();
          trigger.focus();
        } else if (e.key === 'Tab' && !e.shiftKey && i === links.length - 1) {
          closeAllDropdowns();
        }
      });
    });

    // Close on focus out
    trigger.closest('.orbital-item').addEventListener('focusout', function (e) {
      setTimeout(function () {
        var item = trigger.closest('.orbital-item');
        if (!item.contains(document.activeElement)) {
          panel.classList.remove('open');
          trigger.setAttribute('aria-expanded', 'false');
          if (openDropdown === panel) openDropdown = null;
        }
      }, 0);
    });
  });

  /* ---- Theme Toggle ---- */
  var themeToggle = document.getElementById('orbital-theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', function () {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('jinki-theme', next);
      themeToggle.style.transform = 'rotate(180deg) scale(0.85)';
      setTimeout(function () { themeToggle.style.transform = ''; }, 300);
    });
  }

  /* ================================================================
     COMMAND PALETTE
     ================================================================ */
  var cmdOverlay = document.getElementById('command-palette');
  var cmdInput = document.getElementById('cmd-palette-input');
  var cmdResults = document.getElementById('cmd-palette-results');
  var cmdActiveIndex = -1;

  function openCommandPalette() {
    cmdOverlay.classList.add('open');
    cmdOverlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    cmdInput.value = '';
    renderResults('');
    cmdActiveIndex = -1;
    setTimeout(function () { cmdInput.focus(); }, 50);
  }

  function closeCommandPalette() {
    cmdOverlay.classList.remove('open');
    cmdOverlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function fuzzyMatch(query, text) {
    query = query.toLowerCase();
    text = text.toLowerCase();
    if (!query) return true;
    // Simple substring match
    return text.indexOf(query) !== -1;
  }

  function renderResults(query) {
    var filtered = allPages.filter(function (p) {
      return fuzzyMatch(query, p.label) || fuzzyMatch(query, p.section);
    });

    cmdResults.innerHTML = '';
    if (filtered.length === 0) {
      cmdResults.innerHTML = '<div style="padding: 24px 16px; text-align: center; font-size: 0.8125rem; color: var(--text-tertiary); font-family: var(--font-body);">No results found</div>';
      return;
    }

    // Group by section
    var sections = {};
    filtered.forEach(function (p) {
      if (!sections[p.section]) sections[p.section] = [];
      sections[p.section].push(p);
    });

    var index = 0;
    Object.keys(sections).forEach(function (sectionName) {
      var heading = document.createElement('div');
      heading.className = 'cmd-result-section';
      heading.textContent = sectionName;
      cmdResults.appendChild(heading);

      sections[sectionName].forEach(function (page) {
        var link = document.createElement('a');
        link.href = page.href;
        link.className = 'cmd-result-item';
        link.setAttribute('role', 'option');
        link.setAttribute('data-cmd-index', index);
        link.textContent = page.label;
        link.addEventListener('click', function () {
          closeCommandPalette();
        });
        cmdResults.appendChild(link);
        index++;
      });
    });
  }

  function updateCmdActive() {
    var items = cmdResults.querySelectorAll('.cmd-result-item');
    items.forEach(function (item, i) {
      if (i === cmdActiveIndex) {
        item.classList.add('active');
        item.scrollIntoView({ block: 'nearest' });
      } else {
        item.classList.remove('active');
      }
    });
  }

  if (cmdInput) {
    cmdInput.addEventListener('input', function () {
      renderResults(cmdInput.value);
      cmdActiveIndex = -1;
    });

    cmdInput.addEventListener('keydown', function (e) {
      var items = cmdResults.querySelectorAll('.cmd-result-item');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        cmdActiveIndex = Math.min(cmdActiveIndex + 1, items.length - 1);
        updateCmdActive();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        cmdActiveIndex = Math.max(cmdActiveIndex - 1, 0);
        updateCmdActive();
      } else if (e.key === 'Enter') {
        e.preventDefault();
        if (cmdActiveIndex >= 0 && items[cmdActiveIndex]) {
          items[cmdActiveIndex].click();
        }
      } else if (e.key === 'Escape') {
        closeCommandPalette();
      }
    });
  }

  // Cmd+K / Ctrl+K to open
  document.addEventListener('keydown', function (e) {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (cmdOverlay.classList.contains('open')) {
        closeCommandPalette();
      } else {
        openCommandPalette();
      }
    }
    // Escape to close any open dropdown
    if (e.key === 'Escape') {
      if (cmdOverlay.classList.contains('open')) {
        closeCommandPalette();
      } else {
        closeAllDropdowns();
      }
    }
  });

  // Cmd+K button click
  var cmdKTrigger = document.getElementById('cmd-k-trigger');
  if (cmdKTrigger) {
    cmdKTrigger.addEventListener('click', openCommandPalette);
  }

  // Click backdrop to close
  var cmdBackdrop = cmdOverlay.querySelector('.cmd-palette-backdrop');
  if (cmdBackdrop) {
    cmdBackdrop.addEventListener('click', closeCommandPalette);
  }

  /* ================================================================
     MOBILE DOCK + BOTTOM SHEET
     ================================================================ */
  var mobileSheet = document.getElementById('mobile-sheet');
  var sheetContent = document.getElementById('mobile-sheet-content');
  var sheetBackdrop = mobileSheet ? mobileSheet.querySelector('.mobile-sheet-backdrop') : null;
  var activeDockTrigger = null;

  function openSheet(category) {
    if (!mobileSheet || !sheetContent) return;

    sheetContent.innerHTML = '';
    var items = [];
    var title = '';

    if (category === 'verticals') {
      title = 'Verticals';
      items = navItemData[1].children;
    } else if (category === 'services') {
      title = 'Services';
      items = navItemData[2].children;
    } else if (category === 'more') {
      title = 'More';
      items = [].concat(
        navItemData[0].children.map(function (c) { return Object.assign({}, c, { section: 'About Us' }); }),
        navItemData[3].children.map(function (c) { return Object.assign({}, c, { section: 'Careers' }); })
      );

      // Add CTA
      var ctaLink = document.createElement('a');
      ctaLink.href = '#lead-gen';
      ctaLink.className = 'sheet-cta';
      ctaLink.textContent = 'Get in Touch';
      ctaLink.addEventListener('click', function () { closeSheet(); });

      // Build "More" sheet with section headers
      var aboutTitle = document.createElement('div');
      aboutTitle.className = 'sheet-section-title';
      aboutTitle.textContent = 'About Us';
      sheetContent.appendChild(aboutTitle);

      navItemData[0].children.forEach(function (child) {
        appendSheetLink(child);
      });

      var careersTitle = document.createElement('div');
      careersTitle.className = 'sheet-section-title';
      careersTitle.textContent = 'Careers';
      sheetContent.appendChild(careersTitle);

      navItemData[3].children.forEach(function (child) {
        appendSheetLink(child);
      });

      sheetContent.appendChild(ctaLink);
      showSheet();
      return;
    }

    if (title) {
      var heading = document.createElement('div');
      heading.className = 'sheet-section-title';
      heading.textContent = title;
      sheetContent.appendChild(heading);
    }

    items.forEach(function (child) {
      appendSheetLink(child);
    });

    showSheet();
  }

  function appendSheetLink(child) {
    var a = document.createElement('a');
    a.href = child.href;
    a.className = 'sheet-link';
    a.innerHTML = '<span class="material-symbols-outlined sheet-link-icon" aria-hidden="true">' + (child.icon || 'arrow_forward') + '</span><span>' + child.label + '</span>';
    a.addEventListener('click', function () { closeSheet(); });
    sheetContent.appendChild(a);
  }

  function showSheet() {
    mobileSheet.classList.add('open');
    mobileSheet.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeSheet() {
    if (!mobileSheet) return;
    mobileSheet.classList.remove('open');
    mobileSheet.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    if (activeDockTrigger) {
      activeDockTrigger.setAttribute('aria-expanded', 'false');
      activeDockTrigger = null;
    }
  }

  // Dock button triggers
  document.querySelectorAll('[data-dock-trigger]').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var category = btn.getAttribute('data-dock-trigger');
      activeDockTrigger = btn;
      btn.setAttribute('aria-expanded', 'true');
      openSheet(category);
    });
  });

  // Close sheet on backdrop click
  if (sheetBackdrop) {
    sheetBackdrop.addEventListener('click', closeSheet);
  }

  // Close sheet on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && mobileSheet && mobileSheet.classList.contains('open')) {
      closeSheet();
    }
  });

})();
</script>
