              </rect>
              <rect class="bar bar-2" x="27" y="80" width="16" height="0" fill="#7B61FF" rx="2" opacity="0.9">
                <animate attributeName="height" from="0" to="65" dur="0.6s" fill="freeze" begin="indefinite"/>
                <animate attributeName="y" from="80" to="15" dur="0.6s" fill="freeze" begin="indefinite"/>
              </rect>
              <rect class="bar bar-3" x="49" y="80" width="16" height="0" fill="#34D399" rx="2" opacity="0.9">
                <animate attributeName="height" from="0" to="35" dur="0.6s" fill="freeze" begin="indefinite"/>
