              </rect>
              <rect class="bar bar-4" x="71" y="80" width="16" height="0" fill="#FF8C00" rx="2" opacity="0.9">
                <animate attributeName="height" from="0" to="55" dur="0.6s" fill="freeze" begin="indefinite"/>
