---
/**
 * Animations-Omega.astro — Interaction Patterns Showcase
 * TEAM OMEGA | Jinki Aerial Intelligence
 *
 * 8 interactive cards, 6 transition concepts, 6 text effects, 4 SVG animations
 * Dark/light theme aware. Respects prefers-reduced-motion.
 */
---

<section class="omega-animations" id="animations-omega" style="padding: 80px 0; position: relative; overflow: hidden;">
  <div style="max-width: 1280px; margin: 0 auto; padding: 0 24px;">

    <!-- ============================================================
         SECTION HEADER
         ============================================================ -->
    <header style="text-align: center; margin-bottom: 64px;">
      <span class="omega-label" style="display: inline-block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; padding: 6px 16px; border: 1px solid var(--accent); border-radius: 100px;">Motion Design System</span>
      <h2 style="font-family: var(--font-headline); font-size: clamp(2rem, 5vw, 3.5rem); color: var(--text-primary); margin-bottom: 16px; letter-spacing: -0.03em;">
        Interaction <span style="background: linear-gradient(135deg, var(--accent), #7B61FF); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Patterns</span>
      </h2>
      <p style="font-family: var(--font-body); color: var(--text-secondary); font-size: 1.125rem; max-width: 600px; margin: 0 auto;">Every surface responds. Every element breathes. Micro-interactions that make intelligence feel alive.</p>
    </header>

    <!-- ============================================================
         1. CARD INTERACTION GALLERY — 8 unique cards
         ============================================================ -->
    <div style="margin-bottom: 96px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">Card Interactions</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Hover and move your cursor over each card to activate the effect.</p>

      <div class="card-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">

        <!-- Card 1: Spotlight -->
        <div class="interaction-card spotlight-card" data-effect="spotlight" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: border-color 0.3s ease;">
          <div class="spotlight-layer" style="position: absolute; inset: 0; opacity: 0; transition: opacity 0.3s ease; pointer-events: none; z-index: 1;"></div>
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: var(--accent); margin-bottom: 12px;">highlight</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Spotlight</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">Radial gradient follows your cursor, illuminating the surface beneath.</p>
          </div>
        </div>

        <!-- Card 2: Tilt -->
        <div class="interaction-card tilt-card" data-effect="tilt" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: transform 0.15s ease-out, border-color 0.3s ease; transform-style: preserve-3d; perspective: 800px;">
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: #7B61FF; margin-bottom: 12px;">view_in_ar</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">3D Tilt</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">Card tilts in 3D space, responding to mouse position with perspective transforms.</p>
          </div>
        </div>

        <!-- Card 3: Clip Reveal -->
        <div class="interaction-card reveal-card" data-effect="reveal" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: border-color 0.3s ease;">
          <div class="reveal-overlay" style="position: absolute; inset: 0; background: linear-gradient(135deg, var(--accent), #7B61FF); clip-path: circle(0% at 50% 50%); transition: clip-path 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); z-index: 1; pointer-events: none;"></div>
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: #34D399; margin-bottom: 12px;">visibility</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Clip Reveal</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">A circle expands from your cursor position, revealing a hidden layer beneath.</p>
          </div>
        </div>

        <!-- Card 4: Depth Shadow -->
        <div class="interaction-card depth-card" data-effect="depth" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: box-shadow 0.2s ease, border-color 0.3s ease;">
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: #FF8C00; margin-bottom: 12px;">layers</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Depth Shadow</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">Shadow direction shifts with your cursor, creating a floating depth illusion.</p>
          </div>
        </div>

        <!-- Card 5: Color Shift -->
        <div class="interaction-card colorshift-card" data-effect="colorshift" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; border: 1px solid var(--border); transition: border-color 0.3s ease;">
          <div class="colorshift-bg" style="position: absolute; inset: 0; background: linear-gradient(135deg, var(--accent), #7B61FF, #FF8C00, #34D399); background-size: 300% 300%; animation: colorShiftIdle 8s ease infinite; z-index: 0; opacity: 0.15; transition: opacity 0.4s ease;"></div>
          <div style="position: absolute; inset: 0; background: var(--bg-card); z-index: 0;"></div>
          <div class="colorshift-bg" style="position: absolute; inset: 0; background: linear-gradient(135deg, var(--accent), #7B61FF, #FF8C00, #34D399); background-size: 300% 300%; animation: colorShiftIdle 8s ease infinite; z-index: 1; opacity: 0; transition: opacity 0.4s ease; pointer-events: none;"></div>
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: #FF6B35; margin-bottom: 12px;">palette</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Color Shift</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">Gradient hue rotates dynamically on hover, cycling through the brand palette.</p>
          </div>
        </div>

        <!-- Card 6: Scanline -->
        <div class="interaction-card scanline-card" data-effect="scanline" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: border-color 0.3s ease;">
          <div class="scanline-beam" style="position: absolute; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent); box-shadow: 0 0 20px var(--accent), 0 0 60px rgba(0,229,255,0.3); top: -2px; opacity: 0; z-index: 3; pointer-events: none;"></div>
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: var(--accent); margin-bottom: 12px;">document_scanner</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Scanline</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">A horizontal beam sweeps across the card on hover, evoking aerial sensor scans.</p>
          </div>
        </div>

        <!-- Card 7: Data Rain -->
        <div class="interaction-card datarain-card" data-effect="datarain" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: border-color 0.3s ease;">
          <canvas class="datarain-canvas" style="position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0; transition: opacity 0.5s ease; z-index: 1; pointer-events: none;"></canvas>
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: #34D399; margin-bottom: 12px;">data_array</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Data Rain</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">Matrix-style cascading characters stream behind the card content on hover.</p>
          </div>
        </div>

        <!-- Card 8: Thermal Glow -->
        <div class="interaction-card thermal-card" data-effect="thermal" style="position: relative; height: 260px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border); transition: border-color 0.3s ease;">
          <div class="thermal-layer" style="position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 50%, rgba(255,0,0,0.3) 0%, rgba(255,165,0,0.2) 30%, rgba(0,0,255,0.15) 60%, transparent 80%); opacity: 0; transition: opacity 0.5s ease; z-index: 1; pointer-events: none; mix-blend-mode: screen;"></div>
          <div style="position: relative; z-index: 2; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding: 24px;">
            <span class="card-icon" style="font-family: 'Material Symbols Outlined'; font-size: 32px; color: #FF4444; margin-bottom: 12px;">thermostat</span>
            <h4 style="font-family: var(--font-headline); font-size: 1.125rem; color: var(--text-primary); margin-bottom: 6px;">Thermal Glow</h4>
            <p style="font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-tertiary); line-height: 1.5;">Infrared-style heat map gradient pulses on hover, mimicking thermal sensor output.</p>
          </div>
        </div>

      </div>
    </div>

    <!-- ============================================================
         2. TRANSITION GALLERY — 6 page transitions
         ============================================================ -->
    <div style="margin-bottom: 96px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">Transition Concepts</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Click each panel to preview the transition effect. Click again to reset.</p>

      <div class="transition-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 24px;">

        <!-- Transition 1: Iris Wipe -->
        <div class="transition-demo" data-transition="iris" style="position: relative; height: 220px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border);">
          <div class="transition-before" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2;">
            <div style="text-align: center;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 40px; color: var(--accent); display: block; margin-bottom: 8px;">radio_button_checked</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Iris Wipe</span>
              <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-tertiary); margin-top: 4px;">Circular reveal from center</p>
            </div>
          </div>
          <div class="transition-after iris-target" style="position: absolute; inset: 0; background: linear-gradient(135deg, var(--accent), #7B61FF); clip-path: circle(0% at 50% 50%); transition: clip-path 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94); z-index: 3; display: flex; align-items: center; justify-content: center;">
            <span style="font-family: var(--font-headline); font-size: 1.25rem; color: #fff;">Page Revealed</span>
          </div>
        </div>

        <!-- Transition 2: Grid Dissolve -->
        <div class="transition-demo" data-transition="grid" style="position: relative; height: 220px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border);">
          <div class="transition-before" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2;">
            <div style="text-align: center;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 40px; color: #7B61FF; display: block; margin-bottom: 8px;">grid_view</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Grid Dissolve</span>
              <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-tertiary); margin-top: 4px;">Sections fade in grid pattern</p>
            </div>
          </div>
          <div class="grid-dissolve-container" style="position: absolute; inset: 0; z-index: 3; display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(3, 1fr); pointer-events: none;"></div>
        </div>

        <!-- Transition 3: Slide Stack -->
        <div class="transition-demo" data-transition="slide" style="position: relative; height: 220px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border);">
          <div class="transition-before" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2;">
            <div style="text-align: center;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 40px; color: #FF8C00; display: block; margin-bottom: 8px;">view_carousel</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Slide Stack</span>
              <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-tertiary); margin-top: 4px;">Pages slide like a card deck</p>
            </div>
          </div>
          <div class="slide-stack-layers" style="position: absolute; inset: 0; z-index: 3; pointer-events: none;">
            <div class="slide-layer" style="position: absolute; inset: 0; background: linear-gradient(135deg, #FF8C00, #FF6B35); transform: translateX(100%); transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); display: flex; align-items: center; justify-content: center;">
              <span style="font-family: var(--font-headline); font-size: 1.25rem; color: #fff;">New Page</span>
            </div>
          </div>
        </div>

        <!-- Transition 4: Morph -->
        <div class="transition-demo" data-transition="morph" style="position: relative; height: 220px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border);">
          <div class="transition-before" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2;">
            <div style="text-align: center;">
              <div class="morph-shape" style="width: 60px; height: 60px; background: linear-gradient(135deg, #34D399, #10B981); border-radius: 12px; margin: 0 auto 12px; transition: all 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);"></div>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Morph</span>
              <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-tertiary); margin-top: 4px;">Elements morph between states</p>
            </div>
          </div>
        </div>

        <!-- Transition 5: Particle Dissolve -->
        <div class="transition-demo" data-transition="particle" style="position: relative; height: 220px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border);">
          <div class="transition-before" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2;">
            <div style="text-align: center;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 40px; color: var(--accent); display: block; margin-bottom: 8px;">blur_on</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Particle Dissolve</span>
              <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-tertiary); margin-top: 4px;">Elements break into particles</p>
            </div>
          </div>
          <canvas class="particle-canvas" style="position: absolute; inset: 0; width: 100%; height: 100%; z-index: 3; pointer-events: none; opacity: 0; transition: opacity 0.3s ease;"></canvas>
        </div>

        <!-- Transition 6: Curtain -->
        <div class="transition-demo" data-transition="curtain" style="position: relative; height: 220px; border-radius: 16px; overflow: hidden; cursor: pointer; background: var(--bg-card); border: 1px solid var(--border);">
          <div class="transition-before" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; z-index: 2;">
            <div style="text-align: center;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 40px; color: #7B61FF; display: block; margin-bottom: 8px;">curtains</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Curtain Reveal</span>
              <p style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-tertiary); margin-top: 4px;">Vertical curtains open</p>
            </div>
          </div>
          <div class="curtain-container" style="position: absolute; inset: 0; z-index: 3; display: flex; pointer-events: none;">
            <div class="curtain-left" style="width: 50%; height: 100%; background: linear-gradient(90deg, #7B61FF, #4F46E5); transform: translateX(0); transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);"></div>
            <div class="curtain-right" style="width: 50%; height: 100%; background: linear-gradient(270deg, #7B61FF, #4F46E5); transform: translateX(0); transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);"></div>
          </div>
        </div>

      </div>
    </div>

    <!-- ============================================================
         3. TEXT ANIMATIONS — 6 text effects
         ============================================================ -->
    <div style="margin-bottom: 96px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">Text Animations</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Each text effect activates when scrolled into view, or click to replay.</p>

      <div class="text-effects-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(380px, 1fr)); gap: 24px;">

        <!-- Text 1: Typewriter -->
        <div class="text-effect-card" data-text-effect="typewriter" style="position: relative; padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); cursor: pointer; min-height: 140px;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 16px;">Typewriter</span>
          <div class="typewriter-text" style="font-family: var(--font-mono); font-size: 1.125rem; color: var(--text-primary); line-height: 1.6; min-height: 2em;">
            <span class="typewriter-content"></span><span class="typewriter-cursor" style="display: inline-block; width: 2px; height: 1.2em; background: var(--accent); vertical-align: text-bottom; animation: cursorBlink 0.8s step-end infinite;"></span>
          </div>
        </div>

        <!-- Text 2: Word Fade -->
        <div class="text-effect-card" data-text-effect="wordfade" style="position: relative; padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); cursor: pointer; min-height: 140px;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #7B61FF; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 16px;">Word-by-Word Fade</span>
          <div class="wordfade-text" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); line-height: 1.4;" data-words="Aerial intelligence that sees beyond the visible spectrum">
          </div>
        </div>

        <!-- Text 3: Scramble -->
        <div class="text-effect-card" data-text-effect="scramble" style="position: relative; padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); cursor: pointer; min-height: 140px;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #FF8C00; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 16px;">Character Scramble</span>
          <div class="scramble-text" style="font-family: var(--font-mono); font-size: 1.25rem; color: var(--text-primary); line-height: 1.5; letter-spacing: 0.02em;" data-target="JINKI AERIAL INTELLIGENCE">
            <span style="color: var(--text-tertiary);">Hover or click to decode</span>
          </div>
        </div>

        <!-- Text 4: Gradient Wave -->
        <div class="text-effect-card" data-text-effect="gradientwave" style="position: relative; padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); cursor: pointer; min-height: 140px;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #34D399; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 16px;">Gradient Wave</span>
          <div class="gradientwave-text" style="font-family: var(--font-headline); font-size: 2rem; font-weight: 700; line-height: 1.2; background: linear-gradient(90deg, var(--text-primary) 0%, var(--text-primary) 40%, var(--accent) 50%, #7B61FF 55%, var(--text-primary) 60%, var(--text-primary) 100%); background-size: 200% 100%; -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; animation: gradientWaveSweep 3s ease-in-out infinite;">
            Precision Intelligence
          </div>
        </div>

        <!-- Text 5: Bounce In -->
        <div class="text-effect-card" data-text-effect="bounce" style="position: relative; padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); cursor: pointer; min-height: 140px;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 16px;">Bounce In</span>
          <div class="bounce-text" style="font-family: var(--font-headline); font-size: 2rem; font-weight: 700; color: var(--text-primary); line-height: 1.2; display: flex; flex-wrap: wrap;" data-text="JINKI.AI">
          </div>
        </div>

        <!-- Text 6: Split Reveal -->
        <div class="text-effect-card" data-text-effect="split" style="position: relative; padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); cursor: pointer; min-height: 140px; overflow: hidden;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #FF6B35; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 16px;">Split Reveal</span>
          <div class="split-text-container" style="position: relative; height: 2.5rem; overflow: hidden;">
            <div class="split-top" style="font-family: var(--font-headline); font-size: 2rem; font-weight: 700; color: var(--text-primary); line-height: 1.2; position: absolute; width: 100%; clip-path: inset(0 0 50% 0); transform: translateY(-20px); opacity: 0; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.6s ease;">Autonomous Vision</div>
            <div class="split-bottom" style="font-family: var(--font-headline); font-size: 2rem; font-weight: 700; color: var(--text-primary); line-height: 1.2; position: absolute; width: 100%; clip-path: inset(50% 0 0 0); transform: translateY(20px); opacity: 0; transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.05s, opacity 0.6s ease 0.05s;">Autonomous Vision</div>
          </div>
        </div>

      </div>
    </div>

    <!-- ============================================================
         4. SVG ANIMATIONS — 4 animated SVGs
         ============================================================ -->
    <div style="margin-bottom: 48px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">SVG Animations</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Vector graphics that animate with precision, from path drawing to data visualization.</p>

      <div class="svg-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">

        <!-- SVG 1: Path Drawing -->
        <div class="svg-card" data-svg="path" style="padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); text-align: center; cursor: pointer;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 20px;">Path Drawing</span>
          <svg class="path-svg" viewBox="0 0 240 120" style="width: 100%; max-width: 240px; height: auto; margin: 0 auto; display: block;">
            <!-- Aerial vehicle outline -->
            <path class="draw-path" d="M120 20 L160 50 L180 45 L160 55 L170 90 L140 70 L120 100 L100 70 L70 90 L80 55 L60 45 L80 50 Z" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="stroke-dasharray: 500; stroke-dashoffset: 500;"/>
            <!-- Scan lines -->
            <line class="draw-path draw-delay-1" x1="90" y1="110" x2="150" y2="110" stroke="var(--accent)" stroke-width="1" opacity="0.5" style="stroke-dasharray: 60; stroke-dashoffset: 60;"/>
            <line class="draw-path draw-delay-2" x1="80" y1="115" x2="160" y2="115" stroke="var(--accent)" stroke-width="1" opacity="0.3" style="stroke-dasharray: 80; stroke-dashoffset: 80;"/>
          </svg>
        </div>

        <!-- SVG 2: Morphing Shapes -->
        <div class="svg-card" data-svg="morph" style="padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); text-align: center; cursor: pointer;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #7B61FF; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 20px;">Morphing Shapes</span>
          <svg class="morph-svg" viewBox="0 0 200 120" style="width: 100%; max-width: 200px; height: auto; margin: 0 auto; display: block;">
            <defs>
              <linearGradient id="morphGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#7B61FF"/>
                <stop offset="100%" style="stop-color:var(--accent)"/>
              </linearGradient>
            </defs>
            <path class="morph-target" d="M100 10 L180 40 L180 80 L100 110 L20 80 L20 40 Z" fill="url(#morphGrad)" opacity="0.8">
              <animate attributeName="d" dur="4s" repeatCount="indefinite" values="
                M100 10 L180 40 L180 80 L100 110 L20 80 L20 40 Z;
                M100 20 C150 20 180 50 180 60 C180 80 150 100 100 100 C50 100 20 80 20 60 C20 50 50 20 100 20 Z;
                M60 20 L140 20 L170 60 L140 100 L60 100 L30 60 Z;
                M100 10 L180 40 L180 80 L100 110 L20 80 L20 40 Z
              "/>
            </path>
          </svg>
        </div>

        <!-- SVG 3: Animated Icons -->
        <div class="svg-card" data-svg="icons" style="padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); text-align: center; cursor: pointer;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #34D399; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 20px;">Animated Icons</span>
          <div class="animated-icons" style="display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;">
            <div class="icon-anim icon-anim-1" style="opacity: 0; transform: scale(0) rotate(-180deg); transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);">
              <svg viewBox="0 0 48 48" style="width: 48px; height: 48px;">
                <circle cx="24" cy="24" r="20" fill="none" stroke="#34D399" stroke-width="2" stroke-dasharray="126" stroke-dashoffset="126" class="icon-circle"/>
                <path d="M16 24 L22 30 L32 18" fill="none" stroke="#34D399" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="30" stroke-dashoffset="30" class="icon-check"/>
              </svg>
            </div>
            <div class="icon-anim icon-anim-2" style="opacity: 0; transform: scale(0) rotate(-180deg); transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s;">
              <svg viewBox="0 0 48 48" style="width: 48px; height: 48px;">
                <rect x="8" y="8" width="32" height="32" rx="4" fill="none" stroke="var(--accent)" stroke-width="2" stroke-dasharray="128" stroke-dashoffset="128" class="icon-rect"/>
                <circle cx="24" cy="24" r="6" fill="none" stroke="var(--accent)" stroke-width="2" stroke-dasharray="38" stroke-dashoffset="38" class="icon-inner"/>
              </svg>
            </div>
            <div class="icon-anim icon-anim-3" style="opacity: 0; transform: scale(0) rotate(-180deg); transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.3s;">
              <svg viewBox="0 0 48 48" style="width: 48px; height: 48px;">
                <polygon points="24,6 30,18 44,20 34,30 36,44 24,38 12,44 14,30 4,20 18,18" fill="none" stroke="#FF8C00" stroke-width="2" stroke-linejoin="round" stroke-dasharray="120" stroke-dashoffset="120" class="icon-star"/>
              </svg>
            </div>
          </div>
        </div>

        <!-- SVG 4: Data Visualization -->
        <div class="svg-card" data-svg="dataviz" style="padding: 32px; border-radius: 16px; background: var(--bg-card); border: 1px solid var(--border); text-align: center; cursor: pointer;">
          <span style="font-family: var(--font-mono); font-size: 0.7rem; color: #FF8C00; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 20px;">Data Visualization</span>
          <div style="display: flex; gap: 24px; justify-content: center; align-items: flex-end;">
            <!-- Bar Chart -->
            <svg class="bar-chart" viewBox="0 0 120 80" style="width: 120px; height: 80px;">
