              <rect class="bar bar-5" x="93" y="80" width="16" height="0" fill="var(--accent)" rx="2" opacity="0.7">
                <animate attributeName="height" from="0" to="72" dur="0.6s" fill="freeze" begin="indefinite"/>
                <animate attributeName="y" from="80" to="8" dur="0.6s" fill="freeze" begin="indefinite"/>
