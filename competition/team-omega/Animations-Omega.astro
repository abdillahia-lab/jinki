            <!-- Pie Chart -->
            <svg class="pie-chart" viewBox="0 0 80 80" style="width: 80px; height: 80px;">
              <circle cx="40" cy="40" r="30" fill="none" stroke="var(--accent)" stroke-width="8" stroke-dasharray="0 188.5" transform="rotate(-90 40 40)" class="pie-slice pie-1">
                <animate attributeName="stroke-dasharray" from="0 188.5" to="75.4 188.5" dur="0.8s" fill="freeze" begin="indefinite"/>
              </circle>
              <circle cx="40" cy="40" r="30" fill="none" stroke="#7B61FF" stroke-width="8" stroke-dasharray="0 188.5" stroke-dashoffset="-75.4" transform="rotate(-90 40 40)" class="pie-slice pie-2">
                <animate attributeName="stroke-dasharray" from="0 188.5" to="47.1 188.5" dur="0.8s" fill="freeze" begin="indefinite"/>
              </circle>
              <circle cx="40" cy="40" r="30" fill="none" stroke="#FF8C00" stroke-width="8" stroke-dasharray="0 188.5" stroke-dashoffset="-122.5" transform="rotate(-90 40 40)" class="pie-slice pie-3">
                <animate attributeName="stroke-dasharray" from="0 188.5" to="37.7 188.5" dur="0.8s" fill="freeze" begin="indefinite"/>
              </circle>
              <circle cx="40" cy="40" r="30" fill="none" stroke="#34D399" stroke-width="8" stroke-dasharray="0 188.5" stroke-dashoffset="-160.2" transform="rotate(-90 40 40)" class="pie-slice pie-4">
                <animate attributeName="stroke-dasharray" from="0 188.5" to="28.3 188.5" dur="0.8s" fill="freeze" begin="indefinite"/>
              </circle>
            </svg>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* ============================================================
     KEYFRAMES
     ============================================================ */
  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes colorShiftIdle {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes gradientWaveSweep {
    0% { background-position: 100% 0%; }
    100% { background-position: -100% 0%; }
  }

  @keyframes scanDown {
    0% { top: -2px; opacity: 1; }
    100% { top: 100%; opacity: 0.3; }
  }

  @keyframes thermalPulse {
    0%, 100% {
      background: radial-gradient(ellipse at 50% 50%, rgba(255,0,0,0.35) 0%, rgba(255,165,0,0.25) 30%, rgba(0,100,255,0.15) 60%, transparent 80%);
    }
    33% {
      background: radial-gradient(ellipse at 40% 40%, rgba(255,80,0,0.35) 0%, rgba(255,200,0,0.25) 30%, rgba(100,0,255,0.15) 60%, transparent 80%);
    }
    66% {
      background: radial-gradient(ellipse at 60% 60%, rgba(255,0,80,0.35) 0%, rgba(255,120,0,0.25) 30%, rgba(0,50,255,0.15) 60%, transparent 80%);
    }
  }

  @keyframes letterBounce {
    0% { transform: translateY(40px); opacity: 0; }
    50% { transform: translateY(-8px); opacity: 1; }
    70% { transform: translateY(3px); }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* ============================================================
     CARD INTERACTIONS - hover states
     ============================================================ */
  .interaction-card:hover {
    border-color: var(--border-hover);
  }

  .spotlight-card:hover .spotlight-layer {
    opacity: 1;
  }

  .colorshift-card:hover .colorshift-bg {
    opacity: 0.25 !important;
  }

  .scanline-card:hover .scanline-beam {
    opacity: 1;
    animation: scanDown 1.5s ease-in-out infinite;
  }

  .datarain-card:hover .datarain-canvas {
    opacity: 0.6;
  }

  .thermal-card:hover .thermal-layer {
    opacity: 1;
    animation: thermalPulse 3s ease-in-out infinite;
  }

  /* ============================================================
     TRANSITION DEMOS
     ============================================================ */
  .transition-demo.active .iris-target {
    clip-path: circle(75% at 50% 50%);
  }

  .transition-demo.active .slide-layer {
    transform: translateX(0) !important;
  }

  .transition-demo.active .curtain-left {
    transform: translateX(-100%);
  }

  .transition-demo.active .curtain-right {
    transform: translateX(100%);
  }

  .transition-demo.active .morph-shape {
    border-radius: 50%;
    transform: scale(1.5) rotate(45deg);
    background: linear-gradient(135deg, var(--accent), #7B61FF);
  }

  /* Grid dissolve cells */
  .grid-cell {
    background: linear-gradient(135deg, #7B61FF, #4F46E5);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .transition-demo.active .grid-cell {
    opacity: 1;
  }

  /* ============================================================
     TEXT EFFECTS
     ============================================================ */
  .text-effect-card:hover {
    border-color: var(--border-hover);
  }

  .split-text-container.active .split-top {
    transform: translateY(0);
    opacity: 1;
  }

  .split-text-container.active .split-bottom {
    transform: translateY(0);
    opacity: 1;
  }

  /* ============================================================
     SVG ANIMATIONS
     ============================================================ */
  .svg-card:hover {
    border-color: var(--border-hover);
  }

  .svg-card.active .draw-path {
    animation: drawStroke 2s ease forwards;
  }

  .svg-card.active .draw-delay-1 {
    animation: drawStroke 1s ease 0.8s forwards;
  }

  .svg-card.active .draw-delay-2 {
    animation: drawStroke 1s ease 1.2s forwards;
  }

  @keyframes drawStroke {
    to { stroke-dashoffset: 0; }
  }

  .svg-card.active .icon-anim {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .svg-card.active .icon-circle {
    animation: drawStroke 0.8s ease 0.3s forwards;
  }

  .svg-card.active .icon-check {
    animation: drawStroke 0.4s ease 0.8s forwards;
  }

  .svg-card.active .icon-rect {
    animation: drawStroke 0.8s ease 0.45s forwards;
  }

  .svg-card.active .icon-inner {
    animation: drawStroke 0.5s ease 1s forwards;
  }

  .svg-card.active .icon-star {
    animation: drawStroke 1s ease 0.6s forwards;
  }

  /* ============================================================
     LIGHT THEME
     ============================================================ */
  :global([data-theme="light"]) .interaction-card,
  :global([data-theme="light"]) .transition-demo,
  :global([data-theme="light"]) .text-effect-card,
  :global([data-theme="light"]) .svg-card {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  :global([data-theme="light"]) .thermal-card:hover .thermal-layer {
    mix-blend-mode: multiply;
  }

  /* ============================================================
     REDUCED MOTION
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .scanline-beam,
    .thermal-layer,
    .colorshift-bg,
    .gradientwave-text {
      animation: none !important;
    }

    .typewriter-cursor {
      animation: none !important;
      opacity: 1;
    }

    .draw-path,
    .icon-circle,
    .icon-check,
    .icon-rect,
    .icon-inner,
    .icon-star {
      stroke-dashoffset: 0 !important;
      animation: none !important;
    }

    .icon-anim {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    .morph-target animate {
      dur: 0.01ms;
    }
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 480px) {
    .card-grid,
    .transition-grid,
    .text-effects-grid,
    .svg-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  /* ============================================================
     ANIMATIONS-OMEGA CONTROLLER
     Initializes all interactive effects with reduced-motion check
     ============================================================ */
  (function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- 1. SPOTLIGHT CARD ----
    document.querySelectorAll('.spotlight-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        if (prefersReducedMotion) return;
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const layer = card.querySelector('.spotlight-layer') as HTMLElement;
        if (layer) {
          layer.style.background = `radial-gradient(300px circle at ${x}px ${y}px, rgba(0,229,255,0.15), transparent 60%)`;
        }
      });
    });

    // ---- 2. TILT CARD ----
    document.querySelectorAll('.tilt-card').forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e) => {
        if (prefersReducedMotion) return;
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        el.style.transform = `perspective(800px) rotateY(${x * 20}deg) rotateX(${-y * 20}deg) scale(1.02)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.transform = 'perspective(800px) rotateY(0) rotateX(0) scale(1)';
      });
    });

    // ---- 3. CLIP REVEAL CARD ----
    document.querySelectorAll('.reveal-card').forEach(card => {
      const overlay = card.querySelector('.reveal-overlay') as HTMLElement;
      card.addEventListener('mousemove', (e) => {
        if (prefersReducedMotion || !overlay) return;
        const rect = (card as HTMLElement).getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        overlay.style.clipPath = `circle(40% at ${x}% ${y}%)`;
      });
      card.addEventListener('mouseleave', () => {
        if (overlay) overlay.style.clipPath = 'circle(0% at 50% 50%)';
      });
    });

    // ---- 4. DEPTH SHADOW CARD ----
    document.querySelectorAll('.depth-card').forEach(card => {
      const el = card as HTMLElement;
      el.addEventListener('mousemove', (e) => {
        if (prefersReducedMotion) return;
        const rect = el.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        el.style.boxShadow = `${-x * 30}px ${-y * 30}px 40px rgba(0,0,0,0.3), ${-x * 10}px ${-y * 10}px 15px rgba(0,229,255,0.1)`;
      });
      el.addEventListener('mouseleave', () => {
        el.style.boxShadow = 'none';
      });
    });

    // ---- 5. DATA RAIN CANVAS ----
    document.querySelectorAll('.datarain-card').forEach(card => {
      const canvas = card.querySelector('.datarain-canvas') as HTMLCanvasElement;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      let animFrame: number;
      let columns: number[];
      const chars = '01アイウエオカキクケコ量子空気熱'.split('');
      const fontSize = 12;

      function initRain() {
        canvas.width = canvas.offsetWidth * window.devicePixelRatio;
        canvas.height = canvas.offsetHeight * window.devicePixelRatio;
        ctx!.scale(window.devicePixelRatio, window.devicePixelRatio);
        const colCount = Math.floor(canvas.offsetWidth / fontSize);
        columns = Array(colCount).fill(0);
      }

      function drawRain() {
        if (!ctx) return;
        ctx.fillStyle = 'rgba(30, 32, 34, 0.15)';
        ctx.fillRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);
        ctx.fillStyle = '#00e5ff';
        ctx.font = `${fontSize}px "JetBrains Mono", monospace`;
        for (let i = 0; i < columns.length; i++) {
          const char = chars[Math.floor(Math.random() * chars.length)];
          ctx.globalAlpha = 0.5 + Math.random() * 0.5;
          ctx.fillText(char, i * fontSize, columns[i] * fontSize);
          if (columns[i] * fontSize > canvas.offsetHeight && Math.random() > 0.975) {
            columns[i] = 0;
          }
          columns[i]++;
        }
        ctx.globalAlpha = 1;
        animFrame = requestAnimationFrame(drawRain);
      }

      card.addEventListener('mouseenter', () => {
        if (prefersReducedMotion) return;
        initRain();
        drawRain();
      });
      card.addEventListener('mouseleave', () => {
        cancelAnimationFrame(animFrame);
      });
    });

    // ---- 6. TRANSITION DEMOS ----
    document.querySelectorAll('.transition-demo').forEach(demo => {
      const type = (demo as HTMLElement).dataset.transition;

      // Init grid dissolve cells
      if (type === 'grid') {
        const container = demo.querySelector('.grid-dissolve-container');
        if (container) {
          for (let i = 0; i < 12; i++) {
            const cell = document.createElement('div');
            cell.className = 'grid-cell';
            cell.style.transitionDelay = `${Math.random() * 0.6}s`;
            container.appendChild(cell);
          }
        }
      }

      // Init particle canvas
      if (type === 'particle') {
        const canvas = demo.querySelector('.particle-canvas') as HTMLCanvasElement;
        if (canvas) {
          const ctx = canvas.getContext('2d');
          let particles: {x:number;y:number;vx:number;vy:number;life:number;color:string}[] = [];
          let pAnimFrame: number;

          demo.addEventListener('click', () => {
            if (prefersReducedMotion) return;
            canvas.width = canvas.offsetWidth * window.devicePixelRatio;
            canvas.height = canvas.offsetHeight * window.devicePixelRatio;
            ctx?.scale(window.devicePixelRatio, window.devicePixelRatio);
            canvas.style.opacity = '1';
            particles = [];
            const colors = ['#00e5ff', '#7B61FF', '#34D399', '#FF8C00'];
            for (let i = 0; i < 120; i++) {
              particles.push({
                x: canvas.offsetWidth / 2 + (Math.random() - 0.5) * 60,
                y: canvas.offsetHeight / 2 + (Math.random() - 0.5) * 40,
                vx: (Math.random() - 0.5) * 6,
                vy: (Math.random() - 0.5) * 6,
                life: 1,
                color: colors[Math.floor(Math.random() * colors.length)]
              });
            }

            function animate() {
              if (!ctx) return;
              ctx.clearRect(0, 0, canvas.offsetWidth, canvas.offsetHeight);
              let alive = false;
              for (const p of particles) {
                if (p.life <= 0) continue;
                alive = true;
                p.x += p.vx;
                p.y += p.vy;
                p.life -= 0.015;
                ctx.globalAlpha = p.life;
                ctx.fillStyle = p.color;
                ctx.fillRect(p.x, p.y, 3, 3);
              }
              ctx.globalAlpha = 1;
              if (alive) {
                pAnimFrame = requestAnimationFrame(animate);
              } else {
                canvas.style.opacity = '0';
              }
            }
            cancelAnimationFrame(pAnimFrame);
            animate();
          });
        }
      }

      // Toggle active state on click
      demo.addEventListener('click', () => {
        if (prefersReducedMotion) return;
        demo.classList.toggle('active');
      });
    });

    // ---- 7. TEXT EFFECTS ----

    // Typewriter
    const typewriterCards = document.querySelectorAll('[data-text-effect="typewriter"]');
    const typewriterText = 'Autonomous aerial intelligence for critical infrastructure monitoring.';
    typewriterCards.forEach(card => {
      const content = card.querySelector('.typewriter-content');
      if (!content) return;
      let index = 0;
      let typing = false;

      function startTyping() {
        if (typing || prefersReducedMotion) {
          if (prefersReducedMotion && content) content.textContent = typewriterText;
          return;
        }
        typing = true;
        index = 0;
        content.textContent = '';
        function typeChar() {
          if (index < typewriterText.length) {
            content!.textContent += typewriterText[index];
            index++;
            setTimeout(typeChar, 40 + Math.random() * 40);
          } else {
            typing = false;
          }
        }
        typeChar();
      }

      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) startTyping();
      }, { threshold: 0.5 });
      observer.observe(card);
      card.addEventListener('click', () => { typing = false; setTimeout(startTyping, 100); });
    });

    // Word fade
    document.querySelectorAll('[data-text-effect="wordfade"]').forEach(card => {
      const container = card.querySelector('.wordfade-text') as HTMLElement;
      if (!container) return;
      const text = container.dataset.words || '';
      const words = text.split(' ');

      function buildWords() {
        container.innerHTML = '';
        words.forEach((word, i) => {
          const span = document.createElement('span');
          span.textContent = word + ' ';
          span.style.opacity = prefersReducedMotion ? '1' : '0';
          span.style.transform = prefersReducedMotion ? 'none' : 'translateY(10px)';
          span.style.display = 'inline-block';
          span.style.transition = `opacity 0.4s ease ${i * 0.1}s, transform 0.4s ease ${i * 0.1}s`;
          container.appendChild(span);
        });
      }
      buildWords();

      function animateWords() {
        container.querySelectorAll('span').forEach(span => {
          (span as HTMLElement).style.opacity = '1';
          (span as HTMLElement).style.transform = 'translateY(0)';
        });
      }

      function resetWords() {
        container.querySelectorAll('span').forEach(span => {
          (span as HTMLElement).style.opacity = '0';
          (span as HTMLElement).style.transform = 'translateY(10px)';
        });
      }

      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) animateWords();
      }, { threshold: 0.5 });
      observer.observe(card);
      card.addEventListener('click', () => { resetWords(); setTimeout(animateWords, 200); });
    });

    // Character scramble
    document.querySelectorAll('[data-text-effect="scramble"]').forEach(card => {
      const container = card.querySelector('.scramble-text') as HTMLElement;
      if (!container) return;
      const target = container.dataset.target || '';
      const glyphs = '!<>-_\\/[]{}=+*^?#_ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
      let scrambling = false;

      function scramble() {
        if (scrambling || prefersReducedMotion) {
          if (prefersReducedMotion) container.textContent = target;
          return;
        }
        scrambling = true;
        let iteration = 0;
        const interval = setInterval(() => {
          container.textContent = target.split('').map((char, i) => {
            if (i < iteration) return char;
            return glyphs[Math.floor(Math.random() * glyphs.length)];
          }).join('');
          if (iteration >= target.length) {
            clearInterval(interval);
            scrambling = false;
          }
          iteration += 0.5;
        }, 30);
      }

      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) scramble();
      }, { threshold: 0.5 });
      observer.observe(card);
      card.addEventListener('click', () => { scrambling = false; scramble(); });
      card.addEventListener('mouseenter', scramble);
    });

    // Bounce in
    document.querySelectorAll('[data-text-effect="bounce"]').forEach(card => {
      const container = card.querySelector('.bounce-text') as HTMLElement;
      if (!container) return;
      const text = container.dataset.text || '';

      function buildLetters() {
        container.innerHTML = '';
        text.split('').forEach((char, i) => {
          const span = document.createElement('span');
          span.textContent = char === ' ' ? '\u00A0' : char;
          span.style.display = 'inline-block';
          span.style.opacity = prefersReducedMotion ? '1' : '0';
          span.style.animation = prefersReducedMotion ? 'none' : 'none';
          container.appendChild(span);
        });
      }
      buildLetters();

      function animateBounce() {
        container.querySelectorAll('span').forEach((span, i) => {
          const el = span as HTMLElement;
          el.style.opacity = '0';
          el.style.animation = 'none';
          setTimeout(() => {
            el.style.animation = `letterBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) ${i * 0.06}s forwards`;
          }, 10);
        });
      }

      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting && !prefersReducedMotion) animateBounce();
        if (prefersReducedMotion) {
          container.querySelectorAll('span').forEach(s => (s as HTMLElement).style.opacity = '1');
        }
      }, { threshold: 0.5 });
      observer.observe(card);
      card.addEventListener('click', () => { if (!prefersReducedMotion) animateBounce(); });
    });

    // Split reveal
    document.querySelectorAll('[data-text-effect="split"]').forEach(card => {
      const container = card.querySelector('.split-text-container');
      if (!container) return;
      if (prefersReducedMotion) container.classList.add('active');

      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) container.classList.add('active');
      }, { threshold: 0.5 });
      observer.observe(card);
      card.addEventListener('click', () => {
        container.classList.remove('active');
        setTimeout(() => container.classList.add('active'), 200);
      });
    });

    // ---- 8. SVG ANIMATIONS ----
    document.querySelectorAll('.svg-card').forEach(card => {
      const type = (card as HTMLElement).dataset.svg;

      if (prefersReducedMotion) {
        card.classList.add('active');
        return;
      }

      function activateSVG() {
        card.classList.remove('active');
        // Reset stroke-dashoffsets for path drawing
        if (type === 'path') {
          card.querySelectorAll('.draw-path').forEach(p => {
            (p as SVGElement).style.animation = 'none';
            const len = (p as SVGGeometryElement).getTotalLength?.() || 500;
            (p as SVGElement).style.strokeDasharray = `${len}`;
            (p as SVGElement).style.strokeDashoffset = `${len}`;
          });
        }
        // Reset icon anims
        if (type === 'icons') {
          card.querySelectorAll('.icon-anim').forEach(icon => {
            (icon as HTMLElement).style.opacity = '0';
            (icon as HTMLElement).style.transform = 'scale(0) rotate(-180deg)';
          });
          card.querySelectorAll('.icon-circle, .icon-check, .icon-rect, .icon-inner, .icon-star').forEach(el => {
            (el as SVGElement).style.animation = 'none';
            const len = parseFloat((el as SVGElement).getAttribute('stroke-dasharray') || '0');
            (el as SVGElement).style.strokeDashoffset = `${len}`;
          });
        }
        // Trigger bar chart animations
        if (type === 'dataviz') {
          card.querySelectorAll('.bar animate, .pie-slice animate').forEach(anim => {
            (anim as SVGAnimateElement).beginElement?.();
          });
        }

        requestAnimationFrame(() => {
          card.classList.add('active');
          if (type === 'dataviz') {
            setTimeout(() => {
              card.querySelectorAll('.bar animate, .pie-slice animate').forEach(anim => {
                (anim as SVGAnimateElement).beginElement?.();
              });
            }, 50);
          }
        });
      }

      const observer = new IntersectionObserver(entries => {
        if (entries[0].isIntersecting) activateSVG();
      }, { threshold: 0.3 });
      observer.observe(card);
      card.addEventListener('click', activateSVG);
    });

  })();
</script>
