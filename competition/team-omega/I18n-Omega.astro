---
/*  I18n-Omega.astro — Internationalization framework showcase
    Team Omega | Rounds 19+20
    Jinki Aerial Intelligence  */
---
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>i18n Framework — Omega | Jinki Aerial Intelligence</title>
  <style>
    :root{
      --surface:#121416;--bg-primary:#121416;--bg-elevated:#1a1c1e;--bg-card:#1e2022;
      --bg-card-hover:#282a2c;
      --text-primary:#e2e2e5;--text-secondary:#bac9cc;--text-tertiary:#849396;
      --accent:#00e5ff;--accent-soft:#c3f5ff;--accent-glow:rgba(0,229,255,.15);
      --border:rgba(59,73,76,.2);--border-hover:rgba(59,73,76,.4);
      --glass-bg:rgba(30,32,34,.6);--glass-border:rgba(255,255,255,.06);
      --glass-shadow:0 8px 32px rgba(0,0,0,.3),0 2px 8px rgba(0,0,0,.2);
      --glossy-shine:linear-gradient(135deg,rgba(255,255,255,.12) 0%,rgba(255,255,255,0) 40%,rgba(255,255,255,.04) 100%);
      --font-headline:'Space Grotesk',system-ui,sans-serif;
      --font-body:'Inter',system-ui,sans-serif;
      --font-mono:'JetBrains Mono','SF Mono',monospace;
      --success:#4ade80;
    }
    [data-theme="light"]{
      --surface:#fff;--bg-primary:#fafbfc;--bg-elevated:#fff;--bg-card:#f0f1f3;
      --bg-card-hover:#e8e9eb;
      --text-primary:#1a1c1e;--text-secondary:#3b494c;--text-tertiary:#6f7979;
      --accent:#00838f;--accent-soft:#004f58;--accent-glow:rgba(0,131,143,.1);
      --border:rgba(0,0,0,.08);--border-hover:rgba(0,0,0,.15);
      --glass-bg:rgba(255,255,255,.7);--glass-border:rgba(0,0,0,.06);
      --glass-shadow:0 8px 32px rgba(0,0,0,.08),0 2px 8px rgba(0,0,0,.04);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{-webkit-font-smoothing:antialiased;font-family:var(--font-body);color:var(--text-primary);background:var(--bg-primary)}
    body{min-height:100vh;line-height:1.7}

    .page{max-width:1120px;margin:0 auto;padding:48px 24px 80px}
    .page-title{font-family:var(--font-headline);font-size:clamp(28px,4vw,40px);font-weight:700;text-align:center;margin:0 0 8px}
    .page-subtitle{font-family:var(--font-body);font-size:16px;color:var(--text-tertiary);text-align:center;margin:0 0 56px}

    .section{margin:0 0 64px}
    .section-label{font-family:var(--font-mono);font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--accent);margin:0 0 8px}
    .section-title{font-family:var(--font-headline);font-size:clamp(20px,3vw,28px);font-weight:700;margin:0 0 24px}

    .theme-toggle{
      position:fixed;top:16px;right:16px;z-index:100;
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:10px;padding:10px 14px;cursor:pointer;
      color:var(--text-primary);font-size:18px;
      backdrop-filter:blur(12px);transition:border-color .2s;
    }
    .theme-toggle:hover{border-color:var(--accent)}

    /* ════════════════════════════════════
       1. SLIDE-OUT LANGUAGE PANEL
    ════════════════════════════════════ */
    .panel-trigger{
      display:inline-flex;align-items:center;gap:10px;
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:12px;padding:14px 20px;cursor:pointer;
      color:var(--text-primary);font-family:var(--font-headline);
      font-size:15px;font-weight:600;transition:all .2s;
      backdrop-filter:blur(12px);
    }
    .panel-trigger:hover{border-color:var(--accent)}
    .panel-trigger .flag{font-size:22px}

    /* Overlay */
    .panel-overlay{
      position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:200;
      opacity:0;visibility:hidden;transition:all .3s;
    }
    .panel-overlay.open{opacity:1;visibility:visible}

    /* Slide-out panel */
    .lang-panel{
      position:fixed;top:0;right:-420px;bottom:0;width:400px;max-width:90vw;
      background:var(--bg-elevated);border-left:1px solid var(--glass-border);
      z-index:201;transition:right .35s cubic-bezier(.4,0,.2,1);
      display:flex;flex-direction:column;overflow-y:auto;
    }
    .lang-panel.open{right:0}

    .panel-header{
      display:flex;align-items:center;justify-content:space-between;
      padding:24px;border-bottom:1px solid var(--border);flex-shrink:0;
    }
    .panel-header h3{font-family:var(--font-headline);font-size:20px;font-weight:700}
    .panel-close{
      background:none;border:none;color:var(--text-tertiary);cursor:pointer;
      width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;
      transition:all .2s;
    }
    .panel-close:hover{background:var(--bg-card);color:var(--text-primary)}

    .panel-body{padding:24px;flex:1}

    /* Region groups */
    .region-group{margin:0 0 28px}
    .region-label{
      font-family:var(--font-mono);font-size:10px;text-transform:uppercase;
      letter-spacing:.12em;color:var(--text-tertiary);margin:0 0 12px;
    }
    .lang-list{display:flex;flex-direction:column;gap:4px}
    .lang-item{
      display:flex;align-items:center;gap:14px;
      padding:12px 16px;border-radius:10px;cursor:pointer;
      border:none;background:none;width:100%;text-align:left;
      transition:background .15s;color:var(--text-secondary);
      font-family:var(--font-body);font-size:14px;
    }
    .lang-item:hover{background:var(--bg-card)}
    .lang-item.active{background:var(--accent-glow);color:var(--accent);font-weight:600}
    .lang-item .flag{font-size:22px;flex-shrink:0}
    .lang-item .lang-name{flex:1}
    .lang-item .lang-native{
      font-size:12px;color:var(--text-tertiary);margin-left:auto;
    }
    .lang-item.active .lang-native{color:var(--accent);opacity:.7}
    .lang-item .check{color:var(--accent);opacity:0;flex-shrink:0}
    .lang-item.active .check{opacity:1}

    /* ════════════════════════════════════
       2. CONTENT PREVIEW
    ════════════════════════════════════ */
    .preview-card{
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:16px;padding:32px;position:relative;overflow:hidden;
    }
    .preview-card::before{content:'';position:absolute;inset:0;border-radius:inherit;background:var(--glossy-shine);pointer-events:none}

    .preview-lang-badge{
      display:inline-flex;align-items:center;gap:6px;
      font-family:var(--font-mono);font-size:11px;text-transform:uppercase;
      letter-spacing:.08em;color:var(--accent);
      background:var(--accent-glow);border-radius:20px;
      padding:6px 14px;margin:0 0 16px;
    }
    .preview-heading{
      font-family:var(--font-headline);font-size:clamp(20px,3vw,28px);
      font-weight:700;margin:0 0 12px;line-height:1.2;
    }
    .preview-body{
      font-family:var(--font-body);font-size:15px;color:var(--text-secondary);
      line-height:1.7;margin:0 0 20px;
    }
    .preview-cta{
      display:inline-flex;align-items:center;gap:8px;
      background:var(--accent);color:#000;border:none;border-radius:10px;
      font-family:var(--font-headline);font-weight:600;font-size:14px;
      padding:12px 24px;cursor:pointer;
    }

    /* ════════════════════════════════════
       3. PLURALIZATION RULES
    ════════════════════════════════════ */
    .plural-demo{
      display:flex;flex-direction:column;gap:16px;
    }
    .plural-control{
      display:flex;align-items:center;gap:16px;flex-wrap:wrap;
    }
    .plural-label{font-family:var(--font-headline);font-size:14px;font-weight:600}
    .plural-slider{
      flex:1;min-width:200px;accent-color:var(--accent);cursor:pointer;
    }
    .plural-value{
      font-family:var(--font-mono);font-size:24px;font-weight:700;
      color:var(--accent);min-width:48px;text-align:right;
    }

    .plural-grid{
      display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;
    }
    .plural-card{
      background:var(--bg-card);border:1px solid var(--glass-border);
      border-radius:10px;padding:16px;
    }
    .plural-card-locale{
      font-family:var(--font-mono);font-size:11px;color:var(--accent);
      text-transform:uppercase;letter-spacing:.08em;margin:0 0 8px;
    }
    .plural-card-result{
      font-family:var(--font-body);font-size:16px;color:var(--text-primary);
      font-weight:600;
    }
    .plural-card-rule{
      font-family:var(--font-mono);font-size:11px;color:var(--text-tertiary);
      margin:4px 0 0;
    }

    /* ════════════════════════════════════
       4. CURRENCY & MEASUREMENT
    ════════════════════════════════════ */
    .adapt-grid{
      display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;
    }
    .adapt-card{
      background:var(--glass-bg);border:1px solid var(--glass-border);
      border-radius:12px;padding:24px;position:relative;overflow:hidden;
      transition:border-color .2s;
    }
    .adapt-card:hover{border-color:var(--accent)}
    .adapt-card::before{content:'';position:absolute;inset:0;border-radius:inherit;background:var(--glossy-shine);pointer-events:none}

    .adapt-locale{
      display:flex;align-items:center;gap:8px;margin:0 0 16px;
    }
    .adapt-flag{font-size:24px}
    .adapt-locale-name{font-family:var(--font-headline);font-size:14px;font-weight:700}

    .adapt-row{
      display:flex;justify-content:space-between;align-items:baseline;
      padding:8px 0;border-bottom:1px solid var(--border);
    }
    .adapt-row:last-child{border-bottom:none}
    .adapt-label{font-family:var(--font-body);font-size:12px;color:var(--text-tertiary)}
    .adapt-value{font-family:var(--font-mono);font-size:14px;color:var(--text-primary);font-weight:600}

    /* ── Reduced motion / a11y ── */
    @media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}}
    :focus-visible{outline:2px solid var(--accent);outline-offset:2px}
  </style>
</head>
<body>
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme"><span id="themeIcon">&#9790;</span></button>

  <!-- Slide-out overlay -->
  <div class="panel-overlay" id="panelOverlay"></div>

  <!-- Slide-out language panel -->
  <aside class="lang-panel" id="langPanel" role="dialog" aria-label="Language selection" aria-modal="true">
    <div class="panel-header">
      <h3>Language &amp; Region</h3>
      <button class="panel-close" id="panelClose" aria-label="Close language panel">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="panel-body">
      <div class="region-group">
        <div class="region-label">Americas</div>
        <div class="lang-list">
          <button class="lang-item active" data-lang="en-US" data-flag="&#127482;&#127480;">
            <span class="flag">&#127482;&#127480;</span>
            <span class="lang-name">English</span>
            <span class="lang-native">United States</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="es-MX" data-flag="&#127474;&#127485;">
            <span class="flag">&#127474;&#127485;</span>
            <span class="lang-name">Espa&ntilde;ol</span>
            <span class="lang-native">M&eacute;xico</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="pt-BR" data-flag="&#127463;&#127479;">
            <span class="flag">&#127463;&#127479;</span>
            <span class="lang-name">Portugu&ecirc;s</span>
            <span class="lang-native">Brasil</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>
      <div class="region-group">
        <div class="region-label">Europe</div>
        <div class="lang-list">
          <button class="lang-item" data-lang="en-GB" data-flag="&#127468;&#127463;">
            <span class="flag">&#127468;&#127463;</span>
            <span class="lang-name">English</span>
            <span class="lang-native">United Kingdom</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="fr-FR" data-flag="&#127467;&#127479;">
            <span class="flag">&#127467;&#127479;</span>
            <span class="lang-name">Fran&ccedil;ais</span>
            <span class="lang-native">France</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="de-DE" data-flag="&#127465;&#127466;">
            <span class="flag">&#127465;&#127466;</span>
            <span class="lang-name">Deutsch</span>
            <span class="lang-native">Deutschland</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="es-ES" data-flag="&#127466;&#127480;">
            <span class="flag">&#127466;&#127480;</span>
            <span class="lang-name">Espa&ntilde;ol</span>
            <span class="lang-native">Espa&ntilde;a</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>
      <div class="region-group">
        <div class="region-label">Asia-Pacific</div>
        <div class="lang-list">
          <button class="lang-item" data-lang="ja-JP" data-flag="&#127471;&#127477;">
            <span class="flag">&#127471;&#127477;</span>
            <span class="lang-name">&#26085;&#26412;&#35486;</span>
            <span class="lang-native">Japan</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="ko-KR" data-flag="&#127472;&#127479;">
            <span class="flag">&#127472;&#127479;</span>
            <span class="lang-name">&#54620;&#44397;&#50612;</span>
            <span class="lang-native">Korea</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
          <button class="lang-item" data-lang="zh-CN" data-flag="&#127464;&#127475;">
            <span class="flag">&#127464;&#127475;</span>
            <span class="lang-name">&#20013;&#25991;</span>
            <span class="lang-native">China</span>
            <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </button>
        </div>
      </div>
    </div>
  </aside>

  <div class="page">
    <h1 class="page-title">i18n Framework</h1>
    <p class="page-subtitle">Team Omega &mdash; regional precision, global reach</p>

    <!-- ─── 1. LANGUAGE SELECTOR ─── -->
    <section class="section" aria-labelledby="selector-heading">
      <p class="section-label">01</p>
      <h2 class="section-title" id="selector-heading">Language &amp; Region Selector</h2>
      <button class="panel-trigger" id="panelTrigger">
        <span class="flag" id="triggerFlag">&#127482;&#127480;</span>
        <span id="triggerLabel">English &mdash; United States</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </section>

    <!-- ─── 2. CONTENT PREVIEW ─── -->
    <section class="section" aria-labelledby="preview-heading">
      <p class="section-label">02</p>
      <h2 class="section-title" id="preview-heading">Content Preview</h2>
      <div class="preview-card" id="previewCard">
        <div class="preview-lang-badge" id="previewBadge">EN-US</div>
        <h3 class="preview-heading" id="previewHeading">Aerial Intelligence for Critical Infrastructure</h3>
        <p class="preview-body" id="previewBody">Autonomous inspection systems delivering actionable data for data centers, energy grids, and perimeter security. Reduce risk, cut costs, and gain real-time situational awareness.</p>
        <button class="preview-cta" id="previewCta">Get in Touch</button>
      </div>
    </section>

    <!-- ─── 3. PLURALIZATION ─── -->
    <section class="section" aria-labelledby="plural-heading">
      <p class="section-label">03</p>
      <h2 class="section-title" id="plural-heading">Pluralization Rules</h2>
      <div class="plural-demo">
        <div class="plural-control">
          <span class="plural-label">Mission count:</span>
          <input type="range" class="plural-slider" id="pluralSlider" min="0" max="100" value="1" aria-label="Mission count" />
          <span class="plural-value" id="pluralValue">1</span>
        </div>
        <div class="plural-grid" id="pluralGrid"></div>
      </div>
    </section>

    <!-- ─── 4. CURRENCY & MEASUREMENT ─── -->
    <section class="section" aria-labelledby="adapt-heading">
      <p class="section-label">04</p>
      <h2 class="section-title" id="adapt-heading">Currency &amp; Measurement Adaptation</h2>
      <div class="adapt-grid" id="adaptGrid"></div>
    </section>
  </div>

  <script>
    // Theme toggle
    const toggle = document.getElementById('themeToggle');
    const themeIcon = document.getElementById('themeIcon');
    function setTheme(t) {
      document.documentElement.setAttribute('data-theme', t);
      themeIcon.textContent = t === 'light' ? '\u2600' : '\u263E';
      localStorage.setItem('theme', t);
    }
    toggle.addEventListener('click', () => {
      const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      setTheme(next);
    });
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) setTheme(savedTheme);

    // ── Panel open/close ──
    const panelTrigger = document.getElementById('panelTrigger');
    const panel = document.getElementById('langPanel');
    const overlay = document.getElementById('panelOverlay');
    const panelClose = document.getElementById('panelClose');

    function openPanel() { panel.classList.add('open'); overlay.classList.add('open'); }
    function closePanel() { panel.classList.remove('open'); overlay.classList.remove('open'); }
    panelTrigger.addEventListener('click', openPanel);
    panelClose.addEventListener('click', closePanel);
    overlay.addEventListener('click', closePanel);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });

    // ── Translations data ──
    const translations = {
      'en-US': { badge: 'EN-US', heading: 'Aerial Intelligence for Critical Infrastructure', body: 'Autonomous inspection systems delivering actionable data for data centers, energy grids, and perimeter security. Reduce risk, cut costs, and gain real-time situational awareness.', cta: 'Get in Touch' },
      'es-MX': { badge: 'ES-MX', heading: 'Inteligencia A\u00e9rea para Infraestructura Cr\u00edtica', body: 'Sistemas de inspecci\u00f3n aut\u00f3nomos que brindan datos procesables para centros de datos, redes energ\u00e9ticas y seguridad perimetral. Reduzca riesgos, costos y obtenga conciencia situacional en tiempo real.', cta: 'Cont\u00e1ctenos' },
      'pt-BR': { badge: 'PT-BR', heading: 'Intelig\u00eancia A\u00e9rea para Infraestrutura Cr\u00edtica', body: 'Sistemas de inspe\u00e7\u00e3o aut\u00f4nomos que fornecem dados acion\u00e1veis para data centers, redes de energia e seguran\u00e7a perimetral. Reduza riscos, custos e obtenha consci\u00eancia situacional em tempo real.', cta: 'Fale Conosco' },
      'en-GB': { badge: 'EN-GB', heading: 'Aerial Intelligence for Critical Infrastructure', body: 'Autonomous inspection systems delivering actionable data for data centres, energy grids, and perimeter security. Reduce risk, cut costs, and gain real-time situational awareness.', cta: 'Get in Touch' },
      'fr-FR': { badge: 'FR-FR', heading: 'Intelligence A\u00e9rienne pour les Infrastructures Critiques', body: 'Syst\u00e8mes d\u2019inspection autonomes fournissant des donn\u00e9es exploitables pour les centres de donn\u00e9es, les r\u00e9seaux \u00e9nerg\u00e9tiques et la s\u00e9curit\u00e9 p\u00e9rim\u00e9trique. R\u00e9duisez les risques et obtenez une connaissance situationnelle en temps r\u00e9el.', cta: 'Nous Contacter' },
      'de-DE': { badge: 'DE-DE', heading: 'Luftgest\u00fctzte Intelligenz f\u00fcr Kritische Infrastruktur', body: 'Autonome Inspektionssysteme liefern verwertbare Daten f\u00fcr Rechenzentren, Energienetze und Perimetersicherheit. Risiken reduzieren, Kosten senken und Echtzeit-Lagebewusstsein gewinnen.', cta: 'Kontakt Aufnehmen' },
      'es-ES': { badge: 'ES-ES', heading: 'Inteligencia A\u00e9rea para Infraestructura Cr\u00edtica', body: 'Sistemas de inspecci\u00f3n aut\u00f3nomos que proporcionan datos accionables para centros de datos, redes energ\u00e9ticas y seguridad perimetral.', cta: 'Cont\u00e1ctenos' },
      'ja-JP': { badge: 'JA-JP', heading: '\u91cd\u8981\u30a4\u30f3\u30d5\u30e9\u306e\u305f\u3081\u306e\u822a\u7a7a\u30a4\u30f3\u30c6\u30ea\u30b8\u30a7\u30f3\u30b9', body: '\u30c7\u30fc\u30bf\u30bb\u30f3\u30bf\u30fc\u3001\u30a8\u30cd\u30eb\u30ae\u30fc\u30b0\u30ea\u30c3\u30c9\u3001\u5468\u8fba\u30bb\u30ad\u30e5\u30ea\u30c6\u30a3\u5411\u3051\u306e\u5b9f\u7528\u7684\u306a\u30c7\u30fc\u30bf\u3092\u63d0\u4f9b\u3059\u308b\u81ea\u5f8b\u578b\u691c\u67fb\u30b7\u30b9\u30c6\u30e0\u3002', cta: '\u304a\u554f\u3044\u5408\u308f\u305b' },
      'ko-KR': { badge: 'KO-KR', heading: '\ud575\uc2ec \uc778\ud504\ub77c\ub97c \uc704\ud55c \ud56d\uacf5 \uc778\ud154\ub9ac\uc804\uc2a4', body: '\ub370\uc774\ud130 \uc13c\ud130, \uc5d0\ub108\uc9c0 \uadf8\ub9ac\ub4dc, \uacbd\uacc4 \ubcf4\uc548\uc744 \uc704\ud55c \uc2e4\ud589 \uac00\ub2a5\ud55c \ub370\uc774\ud130\ub97c \uc81c\uacf5\ud558\ub294 \uc790\uc728 \uac80\uc0ac \uc2dc\uc2a4\ud15c.', cta: '\ubb38\uc758\ud558\uae30' },
      'zh-CN': { badge: 'ZH-CN', heading: '\u5173\u952e\u57fa\u7840\u8bbe\u65bd\u7684\u822a\u7a7a\u667a\u80fd', body: '\u81ea\u4e3b\u68c0\u67e5\u7cfb\u7edf\u4e3a\u6570\u636e\u4e2d\u5fc3\u3001\u80fd\u6e90\u7f51\u7edc\u548c\u5468\u754c\u5b89\u5168\u63d0\u4f9b\u53ef\u64cd\u4f5c\u7684\u6570\u636e\u3002\u964d\u4f4e\u98ce\u9669\uff0c\u51cf\u5c11\u6210\u672c\u3002', cta: '\u8054\u7cfb\u6211\u4eec' },
    };

    // ── Language selection ──
    let currentLang = 'en-US';
    const langItems = document.querySelectorAll('.lang-item');
    const triggerFlag = document.getElementById('triggerFlag');
    const triggerLabel = document.getElementById('triggerLabel');

    langItems.forEach(item => {
      item.addEventListener('click', () => {
        langItems.forEach(i => { i.classList.remove('active'); });
        item.classList.add('active');
        currentLang = item.dataset.lang;
        triggerFlag.innerHTML = item.dataset.flag;
        triggerLabel.textContent = item.querySelector('.lang-name').textContent + ' \u2014 ' + item.querySelector('.lang-native').textContent;
        updatePreview();
        updatePlurals();
        closePanel();
      });
    });

    // ── Content preview ──
    function updatePreview() {
      const t = translations[currentLang] || translations['en-US'];
      document.getElementById('previewBadge').textContent = t.badge;
      document.getElementById('previewHeading').textContent = t.heading;
      document.getElementById('previewBody').textContent = t.body;
      document.getElementById('previewCta').textContent = t.cta;
    }

    // ── Pluralization ──
    const pluralRules = {
      'en-US': { locale: 'en', zero: '{0} missions completed', one: '{0} mission completed', other: '{0} missions completed' },
      'fr-FR': { locale: 'fr', zero: '{0} mission effectu\u00e9e', one: '{0} mission effectu\u00e9e', other: '{0} missions effectu\u00e9es' },
      'ja-JP': { locale: 'ja', other: '{0}\u56de\u306e\u30df\u30c3\u30b7\u30e7\u30f3\u5b8c\u4e86' },
      'de-DE': { locale: 'de', one: '{0} Mission abgeschlossen', other: '{0} Missionen abgeschlossen' },
      'es-MX': { locale: 'es', one: '{0} misi\u00f3n completada', other: '{0} misiones completadas' },
    };

    const slider = document.getElementById('pluralSlider');
    const pluralValue = document.getElementById('pluralValue');
    const pluralGrid = document.getElementById('pluralGrid');

    function updatePlurals() {
      const n = parseInt(slider.value);
      pluralValue.textContent = n;
      pluralGrid.innerHTML = '';
      Object.entries(pluralRules).forEach(([key, rules]) => {
        const pr = new Intl.PluralRules(rules.locale);
        const category = pr.select(n);
        const template = rules[category] || rules.other;
        const formatted = template.replace('{0}', new Intl.NumberFormat(rules.locale).format(n));
        const card = document.createElement('div');
        card.className = 'plural-card';
        if (key === currentLang) card.style.borderColor = 'var(--accent)';
        card.innerHTML = `
          <div class="plural-card-locale">${key}</div>
          <div class="plural-card-result">${formatted}</div>
          <div class="plural-card-rule">Rule: ${category}</div>
        `;
        pluralGrid.appendChild(card);
      });
    }
    slider.addEventListener('input', updatePlurals);
    updatePlurals();

    // ── Currency & measurement ──
    const adaptData = [
      { lang: 'en-US', flag: '\ud83c\uddfa\ud83c\uddf8', name: 'United States', currency: 'USD', locale: 'en-US', tempUnit: '\u00b0F', distUnit: 'ft', tempConvert: f => f, distConvert: d => d },
      { lang: 'en-GB', flag: '\ud83c\uddec\ud83c\udde7', name: 'United Kingdom', currency: 'GBP', locale: 'en-GB', tempUnit: '\u00b0C', distUnit: 'm', tempConvert: f => (f-32)*5/9, distConvert: d => d*0.3048 },
      { lang: 'fr-FR', flag: '\ud83c\uddeb\ud83c\uddf7', name: 'France', currency: 'EUR', locale: 'fr-FR', tempUnit: '\u00b0C', distUnit: 'm', tempConvert: f => (f-32)*5/9, distConvert: d => d*0.3048 },
      { lang: 'ja-JP', flag: '\ud83c\uddef\ud83c\uddf5', name: 'Japan', currency: 'JPY', locale: 'ja-JP', tempUnit: '\u00b0C', distUnit: 'm', tempConvert: f => (f-32)*5/9, distConvert: d => d*0.3048 },
    ];
    const basePriceUSD = 45000;
    const baseTempF = 156;
    const baseDistFt = 400;

    function renderAdaptGrid() {
      const grid = document.getElementById('adaptGrid');
      grid.innerHTML = '';
      adaptData.forEach(cfg => {
        const price = basePriceUSD; // would be converted via exchange rates in production
        const temp = cfg.tempConvert(baseTempF);
        const dist = cfg.distConvert(baseDistFt);
        const isActive = cfg.lang === currentLang;
        const card = document.createElement('div');
        card.className = 'adapt-card';
        if (isActive) card.style.borderColor = 'var(--accent)';
        card.innerHTML = `
          <div class="adapt-locale">
            <span class="adapt-flag">${cfg.flag}</span>
            <span class="adapt-locale-name">${cfg.name}</span>
          </div>
          <div class="adapt-row"><span class="adapt-label">Service Price</span><span class="adapt-value">${new Intl.NumberFormat(cfg.locale, { style:'currency', currency:cfg.currency, maximumFractionDigits:0 }).format(price)}</span></div>
          <div class="adapt-row"><span class="adapt-label">Thermal Alert</span><span class="adapt-value">${temp.toFixed(1)}${cfg.tempUnit}</span></div>
          <div class="adapt-row"><span class="adapt-label">Flight Altitude</span><span class="adapt-value">${dist.toFixed(0)} ${cfg.distUnit}</span></div>
          <div class="adapt-row"><span class="adapt-label">Date Format</span><span class="adapt-value">${new Intl.DateTimeFormat(cfg.locale, {dateStyle:'medium'}).format(new Date())}</span></div>
        `;
        grid.appendChild(card);
      });
    }
    renderAdaptGrid();
  </script>
</body>
</html>
