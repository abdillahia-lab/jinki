---
/*
  TEAM OMEGA — Facility Intelligence Audit | Jinki Aerial Intelligence
  Redesigned: cinematic mission-briefing aesthetic with interactive process wheel,
  findings gallery, comparison, and tabbed deliverable preview.
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

const process = [
  { step: '01', title: 'Scoping Call', desc: 'We learn your facility, your priorities, and your pain points. A real conversation about what matters to your operations team.', icon: 'call' },
  { step: '02', title: 'Flight Planning', desc: 'Airspace authorization, safety planning, and mission design tailored to your site geometry and inspection requirements.', icon: 'flight_takeoff' },
  { step: '03', title: 'Data Capture', desc: 'On-site aerial operations. Thermal, visual, and multispectral data across every structure — typically completed in a single day.', icon: 'satellite_alt' },
  { step: '04', title: 'AI Analysis', desc: 'Our analytics pipeline processes thousands of data points: anomaly detection, severity classification, and automated damage assessment.', icon: 'model_training' },
  { step: '05', title: 'Recommendations', desc: 'The Facility Intelligence Report: severity-ranked findings, remediation priorities, cost estimates, and suggested timelines.', icon: 'assignment' },
  { step: '06', title: 'Review & Handoff', desc: 'We walk your team through every finding. Questions answered, priorities confirmed, and a clear path forward.', icon: 'groups' },
];

const findings = [
  { type: 'CRITICAL', label: 'Cooling Unit Thermal Anomaly', category: 'Thermal', color: '#FF3B30', img: 'thermostat' },
  { type: 'HIGH', label: 'Roof Membrane Degradation', category: 'Structural', color: '#FF6B35', img: 'roofing' },
  { type: 'MEDIUM', label: 'Camera Blind Spot — NE Gate', category: 'Security', color: '#FFBD2E', img: 'security' },
  { type: 'LOW', label: 'Insulation Gap — Mech Room 2', category: 'Efficiency', color: '#00E5FF', img: 'electric_bolt' },
];

const reportTabs = [
  { id: 'executive', label: 'Executive Summary', icon: 'summarize', content: 'High-level facility health score, total findings by severity, estimated remediation budget, and recommended priority actions for leadership review.' },
  { id: 'thermal', label: 'Thermal Analysis', icon: 'thermostat', content: 'Complete thermal mapping with anomaly locations, delta-T measurements, equipment identification, and NFPA 70B compliance status for every inspected system.' },
  { id: 'structural', label: 'Structural Report', icon: 'roofing', content: 'AI-classified damage assessment with visual evidence, area measurements, degradation ratings, and projected repair costs for every roof section and exterior surface.' },
  { id: 'security', label: 'Security Evaluation', icon: 'security', content: 'Perimeter coverage analysis, camera blind spot mapping, lighting gap identification, and access vulnerability documentation with remediation recommendations.' },
  { id: 'compliance', label: 'Compliance Package', icon: 'verified', content: 'Regulatory-ready documentation including ASHRAE temperature verification, environmental records, inspection certificates, and audit trail for every data point collected.' },
];
---

<Layout title="Facility Intelligence Audit — Jinki Aerial Intelligence" description="Comprehensive aerial assessment of your facility. One mission. One report. Clear next steps.">
  <Nav />
  <main id="main-content">

    <!-- ============ HERO — Mission Briefing ============ -->
    <section class="omega-hero" aria-label="Facility Intelligence Audit">
      <div class="omega-hero-inner">
        <div class="omega-hero-content reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Mission Briefing</span>
          </div>
          <h1 class="omega-hero-title">
            One Mission.<br/>
            <span class="gradient-text-cyan">Total Facility Intelligence.</span>
          </h1>
          <p class="omega-hero-subtitle">
            Jinki's Facility Intelligence Audit combines thermal diagnostics, structural assessment,
            and security evaluation into a single engagement. You receive a prioritized recommendations
            report — not raw data. Clear findings. Clear next steps.
          </p>
          <div class="omega-hero-actions">
            <a href="#lead-gen" class="btn-premium omega-cta">Schedule Your Audit</a>
            <a href="#process-wheel" class="omega-cta-secondary">See the Process</a>
          </div>
        </div>
        <div class="omega-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <div class="mission-briefing-card">
            <div class="mission-grid-overlay"></div>
            <!-- Countdown rings -->
            <div class="countdown-ring ring-outer">
              <svg viewBox="0 0 120 120" class="countdown-svg">
                <circle cx="60" cy="60" r="54" fill="none" stroke="rgba(0,229,255,0.08)" stroke-width="2" />
                <circle cx="60" cy="60" r="54" fill="none" stroke="rgba(0,229,255,0.5)" stroke-width="2" stroke-dasharray="339.29" stroke-dashoffset="50" stroke-linecap="round" class="countdown-progress" />
              </svg>
            </div>
            <div class="mission-center-icon">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 36px; color: var(--accent);">assignment</span>
            </div>
            <!-- Mission status badges -->
            <div class="mission-stat-badge badge-tl">
              <span class="mission-stat-label">TARGETS</span>
              <span class="mission-stat-val">4 BUILDINGS</span>
            </div>
            <div class="mission-stat-badge badge-tr">
              <span class="mission-stat-label">DURATION</span>
              <span class="mission-stat-val">1 DAY</span>
            </div>
            <div class="mission-stat-badge badge-bl">
              <span class="mission-stat-label">SENSORS</span>
              <span class="mission-stat-val">THERMAL + VISUAL</span>
            </div>
            <div class="mission-stat-badge badge-br">
              <span class="mission-stat-label">STATUS</span>
              <span class="mission-stat-val status-ready">READY</span>
            </div>
            <div class="mission-scan-line"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTERACTIVE PROCESS WHEEL ============ -->
    <section id="process-wheel" class="omega-section" style="background: var(--surface-dim);" aria-label="The Process">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">The Process</span>
          </div>
          <h2>Six Steps to<br/>Actionable Intelligence</h2>
          <p class="omega-section-subtitle">Click any step to learn more. Most facilities complete the entire process in two to three weeks.</p>
        </div>

        <div class="process-wheel-container reveal">
          <!-- Circular wheel for desktop -->
          <div class="process-wheel" role="tablist" aria-label="Audit process steps">
            <div class="wheel-center">
              <div class="wheel-center-content" id="wheel-center-content">
                <span class="material-symbols-outlined wheel-center-icon" style="font-variation-settings: 'FILL' 1;" id="wheel-icon" aria-hidden="true">call</span>
                <span class="wheel-center-step" id="wheel-step">01</span>
                <span class="wheel-center-title" id="wheel-title">Scoping Call</span>
              </div>
            </div>
            {process.map((p, i) => {
              const angle = (i * 60) - 90;
              const rad = angle * Math.PI / 180;
              const radius = 42;
              const x = 50 + radius * Math.cos(rad);
              const y = 50 + radius * Math.sin(rad);
              return (
                <button
                  class={`wheel-node ${i === 0 ? 'active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-controls="wheel-detail-panel"
                  data-step={i}
                  data-icon={p.icon}
                  data-title={p.title}
                  data-desc={p.desc}
                  data-num={p.step}
                  style={`left: ${x}%; top: ${y}%;`}
                >
                  <span class="wheel-node-num">{p.step}</span>
                  <span class="wheel-node-label">{p.title}</span>
                </button>
              );
            })}
            <!-- SVG connector ring -->
            <svg class="wheel-ring-svg" viewBox="0 0 100 100" aria-hidden="true">
              <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.3" stroke-dasharray="2,2" />
            </svg>
          </div>

          <!-- Detail panel -->
          <div class="wheel-detail-panel" id="wheel-detail-panel" role="tabpanel" aria-live="polite">
            <p class="wheel-detail-desc" id="wheel-desc">We learn your facility, your priorities, and your pain points. A real conversation about what matters to your operations team.</p>
          </div>

          <!-- Mobile fallback: vertical timeline -->
          <div class="process-mobile-list">
            {process.map((p, i) => (
              <div class={`process-mobile-item reveal reveal-delay-${(i % 4) + 1}`}>
                <div class="process-mobile-marker">
                  <span class="process-mobile-step">{p.step}</span>
                  {i < process.length - 1 && <div class="process-mobile-connector"></div>}
                </div>
                <div class="process-mobile-body">
                  <div class="process-mobile-icon-wrap">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 20px;" aria-hidden="true">{p.icon}</span>
                  </div>
                  <h3>{p.title}</h3>
                  <p>{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SAMPLE FINDINGS GALLERY ============ -->
    <section class="omega-section" aria-label="Sample Findings">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Sample Findings</span>
          </div>
          <h2>What We Find.<br/>What You Act On.</h2>
          <p class="omega-section-subtitle">
            Every finding is severity-ranked, geolocated, and paired with remediation recommendations and cost estimates.
          </p>
        </div>

        <div class="findings-gallery">
          <div class="findings-carousel" id="findings-carousel">
            {findings.map((f, i) => (
              <div class={`finding-card reveal reveal-delay-${(i % 4) + 1}`}>
                <div class="finding-image-area">
                  <div class="finding-placeholder">
                    <span class="material-symbols-outlined" style={`font-variation-settings: 'FILL' 1; font-size: 48px; color: ${f.color};`} aria-hidden="true">{f.img}</span>
                    <span class="finding-placeholder-label">Sample Image</span>
                  </div>
                  <span class="finding-severity-badge" style={`background: ${f.color}20; color: ${f.color}; border-color: ${f.color}40;`}>{f.type}</span>
                  <span class="finding-category-badge">{f.category}</span>
                </div>
                <div class="finding-info">
                  <h3>{f.label}</h3>
                  <div class="finding-meta">
                    <span class="finding-meta-item">
                      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 14px;" aria-hidden="true">location_on</span>
                      Building C, Zone 3
                    </span>
                    <span class="finding-meta-item">
                      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 14px;" aria-hidden="true">attach_money</span>
                      Est. $2,400 - $34,200
                    </span>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="findings-nav" aria-label="Findings navigation">
            <button class="findings-nav-btn" id="findings-prev" aria-label="Previous finding">
              <span class="material-symbols-outlined" style="font-size: 20px;">chevron_left</span>
            </button>
            <div class="findings-dots" id="findings-dots">
              {findings.map((_, i) => (
                <button class={`findings-dot ${i === 0 ? 'active' : ''}`} data-slide={i} aria-label={`Go to finding ${i + 1}`}></button>
              ))}
            </div>
            <button class="findings-nav-btn" id="findings-next" aria-label="Next finding">
              <span class="material-symbols-outlined" style="font-size: 20px;">chevron_right</span>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ COMPARISON: TRADITIONAL vs JINKI ============ -->
    <section class="omega-section" style="background: var(--surface-dim);" aria-label="Comparison">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">The Difference</span>
          </div>
          <h2>Traditional Audit<br/>vs Jinki Intelligence</h2>
        </div>

        <div class="comparison-container reveal">
          <div class="comparison-side comparison-traditional">
            <div class="comparison-header-bar traditional-bar">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 20px;" aria-hidden="true">schedule</span>
              <h3>Traditional Audit</h3>
            </div>
            <ul class="comparison-list">
              <li class="comparison-negative">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">close</span>
                <div>
                  <strong>2 - 4 weeks</strong>
                  <span>to complete full facility assessment</span>
                </div>
              </li>
              <li class="comparison-negative">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">close</span>
                <div>
                  <strong>Partial coverage</strong>
                  <span>Accessible areas only, blind spots remain</span>
                </div>
              </li>
              <li class="comparison-negative">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">close</span>
                <div>
                  <strong>Manual reporting</strong>
                  <span>Subjective findings, inconsistent formatting</span>
                </div>
              </li>
              <li class="comparison-negative">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">close</span>
                <div>
                  <strong>Safety risk</strong>
                  <span>Personnel on roofs, in confined spaces</span>
                </div>
              </li>
              <li class="comparison-negative">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">close</span>
                <div>
                  <strong>No trend data</strong>
                  <span>Point-in-time snapshot with no baseline</span>
                </div>
              </li>
            </ul>
          </div>

          <div class="comparison-divider">
            <span class="comparison-vs">VS</span>
          </div>

          <div class="comparison-side comparison-jinki">
            <div class="comparison-header-bar jinki-bar">
              <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 20px;" aria-hidden="true">bolt</span>
              <h3>Jinki Intelligence Audit</h3>
            </div>
            <ul class="comparison-list">
              <li class="comparison-positive">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                <div>
                  <strong>1 day on-site</strong>
                  <span>Full facility data captured in hours</span>
                </div>
              </li>
              <li class="comparison-positive">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                <div>
                  <strong>100% coverage</strong>
                  <span>Every surface, every system, no blind spots</span>
                </div>
              </li>
              <li class="comparison-positive">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                <div>
                  <strong>AI-powered analysis</strong>
                  <span>Consistent, severity-ranked, cost-estimated</span>
                </div>
              </li>
              <li class="comparison-positive">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                <div>
                  <strong>Zero personnel risk</strong>
                  <span>Aerial operations eliminate roof access</span>
                </div>
              </li>
              <li class="comparison-positive">
                <span class="material-symbols-outlined cmp-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
                <div>
                  <strong>Trend-ready baseline</strong>
                  <span>Data structured for recurring comparisons</span>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ DELIVERABLE PREVIEW — TABBED ============ -->
    <section class="omega-section" aria-label="The Deliverable">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">The Deliverable</span>
          </div>
          <h2>The Facility Intelligence Report</h2>
          <p class="omega-section-subtitle">
            Your team gets a work order, not a file dump. Every finding is ranked, costed, and scheduled.
          </p>
        </div>

        <div class="report-tabs-container reveal">
          <div class="report-tabs" role="tablist" aria-label="Report sections">
            {reportTabs.map((tab, i) => (
              <button
                class={`report-tab ${i === 0 ? 'active' : ''}`}
                role="tab"
                aria-selected={i === 0 ? 'true' : 'false'}
                aria-controls={`report-panel-${tab.id}`}
                id={`report-tab-${tab.id}`}
                data-tab={tab.id}
              >
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;" aria-hidden="true">{tab.icon}</span>
                <span class="report-tab-label">{tab.label}</span>
              </button>
            ))}
          </div>

          <div class="report-panels">
            {reportTabs.map((tab, i) => (
              <div
                class={`report-panel ${i === 0 ? 'active' : ''}`}
                role="tabpanel"
                id={`report-panel-${tab.id}`}
                aria-labelledby={`report-tab-${tab.id}`}
              >
                <div class="report-panel-mockup">
                  <div class="report-panel-header">
                    <span class="report-panel-dot" style="background: #FF6B35;"></span>
                    <span class="report-panel-dot" style="background: #FFBD2E;"></span>
                    <span class="report-panel-dot" style="background: #27C93F;"></span>
                    <span class="report-panel-title">{tab.label}</span>
                  </div>
                  <div class="report-panel-body">
                    <div class="report-panel-icon-area">
                      <span class="material-symbols-outlined" style={`font-variation-settings: 'FILL' 1; font-size: 40px; color: var(--accent);`} aria-hidden="true">{tab.icon}</span>
                    </div>
                    <p class="report-panel-desc">{tab.content}</p>
                    <div class="report-panel-bars">
                      <div class="report-bar" style="width: 85%;"><span class="report-bar-fill bar-fill-1"></span></div>
                      <div class="report-bar" style="width: 62%;"><span class="report-bar-fill bar-fill-2"></span></div>
                      <div class="report-bar" style="width: 94%;"><span class="report-bar-fill bar-fill-3"></span></div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <LeadGen />
  </main>
  <Footer />
</Layout>

<style>
  /* ================ HERO ================ */
  .omega-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 140px clamp(20px, 5vw, 80px) 60px;
    background: var(--surface-container-lowest);
    position: relative;
    overflow: hidden;
  }

  .omega-hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .omega-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .omega-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .omega-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
  }

  .omega-hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .gradient-text-cyan {
    background: linear-gradient(135deg, #00E5FF, #00a8b5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .omega-hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 540px;
    margin-bottom: 32px;
  }

  .omega-hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .omega-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.875rem 2rem;
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
  }

  .omega-cta-secondary {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .omega-cta-secondary:hover { color: var(--accent); }

  /* Mission Briefing Card */
  .mission-briefing-card {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #0a0c10, #141820);
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mission-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .countdown-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
  }

  .countdown-svg {
    width: 100%;
    height: 100%;
    animation: countdown-rotate 12s linear infinite;
  }

  .countdown-progress {
    transform-origin: center;
    animation: countdown-dash 6s ease-in-out infinite alternate;
  }

  @keyframes countdown-rotate {
    from { transform: rotate(-90deg); }
    to { transform: rotate(270deg); }
  }

  @keyframes countdown-dash {
    0% { stroke-dashoffset: 200; }
    100% { stroke-dashoffset: 20; }
  }

  .mission-center-icon {
    position: relative;
    z-index: 2;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: glow-pulse 4s ease-in-out infinite;
  }

  .mission-stat-badge {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid rgba(0, 229, 255, 0.12);
    z-index: 2;
  }

  .badge-tl { top: 16px; left: 16px; }
  .badge-tr { top: 16px; right: 16px; }
  .badge-bl { bottom: 16px; left: 16px; }
  .badge-br { bottom: 16px; right: 16px; }

  .mission-stat-label {
    font-family: var(--font-mono);
    font-size: 8px;
