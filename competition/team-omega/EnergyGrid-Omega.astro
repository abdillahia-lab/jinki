---
/*
  TEAM OMEGA — Round 4
  Energy Grid Vertical Page Redesign | Jinki Aerial Intelligence

  Cinematic tower hero, interactive failure explorer, live dashboard mockup,
  ROI calculator, process animation, customer impact stories.

  Orange accent: #FF8C00 / #FF6B35
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

const stats = [
  { value: '75%', label: 'Faster Than Manual Inspection', source: 'Operational Data' },
  { value: '3x', label: 'More Anomalies Detected', source: 'Georgia Power Benchmark' },
  { value: '60%', label: 'Reduction in O&M Costs', source: 'Client Average' },
  { value: '14mi', label: 'Inspected Per Day', source: 'Field Average' },
];

const failureHotspots = [
  {
    id: 'insulator',
    label: 'Insulator Degradation',
    x: '50%', y: '18%',
    defect: 'Cracked / contaminated ceramic or polymer insulator',
    detection: 'Visual + thermal comparison: degraded insulators show 8-15\u00b0C differential under load',
    cost: 'Undetected failure: $180K+ per outage event. Inspection cost: $47 per structure.',
  },
  {
    id: 'conductor',
    label: 'Conductor Splice Failure',
    x: '22%', y: '42%',
    defect: 'Overheated compression splice or bolted connection',
    detection: 'Thermal imaging reveals hot-spot at splice joint, 20-40\u00b0C above ambient conductor temp',
    cost: 'Splice failure causes line drop: $95K avg repair + $310K revenue loss per hour.',
  },
  {
    id: 'crossarm',
    label: 'Crossarm Rot / Fracture',
    x: '78%', y: '35%',
    defect: 'Internal wood decay, fiberglass delamination, or steel corrosion',
    detection: 'High-res imaging + LiDAR deflection analysis detects structural compromise',
    cost: 'Crossarm collapse risk: $220K liability per incident. Early replacement: $1,200.',
  },
  {
    id: 'vegetation',
    label: 'Vegetation Encroachment',
    x: '85%', y: '72%',
    defect: 'Tree limbs within minimum approach distance of energized conductors',
    detection: 'LiDAR point cloud measures exact clearance distance to sub-inch accuracy',
    cost: 'Vegetation contact causes 30% of outages. Wildfire liability: $2M+ per event.',
  },
  {
    id: 'foundation',
    label: 'Foundation Erosion',
    x: '50%', y: '90%',
    defect: 'Soil washout, concrete spalling, or anchor bolt corrosion at tower base',
    detection: 'Aerial photogrammetry + thermal imaging of exposed rebar / moisture intrusion',
    cost: 'Foundation failure: $450K replacement. Erosion remediation: $8K if caught early.',
  },
];

const dashboardMetrics = [
  { label: 'Grid Health Score', value: '94.2', unit: '%', trend: '+1.8', color: '#34D399' },
  { label: 'Active Alerts', value: '7', unit: '', trend: '-3', color: '#FF8C00' },
  { label: 'Structures Inspected', value: '1,247', unit: '', trend: '+89', color: '#00D4FF' },
  { label: 'Miles Covered', value: '312', unit: 'mi', trend: '+24', color: '#A78BFA' },
];

const alertFeed = [
  { time: '2m ago', severity: 'critical', msg: 'Thermal anomaly: Tower #1847 — splice temp 62\u00b0C', icon: 'warning' },
  { time: '14m ago', severity: 'warning', msg: 'Vegetation clearance < 4ft: Span 2201-2202', icon: 'forest' },
  { time: '28m ago', severity: 'info', msg: 'Inspection complete: Sector NW-7 — 43 structures', icon: 'check_circle' },
  { time: '1h ago', severity: 'warning', msg: 'Insulator contamination: Tower #1203', icon: 'electric_bolt' },
  { time: '2h ago', severity: 'info', msg: 'Patrol route optimized: 12% efficiency gain', icon: 'route' },
];

const processSteps = [
  { num: '01', title: 'Plan', desc: 'Route optimization using GIS data, weather windows, and regulatory requirements. Every mission maximizes coverage per flight.', icon: 'map' },
  { num: '02', title: 'Deploy', desc: 'Autonomous or piloted aerial platforms equipped with H30T thermal, L3 LiDAR, and high-resolution visual sensors.', icon: 'flight_takeoff' },
  { num: '03', title: 'Capture', desc: 'Multi-sensor data acquisition at 14 miles per day. Thermal, visual, and 3D point cloud data collected simultaneously.', icon: 'sensors' },
  { num: '04', title: 'Analyze', desc: 'AI-assisted anomaly detection cross-references thermal signatures against component baselines. Every finding is verified by engineers.', icon: 'analytics' },
  { num: '05', title: 'Report', desc: 'Severity-ranked findings with GPS coordinates, component ID, remediation recommendations, and estimated costs. Your team gets work orders, not raw data.', icon: 'summarize' },
];

const caseStudies = [
  {
    company: 'Dominion Valley Electric Cooperative',
    region: 'Shenandoah Valley, VA',
    scope: '1,200 miles of distribution lines',
    result: '342 critical defects identified in first pass — 67% were invisible to ground crews.',
    savings: '$2.1M avoided outage costs in Year 1',
    metric: '67%',
    metricLabel: 'Hidden defects found',
  },
  {
    company: 'SunBridge Solar Partners',
    region: 'Eastern Shore, MD',
    scope: '280 MW utility-scale solar installation',
    result: 'Panel-level thermal inspection found 1,847 hotspots across 3 farms in 4 days.',
    savings: '$890K recovered annual energy production',
    metric: '4 days',
    metricLabel: 'Full inspection time',
  },
  {
    company: 'Piedmont Transmission Authority',
    region: 'Central Virginia',
    scope: '87 transmission towers, 345kV corridor',
    result: 'LiDAR + thermal assessment replaced 6-month manual inspection cycle with 2-week aerial survey.',
    savings: '$1.4M annual maintenance cost reduction',
    metric: '86%',
    metricLabel: 'Faster than manual',
  },
];
---

<Layout title="Energy & Grid Intelligence — Jinki Aerial Intelligence" description="Aerial thermal intelligence for power lines, solar farms, substations, and grid infrastructure. Prevent failures, reduce costs 60%, and detect vegetation encroachment from the air.">
  <Nav />
  <main id="main-content">

    <!-- ============================================================
         SECTION 1: Cinematic Tower Hero
         ============================================================ -->
    <section class="omega-hero" aria-label="Energy Grid Intelligence Hero">
      <!-- Particle canvas -->
      <canvas class="hero-particles" aria-hidden="true"></canvas>

      <div class="omega-hero-inner">
        <div class="omega-hero-content reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Energy & Grid</span>
          </div>
          <h1 class="omega-hero-title">
            See Every Fault Before<br/>
            <span class="gradient-text-energy">the Grid Feels It</span>
          </h1>
          <p class="omega-hero-subtitle">
            Aging infrastructure. Expanding service territory. Shrinking budgets.
            Jinki delivers aerial thermal intelligence across your entire grid —
            power lines, substations, and solar farms — without shutdowns,
            scaffolding, or risk to crews.
          </p>
          <div class="omega-hero-stats">
            {stats.map(s => (
              <div class="hero-stat">
                <span class="hero-stat-value">{s.value}</span>
                <span class="hero-stat-label">{s.label}</span>
              </div>
            ))}
          </div>
          <div class="omega-hero-actions" style="margin-top: 40px;">
            <a href="#lead-gen" class="btn-premium omega-cta">Schedule Assessment</a>
            <a href="#failure-explorer" class="omega-cta-ghost">Explore Failure Modes</a>
          </div>
        </div>

        <div class="omega-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <!-- SVG Transmission Tower -->
          <div class="tower-scene">
            <svg class="tower-svg" viewBox="0 0 400 600" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <!-- Tower base -->
              <path d="M140 580 L200 100 L260 580" stroke="url(#towerGrad)" stroke-width="3" fill="none"/>
              <!-- Left leg -->
              <path d="M150 580 L180 300" stroke="url(#towerGrad)" stroke-width="2" fill="none"/>
              <!-- Right leg -->
              <path d="M250 580 L220 300" stroke="url(#towerGrad)" stroke-width="2" fill="none"/>
              <!-- Crossarms -->
              <line x1="80" y1="160" x2="320" y2="160" stroke="url(#towerGrad)" stroke-width="2.5"/>
              <line x1="100" y1="250" x2="300" y2="250" stroke="url(#towerGrad)" stroke-width="2.5"/>
              <line x1="120" y1="340" x2="280" y2="340" stroke="url(#towerGrad)" stroke-width="2"/>
              <!-- Bracing -->
              <line x1="170" y1="200" x2="230" y2="280" stroke="rgba(255,140,0,0.15)" stroke-width="1"/>
              <line x1="230" y1="200" x2="170" y2="280" stroke="rgba(255,140,0,0.15)" stroke-width="1"/>
              <line x1="175" y1="290" x2="225" y2="360" stroke="rgba(255,140,0,0.15)" stroke-width="1"/>
              <line x1="225" y1="290" x2="175" y2="360" stroke="rgba(255,140,0,0.15)" stroke-width="1"/>
              <!-- Insulators -->
              <circle cx="80" cy="165" r="6" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.6"/>
              <circle cx="320" cy="165" r="6" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.6"/>
              <circle cx="100" cy="255" r="5" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.5"/>
              <circle cx="300" cy="255" r="5" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.5"/>
              <!-- Power lines going off-screen -->
              <line x1="0" y1="155" x2="74" y2="163" stroke="rgba(255,140,0,0.25)" stroke-width="1.5"/>
              <line x1="326" y1="163" x2="400" y2="155" stroke="rgba(255,140,0,0.25)" stroke-width="1.5"/>
              <line x1="0" y1="245" x2="95" y2="253" stroke="rgba(255,140,0,0.2)" stroke-width="1.5"/>
              <line x1="305" y1="253" x2="400" y2="245" stroke="rgba(255,140,0,0.2)" stroke-width="1.5"/>
              <!-- Arc effects -->
              <path class="power-arc arc-1" d="M80 165 Q50 120 20 155" stroke="#FF8C00" stroke-width="1" fill="none" opacity="0"/>
              <path class="power-arc arc-2" d="M320 165 Q350 120 380 155" stroke="#FF8C00" stroke-width="1" fill="none" opacity="0"/>
              <path class="power-arc arc-3" d="M100 255 Q70 210 40 245" stroke="#FF6B35" stroke-width="1" fill="none" opacity="0"/>
              <!-- Gradient def -->
              <defs>
                <linearGradient id="towerGrad" x1="200" y1="100" x2="200" y2="580" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#FF8C00"/>
                  <stop offset="100%" stop-color="#FF6B35" stop-opacity="0.3"/>
                </linearGradient>
              </defs>
            </svg>
            <!-- Glow effect at tower top -->
            <div class="tower-glow"></div>
            <!-- Scan line -->
            <div class="tower-scan-line"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 2: Interactive Failure Mode Explorer
         ============================================================ -->
    <section id="failure-explorer" class="omega-section" aria-label="Failure Mode Explorer" style="background: var(--surface-dim);">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Failure Mode Explorer</span>
          </div>
          <h2>Every Structure Tells a Story.<br/><span class="gradient-text-energy">We Read the Warnings.</span></h2>
          <p class="omega-section-subtitle">
            Click any hotspot on the transmission tower to explore the defect type,
            how we detect it, and the cost of missing it.
          </p>
        </div>

        <div class="explorer-layout reveal">
          <div class="explorer-tower" role="img" aria-label="Interactive transmission tower diagram with clickable failure hotspots">
            <!-- Tower SVG for explorer -->
            <svg class="explorer-tower-svg" viewBox="0 0 400 700" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M140 680 L200 80 L260 680" stroke="rgba(255,140,0,0.4)" stroke-width="2.5" fill="none"/>
              <path d="M155 680 L185 320" stroke="rgba(255,140,0,0.25)" stroke-width="1.5" fill="none"/>
              <path d="M245 680 L215 320" stroke="rgba(255,140,0,0.25)" stroke-width="1.5" fill="none"/>
              <line x1="60" y1="160" x2="340" y2="160" stroke="rgba(255,140,0,0.35)" stroke-width="2"/>
              <line x1="80" y1="280" x2="320" y2="280" stroke="rgba(255,140,0,0.3)" stroke-width="2"/>
              <line x1="100" y1="400" x2="300" y2="400" stroke="rgba(255,140,0,0.25)" stroke-width="1.5"/>
              <line x1="170" y1="200" x2="230" y2="320" stroke="rgba(255,140,0,0.1)" stroke-width="1"/>
              <line x1="230" y1="200" x2="170" y2="320" stroke="rgba(255,140,0,0.1)" stroke-width="1"/>
              <!-- Ground line -->
              <line x1="60" y1="680" x2="340" y2="680" stroke="rgba(255,140,0,0.15)" stroke-width="1" stroke-dasharray="6 4"/>
            </svg>
            <!-- Hotspot buttons -->
            {failureHotspots.map((hs, i) => (
              <button
                class="hotspot-btn"
                data-hotspot={hs.id}
                style={`left: ${hs.x}; top: ${hs.y};`}
                aria-label={`View details: ${hs.label}`}
                aria-expanded="false"
                aria-controls={`hotspot-detail-${hs.id}`}
              >
                <span class="hotspot-ping"></span>
                <span class="hotspot-dot"></span>
                <span class="hotspot-label">{hs.label}</span>
              </button>
            ))}
          </div>

          <div class="explorer-detail-panel" id="explorer-detail" role="region" aria-live="polite">
            <div class="detail-placeholder" id="detail-placeholder">
              <span class="material-symbols-outlined" style="font-size: 48px; color: rgba(255,140,0,0.3); font-variation-settings: 'FILL' 1;" aria-hidden="true">touch_app</span>
              <p style="margin-top: 16px; color: var(--text-tertiary); font-family: var(--font-body); font-size: 0.9375rem;">
                Select a hotspot on the tower to explore failure modes
              </p>
            </div>
            {failureHotspots.map(hs => (
              <div class="detail-content" id={`hotspot-detail-${hs.id}`} data-detail={hs.id} hidden>
                <h3 class="detail-title">{hs.label}</h3>
                <div class="detail-row">
                  <span class="detail-label">Defect</span>
                  <p class="detail-value">{hs.defect}</p>
                </div>
                <div class="detail-row">
                  <span class="detail-label">Detection Method</span>
                  <p class="detail-value">{hs.detection}</p>
                </div>
                <div class="detail-row detail-row-cost">
                  <span class="detail-label">Cost Impact</span>
                  <p class="detail-value">{hs.cost}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 3: Live Monitoring Dashboard Mockup
         ============================================================ -->
    <section class="omega-section" aria-label="Live Monitoring Dashboard">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Real-Time Monitoring</span>
          </div>
          <h2>Your Entire Grid.<br/><span class="gradient-text-energy">One Dashboard.</span></h2>
          <p class="omega-section-subtitle">
            Continuous aerial intelligence feeds into a unified command view.
            Track grid health, active alerts, inspection progress, and coverage
            in real time.
          </p>
        </div>

        <div class="dashboard-mockup reveal" role="img" aria-label="Animated dashboard showing grid health metrics, alert feed, and coverage map">
          <div class="dash-titlebar">
            <div class="dash-dots">
              <span class="dash-dot" style="background: #ff5f57;"></span>
              <span class="dash-dot" style="background: #febc2e;"></span>
              <span class="dash-dot" style="background: #28c840;"></span>
            </div>
            <span class="dash-title">JINKI GRID COMMAND</span>
            <span class="dash-live">
              <span class="dash-live-dot"></span>
              LIVE
            </span>
          </div>

          <div class="dash-body">
            <!-- Metric cards -->
            <div class="dash-metrics">
              {dashboardMetrics.map((m, i) => (
                <div class="dash-metric-card" style={`animation-delay: ${i * 0.15}s;`}>
                  <span class="dash-metric-label">{m.label}</span>
                  <div class="dash-metric-row">
                    <span class="dash-metric-value" style={`color: ${m.color};`}>{m.value}<small>{m.unit}</small></span>
                    <span class={`dash-metric-trend ${m.trend.startsWith('-') ? 'trend-down' : 'trend-up'}`}>
                      {m.trend.startsWith('-') ? '' : '+'}{m.trend}
                    </span>
                  </div>
                  <div class="dash-metric-bar">
                    <div class="dash-metric-fill" style={`background: ${m.color}; width: ${60 + i * 10}%;`}></div>
                  </div>
                </div>
              ))}
            </div>

            <div class="dash-lower">
              <!-- Alert feed -->
              <div class="dash-alerts">
                <div class="dash-alerts-header">
                  <span class="material-symbols-outlined" style="font-size: 16px; color: #FF8C00; font-variation-settings: 'FILL' 1;" aria-hidden="true">notifications_active</span>
                  <span>Alert Feed</span>
                </div>
                <div class="dash-alerts-list">
                  {alertFeed.map((a, i) => (
                    <div class={`dash-alert-item severity-${a.severity}`} style={`animation-delay: ${0.8 + i * 0.2}s;`}>
                      <span class="material-symbols-outlined alert-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{a.icon}</span>
                      <div class="alert-body">
                        <span class="alert-msg">{a.msg}</span>
                        <span class="alert-time">{a.time}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Coverage map placeholder -->
              <div class="dash-map">
                <div class="dash-map-header">
                  <span class="material-symbols-outlined" style="font-size: 16px; color: #FF8C00; font-variation-settings: 'FILL' 1;" aria-hidden="true">map</span>
                  <span>Coverage Map</span>
                </div>
                <div class="dash-map-canvas">
                  <!-- Stylized grid lines -->
                  <svg class="map-grid-svg" viewBox="0 0 300 200" fill="none" preserveAspectRatio="none">
                    <line x1="30" y1="30" x2="270" y2="30" stroke="rgba(255,140,0,0.12)" stroke-width="1"/>
                    <line x1="50" y1="80" x2="250" y2="80" stroke="rgba(255,140,0,0.1)" stroke-width="1"/>
                    <line x1="40" y1="130" x2="260" y2="130" stroke="rgba(255,140,0,0.08)" stroke-width="1"/>
                    <line x1="60" y1="170" x2="240" y2="170" stroke="rgba(255,140,0,0.06)" stroke-width="1"/>
                    <!-- Nodes -->
                    <circle cx="80" cy="50" r="4" fill="#34D399" opacity="0.8"/>
                    <circle cx="150" cy="40" r="4" fill="#34D399" opacity="0.8"/>
                    <circle cx="220" cy="60" r="4" fill="#FF8C00" opacity="0.8"/>
                    <circle cx="100" cy="100" r="4" fill="#34D399" opacity="0.8"/>
                    <circle cx="180" cy="90" r="5" fill="#FF4444" class="map-alert-node" opacity="0.9"/>
                    <circle cx="250" cy="110" r="4" fill="#34D399" opacity="0.8"/>
                    <circle cx="70" cy="150" r="4" fill="#34D399" opacity="0.8"/>
                    <circle cx="160" cy="160" r="4" fill="#FF8C00" opacity="0.8"/>
                    <circle cx="230" cy="145" r="4" fill="#34D399" opacity="0.8"/>
                    <!-- Connection lines -->
                    <line x1="80" y1="50" x2="150" y2="40" stroke="rgba(52,211,153,0.3)" stroke-width="1"/>
                    <line x1="150" y1="40" x2="220" y2="60" stroke="rgba(52,211,153,0.3)" stroke-width="1"/>
                    <line x1="100" y1="100" x2="180" y2="90" stroke="rgba(255,68,68,0.4)" stroke-width="1"/>
                    <line x1="180" y1="90" x2="250" y2="110" stroke="rgba(52,211,153,0.3)" stroke-width="1"/>
                    <line x1="70" y1="150" x2="160" y2="160" stroke="rgba(255,140,0,0.3)" stroke-width="1"/>
                    <line x1="160" y1="160" x2="230" y2="145" stroke="rgba(52,211,153,0.3)" stroke-width="1"/>
                  </svg>
                  <!-- Scan sweep -->
                  <div class="map-scan-sweep"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 4: ROI Calculator
         ============================================================ -->
    <section class="omega-section" aria-label="ROI Calculator" style="background: var(--surface-dim);">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">ROI Calculator</span>
          </div>
          <h2>Quantify Your Savings<br/><span class="gradient-text-energy">Before We Fly</span></h2>
          <p class="omega-section-subtitle">
            Enter your infrastructure details to see estimated savings from
            aerial intelligence versus traditional inspection methods.
          </p>
        </div>

        <div class="roi-calculator reveal" role="form" aria-label="Return on investment calculator">
          <div class="roi-inputs">
            <div class="roi-input-group">
              <label class="roi-label" for="roi-miles">Miles of Transmission/Distribution Lines</label>
              <input type="range" id="roi-miles" class="roi-range" min="50" max="2000" value="500" step="50"/>
              <div class="roi-range-labels">
                <span>50 mi</span>
                <span class="roi-current-value" id="roi-miles-display">500 mi</span>
                <span>2,000 mi</span>
              </div>
            </div>
            <div class="roi-input-group">
              <label class="roi-label" for="roi-structures">Number of Structures (Towers/Poles)</label>
              <input type="range" id="roi-structures" class="roi-range" min="100" max="10000" value="2000" step="100"/>
              <div class="roi-range-labels">
                <span>100</span>
                <span class="roi-current-value" id="roi-structures-display">2,000</span>
                <span>10,000</span>
              </div>
            </div>
          </div>

          <div class="roi-results">
            <div class="roi-result-card roi-primary-result">
              <span class="roi-result-label">Estimated Annual Savings</span>
              <span class="roi-result-value" id="roi-savings">$1,200,000</span>
              <span class="roi-result-note">vs. traditional manual inspection</span>
            </div>
            <div class="roi-result-grid">
              <div class="roi-result-card">
                <span class="roi-result-label">Inspection Time Reduction</span>
                <span class="roi-result-value roi-result-secondary" id="roi-time">78%</span>
                <span class="roi-result-note">Faster than ground crews</span>
              </div>
              <div class="roi-result-card">
                <span class="roi-result-label">Risk Reduction Score</span>
                <span class="roi-result-value roi-result-secondary" id="roi-risk">8.4 / 10</span>
                <span class="roi-result-note">Outage prevention index</span>
              </div>
              <div class="roi-result-card">
                <span class="roi-result-label">Aerial Assessment Cost</span>
                <span class="roi-result-value roi-result-secondary" id="roi-cost">$94,000</span>
                <span class="roi-result-note">Annual investment</span>
              </div>
              <div class="roi-result-card">
                <span class="roi-result-label">Return on Investment</span>
                <span class="roi-result-value roi-result-secondary" id="roi-ratio">12.8x</span>
                <span class="roi-result-note">First-year payback</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 5: Process Animation
         ============================================================ -->
