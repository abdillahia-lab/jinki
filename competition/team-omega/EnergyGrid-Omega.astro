<script>
  // --- Failure Explorer Interaction ---
  document.addEventListener('DOMContentLoaded', () => {
    const hotspotBtns = document.querySelectorAll('.hotspot-btn');
    const detailContents = document.querySelectorAll('.detail-content');
    const placeholder = document.getElementById('detail-placeholder');

    hotspotBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-hotspot');

        // Reset all
        hotspotBtns.forEach(b => {
          b.classList.remove('active');
          b.setAttribute('aria-expanded', 'false');
        });
        detailContents.forEach(d => d.hidden = true);

        // Activate
        btn.classList.add('active');
        btn.setAttribute('aria-expanded', 'true');
        if (placeholder) placeholder.hidden = true;

        const detail = document.getElementById(`hotspot-detail-${id}`);
        if (detail) detail.hidden = false;
      });
    });

    // --- ROI Calculator ---
    const milesInput = document.getElementById('roi-miles') as HTMLInputElement;
    const structuresInput = document.getElementById('roi-structures') as HTMLInputElement;
    const milesDisplay = document.getElementById('roi-miles-display');
    const structuresDisplay = document.getElementById('roi-structures-display');
    const savingsEl = document.getElementById('roi-savings');
    const timeEl = document.getElementById('roi-time');
    const riskEl = document.getElementById('roi-risk');
    const costEl = document.getElementById('roi-cost');
    const ratioEl = document.getElementById('roi-ratio');

    function calcROI() {
      const miles = parseInt(milesInput?.value || '500');
      const structures = parseInt(structuresInput?.value || '2000');

      // Manual cost: ~$5,000/tower + $800/mile
      const manualCost = (structures * 5000) + (miles * 800);
      // Aerial cost: ~$47/structure + $320/mile
      const aerialCost = (structures * 47) + (miles * 320);
      const savings = manualCost - aerialCost;
      const timeReduction = Math.min(92, 60 + (miles / 100));
      const riskScore = Math.min(9.8, 6 + (structures / 3000) * 3.8);
      const ratio = aerialCost > 0 ? (savings / aerialCost) : 0;

      if (milesDisplay) milesDisplay.textContent = `${miles.toLocaleString()} mi`;
      if (structuresDisplay) structuresDisplay.textContent = structures.toLocaleString();
      if (savingsEl) savingsEl.textContent = `$${Math.round(savings).toLocaleString()}`;
      if (timeEl) timeEl.textContent = `${Math.round(timeReduction)}%`;
      if (riskEl) riskEl.textContent = `${riskScore.toFixed(1)} / 10`;
      if (costEl) costEl.textContent = `$${Math.round(aerialCost).toLocaleString()}`;
      if (ratioEl) ratioEl.textContent = `${ratio.toFixed(1)}x`;
    }

    milesInput?.addEventListener('input', calcROI);
    structuresInput?.addEventListener('input', calcROI);
    calcROI();

    // --- Hero Particle Canvas ---
    const canvas = document.querySelector('.hero-particles') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let animId: number;
      const particles: Array<{x: number; y: number; vy: number; vx: number; size: number; opacity: number; life: number}> = [];

      function resizeCanvas() {
        const parent = canvas.parentElement;
        if (!parent) return;
        canvas.width = parent.offsetWidth;
        canvas.height = parent.offsetHeight;
      }
      resizeCanvas();
      window.addEventListener('resize', resizeCanvas);

      function spawnParticle() {
        particles.push({
          x: canvas.width * 0.3 + Math.random() * canvas.width * 0.4,
          y: canvas.height,
          vy: -(1 + Math.random() * 2),
          vx: (Math.random() - 0.5) * 0.5,
          size: 1 + Math.random() * 2,
          opacity: 0.3 + Math.random() * 0.5,
          life: 1,
        });
      }

      function animateParticles() {
        if (!ctx) return;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        if (Math.random() < 0.3) spawnParticle();
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          p.y += p.vy;
          p.x += p.vx;
          p.life -= 0.003;
          if (p.life <= 0 || p.y < 0) {
            particles.splice(i, 1);
            continue;
          }
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 140, 0, ${p.opacity * p.life})`;
          ctx.fill();
        }
        animId = requestAnimationFrame(animateParticles);
      }
      animateParticles();

      // Respect reduced motion
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        cancelAnimationFrame(animId);
      }
    }

    // --- Process connector scroll animation ---
    const processConnector = document.querySelector('.process-connector-fill') as HTMLElement;
    if (processConnector) {
      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            processConnector.style.height = '100%';
          }
        });
      }, { threshold: 0.2 });
      const processFlow = document.querySelector('.process-flow');
      if (processFlow) observer.observe(processFlow);
    }
  });
</script>

