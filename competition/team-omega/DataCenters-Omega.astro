const testimonials = [
  {
    quote: 'Jinki found a failing transformer connection that our maintenance team had walked past for months. The thermal data was unambiguous — we replaced it during a scheduled window instead of an emergency.',
    name: 'Marcus Chen',
    role: 'VP of Facility Operations',
    company: 'Meridian Data Systems',
    stars: 5,
  },
  {
    quote: 'We went from quarterly manual inspections taking three weeks each to monthly aerial assessments completed in a single day. The coverage improvement alone justified the investment.',
    name: 'Sarah Okonkwo',
    role: 'Director of Critical Infrastructure',
    company: 'Apex Cloud Services',
    stars: 5,
  },
  {
    quote: 'The prioritized maintenance report changed how our team operates. Instead of reacting to failures, we plan remediation around severity rankings and cost estimates Jinki provides.',
    name: 'David Restrepo',
    role: 'Chief Engineer',
    company: 'Titan Hosting Group',
    stars: 5,
  },
  {
    quote: 'During our campus expansion, Jinki provided construction progress orthomosaics that kept our board informed without adding any overhead to the general contractor.',
    name: 'Jennifer Walsh',
    role: 'SVP of Development',
    company: 'Nexus Infrastructure Partners',
    stars: 5,
  },
];

const pipelineSteps = [
  { icon: 'rocket_launch', label: 'Aerial Platform', sub: 'M400 RTK / M4TD + Dock 3' },
  { icon: 'thermostat', label: 'H30T Thermal Sensor', sub: '640x512 radiometric' },
  { icon: 'psychology', label: 'Manifold 3 AI', sub: 'Edge processing onboard' },
  { icon: 'hub', label: 'Cloud Analysis', sub: 'Pattern recognition + ML' },
  { icon: 'verified_user', label: 'Actionable Report', sub: 'Prioritized findings' },
];

const pricingTiers = [
  {
    name: 'Assessment',
    price: 'Custom',
    period: 'per engagement',
    description: 'One-time comprehensive facility intelligence audit.',
    features: [
      'Full-campus thermal survey',
      'Roof condition assessment',
      'Electrical infrastructure scan',
      'Prioritized findings report',
      'Remediation cost estimates',
      'Executive summary deliverable',
    ],
    highlighted: false,
    cta: 'Request Quote',
  },
  {
    name: 'Monitoring',
    price: 'Custom',
    period: 'per month',
    description: 'Autonomous recurring inspections with trend analysis.',
    features: [
      'Everything in Assessment',
      'Monthly autonomous patrols',
      'Thermal trend dashboards',
      'Anomaly alert notifications',
      'Quarterly executive briefings',
      'Dedicated account manager',
      'API access to findings data',
    ],
    highlighted: true,
    cta: 'Get Started',
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: 'annual contract',
    description: 'Multi-campus program with dedicated operations.',
    features: [
      'Everything in Monitoring',
      'Multi-site coordination',
      'Custom inspection cadence',
      'Compliance documentation',
      'Construction monitoring',
      'Environmental reporting',
      'On-site operations team',
      'SLA-backed response times',
    ],
    highlighted: false,
    cta: 'Contact Sales',
  },
];

const faqs = [
  {
    q: 'How long does a full facility assessment take?',
    a: 'A typical 50-acre data center campus can be surveyed in 4-6 hours of aerial operations. The complete prioritized findings report is delivered within 5 business days, including severity rankings, remediation cost estimates, and recommended timelines.',
  },
  {
    q: 'Do aerial operations disrupt data center operations?',
    a: 'No. All inspections are conducted externally — from rooftops, perimeters, and mechanical equipment areas. There is zero impact on interior operations, no roof access required, and no coordination needed with IT teams. Operations continue uninterrupted.',
  },
  {
    q: 'What compliance requirements do your inspections satisfy?',
    a: 'Our thermal inspections align with NFPA 70B electrical maintenance requirements, ASHRAE temperature monitoring guidelines, and support environmental compliance documentation. Each deliverable maps findings to relevant standards.',
  },
  {
    q: 'How does autonomous monitoring differ from one-time assessment?',
    a: 'Autonomous monitoring uses a permanently stationed aerial platform (DJI M4TD + Dock 3) that conducts 150-200 scheduled missions per month. This enables thermal trend analysis over time — detecting degradation velocity, not just current state.',
  },
  {
    q: 'What is included in the findings report?',
    a: 'Every report includes georeferenced thermal and visual imagery, AI-classified severity ratings, estimated remediation costs, priority rankings, recommended maintenance timelines, and an executive summary suitable for leadership and insurance stakeholders.',
  },
  {
    q: 'How do you handle data security for sensitive facilities?',
    a: 'Our operations are led by a CISSP and CCSP. All data is encrypted in transit and at rest, stored in SOC 2-compliant infrastructure, and purged according to your retention policy. We execute NDAs and security agreements before any engagement.',
  },
