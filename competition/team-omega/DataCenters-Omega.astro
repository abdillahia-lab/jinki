  },
  {
    id: 'membrane',
    icon: 'roofing',
    title: 'Membrane Degradation',
    summary: 'Aging, cracking, and delamination detected across entire roof area.',
    description: 'Multi-spectral imaging identifies UV degradation, seam failures, and mechanical damage across roofing membranes. AI-generated heatmaps prioritize sections by remaining service life.',
    detection: 'Combined visual + thermal survey with machine learning classification of degradation patterns.',
