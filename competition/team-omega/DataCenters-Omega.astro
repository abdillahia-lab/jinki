  },
  {
    id: 'equipment',
    icon: 'dns',
    title: 'Equipment Overheating',
    summary: 'Generators, UPS, and backup systems monitored without disruption.',
    description: 'Exterior thermal signatures from generators, UPS housings, and fuel systems reveal internal stress conditions. Trend analysis across autonomous missions tracks degradation velocity.',
    detection: 'Autonomous scheduled thermal patrols with AI trend analysis and anomaly alerting.',
    cost: 'Prevented cost: $250K-$3M per critical backup system failure during load transfer.',
  },
