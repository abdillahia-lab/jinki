---
/*
  TEAM OMEGA — Data Centers Vertical Redesign
  Jinki Aerial Intelligence — Round 3

  Sections:
  1. 3D Facility Flythrough Hero
  2. Stats Bar
  3. Interactive Problem Explorer
  4. Live Dashboard Mockup
  5. Testimonial Carousel
  6. Technology Stack Showcase
  7. Pricing Tier Cards
  8. FAQ Accordion
  9. LeadGen + Footer
*/
import Layout from '../../src/layouts/Layout.astro';
import Nav from '../../src/components/Nav.astro';
import LeadGen from '../../src/components/LeadGen.astro';
import Footer from '../../src/components/Footer.astro';

const stats = [
