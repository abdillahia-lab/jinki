<style>
  /* ============================================================
     FLOATING KEYFRAMES
     ============================================================ */
  @keyframes floatA {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-18px) rotate(3deg); }
    50% { transform: translateY(-8px) rotate(-2deg); }
    75% { transform: translateY(-22px) rotate(1deg); }
  }

  @keyframes floatB {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    30% { transform: translateY(-14px) rotate(-4deg); }
    60% { transform: translateY(-24px) rotate(2deg); }
  }

  @keyframes floatC {
    0%, 100% { transform: translateY(0) rotate(0deg) scale(1); }
    33% { transform: translateY(-16px) rotate(3deg) scale(1.02); }
    66% { transform: translateY(-10px) rotate(-2deg) scale(0.98); }
  }

  /* ============================================================
     HOLOGRAM
     ============================================================ */
  @keyframes holoFlicker {
    0%, 100% { opacity: 0; }
    5% { opacity: 0.1; }
    5.5% { opacity: 0; }
    10% { opacity: 0.05; }
    10.5% { opacity: 0; }
    50% { opacity: 0; }
    50.5% { opacity: 0.08; }
    51% { opacity: 0; }
    75% { opacity: 0; }
    75.2% { opacity: 0.12; }
    75.5% { opacity: 0; }
  }

  @keyframes holoGlitch {
    0%, 100% { clip-path: inset(0 0 0 0); transform: translateX(0); }
    20% { clip-path: inset(10% 0 80% 0); transform: translateX(3px); }
    21% { clip-path: inset(0 0 0 0); transform: translateX(0); }
    40% { clip-path: inset(60% 0 10% 0); transform: translateX(-2px); }
    41% { clip-path: inset(0 0 0 0); transform: translateX(0); }
    60% { clip-path: inset(30% 0 50% 0); transform: translateX(4px); }
    61% { clip-path: inset(0 0 0 0); transform: translateX(0); }
  }

  .holo-flicker {
    animation: holoFlicker 4s ease-in-out infinite;
    background: rgba(0, 229, 255, 0.1);
  }

  .holo-text-r {
    animation: holoGlitch 8s step-end infinite;
  }

  .holo-text-b {
    animation: holoGlitch 8s step-end infinite reverse;
  }

  /* ============================================================
     CAROUSEL
     ============================================================ */
  .carousel-card-inner::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
  }

  .carousel-prev:hover,
  .carousel-next:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .carousel-auto:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .carousel-auto.playing {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
  }

  /* ============================================================
     FOLDING
     ============================================================ */
  .fold-trigger:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
  }

  .fold-item.open .fold-trigger {
    border-radius: 12px 12px 0 0;
  }

  .fold-item.open .fold-chevron {
    transform: rotate(180deg);
  }

  .fold-item.open .fold-content {
    max-height: 300px;
  }

  .fold-item.open .fold-panel {
    transform: rotateX(0deg);
    opacity: 1;
  }

  /* ============================================================
     DEPTH SCROLL bg grid
     ============================================================ */
  .depth-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.5;
  }

  /* ============================================================
     LIGHT THEME
     ============================================================ */
  :global([data-theme="light"]) .holo-container {
    background: rgba(240, 241, 243, 1);
  }

  :global([data-theme="light"]) .holo-scanlines {
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,131,143,0.03) 2px, rgba(0,131,143,0.03) 4px);
  }

  :global([data-theme="light"]) .holo-flicker {
    background: rgba(0, 131, 143, 0.05);
