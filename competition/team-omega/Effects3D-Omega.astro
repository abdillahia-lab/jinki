    .float-stage {
      height: 280px !important;
    }
  }
</style>

<script>
  /* ============================================================
     EFFECTS3D-OMEGA CONTROLLER
     ============================================================ */
  (function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ---- 1. 3D CAROUSEL ----
    const ring = document.querySelector('.carousel-ring') as HTMLElement;
    const prevBtn = document.querySelector('.carousel-prev');
    const nextBtn = document.querySelector('.carousel-next');
    const autoBtn = document.querySelector('.carousel-auto');
    let carouselAngle = 0;
    let autoRotating = false;
    let autoInterval: ReturnType<typeof setInterval>;

    function rotateCarousel(angle: number) {
      carouselAngle = angle;
      if (ring) ring.style.transform = `rotateY(${angle}deg)`;
    }

    prevBtn?.addEventListener('click', () => {
      rotateCarousel(carouselAngle + 60);
    });

    nextBtn?.addEventListener('click', () => {
      rotateCarousel(carouselAngle - 60);
    });

    autoBtn?.addEventListener('click', () => {
      autoRotating = !autoRotating;
      autoBtn.classList.toggle('playing', autoRotating);
      const icon = autoBtn.querySelector('.auto-icon');
      const label = autoBtn.querySelector('.auto-label');
      if (autoRotating) {
        if (icon) icon.textContent = 'pause';
        if (label) label.textContent = 'Pause';
        autoInterval = setInterval(() => rotateCarousel(carouselAngle - 60), 2500);
      } else {
        if (icon) icon.textContent = 'play_arrow';
        if (label) label.textContent = 'Auto';
        clearInterval(autoInterval);
      }
    });

    // Drag to rotate
    let isDragging = false;
    let dragStartX = 0;
    let dragStartAngle = 0;
    const viewport = document.querySelector('.carousel-viewport');

    viewport?.addEventListener('pointerdown', (e) => {
      isDragging = true;
      dragStartX = (e as PointerEvent).clientX;
      dragStartAngle = carouselAngle;
      (viewport as HTMLElement).style.cursor = 'grabbing';
    });

    window.addEventListener('pointermove', (e) => {
      if (!isDragging || !ring) return;
      const dx = e.clientX - dragStartX;
      ring.style.transition = 'none';
      rotateCarousel(dragStartAngle + dx * 0.3);
    });

    window.addEventListener('pointerup', () => {
      if (!isDragging || !ring) return;
      isDragging = false;
      ring.style.transition = 'transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      // Snap to nearest 60deg
      const snapped = Math.round(carouselAngle / 60) * 60;
      rotateCarousel(snapped);
      if (viewport) (viewport as HTMLElement).style.cursor = 'grab';
    });

    if (viewport) (viewport as HTMLElement).style.cursor = 'grab';

    // ---- 2. FOLDING PANELS ----
    document.querySelectorAll('.fold-item').forEach(item => {
      const trigger = item.querySelector('.fold-trigger');
      trigger?.addEventListener('click', () => {
        const wasOpen = item.classList.contains('open');
        // Close all
        document.querySelectorAll('.fold-item').forEach(i => i.classList.remove('open'));
        // Open clicked if it was closed
        if (!wasOpen) item.classList.add('open');
      });
    });

    // ---- 3. DEPTH SCROLL PARALLAX ----
    const depthContainer = document.querySelector('.depth-container') as HTMLElement;
    if (depthContainer && !prefersReducedMotion) {
      const layers = depthContainer.querySelectorAll('.depth-layer');

      function updateDepth() {
        const rect = depthContainer.getBoundingClientRect();
        const containerCenter = rect.top + rect.height / 2;
        const viewCenter = window.innerHeight / 2;
        const offset = (containerCenter - viewCenter) / window.innerHeight;

        layers.forEach(layer => {
          const speed = parseFloat((layer as HTMLElement).dataset.speed || '0.5');
          const translate = offset * speed * 80;
          (layer as HTMLElement).style.transform = `translateY(${translate}px)`;
        });
      }

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateDepth();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
      updateDepth();
    }

    // Generate background grid
    const depthBg = document.querySelector('.depth-bg');
    if (depthBg) {
      for (let i = 0; i < 48; i++) {
        const cell = document.createElement('div');
        cell.style.background = 'var(--border)';
        cell.style.borderRadius = '2px';
        cell.style.opacity = `${0.1 + Math.random() * 0.3}`;
        depthBg.appendChild(cell);
      }
    }

    // ---- 4. HOLOGRAM GLITCH intensification on hover ----
    const holoContainer = document.querySelector('.holo-container');
    if (holoContainer) {
      holoContainer.addEventListener('mouseenter', () => {
        const r = holoContainer.querySelector('.holo-text-r') as HTMLElement;
        const b = holoContainer.querySelector('.holo-text-b') as HTMLElement;
        if (r) r.style.animationDuration = '2s';
        if (b) b.style.animationDuration = '2s';
      });
      holoContainer.addEventListener('mouseleave', () => {
        const r = holoContainer.querySelector('.holo-text-r') as HTMLElement;
        const b = holoContainer.querySelector('.holo-text-b') as HTMLElement;
        if (r) r.style.animationDuration = '8s';
        if (b) b.style.animationDuration = '8s';
      });
    }

    // ---- 5. ANIMATED MESH GRADIENT ----
    const meshCanvas = document.querySelector('.mesh-canvas') as HTMLCanvasElement;
    if (meshCanvas) {
      const ctx = meshCanvas.getContext('2d');
      if (ctx) {
        let mouseX = 0.5;
        let mouseY = 0.5;
        let animFrame: number;
        let time = 0;

        const meshWrapper = meshCanvas.parentElement;
        meshWrapper?.addEventListener('mousemove', (e) => {
          const rect = meshWrapper.getBoundingClientRect();
          mouseX = (e.clientX - rect.left) / rect.width;
          mouseY = (e.clientY - rect.top) / rect.height;
        });

        // Color palette
        const colors = [
          { r: 0, g: 229, b: 255 },   // accent cyan
          { r: 123, g: 97, b: 255 },   // violet
          { r: 52, g: 211, b: 153 },   // green
          { r: 255, g: 140, b: 0 },    // orange
          { r: 0, g: 100, b: 180 },    // deep blue
        ];

        interface Blob {
          x: number; y: number; vx: number; vy: number; r: number; color: {r:number;g:number;b:number};
        }

        const blobs: Blob[] = colors.map((color, i) => ({
          x: (i + 1) / (colors.length + 1),
          y: 0.3 + Math.random() * 0.4,
          vx: (Math.random() - 0.5) * 0.003,
          vy: (Math.random() - 0.5) * 0.003,
          r: 0.25 + Math.random() * 0.15,
          color
        }));

        function resizeMesh() {
          const dpr = window.devicePixelRatio || 1;
          const rect = meshCanvas.getBoundingClientRect();
          meshCanvas.width = rect.width * dpr;
          meshCanvas.height = rect.height * dpr;
          ctx!.scale(dpr, dpr);
        }

        function drawMesh() {
          if (!ctx) return;
          time += 0.005;
          const w = meshCanvas.getBoundingClientRect().width;
          const h = meshCanvas.getBoundingClientRect().height;

          // Update blob positions
          blobs.forEach(blob => {
            blob.x += blob.vx + (mouseX - 0.5) * 0.001;
            blob.y += blob.vy + (mouseY - 0.5) * 0.001;

            // Organic movement
            blob.x += Math.sin(time * 2 + blob.color.r) * 0.001;
            blob.y += Math.cos(time * 1.5 + blob.color.g) * 0.001;

            // Bounce off edges
            if (blob.x < -0.1 || blob.x > 1.1) blob.vx *= -1;
            if (blob.y < -0.1 || blob.y > 1.1) blob.vy *= -1;
            blob.x = Math.max(-0.2, Math.min(1.2, blob.x));
            blob.y = Math.max(-0.2, Math.min(1.2, blob.y));
          });

          // Clear
          ctx.clearRect(0, 0, w, h);

          // Draw blobs with radial gradients
          blobs.forEach(blob => {
            const gradient = ctx!.createRadialGradient(
              blob.x * w, blob.y * h, 0,
              blob.x * w, blob.y * h, blob.r * Math.max(w, h)
            );
            gradient.addColorStop(0, `rgba(${blob.color.r}, ${blob.color.g}, ${blob.color.b}, 0.6)`);
            gradient.addColorStop(0.5, `rgba(${blob.color.r}, ${blob.color.g}, ${blob.color.b}, 0.2)`);
            gradient.addColorStop(1, `rgba(${blob.color.r}, ${blob.color.g}, ${blob.color.b}, 0)`);

            ctx!.fillStyle = gradient;
            ctx!.fillRect(0, 0, w, h);
          });

          // Noise-like texture overlay
          const imageData = ctx.getImageData(0, 0, meshCanvas.width, meshCanvas.height);
          const data = imageData.data;
          for (let i = 0; i < data.length; i += 16) {
            const noise = (Math.random() - 0.5) * 8;
            data[i] = Math.max(0, Math.min(255, data[i] + noise));
            data[i + 1] = Math.max(0, Math.min(255, data[i + 1] + noise));
            data[i + 2] = Math.max(0, Math.min(255, data[i + 2] + noise));
          }
          ctx.putImageData(imageData, 0, 0);

          if (!prefersReducedMotion) {
            animFrame = requestAnimationFrame(drawMesh);
          }
        }

        // Start when visible
        const meshObserver = new IntersectionObserver(entries => {
          if (entries[0].isIntersecting) {
            resizeMesh();
            drawMesh();
            meshObserver.disconnect();
          }
        }, { threshold: 0.1 });
        meshObserver.observe(meshCanvas);

        window.addEventListener('resize', resizeMesh);

        // For reduced motion, draw once
        if (prefersReducedMotion) {
          resizeMesh();
          drawMesh();
        }
      }
    }

  })();
</script>
