---
/**
 * Effects3D-Omega.astro — 3D Visual Effects Showcase
 * TEAM OMEGA | Jinki Aerial Intelligence
 *
 * CSS 3D carousel, folding panels, depth scroll parallax,
 * floating elements, hologram effect, animated mesh gradient.
 * Dark/light theme aware. Respects prefers-reduced-motion.
 */
---

<section class="omega-3d" id="effects3d-omega" style="padding: 80px 0; position: relative; overflow: hidden;">
  <div style="max-width: 1280px; margin: 0 auto; padding: 0 24px;">

    <!-- ============================================================
         SECTION HEADER
         ============================================================ -->
    <header style="text-align: center; margin-bottom: 64px;">
      <span class="omega-label" style="display: inline-block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 16px; padding: 6px 16px; border: 1px solid var(--accent); border-radius: 100px;">Spatial Design System</span>
      <h2 style="font-family: var(--font-headline); font-size: clamp(2rem, 5vw, 3.5rem); color: var(--text-primary); margin-bottom: 16px; letter-spacing: -0.03em;">
        3D <span style="background: linear-gradient(135deg, #7B61FF, var(--accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Visual Effects</span>
      </h2>
      <p style="font-family: var(--font-body); color: var(--text-secondary); font-size: 1.125rem; max-width: 600px; margin: 0 auto;">Depth, dimension, and spatial awareness. Interfaces that exist in three-dimensional space.</p>
    </header>

    <!-- ============================================================
         1. CSS 3D CAROUSEL
         ============================================================ -->
    <div style="margin-bottom: 96px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">3D Carousel</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Cards orbit in true 3D space. Drag to rotate or use the controls below.</p>

      <div class="carousel-viewport" style="perspective: 1200px; height: 360px; display: flex; align-items: center; justify-content: center; position: relative; overflow: visible;">
        <div class="carousel-ring" style="position: relative; width: 240px; height: 300px; transform-style: preserve-3d; transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);">

          <div class="carousel-card" style="position: absolute; width: 240px; height: 300px; border-radius: 16px; backface-visibility: hidden; transform: rotateY(0deg) translateZ(320px); overflow: hidden;">
            <div class="carousel-card-inner" style="width: 100%; height: 100%; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 24px; left: 24px; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, var(--accent), rgba(0,229,255,0.3)); display: flex; align-items: center; justify-content: center;">
                <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #fff;">sensors</span>
              </div>
              <h4 style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary); margin-bottom: 6px;">Thermal Sensing</h4>
              <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5;">Infrared analysis for hotspot detection across critical infrastructure.</p>
            </div>
          </div>

          <div class="carousel-card" style="position: absolute; width: 240px; height: 300px; border-radius: 16px; backface-visibility: hidden; transform: rotateY(60deg) translateZ(320px); overflow: hidden;">
            <div class="carousel-card-inner" style="width: 100%; height: 100%; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 24px; left: 24px; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #7B61FF, rgba(123,97,255,0.3)); display: flex; align-items: center; justify-content: center;">
                <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #fff;">security</span>
              </div>
              <h4 style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary); margin-bottom: 6px;">Perimeter Watch</h4>
              <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5;">Autonomous surveillance with AI-driven anomaly detection algorithms.</p>
            </div>
          </div>

          <div class="carousel-card" style="position: absolute; width: 240px; height: 300px; border-radius: 16px; backface-visibility: hidden; transform: rotateY(120deg) translateZ(320px); overflow: hidden;">
            <div class="carousel-card-inner" style="width: 100%; height: 100%; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 24px; left: 24px; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #34D399, rgba(52,211,153,0.3)); display: flex; align-items: center; justify-content: center;">
                <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #fff;">grass</span>
              </div>
              <h4 style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary); margin-bottom: 6px;">Crop Analysis</h4>
              <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5;">NDVI mapping and multispectral imagery for precision agriculture.</p>
            </div>
          </div>

          <div class="carousel-card" style="position: absolute; width: 240px; height: 300px; border-radius: 16px; backface-visibility: hidden; transform: rotateY(180deg) translateZ(320px); overflow: hidden;">
            <div class="carousel-card-inner" style="width: 100%; height: 100%; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 24px; left: 24px; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #FF8C00, rgba(255,140,0,0.3)); display: flex; align-items: center; justify-content: center;">
                <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #fff;">bolt</span>
              </div>
              <h4 style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary); margin-bottom: 6px;">Grid Inspection</h4>
              <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5;">Power line and substation monitoring for energy infrastructure.</p>
            </div>
          </div>

          <div class="carousel-card" style="position: absolute; width: 240px; height: 300px; border-radius: 16px; backface-visibility: hidden; transform: rotateY(240deg) translateZ(320px); overflow: hidden;">
            <div class="carousel-card-inner" style="width: 100%; height: 100%; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 24px; left: 24px; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, var(--accent), #7B61FF); display: flex; align-items: center; justify-content: center;">
                <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #fff;">analytics</span>
              </div>
              <h4 style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary); margin-bottom: 6px;">Data Fusion</h4>
              <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5;">Multi-sensor data integration for comprehensive intelligence reports.</p>
            </div>
          </div>

          <div class="carousel-card" style="position: absolute; width: 240px; height: 300px; border-radius: 16px; backface-visibility: hidden; transform: rotateY(300deg) translateZ(320px); overflow: hidden;">
            <div class="carousel-card-inner" style="width: 100%; height: 100%; background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; position: relative; overflow: hidden;">
              <div style="position: absolute; top: 24px; left: 24px; width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, #FF4F5E, rgba(255,79,94,0.3)); display: flex; align-items: center; justify-content: center;">
                <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #fff;">deployed_code</span>
              </div>
              <h4 style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary); margin-bottom: 6px;">Autonomous Ops</h4>
              <p style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); line-height: 1.5;">Persistent autonomous deployment with dock-based operations.</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Carousel Controls -->
      <div style="display: flex; justify-content: center; gap: 16px; margin-top: 24px;">
        <button class="carousel-prev" style="width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-primary); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; font-size: 0;" aria-label="Previous card">
          <span style="font-family: 'Material Symbols Outlined'; font-size: 20px;">chevron_left</span>
        </button>
        <button class="carousel-auto" style="height: 48px; border-radius: 24px; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-secondary); cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 0 20px; transition: all 0.2s ease; font-family: var(--font-mono); font-size: 0.75rem;" aria-label="Toggle auto-rotate">
          <span class="auto-icon" style="font-family: 'Material Symbols Outlined'; font-size: 18px;">play_arrow</span>
          <span class="auto-label">Auto</span>
        </button>
        <button class="carousel-next" style="width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--border); background: var(--bg-card); color: var(--text-primary); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; font-size: 0;" aria-label="Next card">
          <span style="font-family: 'Material Symbols Outlined'; font-size: 20px;">chevron_right</span>
        </button>
      </div>
    </div>

    <!-- ============================================================
         2. FOLDING PANELS
         ============================================================ -->
    <div style="margin-bottom: 96px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">Folding Panels</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Click a panel to unfold it in 3D space, revealing content beneath.</p>

      <div class="folding-accordion" style="max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 2px;">

        <div class="fold-item" data-fold="1">
          <button class="fold-trigger" style="width: 100%; padding: 20px 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: all 0.3s ease; font-size: 0;">
            <div style="display: flex; align-items: center; gap: 16px;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: var(--accent);">flight_takeoff</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Autonomous Flight Operations</span>
            </div>
            <span class="fold-chevron" style="font-family: 'Material Symbols Outlined'; font-size: 20px; color: var(--text-tertiary); transition: transform 0.4s ease;">expand_more</span>
          </button>
          <div class="fold-content" style="perspective: 800px; max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
            <div class="fold-panel" style="transform-origin: top center; transform: rotateX(-90deg); opacity: 0; transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s, opacity 0.3s ease 0.1s; padding: 24px; background: var(--surface-container); border: 1px solid var(--border); border-top: none; border-radius: 0 0 12px 12px;">
              <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;">Pre-programmed flight paths execute with centimeter-level precision. AI-powered obstacle avoidance and real-time route adaptation ensure safe, efficient operations across any terrain or facility layout.</p>
              <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); padding: 4px 12px; border: 1px solid var(--accent); border-radius: 100px; opacity: 0.8;">RTK GPS</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); padding: 4px 12px; border: 1px solid var(--accent); border-radius: 100px; opacity: 0.8;">AI Avoidance</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); padding: 4px 12px; border: 1px solid var(--accent); border-radius: 100px; opacity: 0.8;">Auto-Return</span>
              </div>
            </div>
          </div>
        </div>

        <div class="fold-item" data-fold="2">
          <button class="fold-trigger" style="width: 100%; padding: 20px 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: all 0.3s ease; font-size: 0;">
            <div style="display: flex; align-items: center; gap: 16px;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #7B61FF;">hub</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Multi-Sensor Fusion</span>
            </div>
            <span class="fold-chevron" style="font-family: 'Material Symbols Outlined'; font-size: 20px; color: var(--text-tertiary); transition: transform 0.4s ease;">expand_more</span>
          </button>
          <div class="fold-content" style="perspective: 800px; max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
            <div class="fold-panel" style="transform-origin: top center; transform: rotateX(-90deg); opacity: 0; transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s, opacity 0.3s ease 0.1s; padding: 24px; background: var(--surface-container); border: 1px solid var(--border); border-top: none; border-radius: 0 0 12px 12px;">
              <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;">Thermal, visual, LiDAR, and multispectral data streams converge into a unified intelligence layer. Cross-referencing multiple sensor inputs reveals patterns invisible to any single modality.</p>
              <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #7B61FF; padding: 4px 12px; border: 1px solid #7B61FF; border-radius: 100px; opacity: 0.8;">Thermal</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #7B61FF; padding: 4px 12px; border: 1px solid #7B61FF; border-radius: 100px; opacity: 0.8;">LiDAR</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #7B61FF; padding: 4px 12px; border: 1px solid #7B61FF; border-radius: 100px; opacity: 0.8;">NDVI</span>
              </div>
            </div>
          </div>
        </div>

        <div class="fold-item" data-fold="3">
          <button class="fold-trigger" style="width: 100%; padding: 20px 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: all 0.3s ease; font-size: 0;">
            <div style="display: flex; align-items: center; gap: 16px;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #FF8C00;">shield</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Edge AI Processing</span>
            </div>
            <span class="fold-chevron" style="font-family: 'Material Symbols Outlined'; font-size: 20px; color: var(--text-tertiary); transition: transform 0.4s ease;">expand_more</span>
          </button>
          <div class="fold-content" style="perspective: 800px; max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
            <div class="fold-panel" style="transform-origin: top center; transform: rotateX(-90deg); opacity: 0; transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s, opacity 0.3s ease 0.1s; padding: 24px; background: var(--surface-container); border: 1px solid var(--border); border-top: none; border-radius: 0 0 12px 12px;">
              <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;">Onboard AI compute modules process data in real-time at the edge. Anomaly detection, classification, and alerting happen mid-flight without reliance on cloud connectivity.</p>
              <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #FF8C00; padding: 4px 12px; border: 1px solid #FF8C00; border-radius: 100px; opacity: 0.8;">Manifold 3</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #FF8C00; padding: 4px 12px; border: 1px solid #FF8C00; border-radius: 100px; opacity: 0.8;">Real-time</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #FF8C00; padding: 4px 12px; border: 1px solid #FF8C00; border-radius: 100px; opacity: 0.8;">On-device</span>
              </div>
            </div>
          </div>
        </div>

        <div class="fold-item" data-fold="4">
          <button class="fold-trigger" style="width: 100%; padding: 20px 24px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: all 0.3s ease; font-size: 0;">
            <div style="display: flex; align-items: center; gap: 16px;">
              <span style="font-family: 'Material Symbols Outlined'; font-size: 24px; color: #34D399;">insights</span>
              <span style="font-family: var(--font-headline); font-size: 1rem; color: var(--text-primary);">Intelligence Delivery</span>
            </div>
            <span class="fold-chevron" style="font-family: 'Material Symbols Outlined'; font-size: 20px; color: var(--text-tertiary); transition: transform 0.4s ease;">expand_more</span>
          </button>
          <div class="fold-content" style="perspective: 800px; max-height: 0; overflow: hidden; transition: max-height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);">
            <div class="fold-panel" style="transform-origin: top center; transform: rotateX(-90deg); opacity: 0; transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s, opacity 0.3s ease 0.1s; padding: 24px; background: var(--surface-container); border: 1px solid var(--border); border-top: none; border-radius: 0 0 12px 12px;">
              <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.7;">Raw data transforms into actionable intelligence. Prioritized findings, trend analysis, and predictive recommendations delivered through interactive dashboards and automated reports.</p>
              <div style="display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap;">
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #34D399; padding: 4px 12px; border: 1px solid #34D399; border-radius: 100px; opacity: 0.8;">Dashboards</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #34D399; padding: 4px 12px; border: 1px solid #34D399; border-radius: 100px; opacity: 0.8;">Alerts</span>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: #34D399; padding: 4px 12px; border: 1px solid #34D399; border-radius: 100px; opacity: 0.8;">Predictive</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>

    <!-- ============================================================
         3. DEPTH SCROLL — Parallax layers at different z-depths
         ============================================================ -->
    <div style="margin-bottom: 96px;">
      <h3 class="section-subtitle" style="font-family: var(--font-headline); font-size: 1.5rem; color: var(--text-primary); margin-bottom: 12px;">Depth Scroll</h3>
      <p style="font-family: var(--font-body); color: var(--text-tertiary); font-size: 0.875rem; margin-bottom: 32px;">Layers move at different speeds as you scroll, creating a sense of depth.</p>

      <div class="depth-container" style="position: relative; height: 400px; overflow: hidden; border-radius: 16px; background: var(--surface-container-lowest); border: 1px solid var(--border);">
        <!-- Background layer (slowest) -->
        <div class="depth-layer depth-bg" data-speed="0.2" style="position: absolute; inset: -40px; display: grid; grid-template-columns: repeat(8, 1fr); grid-template-rows: repeat(6, 1fr); gap: 2px; opacity: 0.15;">
          <!-- Grid pattern for background -->
        </div>

        <!-- Middle layer -->
        <div class="depth-layer depth-mid" data-speed="0.5" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;">
          <div style="display: flex; gap: 40px; align-items: center;">
            <div class="depth-orb" style="width: 120px; height: 120px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, var(--accent), rgba(0,229,255,0.1)); opacity: 0.3; filter: blur(1px);"></div>
            <div class="depth-orb" style="width: 80px; height: 80px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, #7B61FF, rgba(123,97,255,0.1)); opacity: 0.25; filter: blur(1px);"></div>
            <div class="depth-orb" style="width: 100px; height: 100px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, #FF8C00, rgba(255,140,0,0.1)); opacity: 0.2; filter: blur(1px);"></div>
          </div>
        </div>

        <!-- Foreground layer (fastest) -->
        <div class="depth-layer depth-fg" data-speed="0.9" style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none;">
          <div style="text-align: center;">
            <div style="font-family: var(--font-headline); font-size: clamp(1.5rem, 4vw, 3rem); color: var(--text-primary); font-weight: 700; letter-spacing: -0.03em;">Parallax Depth</div>
            <div style="font-family: var(--font-mono); font-size: 0.8rem; color: var(--accent); margin-top: 8px; letter-spacing: 0.1em;">SCROLL TO EXPERIENCE</div>
          </div>
        </div>

        <!-- Floating particles -->
        <div class="depth-layer depth-particles" data-speed="0.35" style="position: absolute; inset: 0; pointer-events: none;">
          <div class="particle" style="position: absolute; width: 4px; height: 4px; border-radius: 50%; background: var(--accent); top: 20%; left: 15%; opacity: 0.5;"></div>
          <div class="particle" style="position: absolute; width: 3px; height: 3px; border-radius: 50%; background: #7B61FF; top: 60%; left: 30%; opacity: 0.4;"></div>
          <div class="particle" style="position: absolute; width: 5px; height: 5px; border-radius: 50%; background: #34D399; top: 35%; left: 70%; opacity: 0.3;"></div>
          <div class="particle" style="position: absolute; width: 3px; height: 3px; border-radius: 50%; background: #FF8C00; top: 75%; left: 85%; opacity: 0.5;"></div>
