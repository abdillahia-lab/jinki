  /* ============================================================
     REDUCED MOTION
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .float-obj {
      animation: none !important;
    }

    .holo-flicker,
    .holo-text-r,
    .holo-text-b {
      animation: none !important;
    }

    .carousel-ring {
      transition: none !important;
    }

    .fold-panel,
    .fold-content,
    .fold-chevron {
      transition: none !important;
    }

    .depth-layer {
      transform: none !important;
    }
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 640px) {
    .carousel-viewport {
      height: 300px !important;
    }

    .carousel-card {
      width: 180px !important;
      height: 240px !important;
    }

    .holo-stats {
      gap: 16px !important;
