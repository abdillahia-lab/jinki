  :global([data-theme="light"]) .float-obj div {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }

  :global([data-theme="light"]) .depth-container,
  :global([data-theme="light"]) .float-stage {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
