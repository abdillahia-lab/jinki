---
import '../../styles/global.css';
const title = 'Performance Optimization — Team Omega | Jinki';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Team Omega performance optimization deep-dive for Jinki Aerial Intelligence" />
  <title>{title}</title>
  <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=bolt,cached,compress,deployed_code,dns,image,palette,rocket_launch,speed,storage,text_fields,tune&display=swap" rel="stylesheet" />
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('jinki-theme') || 'dark';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  <style is:inline>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body>
  <a href="#main-content" class="skip-to-content">Skip to main content</a>

  <header class="omp-header" role="banner">
    <div class="omp-header-inner">
      <div style="display:flex;align-items:center;gap:12px;">
        <span class="material-symbols-outlined" style="font-size:32px;color:#7B61FF;" aria-hidden="true">rocket_launch</span>
        <div>
          <h1 style="font-size:clamp(18px,3vw,24px);line-height:1.2;">Performance Optimization</h1>
          <p style="font-family:var(--font-mono);font-size:12px;color:#7B61FF;letter-spacing:0.05em;">Team Omega &mdash; Round 15</p>
        </div>
      </div>
    </div>
  </header>

  <main id="main-content" role="main" style="max-width:1200px;margin:0 auto;padding:32px 24px 80px;">

    <!-- Section 1: Core Web Vitals -->
    <section id="cwv" class="omp-section" aria-labelledby="cwv-heading">
      <div class="omp-section-header">
        <span class="sec-num" aria-hidden="true">01</span>
        <h2 id="cwv-heading">Core Web Vitals Optimization</h2>
      </div>
      <div class="omp-card glass-panel" style="border-radius:16px;">
        <p class="omp-desc">Deep analysis of each Core Web Vital with specific optimization strategies applied to Jinki.</p>

        <div class="cwv-deep-grid">
          <div class="cwv-deep-card">
            <div class="cwv-header-row">
              <h3>LCP: Largest Contentful Paint</h3>
              <div class="cwv-score good-score">1.2s</div>
            </div>
            <div class="cwv-target">Target: &lt; 2.5s</div>
            <div class="cwv-breakdown">
              <h4>LCP Element: Hero Heading</h4>
              <div class="breakdown-bars">
                <div class="bbar">
                  <span class="bbar-label">TTFB</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:20%;background:#34d399;"></div></div>
                  <span class="bbar-val">180ms</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Resource load</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:35%;background:#34d399;"></div></div>
                  <span class="bbar-val">320ms</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Render delay</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:45%;background:#ffa500;"></div></div>
                  <span class="bbar-val">410ms</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Element render</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:30%;background:#34d399;"></div></div>
                  <span class="bbar-val">290ms</span>
                </div>
              </div>
              <div class="cwv-actions">
                <span class="cwv-action-tag">Applied</span>
                <ul>
                  <li>Preload hero fonts with <code>fetchpriority="high"</code></li>
                  <li>Inline critical CSS for above-the-fold</li>
                  <li>CDN with edge caching for static assets</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="cwv-deep-card">
            <div class="cwv-header-row">
              <h3>INP: Interaction to Next Paint</h3>
              <div class="cwv-score good-score">45ms</div>
            </div>
            <div class="cwv-target">Target: &lt; 200ms</div>
            <div class="cwv-breakdown">
              <h4>Slowest Interaction: Theme Toggle</h4>
              <div class="breakdown-bars">
                <div class="bbar">
                  <span class="bbar-label">Input delay</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:10%;background:#34d399;"></div></div>
                  <span class="bbar-val">5ms</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Processing</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:25%;background:#34d399;"></div></div>
                  <span class="bbar-val">15ms</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Presentation</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:40%;background:#34d399;"></div></div>
                  <span class="bbar-val">25ms</span>
                </div>
              </div>
              <div class="cwv-actions">
                <span class="cwv-action-tag">Applied</span>
                <ul>
                  <li>CSS custom properties for instant theme swap</li>
                  <li>No JS frameworks = minimal event overhead</li>
                  <li><code>requestAnimationFrame</code> for scroll handlers</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="cwv-deep-card">
            <div class="cwv-header-row">
              <h3>CLS: Cumulative Layout Shift</h3>
              <div class="cwv-score good-score">0.02</div>
            </div>
            <div class="cwv-target">Target: &lt; 0.1</div>
            <div class="cwv-breakdown">
              <h4>Shift Sources</h4>
              <div class="breakdown-bars">
                <div class="bbar">
                  <span class="bbar-label">Font swap</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:15%;background:#34d399;"></div></div>
                  <span class="bbar-val">0.01</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Icon font</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:10%;background:#34d399;"></div></div>
                  <span class="bbar-val">0.01</span>
                </div>
                <div class="bbar">
                  <span class="bbar-label">Images</span>
                  <div class="bbar-track"><div class="bbar-fill" style="width:2%;background:#34d399;"></div></div>
                  <span class="bbar-val">0.00</span>
                </div>
              </div>
              <div class="cwv-actions">
                <span class="cwv-action-tag">Applied</span>
                <ul>
                  <li><code>font-display: swap</code> with size-adjusted fallback</li>
                  <li>Explicit width/height on all media elements</li>
                  <li>Reserved space for dynamic content</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Font Loading Strategy -->
    <section id="fonts" class="omp-section" aria-labelledby="font-heading">
      <div class="omp-section-header">
        <span class="sec-num" aria-hidden="true">02</span>
        <h2 id="font-heading">Font Loading Strategy</h2>
      </div>
      <div class="omp-card glass-panel" style="border-radius:16px;">
        <p class="omp-desc">Optimized font loading with variable fonts, subsetting, and size-adjusted fallbacks.</p>

        <div class="font-strategy-grid">
          <div class="font-card">
            <h3>Variable Fonts</h3>
            <p>Single file serves all weights (300-700). Eliminates multiple font file requests.</p>
            <div class="font-size-compare">
              <div class="font-bar-row">
                <span>Static (6 weights)</span>
                <div class="font-bar-track"><div class="font-bar-fill" style="width:100%;background:#ff4757;"></div></div>
                <span>186 KB</span>
              </div>
              <div class="font-bar-row">
                <span>Variable (1 file)</span>
                <div class="font-bar-track"><div class="font-bar-fill" style="width:40%;background:#34d399;"></div></div>
                <span>74 KB</span>
              </div>
            </div>
          </div>

          <div class="font-card">
            <h3>font-display: swap</h3>
            <p>Text renders immediately with system fallback. Custom font swaps in when loaded.</p>
            <div class="font-timeline">
              <div class="ft-phase block-phase"><span>Block</span><small>0ms</small></div>
              <div class="ft-phase swap-phase"><span>Swap (fallback visible)</span><small>100ms</small></div>
              <div class="ft-phase loaded-phase"><span>Font loaded</span><small>~400ms</small></div>
            </div>
          </div>

          <div class="font-card">
            <h3>Subsetting</h3>
            <p>Remove unused glyphs. Jinki only needs Latin + basic punctuation.</p>
            <div class="font-size-compare">
              <div class="font-bar-row">
                <span>Full charset</span>
                <div class="font-bar-track"><div class="font-bar-fill" style="width:100%;background:#ffa500;"></div></div>
                <span>74 KB</span>
              </div>
              <div class="font-bar-row">
                <span>Latin subset</span>
                <div class="font-bar-track"><div class="font-bar-fill" style="width:35%;background:#34d399;"></div></div>
                <span>26 KB</span>
              </div>
            </div>
          </div>

          <div class="font-card">
            <h3>Size-Adjusted Fallback</h3>
            <p>CSS <code>size-adjust</code> on system fallback minimizes CLS during font swap.</p>
            <div class="code-snippet">
              <code>@font-face {
  font-family: 'Space Grotesk Fallback';
  src: local('Arial');
  size-adjust: 105%;
  ascent-override: 95%;
  descent-override: 22%;
  line-gap-override: 0%;
}</code>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Image Optimization Pipeline -->
    <section id="images" class="omp-section" aria-labelledby="img-heading">
      <div class="omp-section-header">
        <span class="sec-num" aria-hidden="true">03</span>
        <h2 id="img-heading">Image Optimization Pipeline</h2>
      </div>
      <div class="omp-card glass-panel" style="border-radius:16px;">
        <p class="omp-desc">A complete image processing pipeline from source to delivery.</p>

        <div class="pipeline-flow">
          <div class="pipe-step">
            <span class="pipe-num">1</span>
            <h3>Source</h3>
            <p>High-res originals (4000x3000 JPEG/PNG from aerial captures)</p>
          </div>
          <div class="pipe-arrow" aria-hidden="true">&rarr;</div>
          <div class="pipe-step">
            <span class="pipe-num">2</span>
            <h3>Resize</h3>
            <p>Generate 400w, 800w, 1200w, 1600w variants for srcset</p>
          </div>
          <div class="pipe-arrow" aria-hidden="true">&rarr;</div>
          <div class="pipe-step">
            <span class="pipe-num">3</span>
            <h3>Convert</h3>
            <p>AVIF (primary) + WebP (fallback) + JPEG (legacy)</p>
          </div>
          <div class="pipe-arrow" aria-hidden="true">&rarr;</div>
          <div class="pipe-step">
            <span class="pipe-num">4</span>
            <h3>Compress</h3>
            <p>Quality 80 for AVIF, 85 for WebP. Lossless for UI elements.</p>
          </div>
          <div class="pipe-arrow" aria-hidden="true">&rarr;</div>
          <div class="pipe-step">
            <span class="pipe-num">5</span>
            <h3>Deliver</h3>
            <p>CDN with Accept-based content negotiation. Immutable cache headers.</p>
          </div>
        </div>

        <div class="format-comparison" style="margin-top:28px;">
          <h3 style="margin-bottom:14px;">Format Size Comparison (1200px hero image)</h3>
          <div class="format-bars">
            <div class="fmt-row">
              <span class="fmt-label">JPEG</span>
              <div class="fmt-track"><div class="fmt-fill" style="width:100%;background:#ff4757;"></div></div>
              <span class="fmt-size">245 KB</span>
            </div>
            <div class="fmt-row">
              <span class="fmt-label">WebP</span>
              <div class="fmt-track"><div class="fmt-fill" style="width:55%;background:#ffa500;"></div></div>
              <span class="fmt-size">135 KB</span>
            </div>
            <div class="fmt-row">
              <span class="fmt-label">AVIF</span>
              <div class="fmt-track"><div class="fmt-fill" style="width:30%;background:#34d399;"></div></div>
              <span class="fmt-size">74 KB</span>
            </div>
          </div>
        </div>

        <div class="code-block" style="margin-top:24px;">
          <pre><code>&lt;picture&gt;
  &lt;source type="image/avif"
    srcset="hero-400.avif 400w, hero-800.avif 800w, hero-1200.avif 1200w"
    sizes="100vw" /&gt;
  &lt;source type="image/webp"
    srcset="hero-400.webp 400w, hero-800.webp 800w, hero-1200.webp 1200w"
    sizes="100vw" /&gt;
  &lt;img src="hero-800.jpg" alt="Thermal aerial view of data center"
    width="1200" height="800" loading="eager" fetchpriority="high" /&gt;
&lt;/picture&gt;</code></pre>
        </div>
      </div>
    </section>

    <!-- Section 4: Code Splitting -->
    <section id="splitting" class="omp-section" aria-labelledby="split-heading">
      <div class="omp-section-header">
        <span class="sec-num" aria-hidden="true">04</span>
        <h2 id="split-heading">Code Splitting Strategy</h2>
      </div>
      <div class="omp-card glass-panel" style="border-radius:16px;">
        <p class="omp-desc">Astro's island architecture provides automatic code splitting. Only interactive components ship JS.</p>

        <div class="split-visual">
          <div class="split-page">
            <h3 style="text-align:center;margin-bottom:16px;">Page Bundle Analysis</h3>
            <div class="bundle-stack">
              <div class="bundle-bar html-bar">
                <span class="bundle-label">HTML (SSG)</span>
                <span class="bundle-size">12 KB</span>
              </div>
              <div class="bundle-bar css-bar">
                <span class="bundle-label">CSS (Scoped)</span>
                <span class="bundle-size">8 KB</span>
              </div>
              <div class="bundle-bar js-bar">
                <span class="bundle-label">JS (Islands only)</span>
                <span class="bundle-size">3.2 KB</span>
              </div>
              <div class="bundle-bar font-bar">
                <span class="bundle-label">Fonts (cached)</span>
                <span class="bundle-size">100 KB *</span>
              </div>
            </div>
            <p class="bundle-note">* Fonts cached after first page load. Subsequent pages: ~23 KB total.</p>
          </div>

          <div class="split-comparison">
            <h3 style="margin-bottom:12px;">Astro vs. SPA Framework</h3>
            <div class="framework-rows">
              <div class="fw-row">
                <span class="fw-label">Astro (Jinki)</span>
                <div class="fw-track"><div class="fw-fill astro-fill" style="width:15%;"></div></div>
                <span class="fw-size">23 KB</span>
              </div>
              <div class="fw-row">
                <span class="fw-label">Next.js</span>
                <div class="fw-track"><div class="fw-fill next-fill" style="width:55%;"></div></div>
                <span class="fw-size">85 KB</span>
              </div>
              <div class="fw-row">
                <span class="fw-label">Create React App</span>
                <div class="fw-track"><div class="fw-fill cra-fill" style="width:100%;"></div></div>
                <span class="fw-size">156 KB</span>
              </div>
            </div>
          </div>
        </div>

        <div class="island-demo" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Island Architecture</h3>
          <div class="island-visual">
            <div class="island-zone static">
              <span class="island-tag">Static HTML</span>
              Nav, Hero Copy, Footer
            </div>
            <div class="island-zone interactive">
              <span class="island-tag">Island (JS)</span>
              Theme Toggle
            </div>
            <div class="island-zone static">
              <span class="island-tag">Static HTML</span>
              Verticals Grid, Stats
            </div>
            <div class="island-zone interactive">
              <span class="island-tag">Island (JS)</span>
              Lead Gen Form
            </div>
            <div class="island-zone static">
              <span class="island-tag">Static HTML</span>
              Contact, Footer
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 5: Edge Caching -->
    <section id="caching" class="omp-section" aria-labelledby="cache-heading">
      <div class="omp-section-header">
        <span class="sec-num" aria-hidden="true">05</span>
        <h2 id="cache-heading">Edge Caching Headers</h2>
      </div>
      <div class="omp-card glass-panel" style="border-radius:16px;">
        <p class="omp-desc">Optimal cache-control headers for each asset type, maximizing CDN hit rates and minimizing origin load.</p>

        <div class="cache-table-wrap" tabindex="0" role="region" aria-label="Cache headers table">
          <table class="cache-table">
            <thead>
              <tr>
                <th scope="col">Asset Type</th>
                <th scope="col">Cache-Control Header</th>
                <th scope="col">CDN TTL</th>
                <th scope="col">Browser TTL</th>
                <th scope="col">Notes</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>HTML pages</td>
                <td><code>public, max-age=0, s-maxage=3600, stale-while-revalidate=86400</code></td>
                <td>1 hour</td>
                <td>0 (revalidate)</td>
                <td>Always fresh for users, CDN serves stale while revalidating</td>
              </tr>
              <tr>
                <td>CSS/JS (hashed)</td>
                <td><code>public, max-age=31536000, immutable</code></td>
                <td>1 year</td>
                <td>1 year</td>
                <td>Content-hash in filename = safe to cache forever</td>
              </tr>
              <tr>
                <td>Fonts</td>
                <td><code>public, max-age=31536000, immutable</code></td>
                <td>1 year</td>
                <td>1 year</td>
                <td>Self-hosted, versioned filenames</td>
              </tr>
              <tr>
                <td>Images</td>
                <td><code>public, max-age=2592000, stale-while-revalidate=604800</code></td>
                <td>30 days</td>
                <td>30 days</td>
                <td>Images change infrequently</td>
              </tr>
              <tr>
                <td>API responses</td>
                <td><code>private, no-cache, no-store</code></td>
                <td>&mdash;</td>
                <td>0</td>
                <td>Dynamic content, never cached</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="cache-hit-visual" style="margin-top:24px;">
          <h3 style="margin-bottom:12px;">Expected CDN Hit Rate</h3>
          <div class="hit-bar-wrap">
            <div class="hit-bar">
              <div class="hit-fill" style="width:94%;"></div>
            </div>
            <span class="hit-rate">94% cache hit rate</span>
          </div>
          <p style="font-size:13px;color:var(--text-tertiary);margin-top:8px;">Based on typical traffic patterns. Static site + immutable assets = very high cache efficiency.</p>
        </div>
      </div>
    </section>
  </main>

  <style>
    .omp-header {
      background: var(--nav-bg);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 16px 24px;
    }
    .omp-header-inner { max-width: 1200px; margin: 0 auto; }
    .omp-section { margin-bottom: 48px; }
    .omp-section-header {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 20px;
    }
    .sec-num {
      font-family: var(--font-mono);
      font-size: 48px;
      font-weight: 700;
      color: #7B61FF;
      opacity: 0.25;
      line-height: 1;
    }
    .omp-section-header h2 { font-size: clamp(22px, 4vw, 32px); }
    .omp-card { padding: 32px; position: relative; z-index: 0; }
    .omp-desc {
      color: var(--text-secondary);
      font-size: 15px;
      line-height: 1.7;
      margin-bottom: 24px;
    }
    .code-block {
      background: var(--surface-container-low);
      padding: 16px 20px;
      border-radius: 10px;
      overflow-x: auto;
      border: 1px solid var(--border);
    }
    .code-block pre { margin: 0; }
    .code-block code {
      font-family: var(--font-mono);
      font-size: 13px;
      color: #7B61FF;
      line-height: 1.6;
      background: transparent;
    }

    /* CWV Deep Dive */
    .cwv-deep-grid { display: grid; gap: 20px; }
    .cwv-deep-card {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 24px;
      border: 1px solid var(--border);
    }
    .cwv-header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
    .cwv-header-row h3 { font-size: 17px; }
    .cwv-score {
      font-family: var(--font-mono);
      font-size: 22px;
      font-weight: 700;
      padding: 4px 14px;
      border-radius: 8px;
    }
    .good-score { color: #34d399; background: rgba(52,211,153,0.12); }
    .cwv-target { font-family: var(--font-mono); font-size: 12px; color: var(--text-tertiary); margin-bottom: 16px; }
    .cwv-breakdown h4 { font-size: 14px; color: var(--text-secondary); margin-bottom: 10px; }
    .breakdown-bars { display: grid; gap: 8px; }
    .bbar { display: flex; align-items: center; gap: 10px; }
    .bbar-label { font-family: var(--font-label); font-size: 12px; color: var(--text-tertiary); width: 110px; flex-shrink: 0; }
    .bbar-track { flex: 1; height: 16px; background: var(--surface-container-low); border-radius: 4px; overflow: hidden; }
    .bbar-fill { height: 100%; border-radius: 4px; }
    .bbar-val { font-family: var(--font-mono); font-size: 12px; font-weight: 600; color: var(--text-primary); width: 60px; text-align: right; }
    .cwv-actions { margin-top: 14px; }
    .cwv-action-tag {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(52,211,153,0.15);
      color: #34d399;
      font-size: 11px;
      font-weight: 700;
      font-family: var(--font-label);
      margin-bottom: 8px;
    }
    .cwv-actions ul { list-style: none; display: grid; gap: 4px; }
    .cwv-actions li { font-size: 13px; color: var(--text-secondary); padding-left: 16px; position: relative; }
    .cwv-actions li::before { content: '\2022'; position: absolute; left: 0; color: #7B61FF; }
    .cwv-actions code {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--surface-container-low);
      padding: 1px 6px;
      border-radius: 4px;
      color: #7B61FF;
    }

    /* Fonts */
    .font-strategy-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 16px;
    }
    .font-card {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 20px;
      border: 1px solid var(--border);
    }
    .font-card h3 { font-size: 16px; margin-bottom: 8px; }
    .font-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.5; margin-bottom: 12px; }
    .font-card code {
      font-family: var(--font-mono);
      font-size: 12px;
      color: #7B61FF;
    }
    .font-size-compare { display: grid; gap: 8px; }
    .font-bar-row { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-secondary); }
    .font-bar-row span:first-child { width: 100px; flex-shrink: 0; }
    .font-bar-track { flex: 1; height: 14px; background: var(--surface-container-low); border-radius: 4px; overflow: hidden; }
    .font-bar-fill { height: 100%; border-radius: 4px; }
    .font-bar-row span:last-child { font-family: var(--font-mono); font-weight: 600; width: 55px; text-align: right; }
    .font-timeline { display: flex; gap: 4px; margin-top: 8px; }
    .ft-phase {
      flex: 1;
      padding: 10px 8px;
      border-radius: 8px;
      text-align: center;
      font-size: 12px;
      font-family: var(--font-label);
    }
    .ft-phase span { display: block; font-weight: 600; font-size: 11px; }
    .ft-phase small { color: var(--text-tertiary); font-size: 10px; }
    .block-phase { background: rgba(255,71,87,0.1); color: #ff4757; }
    .swap-phase { background: rgba(255,165,0,0.1); color: #ffa500; }
    .loaded-phase { background: rgba(52,211,153,0.1); color: #34d399; }
    .code-snippet {
      background: var(--surface-container-low);
      border-radius: 8px;
      padding: 12px;
      border: 1px solid var(--border);
    }
    .code-snippet code {
      font-family: var(--font-mono);
      font-size: 11px;
      color: #7B61FF;
      white-space: pre;
      line-height: 1.5;
    }

    /* Pipeline */
    .pipeline-flow {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      flex-wrap: wrap;
    }
    .pipe-step {
      flex: 1;
      min-width: 140px;
      background: var(--surface-container);
      border-radius: 12px;
      padding: 16px;
      border: 1px solid var(--border);
    }
    .pipe-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #7B61FF;
      color: #fff;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .pipe-step h3 { font-size: 15px; margin-bottom: 4px; }
    .pipe-step p { font-size: 12px; color: var(--text-secondary); line-height: 1.4; }
    .pipe-arrow { color: #7B61FF; opacity: 0.4; font-size: 20px; align-self: center; }

    .format-bars { display: grid; gap: 8px; }
    .fmt-row { display: flex; align-items: center; gap: 10px; }
    .fmt-label { font-family: var(--font-label); font-size: 13px; color: var(--text-secondary); width: 50px; }
    .fmt-track { flex: 1; height: 20px; background: var(--surface-container); border-radius: 4px; overflow: hidden; }
    .fmt-fill { height: 100%; border-radius: 4px; }
    .fmt-size { font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--text-primary); width: 60px; text-align: right; }

    /* Code Splitting */
    .split-visual {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
    }
    .split-page, .split-comparison {
      background: var(--surface-container);
      border-radius: 12px;
      padding: 24px;
      border: 1px solid var(--border);
    }
    .bundle-stack { display: grid; gap: 6px; }
    .bundle-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-family: var(--font-label);
    }
    .html-bar { background: rgba(123,97,255,0.12); color: #7B61FF; }
    .css-bar { background: rgba(0,229,255,0.12); color: var(--accent); }
    .js-bar { background: rgba(255,165,0,0.12); color: #ffa500; }
    .font-bar { background: rgba(255,255,255,0.05); color: var(--text-tertiary); }
    .bundle-label { font-weight: 600; }
    .bundle-size { font-family: var(--font-mono); font-size: 12px; }
    .bundle-note { font-size: 11px; color: var(--text-tertiary); margin-top: 12px; text-align: center; }

    .framework-rows { display: grid; gap: 10px; }
    .fw-row { display: flex; align-items: center; gap: 10px; }
    .fw-label { font-family: var(--font-label); font-size: 13px; color: var(--text-secondary); width: 120px; flex-shrink: 0; }
    .fw-track { flex: 1; height: 20px; background: var(--surface-container-low); border-radius: 4px; overflow: hidden; }
    .fw-fill { height: 100%; border-radius: 4px; }
    .astro-fill { background: #34d399; }
    .next-fill { background: #ffa500; }
    .cra-fill { background: #ff4757; }
    .fw-size { font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--text-primary); width: 60px; text-align: right; }

    .island-visual { display: flex; gap: 4px; flex-wrap: wrap; }
    .island-zone {
      padding: 14px 16px;
      border-radius: 10px;
      font-size: 13px;
      color: var(--text-secondary);
      flex: 1;
      min-width: 140px;
      text-align: center;
    }
    .island-zone.static { background: var(--surface-container); border: 1px solid var(--border); }
    .island-zone.interactive { background: rgba(123,97,255,0.1); border: 1px solid rgba(123,97,255,0.25); }
    .island-tag {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }
    .island-zone.static .island-tag { color: var(--text-tertiary); }
    .island-zone.interactive .island-tag { color: #7B61FF; }

    /* Cache Table */
    .cache-table-wrap { overflow-x: auto; border-radius: 10px; border: 1px solid var(--border); }
    .cache-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .cache-table thead th {
      text-align: left;
      padding: 12px 14px;
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-tertiary);
      background: var(--surface-container-low);
      border-bottom: 1px solid var(--border);
      white-space: nowrap;
    }
    .cache-table td {
      padding: 10px 14px;
      color: var(--text-secondary);
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    .cache-table code {
      font-family: var(--font-mono);
      font-size: 11px;
      color: #7B61FF;
      word-break: break-all;
    }
    .cache-table tbody tr:last-child td { border-bottom: none; }
    .cache-table tbody tr:hover td { background: rgba(123,97,255,0.05); }

    .hit-bar-wrap { display: flex; align-items: center; gap: 14px; }
    .hit-bar { flex: 1; height: 24px; background: var(--surface-container); border-radius: 6px; overflow: hidden; }
    .hit-fill { height: 100%; background: linear-gradient(90deg, #7B61FF, #34d399); border-radius: 6px; }
    .hit-rate { font-family: var(--font-mono); font-size: 16px; font-weight: 700; color: #34d399; white-space: nowrap; }

    @media (max-width: 768px) {
      .omp-card { padding: 20px; }
      .sec-num { font-size: 36px; }
      .pipe-arrow { display: none; }
      .pipeline-flow { flex-direction: column; }
    }
  </style>
</body>
</html>
