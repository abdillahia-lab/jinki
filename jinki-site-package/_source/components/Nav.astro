---
/*
  Navigation — Jinki Aerial Intelligence

  Design decisions:
  - Sticky nav with backdrop-blur (glassmorphism) per 2025 AI startup trend
  - Transparent on hero, solid on scroll (Anduril pattern)
  - Theme toggle right-aligned with sun/moon icons
  - Nielsen H4 (Consistency): same nav structure across all pages
  - Nielsen H2 (Real-world match): industry-standard nav labels
*/
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '#capabilities', label: 'Capabilities' },
  { href: '#use-cases', label: 'Use Cases' },
  { href: '/blog', label: 'Blog' },
  { href: '#contact', label: 'Contact' },
];
---

<header id="site-nav" class="nav">
  <div class="nav-inner">
    <!-- Logo: Topographic terrain contour mark with embedded flight trajectory.
         Organic contour shapes suggest terrain viewed from altitude.
         A diagonal scan/flight path cuts through the terrain — intelligence in motion.
         Hover animates the flight path and shifts contour opacity. -->
    <a href="/" class="nav-logo" aria-label="Jinki — Home">
      <svg class="logo-mark" width="38" height="38" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Outer terrain contour — organic, irregular -->
        <path class="logo-contour logo-contour-1" d="M8 22 C10 14 18 8 26 10 C34 12 36 20 33 27 C30 34 20 37 13 33 C6 29 6 26 8 22Z" stroke="var(--text-tertiary)" stroke-width="1" opacity="0.4" stroke-linecap="round"/>
        <!-- Mid terrain contour -->
        <path class="logo-contour logo-contour-2" d="M13 21 C14 16 20 12 26 14 C32 16 33 22 30 27 C27 32 20 33 16 30 C12 27 12 24 13 21Z" stroke="var(--accent)" stroke-width="1.1" opacity="0.6" stroke-linecap="round"/>
        <!-- Inner terrain contour — summit -->
        <path class="logo-contour logo-contour-3" d="M17 20 C18 17 22 15 25 17 C28 19 28 23 26 26 C24 29 20 29 18 27 C16 25 16 22 17 20Z" stroke="var(--accent)" stroke-width="1.3" opacity="0.85" stroke-linecap="round"/>
        <!-- Flight trajectory — diagonal scan path cutting across terrain -->
        <path class="logo-flight" d="M6 33 C12 26 18 20 22 18 C26 16 32 10 36 6" stroke="var(--accent)" stroke-width="1.5" stroke-dasharray="0" opacity="0.9" stroke-linecap="round"/>
        <!-- Data acquisition point on flight path — where intelligence is captured -->
        <circle class="logo-datapoint" cx="22" cy="18" r="2.5" fill="var(--accent)" opacity="0.95"/>
        <!-- Secondary data nodes along flight path -->
        <circle cx="14" cy="25" r="1" fill="var(--text-tertiary)" opacity="0.4"/>
        <circle cx="30" cy="11" r="1" fill="var(--text-tertiary)" opacity="0.4"/>
      </svg>
      <span class="logo-wordmark">
        <span class="logo-text">JINKI</span><span class="logo-dot">.ai</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="nav-links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link">{link.label}</a>
      ))}
    </nav>

    <div class="nav-actions">
      <!-- Theme Toggle — Nielsen H3 (User Control): user chooses their preference -->
      <button
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Toggle dark/light mode"
        type="button"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <a href="#contact" class="btn btn-primary nav-cta">Get in Touch</a>

      <!-- Mobile hamburger -->
      <button id="mobile-toggle" class="mobile-toggle" aria-label="Open menu" aria-expanded="false" type="button">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav" aria-label="Mobile navigation">
      {navLinks.map(link => (
        <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
      <a href="#contact" class="btn btn-primary mobile-cta">Get in Touch</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: background-color 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .nav.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom-color: var(--border);
  }

  .nav-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 16px clamp(20px, 5vw, 80px);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    z-index: 10;
  }

  /* Logo mark — terrain contour with flight trajectory */
  .logo-mark {
    flex-shrink: 0;
  }

  .logo-contour {
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    transform-origin: 20px 20px;
  }

  .logo-flight {
    transition: stroke-dasharray 0.6s ease, opacity 0.4s ease;
    stroke-dasharray: 60;
    stroke-dashoffset: 0;
  }

  .logo-datapoint {
    transition: filter 0.4s ease, r 0.3s ease;
  }

  .nav-logo:hover .logo-contour-1 {
    opacity: 0.6;
  }

  .nav-logo:hover .logo-contour-2 {
    opacity: 0.8;
    transform: scale(1.03);
  }

  .nav-logo:hover .logo-contour-3 {
    opacity: 1;
    transform: scale(1.05);
  }

  .nav-logo:hover .logo-flight {
    stroke-dasharray: 4 3;
    opacity: 1;
  }

  .nav-logo:hover .logo-datapoint {
    filter: drop-shadow(0 0 6px var(--accent));
  }

  /* Logo wordmark */
  .logo-wordmark {
    display: flex;
    align-items: baseline;
    line-height: 1;
  }

  .logo-text {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }

  .logo-dot {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 14px;
    color: var(--accent);
    margin-left: 1px;
    transition: color 0.3s ease;
  }

  .nav-links {
    display: flex;
    gap: 32px;
  }

  .nav-link {
    color: var(--text-secondary);
    font-size: 15px;
    font-weight: 400;
    transition: color 0.2s ease;
    text-decoration: none;
    position: relative;
    padding-bottom: 4px;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active {
    color: var(--accent);
  }

  .nav-link.active::after {
    width: 100%;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* Theme Toggle */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Show/hide sun/moon based on theme */
  .icon-moon { display: none; }
  :global([data-theme="light"]) .icon-sun { display: none; }
  :global([data-theme="light"]) .icon-moon { display: block; }

  .nav-cta {
    font-size: 14px;
    padding: 10px 24px;
  }

  /* Mobile hamburger */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 10;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    transition: all 0.3s ease;
    border-radius: 1px;
  }

  .mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    inset: 0;
    background: var(--bg-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    z-index: 5;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .mobile-link {
    font-size: 24px;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .mobile-link:hover {
    color: var(--accent);
  }

  .mobile-cta {
    margin-top: 16px;
  }

  @media (max-width: 768px) {
    .nav-links, .nav-cta {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
  }
</style>

<script is:inline>
  (function() {
    var nav = document.getElementById('site-nav');
    var scrollThreshold = 50;

    // --- Scroll progress bar ---
    var progressBar = document.querySelector('.scroll-progress');

    function updateScroll() {
      // Nav solid/transparent
      if (window.scrollY > scrollThreshold) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
      // Scroll progress
      if (progressBar) {
        var docH = document.documentElement.scrollHeight - window.innerHeight;
        var pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
        progressBar.style.width = pct + '%';
      }
    }

    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();

    // --- Active section highlighting ---
    var navLinksEls = document.querySelectorAll('.nav-link[href^="#"]');
    var sections = [];
    navLinksEls.forEach(function(link) {
      var id = link.getAttribute('href').slice(1);
      var el = document.getElementById(id);
      if (el) sections.push({ el: el, link: link });
    });

    function updateActiveSection() {
      var scrollPos = window.scrollY + 200;
      var activeLink = null;
      sections.forEach(function(s) {
        if (s.el.offsetTop <= scrollPos) {
          activeLink = s.link;
        }
      });
      navLinksEls.forEach(function(l) { l.classList.remove('active'); });
      if (activeLink) activeLink.classList.add('active');
    }

    if (sections.length) {
      window.addEventListener('scroll', updateActiveSection, { passive: true });
      updateActiveSection();
    }

    // --- Theme toggle with smooth rotation ---
    var toggle = document.getElementById('theme-toggle');
    toggle.addEventListener('click', function() {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('jinki-theme', next);
      // Animate toggle button
      toggle.style.transform = 'rotate(180deg) scale(0.8)';
      setTimeout(function() { toggle.style.transform = ''; }, 300);
    });

    // --- Mobile menu ---
    var mobileToggle = document.getElementById('mobile-toggle');
    var mobileMenu = document.getElementById('mobile-menu');

    mobileToggle.addEventListener('click', function() {
      var expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', !expanded);
      mobileMenu.classList.toggle('open');
      mobileMenu.setAttribute('aria-hidden', expanded);
      document.body.style.overflow = expanded ? '' : 'hidden';
    });

    var mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(function(link) {
      link.addEventListener('click', function() {
        mobileToggle.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.remove('open');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  })();
</script>
