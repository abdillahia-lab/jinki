---
/*
  Hero Section — Jinki Aerial Intelligence

  Scrollytelling hero: An SVG aerial intelligence platform assembles
  from exploded components as the user scrolls. Parts start scattered
  and converge into a unified system — intelligence coming together.

  Inspired by Onyx Security's 3D rocket and scrollytelling chip-explode patterns.
  Uses scroll-driven CSS transforms via JS in Layout.astro.
*/
---

<section id="hero" class="hero" aria-label="Hero">
  <!-- Gradient background -->
  <div class="hero-video-wrap">
    <!-- SWAP: Add real video: <source src="/video/hero.mp4" type="video/mp4" /> -->
    <video class="hero-video" autoplay muted loop playsinline aria-hidden="true"></video>
    <div class="hero-gradient-bg" aria-hidden="true"></div>
    <div class="hero-overlay" aria-hidden="true"></div>
  </div>

  <!-- Scroll-driven aerial platform assembly -->
  <div class="hero-platform" aria-hidden="true">
    <svg class="platform-svg" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- BODY: Central fuselage -->
      <g class="platform-part platform-body">
        <path d="M160 150 L200 130 L240 150 L230 165 L170 165Z" stroke="var(--accent)" stroke-width="1.5" fill="rgba(0,212,255,0.05)"/>
        <line x1="185" y1="140" x2="215" y2="140" stroke="var(--accent)" stroke-width="0.8" opacity="0.6"/>
        <circle cx="200" cy="148" r="4" fill="var(--accent)" opacity="0.8"/>
      </g>

      <!-- LEFT ARM: Port boom + rotor -->
      <g class="platform-part platform-left-arm">
        <line x1="160" y1="150" x2="110" y2="130" stroke="var(--text-secondary)" stroke-width="1.2"/>
        <circle cx="110" cy="130" r="18" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.5"/>
        <circle cx="110" cy="130" r="3" fill="var(--accent)" opacity="0.6"/>
      </g>

      <!-- RIGHT ARM: Starboard boom + rotor -->
      <g class="platform-part platform-right-arm">
        <line x1="240" y1="150" x2="290" y2="130" stroke="var(--text-secondary)" stroke-width="1.2"/>
        <circle cx="290" cy="130" r="18" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.5"/>
        <circle cx="290" cy="130" r="3" fill="var(--accent)" opacity="0.6"/>
      </g>

      <!-- REAR LEFT ARM -->
      <g class="platform-part platform-rear-left">
        <line x1="170" y1="165" x2="125" y2="190" stroke="var(--text-secondary)" stroke-width="1.2"/>
        <circle cx="125" cy="190" r="16" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.4"/>
        <circle cx="125" cy="190" r="2.5" fill="var(--accent)" opacity="0.5"/>
      </g>

      <!-- REAR RIGHT ARM -->
      <g class="platform-part platform-rear-right">
        <line x1="230" y1="165" x2="275" y2="190" stroke="var(--text-secondary)" stroke-width="1.2"/>
        <circle cx="275" cy="190" r="16" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.4"/>
        <circle cx="275" cy="190" r="2.5" fill="var(--accent)" opacity="0.5"/>
      </g>

      <!-- SENSOR PAYLOAD: Camera/LiDAR gimbal -->
      <g class="platform-part platform-sensor">
        <rect x="190" y="165" width="20" height="14" rx="3" stroke="var(--accent)" stroke-width="1" fill="rgba(0,212,255,0.08)"/>
        <circle cx="200" cy="172" r="4" stroke="var(--accent)" stroke-width="0.8" fill="none"/>
        <circle cx="200" cy="172" r="1.5" fill="var(--accent)" opacity="0.9"/>
      </g>

      <!-- DATA LINK: Antenna array -->
      <g class="platform-part platform-antenna">
        <line x1="200" y1="130" x2="200" y2="112" stroke="var(--text-secondary)" stroke-width="1"/>
        <circle cx="200" cy="110" r="3" stroke="var(--accent)" stroke-width="0.8" fill="rgba(0,212,255,0.1)"/>
        <!-- Signal arcs -->
        <path d="M192 105 C196 98 204 98 208 105" stroke="var(--accent)" stroke-width="0.6" fill="none" opacity="0.4"/>
        <path d="M188 100 C194 90 206 90 212 100" stroke="var(--accent)" stroke-width="0.5" fill="none" opacity="0.3"/>
      </g>

      <!-- SCAN LINES: Data acquisition visualization -->
      <g class="platform-part platform-scan" opacity="0.3">
        <line x1="200" y1="180" x2="140" y2="260" stroke="var(--accent)" stroke-width="0.5" stroke-dasharray="4 3"/>
        <line x1="200" y1="180" x2="200" y2="270" stroke="var(--accent)" stroke-width="0.5" stroke-dasharray="4 3"/>
        <line x1="200" y1="180" x2="260" y2="260" stroke="var(--accent)" stroke-width="0.5" stroke-dasharray="4 3"/>
        <!-- Scan footprint -->
        <path d="M130 265 C160 255 240 255 270 265" stroke="var(--accent)" stroke-width="0.6" fill="none" stroke-dasharray="2 2"/>
      </g>
    </svg>
  </div>

  <div class="hero-content">
    <span class="label reveal">Aerial Intelligence Platform</span>
    <h1 class="hero-headline reveal reveal-delay-1">
      Intelligence from Above.<br/>
      <span class="gradient-text">Decisions Below.</span>
    </h1>
    <p class="hero-subtitle reveal reveal-delay-2">
      Autonomous aerial systems powered by AI — delivering actionable intelligence
      for infrastructure, security, and agriculture at scale.
    </p>
    <div class="hero-actions reveal reveal-delay-3">
      <a href="#contact" class="btn btn-primary">Get in Touch</a>
      <a href="#capabilities" class="btn btn-secondary">Explore Capabilities</a>
    </div>
  </div>

  <div class="scroll-indicator reveal reveal-delay-4" aria-hidden="true">
    <span class="scroll-text">Scroll to explore</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-gradient-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(0, 212, 255, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(123, 97, 255, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(0, 212, 255, 0.04) 0%, transparent 40%),
      var(--bg-primary);
    animation: ambientShift 20s ease-in-out infinite alternate;
  }

  @keyframes ambientShift {
    0% { opacity: 1; }
    50% { opacity: 0.7; }
    100% { opacity: 1; }
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(5, 5, 8, 0.3) 0%,
      rgba(5, 5, 8, 0.5) 50%,
      rgba(5, 5, 8, 0.95) 100%
    );
  }

  :global([data-theme="light"]) .hero-gradient-bg {
    background:
      radial-gradient(ellipse at 20% 50%, rgba(0, 136, 204, 0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(123, 97, 255, 0.06) 0%, transparent 50%),
      var(--bg-primary);
  }

  :global([data-theme="light"]) .hero-overlay {
    background: linear-gradient(
      to bottom,
      rgba(250, 251, 252, 0.2) 0%,
      rgba(250, 251, 252, 0.5) 50%,
      rgba(250, 251, 252, 0.95) 100%
    );
  }

  /* Scroll-driven aerial platform assembly */
  .hero-platform {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .platform-svg {
    width: min(70vw, 600px);
    height: auto;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  /* Each part starts displaced — JS animates them to origin on scroll */
  .platform-part {
    transition: transform 0.1s linear, opacity 0.1s linear;
    will-change: transform, opacity;
  }

  .platform-body { transform: translateY(-30px); opacity: 0; }
  .platform-left-arm { transform: translate(-60px, -40px); opacity: 0; }
  .platform-right-arm { transform: translate(60px, -40px); opacity: 0; }
  .platform-rear-left { transform: translate(-50px, 50px); opacity: 0; }
  .platform-rear-right { transform: translate(50px, 50px); opacity: 0; }
  .platform-sensor { transform: translateY(40px); opacity: 0; }
  .platform-antenna { transform: translateY(-50px); opacity: 0; }
  .platform-scan { transform: translateY(60px) scaleY(0); opacity: 0; }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 clamp(20px, 5vw, 80px);
    max-width: 900px;
  }

  .hero-headline {
    margin-bottom: 24px;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.25rem);
    max-width: 600px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .scroll-text {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-tertiary);
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.5); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }

    .platform-svg {
      width: 90vw;
      opacity: 0.4;
    }
  }
</style>
