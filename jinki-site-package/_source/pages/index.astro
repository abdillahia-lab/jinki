---
/*
  Home Page — Jinki Aerial Intelligence

  Single-page layout with all sections.
  Layout handles <html>, <head>, fonts, theme, scroll observer.
  Each component is self-contained with scoped styles.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Capabilities from '../components/Capabilities.astro';
import UseCases from '../components/UseCases.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <Nav />
  <main id="main-content">
    <Hero />
    <About />
    <Capabilities />
    <UseCases />
    <Contact />
  </main>
</Layout>
