---
/*
  Blog Listing Page — Jinki Aerial Intelligence

  Displays all blog posts in reverse chronological order.
  Uses Astro content collections for type-safe blog management.
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog — Jinki Aerial Intelligence">
  <Nav />
  <main id="main-content" class="blog-page">
    <div class="section-inner">
      <div class="blog-header reveal">
        <span class="label">Blog</span>
        <h1>Insights & Updates</h1>
        <p class="blog-subtitle">
          The latest on aerial intelligence, autonomous systems, and industry trends.
        </p>
      </div>

      <div class="blog-grid">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class={`blog-card card reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="blog-card-content">
              <div class="blog-meta">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags.length > 0 && (
                  <span class="blog-tag">{post.data.tags[0]}</span>
                )}
              </div>
              <h2 class="blog-card-title">{post.data.title}</h2>
              <p class="blog-card-desc">{post.data.description}</p>
              <span class="blog-read-more">
                Read more
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      )}
    </div>
  </main>
</Layout>

<style>
  .blog-page {
    padding-top: 120px;
    min-height: 100vh;
    background: var(--bg-primary);
  }

  .blog-header {
    margin-bottom: 48px;
  }

  .blog-header h1 {
    margin-bottom: 16px;
  }

  .blog-subtitle {
    max-width: 480px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    padding-bottom: 80px;
  }

  .blog-card {
    text-decoration: none;
    display: block;
  }

  .blog-card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .blog-meta time {
    font-size: 13px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .blog-tag {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 3px 10px;
    border-radius: 4px;
    background: var(--accent-glow);
    color: var(--accent);
  }

  .blog-card-title {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .blog-card-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .blog-read-more {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
  }

  .blog-empty {
    text-align: center;
    padding: 80px 0;
    color: var(--text-tertiary);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
