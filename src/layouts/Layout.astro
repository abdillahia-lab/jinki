---
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';

interface Props {
  title?: string;
  description?: string;
  jsonLd?: Record<string, any>;
}

const {
  title = 'Jinki | Aerial Intelligence for Critical Infrastructure',
  description = 'Jinki turns aerial data into prioritized maintenance recommendations for critical infrastructure — data centers, power grids, perimeters, and agricultural operations.',
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, 'https://jinki.ai').href;

// Default Organization schema (every page)
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Jinki Aerial Intelligence",
  "url": "https://jinki.ai",
  "logo": "https://jinki.ai/images/jinki-logo-512.png",
  "description": "Aerial intelligence platform delivering thermal inspection, condition assessment, and autonomous monitoring for critical infrastructure.",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "info@jinki.ai",
  },
  "sameAs": [],
  "areaServed": "Mid-Atlantic United States",
  "serviceType": ["Aerial Thermal Inspection", "Autonomous Infrastructure Monitoring", "Facility Intelligence Assessment"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="author" content="Jinki Aerial Intelligence" />
    <meta name="theme-color" content="#121416" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme: light)" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://jinki.ai/images/og-default.png" />
    <meta property="og:site_name" content="Jinki Aerial Intelligence" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://jinki.ai/images/og-default.png" />
    <meta name="twitter:creator" content="@jinkiai" />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <!-- Preload critical fonts (self-hosted) -->
    <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Material Symbols (icons only — fonts are self-hosted) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="dns-prefetch" href="https://api.web3forms.com" />
    <link rel="me" href="mailto:info@jinki.ai" />
    <link rel="alternate" type="application/rss+xml" title="Jinki Blog" href="/rss.xml" />
    <link rel="apple-touch-icon" href="/images/jinki-logo.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <meta name="view-transition" content="same-origin" />

    <!-- (JSON-LD structured data is in the head above) -->

    <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('jinki-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <style is:inline>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    <slot />

    <Chatbot />

    <!-- Scroll progress + reveal animations -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Scroll progress bar
        var progressBar = document.querySelector('.scroll-progress');
        function updateProgress() {
          if (progressBar) {
            var docH = document.documentElement.scrollHeight - window.innerHeight;
            var pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
            progressBar.style.width = pct + '%';
          }
        }

        // Scroll reveal
        var reveals = document.querySelectorAll('.reveal');
        if (reveals.length) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
          reveals.forEach(function(el) { observer.observe(el); });
        }

        // Counter animation
        var statValues = document.querySelectorAll('[data-count]');
        if (statValues.length) {
          var counterObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                counterObserver.unobserve(entry.target);
              }
            });
          }, { threshold: 0.3 });
          statValues.forEach(function(el) { counterObserver.observe(el); });
        }

        function animateCounter(el) {
          var target = el.getAttribute('data-count');
          var suffix = el.getAttribute('data-suffix') || '';
          var num = parseFloat(target);
          var isDecimal = target.indexOf('.') !== -1;
          var duration = 1500;
          var start = performance.now();
          function update(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = num * eased;
            el.textContent = isDecimal ? current.toFixed(1) + suffix : Math.round(current) + suffix;
            if (progress < 1) requestAnimationFrame(update);
          }
          requestAnimationFrame(update);
        }

        var scrollTicking = false;
        window.addEventListener('scroll', function() {
          if (!scrollTicking) {
            requestAnimationFrame(function() {
              updateProgress();
              scrollTicking = false;
            });
            scrollTicking = true;
          }
        }, { passive: true });
        updateProgress();
      });
    </script>
  </body>
</html>
