---
import '../styles/global.css';
import Chatbot from '../components/Chatbot.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  jsonLd?: Record<string, any>;
  ogImage?: string;
}

const {
  title = 'Jinki | Aerial Intelligence for Critical Infrastructure',
  description = 'Jinki turns aerial data into prioritized maintenance recommendations for critical infrastructure — data centers, power grids, perimeters, and agricultural operations.',
  jsonLd,
  ogImage = '/images/og-default.png',
} = Astro.props;

const ogImageUrl = ogImage.startsWith('http') ? ogImage : `https://jinki.ai${ogImage}`;

const canonicalUrl = new URL(Astro.url.pathname, 'https://jinki.ai').href;

// Default Organization schema (every page)
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Jinki Aerial Intelligence",
  "url": "https://jinki.ai",
  "logo": "https://jinki.ai/images/jinki-logo-512.png",
  "description": "Aerial intelligence platform delivering thermal inspection, condition assessment, and autonomous monitoring for critical infrastructure.",
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "info@jinki.ai",
  },
  "sameAs": [],
  "areaServed": "Mid-Atlantic United States",
  "serviceType": ["Aerial Thermal Inspection", "Autonomous Infrastructure Monitoring", "Facility Intelligence Assessment"],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="author" content="Jinki Aerial Intelligence" />
    <meta name="theme-color" content="#121416" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme: light)" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Jinki Aerial Intelligence" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:creator" content="@jinkiai" />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" /></noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="dns-prefetch" href="https://api.web3forms.com" />
    <link rel="dns-prefetch" href="https://api.groq.com" />
    <link rel="me" href="mailto:info@jinki.ai" />
    <link rel="alternate" type="application/rss+xml" title="Jinki Blog" href="/rss.xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>{title}</title>
    <meta name="view-transition" content="same-origin" />

    <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>

    <script is:inline>
      (function() {
        var stored;
        try { stored = localStorage.getItem('jinki-theme'); } catch(e) {}
        var theme = (stored === 'light' || stored === 'dark') ? stored : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <style is:inline>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      /* Mobile sticky CTA — hidden on desktop */
      .mobile-sticky-cta {
        display: none;
      }
      @media (max-width: 767px) {
        .mobile-sticky-cta {
          display: block;
          position: fixed;
          bottom: 0;
          transform: translateY(100%);
          transition: transform 0.4s var(--ease-out-premium);
          left: 0;
          right: 0;
          z-index: 9997;
          padding: 10px 16px;
          padding-bottom: max(10px, env(safe-area-inset-bottom));
          background: rgba(18, 20, 22, 0.95);
          backdrop-filter: blur(16px);
          -webkit-backdrop-filter: blur(16px);
          border-top: 1px solid color-mix(in srgb, var(--accent) 10%, transparent);
          box-shadow: 0 -4px 20px color-mix(in srgb, var(--accent) 5%, transparent);
        }
        .mobile-sticky-cta a {
          display: block;
          text-align: center;
          padding: 14px;
          border-radius: 12px;
          background: linear-gradient(135deg, var(--accent), #00a8b5);
          color: var(--text-on-accent);
          font-family: var(--font-headline);
          font-weight: 600;
          font-size: 0.875rem;
          text-transform: uppercase;
          letter-spacing: 0.08em;
          text-decoration: none;
          box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 25%, transparent);
        }
        [data-theme="light"] .mobile-sticky-cta {
          background: rgba(255, 255, 255, 0.96);
          border-top-color: rgba(0,0,0,0.08);
          box-shadow: 0 -4px 16px rgba(0,0,0,0.06);
        }
        /* Hide when footer is visible */
        .mobile-sticky-cta.visible { transform: translateY(0); }
      }
    </style>

    <!-- Speculative prerendering for instant navigation (Chrome 122+) -->
    <script type="speculationrules">
    {
      "prerender": [
        {
          "where": { "href_matches": [
            "/services/intelligence-scan",
            "/verticals/data-centers",
            "/verticals/energy-grid",
            "/verticals/security",
            "/verticals/agriculture",
            "/about",
            "/security"
          ]},
          "eagerness": "moderate"
        }
      ]
    }
    </script>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    <slot />

    <!-- Announce dynamic updates (form success, chatbot messages) to screen readers -->
    <div id="aria-live-region" aria-live="polite" aria-atomic="true" class="sr-only" style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;"></div>

    <Chatbot />
    <CookieConsent />

    <!-- Mobile sticky CTA -->
    <div class="mobile-sticky-cta">
      <a href="#lead-gen">Free Facility Assessment</a>
    </div>

    <!-- Scroll progress + reveal animations -->
    <script is:inline>
      // Prefetch fallback for browsers without Speculation Rules (Safari, Firefox)
      if (!HTMLScriptElement.supports || !HTMLScriptElement.supports('speculationrules')) {
        document.querySelectorAll('a[href^="/"]').forEach(function(a) {
          a.addEventListener('pointerenter', function() {
            if (!document.querySelector('link[href="' + a.pathname + '"]')) {
              var link = document.createElement('link');
              link.rel = 'prefetch';
              link.href = a.pathname;
              document.head.appendChild(link);
            }
          }, { once: true });
        });
      }

      document.addEventListener('DOMContentLoaded', function() {
        // Web Share API — progressive enhancement
        if (navigator.share) {
          document.querySelectorAll('.share-btn').forEach(function(btn) {
            btn.style.display = 'inline-flex';
            btn.addEventListener('click', function() {
              navigator.share({ title: document.title, url: window.location.href });
            });
          });
        }

        // Scroll progress bar
        var progressBar = document.querySelector('.scroll-progress');
        function updateProgress() {
          if (progressBar) {
            var docH = document.documentElement.scrollHeight - window.innerHeight;
            var pct = docH > 0 ? window.scrollY / docH : 0;
            progressBar.style.transform = 'scaleX(' + pct + ')';
          }
        }

        // Scroll reveal
        var reveals = document.querySelectorAll('.reveal');
        if (reveals.length) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
          // Immediate reveal for above-fold — runs synchronously before first paint
          // Below-fold: skip JS observer when CSS scroll-driven animations handle it
          var hasScrollTimeline = CSS.supports('animation-timeline', 'view()');
          reveals.forEach(function(el) {
            var rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight + 100) {
              el.classList.add('revealed');
            } else if (!hasScrollTimeline) {
              observer.observe(el);
            }
          });
        }

        // Counter animation
        var statValues = document.querySelectorAll('[data-count]');
        if (statValues.length) {
          var counterObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                counterObserver.unobserve(entry.target);
              }
            });
          }, { threshold: 0.3 });
          statValues.forEach(function(el) { counterObserver.observe(el); });
        }

        function animateCounter(el) {
          var target = el.getAttribute('data-count');
          var suffix = el.getAttribute('data-suffix') || '';
          var num = parseFloat(target);
          if (isNaN(num)) return;
          var isDecimal = target.indexOf('.') !== -1;
          var duration = 1400;
          var start = performance.now();
          function update(now) {
            var elapsed = now - start;
            var t = Math.min(elapsed / duration, 1);
            // Instrument calibration: fast spin → decelerate → overshoot → settle
            var eased = 1 - Math.pow(1 - t, 4) * Math.cos(t * Math.PI * 2);
            var current = num * Math.min(eased, 1.03); // Allow 3% overshoot
            if (t >= 1) current = num; // Lock to exact value
            el.textContent = isDecimal ? current.toFixed(1) + suffix : Math.round(current) + suffix;
            if (t < 1) requestAnimationFrame(update);
          }
          requestAnimationFrame(update);
        }

        // Sticky CTA visibility
        var stickyCta = document.querySelector('.mobile-sticky-cta');

        var scrollTicking = false;
        window.addEventListener('scroll', function() {
          if (!scrollTicking) {
            requestAnimationFrame(function() {
              updateProgress();
              // Show sticky CTA after scrolling 400px
              if (stickyCta) {
                if (window.scrollY > 400) { stickyCta.classList.add('visible'); }
                else { stickyCta.classList.remove('visible'); }
              }
              scrollTicking = false;
            });
            scrollTicking = true;
          }
        }, { passive: true });
        updateProgress();

        // Card tilt micro-interaction
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.querySelectorAll('[data-tilt]').forEach(function(card) {
            card.addEventListener('mousemove', function(e) {
              var rect = card.getBoundingClientRect();
              var x = (e.clientX - rect.left) / rect.width - 0.5;
              var y = (e.clientY - rect.top) / rect.height - 0.5;
              card.style.transform = 'perspective(800px) rotateX(' + (-y * 4) + 'deg) rotateY(' + (x * 4) + 'deg) translateY(-2px)';
            });
            card.addEventListener('mouseleave', function() {
              card.style.transform = '';
            });
          });

          // Magnetic CTA — subtle pull toward cursor on hover
          document.querySelectorAll('.btn-premium, .cta-primary').forEach(function(btn) {
            btn.addEventListener('mousemove', function(e) {
              var rect = btn.getBoundingClientRect();
              var x = e.clientX - rect.left - rect.width / 2;
              var y = e.clientY - rect.top - rect.height / 2;
              btn.style.transform = 'translate(' + (x * 0.15) + 'px,' + (y * 0.15) + 'px)';
            });
            btn.addEventListener('mouseleave', function() {
              btn.style.transform = '';
            });
          });
        }
      });
    </script>
  </body>
</html>
