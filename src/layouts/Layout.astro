---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jinki | Aerial Intelligence for Critical Infrastructure',
  description = 'Jinki turns aerial data into prioritized maintenance recommendations for infrastructure you can\'t easily reach — power lines, data centers, and farmland.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#121416" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafbfc" media="(prefers-color-scheme: light)" />
    <link rel="canonical" href="https://jinki.ai" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jinki.ai" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Preload critical fonts (self-hosted) -->
    <link rel="preload" href="/fonts/SpaceGrotesk-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Material Symbols (icons only — fonts are self-hosted) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=agriculture,construction,dark_mode,dns,eco,electric_bolt,forest,hub,light_mode,location_on,lock,precision_manufacturing,psychology,radar,rocket_launch,roofing,security,share,shield,solar_power,speed,thermostat,thunderstorm,trending_down,trending_up,verified_user,warning,water_drop,work&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "Jinki",
          "url": "https://jinki.ai",
          "description": description,
          "foundingDate": "2025",
          "areaServed": "Worldwide",
          "serviceType": ["Aerial Intelligence", "Infrastructure Inspection", "Thermal Imaging", "Predictive Maintenance"],
          "knowsAbout": ["aerial data analytics", "infrastructure monitoring", "thermal imaging", "predictive maintenance", "data center inspection", "energy grid inspection", "agricultural intelligence"]
        },
        {
          "@type": "WebSite",
          "name": "Jinki",
          "url": "https://jinki.ai",
          "description": description,
          "potentialAction": {
            "@type": "SearchAction",
            "target": "https://jinki.ai/search?q={search_term_string}",
            "query-input": "required name=search_term_string"
          }
        }
      ]
    })} />

    <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('jinki-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <style is:inline>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>

    <slot />

    <!-- Scroll progress + reveal animations -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // Scroll progress bar
        var progressBar = document.querySelector('.scroll-progress');
        function updateProgress() {
          if (progressBar) {
            var docH = document.documentElement.scrollHeight - window.innerHeight;
            var pct = docH > 0 ? (window.scrollY / docH) * 100 : 0;
            progressBar.style.width = pct + '%';
          }
        }

        // Scroll reveal
        var reveals = document.querySelectorAll('.reveal');
        if (reveals.length) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
          reveals.forEach(function(el) { observer.observe(el); });
        }

        // Counter animation
        var statValues = document.querySelectorAll('[data-count]');
        if (statValues.length) {
          var counterObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                animateCounter(entry.target);
                counterObserver.unobserve(entry.target);
              }
            });
          }, { threshold: 0.3 });
          statValues.forEach(function(el) { counterObserver.observe(el); });
        }

        function animateCounter(el) {
          var target = el.getAttribute('data-count');
          var suffix = el.getAttribute('data-suffix') || '';
          var num = parseFloat(target);
          var isDecimal = target.indexOf('.') !== -1;
          var duration = 1500;
          var start = performance.now();
          function update(now) {
            var elapsed = now - start;
            var progress = Math.min(elapsed / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = num * eased;
            el.textContent = isDecimal ? current.toFixed(1) + suffix : Math.round(current) + suffix;
            if (progress < 1) requestAnimationFrame(update);
          }
          requestAnimationFrame(update);
        }

        var scrollTicking = false;
        window.addEventListener('scroll', function() {
          if (!scrollTicking) {
            requestAnimationFrame(function() {
              updateProgress();
              scrollTicking = false;
            });
            scrollTicking = true;
          }
        }, { passive: true });
        updateProgress();
      });
    </script>
  </body>
</html>
