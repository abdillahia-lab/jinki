---
/*
  Blog Post Page — Jinki Aerial Intelligence
  Immersive hero, floating sidebar with ToC + share,
  pull quotes, lightbox gallery, "up next" bar,
  reading time, reaction buttons, print styles.
  Dark/Light theme aware.
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      nextPost: posts[i + 1] || posts[0],
    },
  }));
}

const { post, nextPost } = Astro.props;
const { Content } = await render(post);

// Word count & reading time — estimate from description + typical article length
const wordCount = post.data.description.split(/\s+/).length * 12; // rough estimate
const readingTime = Math.max(3, Math.ceil(wordCount / 250));

const dateFormatted = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const currentUrl = `https://jinki.ai/blog/${post.id}`;
const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(currentUrl);
---

<Layout title={`${post.data.title} — Jinki Blog`} description={post.data.description} jsonLd={{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "author": { "@type": "Person", "name": post.data.author || "Adnan Abdillahi", "image": "https://jinki.ai/images/founder-adnan.jpg", "url": "https://jinki.ai/about" },
  "publisher": { "@type": "Organization", "name": "Jinki Aerial Intelligence", "url": "https://jinki.ai", "logo": { "@type": "ImageObject", "url": "https://jinki.ai/images/jinki-logo.png" } },
  "image": "https://jinki.ai/images/og-default.png",
  "datePublished": post.data.date.toISOString(),
  "url": currentUrl,
  "mainEntityOfPage": currentUrl
}}>
  <Nav />

  <main id="main-content" class="omega-post-page">
    <!-- Immersive Hero -->
    <section class="omega-post-hero">
      <div class="omega-post-hero-bg">
        {post.data.image ? (
          <img src={post.data.image} alt={post.data.title} class="omega-hero-image" loading="eager" />
        ) : (
          <div class="omega-hero-gradient"></div>
        )}
        <div class="omega-hero-fade"></div>
      </div>
      <div class="omega-post-hero-content">
        <div class="omega-post-hero-inner">
          <!-- Breadcrumb -->
          <nav class="omega-breadcrumb reveal" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true">/</span>
            <a href="/blog">Blog</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page">{post.data.title}</span>
          </nav>

          <div class="omega-post-hero-meta reveal reveal-delay-1" style="margin-bottom: 16px;">
            {post.data.tags.map(tag => (
              <span class="omega-tag">{tag}</span>
            ))}
          </div>

          <h1 class="omega-post-title reveal reveal-delay-1" style="margin-bottom: 20px;">
            {post.data.title}
          </h1>

          <p class="omega-post-desc reveal reveal-delay-2" style="margin-bottom: 24px;">
            {post.data.description}
          </p>

          <div class="omega-post-info reveal reveal-delay-2">
            <div class="omega-author-block">
              <div class="omega-author-avatar" aria-hidden="true">
                {post.data.author.charAt(0)}
              </div>
              <div>
                <span class="omega-author-name">{post.data.author}</span>
                <time class="omega-author-date" datetime={post.data.date.toISOString()}>{dateFormatted}</time>
              </div>
            </div>
            <div class="omega-reading-stats">
              <span class="omega-stat">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {readingTime} min read
              </span>
              <span class="omega-stat">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
                ~{wordCount.toLocaleString()} words
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Article Body with Floating Sidebar -->
    <div class="omega-post-layout" style="padding-top: 48px; padding-bottom: 96px;">
      <div class="omega-post-layout-inner">
        <!-- Floating Sidebar -->
        <aside class="omega-sidebar" aria-label="Article tools">
          <div class="omega-sidebar-sticky">
            <!-- Author Card -->
            <div class="omega-sidebar-card" style="padding: 20px; margin-bottom: 16px;">
              <div class="omega-sidebar-author">
                <div class="omega-author-avatar-sm" aria-hidden="true">
                  {post.data.author.charAt(0)}
                </div>
                <div>
                  <span class="omega-sidebar-author-name">{post.data.author}</span>
                  <span class="omega-sidebar-author-role">Jinki Team</span>
                </div>
              </div>
            </div>

            <!-- Share -->
            <div class="omega-sidebar-card" style="padding: 20px; margin-bottom: 16px;">
              <span class="omega-sidebar-label" style="margin-bottom: 12px;">Share</span>
              <div class="omega-share-buttons">
                <a href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
                   target="_blank" rel="noopener noreferrer"
                   class="omega-share-btn" aria-label="Share on X">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
                   target="_blank" rel="noopener noreferrer"
                   class="omega-share-btn" aria-label="Share on LinkedIn">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
                <button class="omega-share-btn" aria-label="Copy link" id="omega-copy-link" data-url={currentUrl}>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                  </svg>
                </button>
              </div>
            </div>

            <!-- Table of Contents -->
            <div class="omega-sidebar-card" style="padding: 20px;">
              <span class="omega-sidebar-label" style="margin-bottom: 12px;">Contents</span>
              <nav class="omega-toc" aria-label="Table of contents" id="omega-toc">
                <p class="omega-toc-empty">Loading...</p>
              </nav>
            </div>
          </div>
        </aside>

        <!-- Article Content -->
        <article class="omega-article">
          <div class="omega-article-content reveal" id="omega-article-content">
            <Content />
          </div>

          <!-- Reactions -->
          <div class="omega-reactions reveal" style="margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--border);">
            <p class="omega-reactions-label" style="margin-bottom: 16px;">Was this article helpful?</p>
            <div class="omega-reaction-buttons">
              <button class="omega-reaction-btn" data-reaction="insightful" aria-label="Mark as insightful">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="16" x2="12" y2="12"/>
                  <line x1="12" y1="8" x2="12.01" y2="8"/>
                </svg>
                <span>Insightful</span>
                <span class="omega-reaction-count">0</span>
              </button>
              <button class="omega-reaction-btn" data-reaction="helpful" aria-label="Mark as helpful">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
                </svg>
                <span>Helpful</span>
                <span class="omega-reaction-count">0</span>
              </button>
              <button class="omega-reaction-btn" data-reaction="innovative" aria-label="Mark as innovative">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 1 1 7.072 0l-.548.547A3.374 3.374 0 0 0 14 18.469V19a2 2 0 1 1-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                </svg>
                <span>Innovative</span>
                <span class="omega-reaction-count">0</span>
              </button>
            </div>
          </div>

          <!-- Back to blog -->
          <div style="margin-top: 48px;">
            <a href="/blog" class="omega-back-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
              </svg>
              Back to Blog
            </a>
          </div>
        </article>
      </div>
    </div>

    <!-- Up Next Bar -->
    {nextPost && nextPost.id !== post.id && (
      <div class="omega-upnext" id="omega-upnext" role="complementary" aria-label="Next article">
        <div class="omega-upnext-inner">
          <span class="omega-upnext-label">Up Next</span>
          <a href={`/blog/${nextPost.id}`} class="omega-upnext-link">
            <span class="omega-upnext-title">{nextPost.data.title}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <button class="omega-upnext-dismiss" aria-label="Dismiss" id="omega-upnext-dismiss">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>
      </div>
    )}
  </main>
  <Footer />
</Layout>

<style>
  /* ===== Page ===== */
  .omega-post-page {
    min-height: 100vh;
    background: var(--bg-primary);
  }

  /* ===== Immersive Hero ===== */
  .omega-post-hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .omega-post-hero-bg {
    position: absolute;
    inset: 0;
  }

  .omega-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .omega-hero-gradient {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--bg-primary) 0%, var(--bg-elevated) 40%, rgba(0, 229, 255, 0.05) 100%);
  }

  .omega-hero-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--bg-primary) 0%,
      rgba(18, 20, 22, 0.85) 35%,
      rgba(18, 20, 22, 0.5) 60%,
      rgba(18, 20, 22, 0.3) 100%
    );
  }

  :global([data-theme="light"]) .omega-hero-fade {
    background: linear-gradient(
      to top,
      var(--bg-primary) 0%,
      rgba(250, 251, 252, 0.85) 35%,
      rgba(250, 251, 252, 0.5) 60%,
      rgba(250, 251, 252, 0.3) 100%
    );
  }

  .omega-post-hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 160px;
    padding-bottom: 48px;
  }

  .omega-post-hero-inner {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== Breadcrumb ===== */
  .omega-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-tertiary);
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .omega-breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .omega-breadcrumb a:hover {
    color: var(--accent);
  }

  .omega-breadcrumb [aria-current="page"] {
    color: var(--text-tertiary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300px;
  }

  /* ===== Tags ===== */
  .omega-tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 10px;
    border-radius: 4px;
    background: var(--accent-glow);
    color: var(--accent);
    margin-right: 6px;
  }

  .omega-post-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  /* ===== Title & Description ===== */
  .omega-post-title {
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .omega-post-desc {
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 600px;
  }

  /* ===== Author & Stats ===== */
  .omega-post-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .omega-author-block {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .omega-author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent-glow);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }

  .omega-author-name {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .omega-author-date {
    display: block;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--text-tertiary);
  }

  .omega-reading-stats {
    display: flex;
    gap: 16px;
  }

  .omega-stat {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-family: var(--font-mono);
    color: var(--text-tertiary);
  }

  /* ===== Article Layout ===== */
  .omega-post-layout-inner {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
  }

  /* ===== Floating Sidebar ===== */
  .omega-sidebar {
    position: relative;
  }

  .omega-sidebar-sticky {
    position: sticky;
    top: 100px;
  }

  .omega-sidebar-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .omega-sidebar-author {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .omega-author-avatar-sm {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--accent-glow);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }

  .omega-sidebar-author-name {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .omega-sidebar-author-role {
    display: block;
    font-size: 11px;
    color: var(--text-tertiary);
  }

  .omega-sidebar-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  /* ===== Share Buttons ===== */
  .omega-share-buttons {
    display: flex;
    gap: 8px;
  }

  .omega-share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    text-decoration: none;
  }

  .omega-share-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  /* ===== Table of Contents ===== */
  .omega-toc {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .omega-toc-empty {
    font-size: 12px;
    color: var(--text-tertiary);
  }

  .omega-toc a {
    display: block;
    font-size: 12px;
    line-height: 1.4;
    color: var(--text-tertiary);
    text-decoration: none;
    padding: 4px 0 4px 12px;
    border-left: 2px solid var(--border);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .omega-toc a:hover,
  .omega-toc a.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  .omega-toc a[data-level="3"] {
    padding-left: 24px;
    font-size: 11px;
  }

  /* ===== Article Content ===== */
  .omega-article {
    max-width: 720px;
    min-width: 0;
  }

  .omega-article-content {
    font-size: 18px;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .omega-article-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 48px;
    margin-bottom: 16px;
    color: var(--text-primary);
    scroll-margin-top: 100px;
  }

  .omega-article-content :global(h3) {
    font-size: 1.2rem;
    margin-top: 32px;
    margin-bottom: 12px;
    color: var(--text-primary);
    scroll-margin-top: 100px;
  }

  .omega-article-content :global(p) {
    margin-bottom: 24px;
    max-width: none;
  }

  /* Drop cap on first paragraph */
  .omega-article-content :global(p:first-of-type::first-letter) {
    font-family: var(--font-headline);
    font-size: 3.5em;
    font-weight: 700;
    float: left;
    line-height: 0.8;
    margin-right: 0.1em;
    margin-top: 0.05em;
    color: var(--accent);
  }

  .omega-article-content :global(ul),
  .omega-article-content :global(ol) {
    margin-bottom: 24px;
    padding-left: 24px;
  }

  .omega-article-content :global(li) {
    margin-bottom: 8px;
    color: var(--text-secondary);
  }

  .omega-article-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 2px 6px;
    background: var(--bg-card);
    border-radius: 4px;
    color: var(--accent);
  }

  .omega-article-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Pull Quotes / Blockquotes */
  .omega-article-content :global(blockquote) {
    position: relative;
    border: none;
    border-left: none;
    margin: 48px 0;
    padding: 32px 32px 32px 48px;
    background: var(--bg-card);
    border-radius: 12px;
    font-style: italic;
    font-size: 1.15rem;
    line-height: 1.7;
    color: var(--text-primary);
  }

  .omega-article-content :global(blockquote)::before {
    content: '\201C';
    position: absolute;
    top: 12px;
    left: 16px;
    font-size: 4rem;
    font-family: var(--font-headline);
    color: var(--accent);
    opacity: 0.4;
    line-height: 1;
  }

  .omega-article-content :global(blockquote p) {
    margin-bottom: 0;
  }

  /* Images — clickable for lightbox */
  .omega-article-content :global(img) {
    width: 100%;
    border-radius: 12px;
    margin: 32px 0;
    cursor: zoom-in;
    transition: transform 0.3s ease;
  }

  .omega-article-content :global(img:hover) {
    transform: scale(1.01);
  }

  /* ===== Reactions ===== */
  .omega-reactions-label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  .omega-reaction-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .omega-reaction-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-label);
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px 16px;
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }

  .omega-reaction-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
  }

  .omega-reaction-btn.active {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-glow);
  }

  .omega-reaction-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    min-width: 16px;
    text-align: center;
  }

  /* ===== Back Link ===== */
  .omega-back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .omega-back-link:hover {
    gap: 12px;
  }

  /* ===== Up Next Bar ===== */
  .omega-upnext {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg-elevated);
    border-top: 1px solid var(--border);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .omega-upnext.visible {
    transform: translateY(0);
  }

  .omega-upnext.dismissed {
    transform: translateY(100%);
  }

  .omega-upnext-inner {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .omega-upnext-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    white-space: nowrap;
  }

  .omega-upnext-link {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--text-primary);
    min-width: 0;
  }

  .omega-upnext-title {
    font-size: 14px;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .omega-upnext-link svg {
    flex-shrink: 0;
    color: var(--accent);
  }

  .omega-upnext-dismiss {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-tertiary);
    cursor: pointer;
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .omega-upnext-dismiss:hover {
    color: var(--text-primary);
  }

  /* ===== Lightbox ===== */
  .omega-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    animation: omegaFadeIn 0.3s ease;
    padding: 48px;
  }

  .omega-lightbox img {
    max-width: 100%;
    max-height: 100%;
    border-radius: 8px;
    object-fit: contain;
  }

  @keyframes omegaFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .omega-post-layout-inner {
      grid-template-columns: 1fr;
    }

    .omega-sidebar {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .omega-post-hero {
      min-height: 400px;
    }

    .omega-post-hero-inner {
      padding-left: 20px;
      padding-right: 20px;
    }

    .omega-post-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .omega-article-content :global(blockquote) {
      padding: 24px 20px 24px 36px;
      margin: 32px 0;
    }
  }

  /* ===== Print ===== */
  @media print {
    .omega-post-hero-bg,
    .omega-sidebar,
    .omega-upnext,
    .omega-reactions,
    .omega-share-buttons,
    .omega-back-link,
    .omega-lightbox {
      display: none !important;
    }

    .omega-post-hero {
      min-height: auto !important;
      padding: 24px 0 !important;
    }

    .omega-post-layout-inner {
      grid-template-columns: 1fr !important;
    }

    .omega-article {
      max-width: 100% !important;
    }

    .omega-article-content :global(blockquote) {
      border-left: 3px solid #333 !important;
      background: none !important;
      padding-left: 16px !important;
    }

    .omega-article-content :global(blockquote)::before {
      display: none !important;
    }

    .omega-article-content :global(a)::after {
      content: " (" attr(href) ")";
      font-size: 0.8em;
      color: #555 !important;
    }

    .omega-article-content :global(img) {
      max-width: 100% !important;
      page-break-inside: avoid;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // --- Build Table of Contents ---
    const articleContent = document.getElementById('omega-article-content');
    const tocContainer = document.getElementById('omega-toc');
    if (articleContent && tocContainer) {
      const headings = articleContent.querySelectorAll('h2, h3');
      if (headings.length > 0) {
        tocContainer.innerHTML = '';
        headings.forEach((heading, i) => {
          const id = `section-${i}`;
          heading.id = id;
          const link = document.createElement('a');
          link.href = `#${id}`;
          link.textContent = heading.textContent || '';
          link.dataset.level = heading.tagName.toLowerCase().replace('h', '');
          tocContainer.appendChild(link);
        });

        // Active heading tracking
        const tocLinks = tocContainer.querySelectorAll('a');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              tocLinks.forEach(l => l.classList.remove('active'));
              const activeLink = tocContainer.querySelector(`a[href="#${entry.target.id}"]`);
              if (activeLink) activeLink.classList.add('active');
            }
          });
        }, { rootMargin: '-100px 0px -60% 0px' });

        headings.forEach(h => observer.observe(h));
      } else {
        tocContainer.innerHTML = '<p class="omega-toc-empty" style="font-size: 12px; color: var(--text-tertiary);">No sections</p>';
      }
    }

    // --- Copy Link ---
    const copyBtn = document.getElementById('omega-copy-link') as HTMLButtonElement | null;
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const url = copyBtn.dataset.url || window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          const originalHTML = copyBtn.innerHTML;
          copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(() => { copyBtn.innerHTML = originalHTML; }, 2000);
        } catch {}
      });
    }

    // --- Lightbox for images ---
    const images = document.querySelectorAll<HTMLImageElement>('.omega-article-content img');
    images.forEach(img => {
      img.addEventListener('click', () => {
        const lightbox = document.createElement('div');
        lightbox.className = 'omega-lightbox';
        lightbox.setAttribute('role', 'dialog');
        lightbox.setAttribute('aria-label', 'Image preview');
        const clone = document.createElement('img');
        clone.src = img.src;
        clone.alt = img.alt || 'Full size image';
        lightbox.appendChild(clone);
        lightbox.addEventListener('click', () => lightbox.remove());
        document.addEventListener('keydown', function handler(e) {
          if (e.key === 'Escape') {
            lightbox.remove();
            document.removeEventListener('keydown', handler);
          }
        });
        document.body.appendChild(lightbox);
      });
    });

    // --- Up Next Bar ---
    const upnext = document.getElementById('omega-upnext');
    const dismissBtn = document.getElementById('omega-upnext-dismiss');
    if (upnext) {
      let dismissed = false;
      const showThreshold = 0.5; // Show after scrolling 50%

      window.addEventListener('scroll', () => {
        if (dismissed) return;
        const scrollPct = window.scrollY / (document.body.scrollHeight - window.innerHeight);
        if (scrollPct > showThreshold) {
          upnext.classList.add('visible');
        } else {
          upnext.classList.remove('visible');
        }
      });

      if (dismissBtn) {
        dismissBtn.addEventListener('click', () => {
          dismissed = true;
          upnext.classList.remove('visible');
          upnext.classList.add('dismissed');
        });
      }
    }

    // --- Reactions ---
    const reactionBtns = document.querySelectorAll<HTMLButtonElement>('.omega-reaction-btn');
    reactionBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const isActive = btn.classList.contains('active');
        const countEl = btn.querySelector('.omega-reaction-count');
        if (countEl) {
          let count = parseInt(countEl.textContent || '0');
          if (isActive) {
            count = Math.max(0, count - 1);
            btn.classList.remove('active');
          } else {
            count += 1;
            btn.classList.add('active');
          }
          countEl.textContent = String(count);
        }
      });
    });
  });
</script>
