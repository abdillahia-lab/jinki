<script>
  // Department tab switching
  function initTabs() {
    const tabs = document.querySelectorAll('.dept-tab');
    const panels = document.querySelectorAll('.dept-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const dept = (tab as HTMLElement).dataset.dept;

        tabs.forEach(t => {
          t.classList.remove('dept-tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('dept-tab--active');
        tab.setAttribute('aria-selected', 'true');

        panels.forEach(p => {
          const panelEl = p as HTMLElement;
          if (panelEl.dataset.panel === dept) {
            panelEl.classList.add('dept-panel--active');
          } else {
            panelEl.classList.remove('dept-panel--active');
          }
        });
      });
    });

    // Keyboard navigation for tabs
    const tabList = document.querySelector('[role="tablist"]');
    if (tabList) {
      tabList.addEventListener('keydown', (e: Event) => {
        const event = e as KeyboardEvent;
        const tabsArr = Array.from(tabs);
        const currentIndex = tabsArr.findIndex(t => t.getAttribute('aria-selected') === 'true');

        let nextIndex = currentIndex;
        if (event.key === 'ArrowRight') nextIndex = (currentIndex + 1) % tabsArr.length;
        else if (event.key === 'ArrowLeft') nextIndex = (currentIndex - 1 + tabsArr.length) % tabsArr.length;
        else return;

        event.preventDefault();
        (tabsArr[nextIndex] as HTMLElement).click();
        (tabsArr[nextIndex] as HTMLElement).focus();
      });
    }
  }

  // Day in the life expandables
  function initDayInLife() {
    document.querySelectorAll('.dil-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const expanded = btn.getAttribute('aria-expanded') === 'true';
        const controlsId = btn.getAttribute('aria-controls');
        if (!controlsId) return;
        const schedule = document.getElementById(controlsId);
        if (!schedule) return;

        btn.setAttribute('aria-expanded', String(!expanded));
        schedule.setAttribute('aria-hidden', String(expanded));
        schedule.classList.toggle('is-open', !expanded);
      });
    });
  }

  // Waypoint animation on scroll
  function initFlightPath() {
    const hero = document.querySelector('.careers-hero');
    if (!hero) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          hero.classList.add('animate-path');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(hero);
  }

  document.addEventListener('DOMContentLoaded', () => {
    initTabs();
    initDayInLife();
    initFlightPath();
  });
</script>
