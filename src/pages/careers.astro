---
/*
  Careers Page — Adapted from Team Omega Round 11
  Jinki Aerial Intelligence

  "Join the Mission" hero with flight path animation, department tabs,
  day-in-the-life expandables, bento benefits grid, hiring process
  timeline, employee testimonials.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const departments = [
  {
    id: 'engineering',
    name: 'Engineering',
    icon: 'code',
    roles: [
      { title: 'Computer Vision Engineer', type: 'Full-time', location: 'Hybrid — NoVA', desc: 'Build and optimize CV models for thermal anomaly detection, object classification, and geospatial feature extraction from aerial sensor data.' },
      { title: 'Platform Engineer', type: 'Full-time', location: 'Hybrid — NoVA', desc: 'Design and maintain the data pipelines, cloud infrastructure, and deployment tooling that power our intelligence platform.' },
      { title: 'Frontend Engineer', type: 'Full-time', location: 'Remote', desc: 'Craft client-facing dashboards and visualization tools that turn complex aerial intelligence into intuitive, actionable interfaces.' },
    ],
  },
  {
    id: 'operations',
    name: 'Operations',
    icon: 'flight_takeoff',
    roles: [
      { title: 'Aerial Operations Specialist', type: 'Full-time', location: 'On-site — NoVA', desc: 'Plan, execute, and QA autonomous and piloted aerial missions across data centers, energy facilities, and perimeter security sites.' },
      { title: 'Sensor Calibration Technician', type: 'Full-time', location: 'On-site — NoVA', desc: 'Maintain and calibrate thermal, multispectral, and LiDAR sensors to ensure sub-meter accuracy on every capture.' },
    ],
  },
  {
    id: 'business',
    name: 'Business',
    icon: 'handshake',
    roles: [
      { title: 'Enterprise Account Executive', type: 'Full-time', location: 'Hybrid — NoVA', desc: 'Build relationships with data center operators, energy utilities, and facility managers to deliver intelligence solutions at scale.' },
      { title: 'Marketing Lead', type: 'Full-time', location: 'Hybrid — NoVA', desc: 'Own brand narrative, content strategy, and demand generation for an aerial intelligence company selling to critical infrastructure.' },
    ],
  },
  {
    id: 'research',
    name: 'Research',
    icon: 'science',
    roles: [
      { title: 'AI Research Scientist', type: 'Full-time', location: 'Hybrid — NoVA', desc: 'Push the boundaries of aerial AI — multi-modal sensor fusion, predictive anomaly models, and autonomous mission planning algorithms.' },
      { title: 'Geospatial Analyst', type: 'Contract', location: 'Remote', desc: 'Transform raw geospatial captures into high-fidelity intelligence products — orthomosaics, thermal maps, change detection reports.' },
    ],
  },
];

const dayInLife = [
  {
    role: 'Aerial Operations Specialist',
    icon: 'flight_takeoff',
    schedule: [
      { time: '07:00', activity: 'Weather check and mission pre-brief' },
      { time: '08:00', activity: 'Sensor calibration and platform prep' },
      { time: '09:00', activity: 'Execute autonomous thermal scan — data center campus' },
      { time: '11:00', activity: 'Post-flight QA and data upload' },
      { time: '13:00', activity: 'Mission debrief with intelligence team' },
      { time: '14:30', activity: 'Plan next-day multi-site deployment' },
      { time: '16:00', activity: 'Equipment maintenance and battery cycling' },
    ],
  },
  {
    role: 'Computer Vision Engineer',
    icon: 'code',
    schedule: [
      { time: '09:00', activity: 'Standup — review model performance metrics' },
      { time: '09:30', activity: 'Train thermal anomaly detection model on new captures' },
      { time: '12:00', activity: 'Evaluate model outputs against ground truth' },
      { time: '13:30', activity: 'Optimize inference pipeline for edge deployment' },
      { time: '15:00', activity: 'Cross-team review with operations on data quality' },
      { time: '16:30', activity: 'Write documentation and push model updates' },
    ],
  },
  {
    role: 'Enterprise Account Executive',
    icon: 'handshake',
    schedule: [
      { time: '08:30', activity: 'Pipeline review and deal prioritization' },
      { time: '09:30', activity: 'Discovery call with energy utility prospect' },
      { time: '11:00', activity: 'Build custom proposal with intelligence team' },
      { time: '13:00', activity: 'On-site demo at data center facility' },
      { time: '15:00', activity: 'Follow-up and contract review' },
      { time: '16:30', activity: 'CRM updates and next-day prep' },
    ],
  },
];

const benefits = [
  { icon: 'medical_services', title: 'Health & Dental', desc: 'Comprehensive medical, dental, and vision coverage from day one.', size: 'large' },
  { icon: 'savings', title: '401(k) Match', desc: 'Competitive retirement matching to build your future.', size: 'small' },
  { icon: 'laptop_mac', title: 'Premium Gear', desc: 'Top-tier hardware and tools — whatever you need to do your best work.', size: 'small' },
  { icon: 'school', title: 'Learning Budget', desc: '$3,000/year for courses, certifications, and conferences.', size: 'medium' },
  { icon: 'flight', title: 'Flexible PTO', desc: 'Take what you need. We trust you to manage your time.', size: 'medium' },
  { icon: 'home', title: 'Hybrid Work', desc: 'Office in Northern Virginia with flexible remote days.', size: 'small' },
  { icon: 'emoji_events', title: 'Equity', desc: 'Stock options so you share in what we build together.', size: 'large' },
  { icon: 'fitness_center', title: 'Wellness', desc: 'Gym stipend and mental health support included.', size: 'small' },
];

const hiringSteps = [
  { step: 1, title: 'Apply', desc: 'Submit your resume and a brief note about what excites you.', icon: 'description' },
  { step: 2, title: 'Screen', desc: 'A 30-minute conversation to understand your background and goals.', icon: 'call' },
  { step: 3, title: 'Interview', desc: 'Technical deep-dive and team culture fit — no trick questions.', icon: 'groups' },
  { step: 4, title: 'Offer', desc: 'We move fast. Expect a decision within one week of final interview.', icon: 'verified' },
];

const culturePoints = [
  {
    icon: 'rocket_launch',
    title: 'Your Code Flies',
    desc: 'The models and systems you build get deployed on live aerial missions. You see results in the real world — not just dashboards.',
    color: '#00E5FF',
  },
  {
    icon: 'security',
    title: 'Security-First Culture',
    desc: 'Leadership comes from enterprise security backgrounds. Rigor is how we operate — not an afterthought.',
    color: '#34D399',
  },
  {
    icon: 'group',
    title: 'Small Team, Massive Impact',
    desc: 'Hard problems, direct ownership, and the kind of work where every contribution moves the needle.',
    color: '#FF8C00',
  },
];
---

<Layout title="Careers — Jinki Aerial Intelligence" description="Join the team building aerial intelligence for critical infrastructure. Open roles in engineering, operations, business, and research.">
  <Nav />
  <main id="main-content">

    <!-- ============ JOIN THE MISSION HERO ============ -->
    <section class="careers-hero" aria-label="Join Jinki">
      <div class="flight-path-bg" aria-hidden="true">
        <svg class="flight-svg" viewBox="0 0 1200 600" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
          <!-- Flight path curve -->
          <path class="flight-path-line" d="M-50 500 Q200 400 350 300 T600 200 T850 250 T1100 100 T1300 50"
            stroke="url(#pathGrad)" stroke-width="2" fill="none" stroke-dasharray="8 12" />
          <!-- Waypoints -->
          <circle class="waypoint wp-1" cx="350" cy="300" r="6" fill="var(--accent)" opacity="0" />
          <circle class="waypoint wp-2" cx="600" cy="200" r="6" fill="var(--accent)" opacity="0" />
          <circle class="waypoint wp-3" cx="850" cy="250" r="6" fill="var(--accent)" opacity="0" />
          <circle class="waypoint wp-4" cx="1100" cy="100" r="8" fill="var(--accent)" opacity="0" />
          <!-- Waypoint labels -->
          <text class="wp-label" x="350" y="330" fill="var(--text-tertiary)" font-size="10" text-anchor="middle" font-family="var(--font-mono)">APPLY</text>
          <text class="wp-label" x="600" y="230" fill="var(--text-tertiary)" font-size="10" text-anchor="middle" font-family="var(--font-mono)">GROW</text>
          <text class="wp-label" x="850" y="280" fill="var(--text-tertiary)" font-size="10" text-anchor="middle" font-family="var(--font-mono)">LEAD</text>
          <text class="wp-label" x="1100" y="130" fill="var(--text-tertiary)" font-size="10" text-anchor="middle" font-family="var(--font-mono)">IMPACT</text>
          <defs>
            <linearGradient id="pathGrad" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.1" />
              <stop offset="50%" stop-color="var(--accent)" stop-opacity="0.6" />
              <stop offset="100%" stop-color="var(--accent)" stop-opacity="0.1" />
            </linearGradient>
          </defs>
        </svg>
      </div>
      <div class="hero-content">
        <span class="label reveal">Careers</span>
        <h1 class="reveal reveal-delay-1">Join the<br/><span class="hero-gradient">Mission</span></h1>
        <p class="hero-subtitle reveal reveal-delay-2">
          We are building the team that will define how critical infrastructure is
          monitored, maintained, and protected. If hard problems at the intersection of
          aerial systems, AI, and real-world impact excite you — we want to talk.
        </p>
        <a href="#open-roles" class="btn-premium hero-cta reveal reveal-delay-3">View Open Roles</a>
      </div>
    </section>

    <!-- ============ DEPARTMENT TABS ============ -->
    <section id="open-roles" class="section" style="background: var(--surface-dim);" aria-label="Open Roles">
      <div class="section-inner">
        <div class="dept-header reveal" style="text-align: center; margin-bottom: 48px;">
          <span class="label">Open Roles</span>
          <h2>Find Your Team</h2>
          <p style="max-width: 560px; margin: 16px auto 0; color: var(--text-secondary);">
            Select a department to explore current openings.
          </p>
        </div>

        <!-- Tab buttons -->
        <div class="dept-tabs reveal" role="tablist" aria-label="Department filter">
          {departments.map((dept, i) => (
            <button
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${dept.id}`}
              id={`tab-${dept.id}`}
              class={`dept-tab ${i === 0 ? 'dept-tab--active' : ''}`}
              data-dept={dept.id}
            >
              <span class="material-symbols-outlined" style="font-size: 20px; font-variation-settings: 'FILL' 1;" aria-hidden="true">{dept.icon}</span>
              <span>{dept.name}</span>
            </button>
          ))}
        </div>

        <!-- Tab panels -->
        {departments.map((dept, i) => (
          <div
            role="tabpanel"
            id={`panel-${dept.id}`}
            aria-labelledby={`tab-${dept.id}`}
            class={`dept-panel ${i === 0 ? 'dept-panel--active' : ''}`}
            data-panel={dept.id}
          >
            <div class="roles-list">
              {dept.roles.map((role, j) => (
                <div class={`role-card reveal reveal-delay-${j + 1}`}>
                  <div class="role-info">
                    <h3 class="role-title">{role.title}</h3>
                    <div class="role-meta">
                      <span class="role-badge">{role.type}</span>
                      <span class="role-location">
                        <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'FILL' 0;" aria-hidden="true">location_on</span>
                        {role.location}
                      </span>
                    </div>
                    <p class="role-desc">{role.desc}</p>
                  </div>
                  <a href="mailto:careers@jinki.ai" class="role-apply-btn btn-premium" aria-label={`Apply for ${role.title}`}>Apply</a>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ DAY IN THE LIFE ============ -->
    <section class="section" aria-label="Day in the Life">
      <div class="section-inner">
        <div class="dil-header reveal" style="text-align: center; margin-bottom: 48px;">
          <span class="label">Day in the Life</span>
          <h2>What a Typical Day Looks Like</h2>
        </div>

        <div class="dil-grid">
          {dayInLife.map((item, i) => (
            <div class={`dil-card reveal reveal-delay-${i + 1}`}>
              <button
                class="dil-toggle"
                aria-expanded="false"
                aria-controls={`dil-schedule-${i}`}
              >
                <span class="material-symbols-outlined" style="font-size: 24px; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">{item.icon}</span>
                <span class="dil-role-name">{item.role}</span>
                <span class="dil-chevron material-symbols-outlined" aria-hidden="true">expand_more</span>
              </button>
              <div class="dil-schedule" id={`dil-schedule-${i}`} aria-hidden="true">
                <div class="dil-timeline">
                  {item.schedule.map(entry => (
                    <div class="dil-entry">
                      <span class="dil-time">{entry.time}</span>
                      <span class="dil-dot" aria-hidden="true"></span>
                      <span class="dil-activity">{entry.activity}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ BENEFITS BENTO GRID ============ -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Benefits">
      <div class="section-inner">
        <div class="benefits-header reveal" style="text-align: center; margin-bottom: 48px;">
          <span class="label">Benefits</span>
          <h2>What We Offer</h2>
        </div>
        <div class="bento-grid">
          {benefits.map((b, i) => (
            <div class={`bento-card bento-card--${b.size} reveal reveal-delay-${(i % 4) + 1}`}>
              <span class="material-symbols-outlined bento-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{b.icon}</span>
              <h3 class="bento-title">{b.title}</h3>
              <p class="bento-desc">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ HIRING PROCESS ============ -->
    <section class="section" aria-label="Hiring Process">
      <div class="section-inner">
        <div class="hiring-header reveal" style="text-align: center; margin-bottom: 56px;">
          <span class="label">Hiring Process</span>
          <h2>Four Steps to Joining</h2>
          <p style="max-width: 560px; margin: 16px auto 0; color: var(--text-secondary);">
            We respect your time. Our process is designed to be thorough, transparent, and fast.
          </p>
        </div>
        <div class="hiring-timeline">
          {hiringSteps.map((step, i) => (
            <div class={`hiring-step reveal reveal-delay-${i + 1}`}>
              <div class="hiring-step-icon">
                <span class="material-symbols-outlined" style="font-size: 28px; font-variation-settings: 'FILL' 1;" aria-hidden="true">{step.icon}</span>
                <span class="hiring-step-num">{step.step}</span>
              </div>
              {i < hiringSteps.length - 1 && <div class="hiring-connector" aria-hidden="true"></div>}
              <h3 class="hiring-step-title">{step.title}</h3>
              <p class="hiring-step-desc">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ WHY JINKI ============ -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Why Jinki">
      <div class="section-inner">
        <div class="testimonials-header reveal" style="text-align: center; margin-bottom: 48px;">
          <span class="label">The Culture</span>
          <h2>Why Jinki</h2>
        </div>
        <div class="testimonials-grid">
          {culturePoints.map((c, i) => (
            <div class={`testimonial-card reveal reveal-delay-${i + 1}`}>
              <span class="material-symbols-outlined" aria-hidden="true" style={`font-size: 2rem; color: ${c.color}; margin-bottom: 1rem; display: block;`}>{c.icon}</span>
              <h3 style="font-family: var(--font-headline); font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">{c.title}</h3>
              <p class="testimonial-text" style="font-style: normal;">{c.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ BOTTOM CTA ============ -->
    <section class="section" aria-label="Apply" style="text-align: center;">
      <div class="section-inner" style="max-width: 640px; margin: 0 auto;">
        <div class="reveal">
          <span class="label">Ready?</span>
          <h2 style="margin-bottom: 16px;">Your Next Mission Starts Here</h2>
          <p style="margin-bottom: 32px; color: var(--text-secondary); line-height: 1.8;">
            Send your resume and a brief note about what excites you about aerial intelligence.
            We read every submission.
          </p>
          <a href="mailto:careers@jinki.ai" class="btn-premium cta-btn">careers@jinki.ai</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ==================== HERO ==================== */
  .careers-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 120px clamp(20px, 5vw, 80px) 80px;
  }

  .flight-path-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .flight-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .flight-path-line {
    stroke-dashoffset: 1000;
    animation: draw-path 3s ease-out forwards 0.5s;
  }

  @keyframes draw-path {
    to { stroke-dashoffset: 0; }
  }

  .waypoint {
    animation: waypoint-pop 0.4s ease-out forwards;
  }

  .wp-1 { animation-delay: 1.2s; }
  .wp-2 { animation-delay: 1.6s; }
  .wp-3 { animation-delay: 2.0s; }
  .wp-4 { animation-delay: 2.4s; }

  @keyframes waypoint-pop {
    from { opacity: 0; r: 0; }
    to { opacity: 0.8; r: 6; }
  }

  .wp-label {
    opacity: 0;
    animation: label-fade 0.5s ease-out forwards;
  }

  .wp-label:nth-of-type(1) { animation-delay: 1.4s; }
  .wp-label:nth-of-type(2) { animation-delay: 1.8s; }
  .wp-label:nth-of-type(3) { animation-delay: 2.2s; }
  .wp-label:nth-of-type(4) { animation-delay: 2.6s; }

  @keyframes label-fade {
    to { opacity: 0.5; }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 6vw + 0.5rem, 4.5rem);
    margin-bottom: 24px;
    line-height: 1.05;
  }

  .hero-gradient {
    background: linear-gradient(135deg, #00E5FF 0%, #7B61FF 50%, #00E5FF 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease infinite;
  }

  :global([data-theme="light"]) .hero-gradient {
    background: linear-gradient(135deg, #00838f 0%, #4F46E5 50%, #00838f 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.2rem);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .hero-cta {
    display: inline-block;
    margin-top: 32px;
    padding: 14px 36px;
    background: linear-gradient(135deg, var(--accent), #0091a1);
    color: #000;
    font-family: var(--font-headline);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 12px;
    text-decoration: none;
    transition: transform 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                background 0.3s ease;
  }
  .hero-cta:hover {
    transform: translateY(-2px);
  }

  :global([data-theme="light"]) .hero-cta {
    color: #fff;
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px var(--accent-glow-strong);
  }

  /* ==================== DEPARTMENT TABS ==================== */
  .dept-tabs {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .dept-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    color: var(--text-secondary);
    font-family: var(--font-headline);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.25s ease;
    white-space: nowrap;
  }

  .dept-tab:hover {
    background: var(--bg-card-hover);
    color: var(--text-primary);
  }

  .dept-tab--active {
    background: var(--accent-glow);
    border-color: var(--accent);
    color: var(--accent);
  }

  .dept-panel {
    display: none;
  }

  .dept-panel--active {
    display: block;
    animation: panel-in 0.35s ease-out;
  }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .roles-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .role-card {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 32px;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .role-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .role-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .role-info {
    flex: 1;
    min-width: 0;
  }

  .role-title {
    font-family: var(--font-headline);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .role-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .role-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 8px;
    border-radius: 6px;
    background: var(--accent-glow);
    color: var(--accent);
  }

  .role-location {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
  }

  .role-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .role-apply-btn {
    flex-shrink: 0;
    padding: 10px 24px;
    background: linear-gradient(135deg, var(--accent), #0091a1);
    color: #000;
