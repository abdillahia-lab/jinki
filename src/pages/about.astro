---
/*
  About Us Page — Jinki Aerial Intelligence

  Agent 5: Full about page with mission statement, core values,
  founder profile (Adnan Abdillahi), and company narrative.
  Positioned as an aerial intelligence company, not a drone vendor.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';

const values = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    name: 'Security by Design',
    description: 'Built on enterprise security principles, our processes, data handling, and personnel standards meet the same bar as the critical infrastructure we serve.'
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>`,
    name: 'Verified Precision',
    description: 'We hold ourselves to auditable accuracy standards because the organizations that trust us with their facilities cannot afford ambiguity.'
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
    name: 'Intelligence Over Hardware',
    description: 'Platforms are replaceable; the ability to extract reliable, timely insight from aerial data is what changes decisions, and that is where we invest.'
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    name: 'Transparent Partnership',
    description: 'Clients receive honest assessments, clear scope, and no surprises — earning long-term trust matters more to us than closing a single contract.'
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M6 8h.01M6 12h.01M10 8h4"/></svg>`,
    name: 'Mission-First Execution',
    description: 'Every engagement begins and ends with the client\'s operational objective — we measure success by outcomes delivered, not hours flown.'
  }
];

const certifications = [
  { abbr: 'CISSP', full: 'Certified Information Systems Security Professional', issuer: 'ISC2', color: '#00A651' },
  { abbr: 'CCSP', full: 'Certified Cloud Security Professional', issuer: 'ISC2', color: '#0072BC' },
  { abbr: 'AIGP', full: 'AI Governance Professional', issuer: 'IAPP', color: '#8B5CF6' },
  { abbr: 'PMP', full: 'Project Management Professional', issuer: 'PMI', color: '#1B75BC' },
];
---

<Layout title="About — Jinki Aerial Intelligence" description="Learn about Jinki's mission, values, and the team behind our aerial intelligence platform.">
  <Nav />
  <main id="main-content">

    <!-- Hero banner for About page -->
    <section class="about-hero" aria-label="About Jinki">
      <div class="about-hero-inner">
        <span class="label reveal">About Jinki</span>
        <h1 class="reveal reveal-delay-1">The Intelligence Layer<br/><span class="gradient-text">Above Your Operations</span></h1>
        <p class="about-hero-subtitle reveal reveal-delay-2">
          We build autonomous aerial intelligence systems that transform how organizations
          see, understand, and protect their most critical assets.
        </p>
      </div>
    </section>

    <!-- Mission Statement -->
    <section class="section" aria-label="Our Mission">
      <div class="section-inner">
        <div class="mission-grid">
          <div class="mission-content reveal">
            <span class="label">Our Mission</span>
            <h2>Trusted Aerial Intelligence<br/>for Critical Operations</h2>
            <p class="mission-text">
              Jinki Aerial Intelligence exists to give organizations a decisive informational
              advantage over the assets they protect, maintain, and grow. We combine certified
              security expertise, autonomous aerial platforms, and applied AI to transform raw
              flight data into actionable intelligence — delivered with the rigor and
              accountability that critical infrastructure demands.
            </p>
            <p class="mission-text">
              Most aerial operators sell flight time. We built an intelligence company that
              uses aerial platforms as sensors, not products — fusing computer vision,
              geospatial analytics, and domain expertise to turn raw captures into decisions
              our clients can act on the same day. The organizations we serve don't need
              more footage. They need verified answers.
            </p>
          </div>
          <div class="mission-visual reveal reveal-delay-1">
            <div class="mission-visual-graphic" aria-hidden="true">
              <!-- Abstract intelligence visualization -->
              <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="150" cy="150" r="120" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="4 8"/>
                <circle cx="150" cy="150" r="90" stroke="var(--accent)" stroke-width="0.6" stroke-dasharray="3 6" opacity="0.4"/>
                <circle cx="150" cy="150" r="60" stroke="var(--accent)" stroke-width="0.8" stroke-dasharray="2 4" opacity="0.6"/>
                <circle cx="150" cy="150" r="30" stroke="var(--accent)" stroke-width="1" opacity="0.8"/>
                <circle cx="150" cy="150" r="8" fill="var(--accent)" opacity="0.9"/>
                <!-- Data flow lines -->
                <line x1="150" y1="30" x2="150" y2="60" stroke="var(--text-tertiary)" stroke-width="0.5" opacity="0.3"/>
                <line x1="150" y1="240" x2="150" y2="270" stroke="var(--text-tertiary)" stroke-width="0.5" opacity="0.3"/>
                <line x1="30" y1="150" x2="60" y2="150" stroke="var(--text-tertiary)" stroke-width="0.5" opacity="0.3"/>
                <line x1="240" y1="150" x2="270" y2="150" stroke="var(--text-tertiary)" stroke-width="0.5" opacity="0.3"/>
                <!-- Diagonal scan lines -->
                <line x1="65" y1="65" x2="95" y2="95" stroke="var(--text-tertiary)" stroke-width="0.4" opacity="0.2"/>
                <line x1="205" y1="205" x2="235" y2="235" stroke="var(--text-tertiary)" stroke-width="0.4" opacity="0.2"/>
                <line x1="235" y1="65" x2="205" y2="95" stroke="var(--text-tertiary)" stroke-width="0.4" opacity="0.2"/>
                <line x1="65" y1="235" x2="95" y2="205" stroke="var(--text-tertiary)" stroke-width="0.4" opacity="0.2"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <section class="section" style="background: var(--bg-elevated);" aria-label="Core Values">
      <div class="section-inner">
        <div class="values-header reveal">
          <span class="label">Core Values</span>
          <h2>What Drives Every Mission</h2>
          <p class="values-subtitle">
            These aren't aspirational statements — they're operational commitments
            embedded in how we build, fly, and deliver.
          </p>
        </div>

        <div class="values-grid">
          {values.map((val, i) => (
            <div class={`value-card card reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="value-icon" set:html={val.icon} />
              <h3 class="value-name">{val.name}</h3>
              <p class="value-desc">{val.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Founder Profile -->
    <section class="section" aria-label="Leadership">
      <div class="section-inner">
        <div class="founder-header reveal">
          <span class="label">Leadership</span>
          <h2>Founded on Security,<br/>Built for Scale</h2>
        </div>

        <div class="founder-grid">
          <div class="founder-photo-wrap reveal">
            <!-- SWAP: Replace placeholder with actual founder photo -->
            <!-- Place photo at public/images/founder.jpg and update the src below -->
            <div class="founder-photo-placeholder" aria-label="Founder & CEO">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--text-tertiary)" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <span class="photo-swap-label">Upload Photo</span>
            </div>
          </div>

          <div class="founder-bio reveal reveal-delay-1">
            <span class="founder-title">Founder & CEO</span>

            <p class="founder-text">
              Our founder brings a rare combination of deep security credentials and
              operational discipline to aerial intelligence. Holding both the CISSP and CCSP
              certifications from ISC2, he applies the same frameworks that protect
              enterprise networks and cloud environments to safeguarding the sensitive
              data Jinki collects over client facilities — an assurance most aerial
              service providers simply cannot offer.
            </p>
            <p class="founder-text">
              As an IAPP-certified AI Governance Professional (AIGP), he ensures that
              every AI model Jinki deploys is governed with the transparency, fairness,
              and accountability that regulated industries require. His PMI Project
              Management Professional (PMP) credential reflects a career spent delivering
              complex, multi-stakeholder technology programs on schedule and within
              scope — exactly the rigor you want behind the team operating above your
              most critical assets.
            </p>

            <!-- Certification badges with issuing body attribution -->
            <div class="cert-badges-grid">
              {certifications.map(cert => (
                <div class="cert-badge-card" title={cert.full}>
                  <div class="cert-badge-icon" style={`border-color: ${cert.color}; box-shadow: 0 0 12px ${cert.color}20;`}>
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke={cert.color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      <path d="M9 12l2 2 4-4"/>
                    </svg>
                  </div>
                  <span class="cert-badge-abbr" style={`color: ${cert.color};`}>{cert.abbr}</span>
                  <span class="cert-badge-full">{cert.full}</span>
                  <span class="cert-badge-issuer">{cert.issuer}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <Contact />
  </main>
</Layout>

<style>
  /* About Hero */
  .about-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px clamp(20px, 5vw, 80px) 80px;
    text-align: center;
    position: relative;
    background: var(--surface-container-lowest);
  }

  .about-hero-inner {
    max-width: 800px;
  }

  .about-hero h1 {
    margin-bottom: 24px;
  }

  .about-hero-subtitle {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.2rem);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* Mission Section */
  .mission-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 80px;
    align-items: center;
  }

  .mission-content h2 {
    margin-bottom: 24px;
  }

  .mission-text {
    margin-bottom: 20px;
    line-height: 1.8;
  }

  .mission-visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mission-visual-graphic {
    width: 100%;
    max-width: 300px;
    opacity: 0.7;
  }

  .mission-visual-graphic svg {
    width: 100%;
    height: auto;
  }

  /* Values Section */
  .values-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .values-subtitle {
    max-width: 560px;
    margin: 16px auto 0;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* Last two values center in their row */
  .values-grid .value-card:nth-child(4) {
    grid-column: 1 / 2;
    margin-left: auto;
    margin-right: 0;
  }

  .value-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .value-icon {
    color: var(--accent);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border-radius: 12px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .value-card:hover .value-icon {
    transform: scale(1.1);
    box-shadow: 0 0 20px var(--accent-glow-strong);
  }

  .value-name {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .value-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: none;
  }

  /* Founder Section */
  .founder-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .founder-grid {
    display: grid;
    grid-template-columns: 0.4fr 0.6fr;
    gap: 64px;
    align-items: start;
    max-width: 900px;
    margin: 0 auto;
  }

  .founder-photo-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .founder-photo-placeholder {
    width: 220px;
    height: 280px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .founder-photo-placeholder::after {
    display: none;
  }

  .photo-swap-label {
    position: absolute;
    bottom: 16px;
    font-size: 11px;
    color: var(--text-tertiary);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .founder-title {
    display: block;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .founder-text {
    margin-bottom: 16px;
    line-height: 1.8;
    font-size: 16px;
    max-width: none;
  }

  /* Certification badge cards — prominent 2x2 grid */
  .cert-badges-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 28px;
  }

  .cert-badge-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 16px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-align: center;
    transition: all 0.3s ease;
    cursor: default;
  }

  .cert-badge-card:hover {
    border-color: var(--border-hover);
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    transform: translateY(-3px);
  }

  .cert-badge-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
  }

  .cert-badge-abbr {
    font-family: var(--font-mono);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .cert-badge-full {
    font-size: 11px;
    color: var(--text-secondary);
    line-height: 1.3;
  }

  .cert-badge-issuer {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .mission-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .mission-visual {
      order: -1;
    }

    .mission-visual-graphic {
      max-width: 200px;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }

    .values-grid .value-card:nth-child(4) {
      grid-column: auto;
      margin-left: 0;
    }

    .founder-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .founder-photo-wrap {
      align-items: center;
    }
  }
</style>
