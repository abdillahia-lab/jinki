---
/*
  About Page — Adapted from Team Omega Round 11
  Jinki Aerial Intelligence

  Immersive parallax hero, scrollytelling narrative, animated counters,
  team carousel with flip cards, approach methodology pillars,
  office/field visual split.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: 4, suffix: '', label: 'Industry Verticals' },
  { value: 0.5, suffix: '°C', label: 'Thermal Accuracy' },
  { value: 50, suffix: '+ mi', label: 'Daily Corridor Range' },
  { value: 24, suffix: 'hr', label: 'Report Turnaround' },
];

const team = [
  {
    name: 'Adnan Abdillahi',
    role: 'Founder & CEO',
    bio: 'Enterprise security and project management background. Built Jinki from the intersection of cybersecurity expertise and aerial intelligence to deliver verified answers for critical infrastructure.',
    initials: 'AA',
  },
  /* Additional team members will be added as roles are filled */
];

const pillars = [
  {
    id: 'data-first',
    icon: 'database',
    title: 'Data-First',
    summary: 'Every decision begins with verified, high-fidelity data.',
    details: 'We invest in sensor calibration, flight path optimization, and multi-spectral fusion to ensure the data entering our pipeline is trustworthy from the first capture. Raw footage means nothing — validated, georeferenced intelligence is everything.',
  },
  {
    id: 'safety-always',
    icon: 'shield',
    title: 'Safety-Always',
    summary: 'Zero compromises on operational and data security.',
    details: 'From encrypted data-at-rest to security-first workflows built on NIST 800-53 controls, safety is not a feature — it is the foundation. Every mission plan undergoes risk assessment, every model output is audited, and every deliverable chain-of-custody is documented.',
  },
  {
    id: 'impact-driven',
    icon: 'trending_up',
    title: 'Impact-Driven',
    summary: 'We measure success by outcomes, not hours flown.',
    details: 'Clients do not pay for flight time — they pay for answers. Our engagements are scoped around operational impact: reduced inspection costs, faster anomaly detection, actionable maintenance schedules. If it does not move the needle, we do not ship it.',
  },
];

const storyBlocks = [
  {
    title: 'The Problem We Saw',
    text: 'Critical infrastructure operators were drowning in raw aerial footage with no reliable way to convert it into decisions. Most providers sold flight hours — not intelligence.',
    visual: 'signal_cellular_alt',
  },
  {
    title: 'The Company We Built',
    text: 'Jinki was built to be an intelligence layer — not another hardware vendor. We bring together security expertise, AI capability, and operational precision. Aerial platforms are sensors, not products.',
    visual: 'hub',
  },
  {
    title: 'The Standard We Set',
    text: 'Every engagement delivers verified, actionable intelligence with clear next steps. Our founder\'s enterprise security background ensures security is embedded in every pipeline, not bolted on afterward.',
    visual: 'verified_user',
  },
  {
    title: 'Where We Are Going',
    text: 'Autonomous persistent monitoring across every critical vertical — data centers, energy grids, perimeter security, and precision agriculture. Intelligence that never sleeps, scales without limits, and earns trust through transparency.',
    visual: 'rocket_launch',
  },
];
---

<Layout title="About — Jinki Aerial Intelligence" description="Learn about Jinki's mission, values, and the team behind our aerial intelligence platform.">
  <Nav />
  <main id="main-content">

    <!-- ============ PARALLAX HERO ============ -->
    <section class="about-hero" aria-label="About Jinki">
      <div class="parallax-bg" aria-hidden="true">
        <div class="parallax-layer parallax-layer--grid"></div>
        <div class="parallax-layer parallax-layer--silhouettes"></div>
        <div class="parallax-layer parallax-layer--scan"></div>
      </div>
      <div class="about-hero-content">
        <span class="label reveal">About Jinki</span>
        <h1 class="reveal reveal-delay-1">The Intelligence Layer<br/><span class="hero-gradient">Above Your Operations</span></h1>
        <p class="hero-subtitle reveal reveal-delay-2">
          We build autonomous aerial intelligence systems that transform how organizations
          see, understand, and protect their most critical assets.
        </p>
        <div class="hero-scroll-cue reveal reveal-delay-3" aria-hidden="true">
          <span class="scroll-line"></span>
          <span class="scroll-label">Scroll to explore</span>
        </div>
      </div>
    </section>

    <!-- ============ SCROLLYTELLING NARRATIVE ============ -->
    <section class="section" aria-label="Our Story" style="background: var(--surface-dim);">
      <div class="section-inner">
        <div class="story-header reveal" style="text-align: center; margin-bottom: 64px;">
          <span class="label">Our Story</span>
          <h2>How Jinki Came to Be</h2>
        </div>
        <div class="story-timeline">
          {storyBlocks.map((block, i) => (
            <div class={`story-block ${i % 2 === 0 ? 'story-block--left' : 'story-block--right'} reveal`}>
              <div class="story-visual" aria-hidden="true">
                <div class="story-icon-wrap">
                  <span class="material-symbols-outlined" style="font-size: 32px; font-variation-settings: 'FILL' 1;">{block.visual}</span>
                </div>
                <div class="story-connector"></div>
              </div>
              <div class="story-content">
                <h3 style="margin-bottom: 12px;">{block.title}</h3>
                <p style="line-height: 1.8;">{block.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ BY THE NUMBERS ============ -->
    <section class="section stats-section" aria-label="By the Numbers">
      <div class="section-inner">
        <div class="stats-header reveal" style="text-align: center; margin-bottom: 56px;">
          <span class="label">Platform Capabilities</span>
          <h2>Built for Scale</h2>
        </div>
        <div class="stats-grid">
          {stats.map((stat, i) => (
            <div class={`stat-card reveal reveal-delay-${(i % 4) + 1}`}>
              <span class="stat-value" data-target={stat.value} data-suffix={stat.suffix}>0{stat.suffix}</span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ TEAM CAROUSEL ============ -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Our Team">
      <div class="section-inner">
        <div class="team-header reveal" style="text-align: center; margin-bottom: 56px;">
          <span class="label">Leadership</span>
          <h2>The Team Behind the Intelligence</h2>
          <p style="max-width: 560px; margin: 16px auto 0; color: var(--text-secondary);">
            Security professionals, AI engineers, and operations specialists building
            the future of aerial intelligence.
          </p>
        </div>
        <div class="team-carousel" role="list">
          {team.map((member, i) => (
            <div class={`team-card-wrapper reveal reveal-delay-${(i % 4) + 1}`} role="listitem">
              <div class="team-card" tabindex="0" aria-label={`${member.name}, ${member.role}. Activate to see bio.`}>
                <div class="team-card-front">
                  <div class="team-avatar">
                    <span class="team-initials">{member.initials}</span>
                  </div>
                  <h3 class="team-name">{member.name}</h3>
                  <span class="team-role">{member.role}</span>
                  <span class="team-flip-hint" aria-hidden="true">Hover for bio</span>
                </div>
                <div class="team-card-back">
                  <p class="team-bio">{member.bio}</p>
                  <span class="team-name-back">{member.name}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="carousel-scroll-hint" aria-hidden="true">
          <span class="material-symbols-outlined" style="font-size: 18px; color: var(--text-tertiary); font-variation-settings: 'FILL' 0;">swipe</span>
          <span style="font-size: 12px; color: var(--text-tertiary); font-family: var(--font-mono); letter-spacing: 0.06em;">SCROLL TO SEE MORE</span>
        </div>
      </div>
    </section>

    <!-- ============ APPROACH / HOW WE THINK ============ -->
    <section class="section" aria-label="Our Approach">
      <div class="section-inner">
        <div class="approach-header reveal" style="text-align: center; margin-bottom: 56px;">
          <span class="label">Our Approach</span>
          <h2>How We Think</h2>
          <p style="max-width: 560px; margin: 16px auto 0; color: var(--text-secondary);">
            Three principles guide every mission, model, and deliverable.
          </p>
        </div>
        <div class="pillars-grid">
          {pillars.map((pillar, i) => (
            <div class={`pillar-card reveal reveal-delay-${i + 1}`}>
              <button
                class="pillar-header-btn"
                aria-expanded="false"
                aria-controls={`pillar-detail-${pillar.id}`}
                data-pillar={pillar.id}
              >
                <div class="pillar-icon-wrap">
                  <span class="material-symbols-outlined" style="font-size: 28px; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">{pillar.icon}</span>
                </div>
                <div class="pillar-text">
                  <h3 style="margin-bottom: 8px;">{pillar.title}</h3>
                  <p class="pillar-summary">{pillar.summary}</p>
                </div>
                <span class="pillar-chevron material-symbols-outlined" aria-hidden="true">expand_more</span>
              </button>
              <div class="pillar-detail" id={`pillar-detail-${pillar.id}`} aria-hidden="true">
                <p style="line-height: 1.8;">{pillar.details}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ OFFICE / FIELD SPLIT ============ -->
    <section class="section split-section" style="background: var(--surface-dim);" aria-label="How We Work">
      <div class="section-inner">
        <div class="split-header reveal" style="text-align: center; margin-bottom: 56px;">
          <span class="label">How We Work</span>
          <h2>Intelligence Meets Operations</h2>
        </div>
        <div class="split-grid">
          <div class="split-panel split-panel--office reveal">
            <div class="split-panel-inner">
              <div class="split-icon-row" aria-hidden="true">
                <span class="material-symbols-outlined" style="font-size: 40px; color: var(--accent); font-variation-settings: 'FILL' 1;">monitoring</span>
              </div>
              <h3 style="margin-bottom: 16px;">The Intelligence Lab</h3>
              <ul class="split-list">
                <li>AI model training & validation</li>
                <li>Thermal & multispectral data fusion</li>
                <li>Geospatial analytics pipelines</li>
                <li>Client report generation</li>
                <li>Security & compliance analysis</li>
              </ul>
            </div>
            <div class="split-tag" aria-hidden="true">OFFICE</div>
          </div>
          <div class="split-divider reveal" aria-hidden="true">
            <div class="split-divider-line"></div>
            <div class="split-divider-dot"></div>
            <div class="split-divider-line"></div>
          </div>
          <div class="split-panel split-panel--field reveal reveal-delay-1">
            <div class="split-panel-inner">
              <div class="split-icon-row" aria-hidden="true">
                <span class="material-symbols-outlined" style="font-size: 40px; color: #34D399; font-variation-settings: 'FILL' 1;">flight_takeoff</span>
              </div>
              <h3 style="margin-bottom: 16px;">The Field</h3>
              <ul class="split-list">
                <li>Autonomous mission deployment</li>
                <li>Facility intelligence scans</li>
                <li>Sensor calibration & QA</li>
                <li>On-site client briefings</li>
                <li>Emergency rapid-response ops</li>
              </ul>
            </div>
            <div class="split-tag split-tag--field" aria-hidden="true">FIELD</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" aria-label="Get in Touch" style="text-align: center;">
      <div class="section-inner" style="max-width: 640px; margin: 0 auto;">
        <div class="reveal">
          <span class="label">Ready to Talk?</span>
          <h2 style="margin-bottom: 16px;">Let Us Show You What We See</h2>
          <p style="margin-bottom: 32px; color: var(--text-secondary); line-height: 1.8;">
            Whether you need a one-time facility intelligence scan or persistent autonomous monitoring,
            we are ready to deliver the intelligence your operations demand.
          </p>
          <a href="/#lead-gen" class="btn-premium cta-btn">Get in Touch</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ==================== PARALLAX HERO ==================== */
  .about-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 120px clamp(20px, 5vw, 80px) 80px;
  }

  .parallax-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .parallax-layer {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  .parallax-layer--grid {
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  :global([data-theme="light"]) .parallax-layer--grid {
    background-image:
      linear-gradient(rgba(0, 131, 143, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 131, 143, 0.05) 1px, transparent 1px);
  }

  .parallax-layer--silhouettes {
    background: linear-gradient(180deg, transparent 50%, var(--bg-primary) 100%);
    opacity: 0.6;
  }

  .parallax-layer--silhouettes::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 200px;
    background:
      linear-gradient(180deg, transparent 0%, var(--surface-container-low) 100%);
    clip-path: polygon(
      0% 100%, 0% 60%, 5% 60%, 5% 40%, 8% 40%, 8% 55%, 12% 55%,
      12% 30%, 15% 30%, 15% 50%, 20% 50%, 20% 35%, 24% 35%, 24% 60%,
      30% 60%, 30% 20%, 34% 20%, 34% 45%, 38% 45%, 38% 55%, 42% 55%,
      42% 25%, 46% 25%, 46% 50%, 52% 50%, 52% 40%, 56% 40%, 56% 65%,
      62% 65%, 62% 35%, 66% 35%, 66% 50%, 70% 50%, 70% 30%, 74% 30%,
      74% 55%, 80% 55%, 80% 45%, 84% 45%, 84% 60%, 90% 60%, 90% 50%,
      94% 50%, 94% 65%, 100% 65%, 100% 100%
    );
  }

  .parallax-layer--scan {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 229, 255, 0.02) 50%,
      transparent 100%
    );
    animation: scan-sweep 8s ease-in-out infinite;
  }

  :global([data-theme="light"]) .parallax-layer--scan {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 131, 143, 0.03) 50%,
      transparent 100%
    );
  }

  @keyframes scan-sweep {
    0%, 100% { transform: translateY(-30%); }
    50% { transform: translateY(30%); }
  }

  .about-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
  }

  .about-hero-content h1 {
    font-size: clamp(2.25rem, 5vw + 0.5rem, 3.75rem);
    margin-bottom: 24px;
    line-height: 1.08;
  }

  .hero-gradient {
    background: linear-gradient(135deg, #00E5FF 0%, #7B61FF 50%, #00E5FF 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease infinite;
  }

  :global([data-theme="light"]) .hero-gradient {
    background: linear-gradient(135deg, #00838f 0%, #4F46E5 50%, #00838f 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.2rem);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .hero-scroll-cue {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    margin-top: 48px;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--accent), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  .scroll-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-tertiary);
  }

  /* ==================== SCROLLYTELLING ==================== */
  .story-timeline {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .story-timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--border-hover), var(--border-hover), transparent);
    transform: translateX(-50%);
  }

  .story-block {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    align-items: start;
    margin-bottom: 48px;
  }

  .story-block:last-child {
    margin-bottom: 0;
  }

  .story-block--left .story-content {
    grid-column: 1;
    grid-row: 1;
    text-align: right;
    padding-right: 40px;
  }

  .story-block--left .story-visual {
    grid-column: 2;
    grid-row: 1;
  }

  .story-block--left::after {
    content: '';
    grid-column: 3;
    grid-row: 1;
  }

  .story-block--right .story-content {
    grid-column: 3;
    grid-row: 1;
    text-align: left;
    padding-left: 40px;
  }

  .story-block--right .story-visual {
    grid-column: 2;
    grid-row: 1;
  }

  .story-block--right::before {
    content: '';
    grid-column: 1;
    grid-row: 1;
  }

  .story-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .story-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 20px var(--accent-glow);
    color: var(--accent);
  }

  .story-connector {
    display: none;
  }

  .story-content h3 {
    font-size: 1.25rem;
    color: var(--text-primary);
  }

  .story-content p {
    font-size: 15px;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .story-timeline::before {
      left: 28px;
    }

    .story-block {
      display: flex;
      gap: 20px;
      align-items: flex-start;
    }

    .story-block--left .story-content,
    .story-block--right .story-content {
      text-align: left;
      padding: 0;
    }

    .story-visual {
      flex-shrink: 0;
    }

    .story-icon-wrap {
      width: 48px;
      height: 48px;
    }

    .story-icon-wrap .material-symbols-outlined {
      font-size: 24px !important;
    }
  }

  /* ==================== STATS / BY THE NUMBERS ==================== */
  .stats-section {
    background: var(--surface-container-lowest);
    position: relative;
    overflow: hidden;
  }

  .stats-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .stat-card {
    text-align: center;
    padding: 32px 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    backdrop-filter: blur(12px);
    transition: transform 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                border-color 0.4s ease;
  }

  .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 20px rgba(0, 229, 255, 0.05);
    border-color: rgba(0, 229, 255, 0.12);
  }

  .stat-value {
    display: block;
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  /* ==================== TEAM CAROUSEL ==================== */
  .team-carousel {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 8px;
  }

  .team-carousel::-webkit-scrollbar {
    display: none;
  }

  .team-card-wrapper {
    flex: 0 0 280px;
    scroll-snap-align: start;
    perspective: 800px;
  }

  .team-card {
    width: 100%;
    height: 340px;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    border-radius: 16px;
  }

  .team-card:hover,
  .team-card:focus-visible {
    transform: rotateY(180deg);
  }

  .team-card-front,
  .team-card-back {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    overflow: hidden;
  }

  .team-card-front::before,
  .team-card-back::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .team-card-back {
    transform: rotateY(180deg);
    background: var(--surface-container-high);
    justify-content: center;
    text-align: center;
  }

  .team-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--accent-glow);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .team-initials {
    font-family: var(--font-headline);
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
  }

  .team-name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .team-role {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
