    justify-content: space-between;
    gap: 12px;
    margin-bottom: 10px;
  }

  .eg-det-header h3 {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .eg-severity {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .eg-severity-critical {
    background: rgba(255, 68, 68, 0.12);
    color: #FF4444;
    border: 1px solid rgba(255, 68, 68, 0.2);
  }

  .eg-severity-high {
    background: rgba(255, 140, 0, 0.12);
    color: #FF8C00;
    border: 1px solid rgba(255, 140, 0, 0.2);
  }

  .eg-severity-medium {
    background: rgba(255, 200, 0, 0.1);
    color: #E6B800;
    border: 1px solid rgba(255, 200, 0, 0.15);
  }

  .eg-detection-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ---- Detection Card Animated Visuals ---- */
  .eg-det-visual {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 48px;
    height: 48px;
    opacity: 0.35;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .eg-detection-card:hover .eg-det-visual {
    opacity: 0.6;
  }

  /* -- Vegetation: Growing vines -- */
  .eg-anim-vegetation {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .eg-vine {
    position: absolute;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to top, #4CAF50, #81C784);
    border-radius: 1px;
    transform-origin: bottom center;
    animation: eg-vine-grow 4s ease-in-out infinite;
  }

  .eg-vine-1 { left: 12px; height: 0; animation-delay: 0s; }
  .eg-vine-2 { left: 24px; height: 0; animation-delay: 0.8s; transform: rotate(5deg); }
  .eg-vine-3 { left: 36px; height: 0; animation-delay: 1.5s; transform: rotate(-3deg); }

  @keyframes eg-vine-grow {
    0% { height: 0; }
    40% { height: 38px; }
    70% { height: 38px; }
    100% { height: 0; }
  }

  .eg-vine-leaf {
    position: absolute;
    width: 8px;
    height: 6px;
    background: #66BB6A;
    border-radius: 0 50% 50% 50%;
    animation: eg-leaf-appear 4s ease-in-out infinite;
    opacity: 0;
  }

  .eg-leaf-1 { left: 14px; bottom: 20px; transform: rotate(30deg); animation-delay: 1s; }
  .eg-leaf-2 { left: 20px; bottom: 28px; transform: rotate(-40deg) scaleX(-1); animation-delay: 1.6s; }

  @keyframes eg-leaf-appear {
    0%, 30% { opacity: 0; transform: rotate(30deg) scale(0.5); }
    50% { opacity: 0.8; transform: rotate(30deg) scale(1); }
    80%, 100% { opacity: 0; transform: rotate(30deg) scale(0.5); }
  }

  /* -- Insulator: Crack & arc sparks -- */
  .eg-anim-insulator {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .eg-crack {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2px;
    height: 0;
    background: rgba(255, 200, 120, 0.8);
    transform-origin: top center;
    animation: eg-crack-grow 3s ease-in-out infinite;
  }

  .eg-crack-1 { transform: translate(-6px, -14px) rotate(15deg); animation-delay: 0s; }
  .eg-crack-2 { transform: translate(4px, -10px) rotate(-25deg); animation-delay: 0.5s; }

  @keyframes eg-crack-grow {
    0%, 60% { height: 0; opacity: 0; }
    70% { height: 18px; opacity: 1; }
    80% { height: 18px; opacity: 0.6; }
    100% { height: 0; opacity: 0; }
  }

  .eg-spark {
    position: absolute;
    width: 3px;
    height: 3px;
    background: #FFD54F;
    border-radius: 50%;
    box-shadow: 0 0 6px 2px rgba(255, 213, 79, 0.6), 0 0 12px 4px rgba(255, 140, 0, 0.3);
    opacity: 0;
    animation: eg-spark-flash 2s ease-in-out infinite;
  }

  .eg-spark-1 { top: 14px; left: 20px; animation-delay: 0.3s; }
  .eg-spark-2 { top: 24px; left: 30px; animation-delay: 1.1s; }
  .eg-spark-3 { top: 18px; left: 36px; animation-delay: 1.8s; }

  @keyframes eg-spark-flash {
    0%, 85%, 100% { opacity: 0; transform: scale(0.5); }
    88% { opacity: 1; transform: scale(1.5); }
    90% { opacity: 0.3; transform: scale(0.8); }
    92% { opacity: 1; transform: scale(1.2); }
    95% { opacity: 0; transform: scale(0.5); }
  }

  /* -- Hot Joints: Thermal glow rings -- */
  .eg-anim-hotjoint {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .eg-thermal-core {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle, #FF4444, #FF8C00);
    transform: translate(-50%, -50%);
    animation: eg-thermal-core-pulse 2s ease-in-out infinite;
  }

  @keyframes eg-thermal-core-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); box-shadow: 0 0 8px rgba(255, 68, 68, 0.5); }
    50% { transform: translate(-50%, -50%) scale(1.3); box-shadow: 0 0 16px rgba(255, 68, 68, 0.8), 0 0 30px rgba(255, 140, 0, 0.3); }
  }

  .eg-thermal-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    border: 1px solid rgba(255, 68, 68, 0.4);
    animation: eg-thermal-expand 2.5s ease-out infinite;
    transform: translate(-50%, -50%);
  }

  .eg-thermal-ring-1 { width: 16px; height: 16px; animation-delay: 0s; }
  .eg-thermal-ring-2 { width: 16px; height: 16px; animation-delay: 0.8s; }
  .eg-thermal-ring-3 { width: 16px; height: 16px; animation-delay: 1.6s; }

  @keyframes eg-thermal-expand {
    0% { width: 16px; height: 16px; opacity: 0.6; border-color: rgba(255, 68, 68, 0.6); }
    100% { width: 44px; height: 44px; opacity: 0; border-color: rgba(255, 140, 0, 0); }
  }

  /* -- Conductor Sag: Drooping wire -- */
  .eg-anim-sag {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .eg-sag-pole {
    position: absolute;
    top: 8px;
    width: 3px;
    height: 20px;
    background: linear-gradient(to bottom, rgba(255, 140, 0, 0.6), rgba(255, 140, 0, 0.3));
    border-radius: 1px;
  }

  .eg-sag-pole-l { left: 6px; }
  .eg-sag-pole-r { right: 6px; }

  .eg-sag-wire {
    position: absolute;
    top: 10px;
    left: 8px;
    right: 8px;
    height: 30px;
    border: none;
    border-bottom: 2px solid #FF8C00;
    border-radius: 0 0 50% 50%;
    animation: eg-sag-droop 3s ease-in-out infinite;
  }

  @keyframes eg-sag-droop {
    0%, 100% { height: 20px; border-bottom-color: rgba(255, 140, 0, 0.5); }
    50% { height: 32px; border-bottom-color: rgba(255, 68, 68, 0.7); }
  }

  /* -- Corrosion: Spreading rust -- */
  .eg-anim-corrosion {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .eg-rust {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(180, 100, 40, 0.6), rgba(139, 69, 19, 0.2), transparent);
    animation: eg-rust-spread 5s ease-in-out infinite;
    opacity: 0;
  }

  .eg-rust-1 { top: 18px; left: 20px; width: 12px; height: 10px; animation-delay: 0s; }
  .eg-rust-2 { top: 12px; left: 28px; width: 10px; height: 8px; animation-delay: 0.8s; }
  .eg-rust-3 { top: 24px; left: 14px; width: 14px; height: 11px; animation-delay: 1.5s; }
  .eg-rust-4 { top: 22px; left: 30px; width: 8px; height: 8px; animation-delay: 2.2s; }
  .eg-rust-5 { top: 14px; left: 16px; width: 9px; height: 7px; animation-delay: 3s; }

  @keyframes eg-rust-spread {
    0% { opacity: 0; transform: scale(0.3); }
    20% { opacity: 0.7; transform: scale(1); }
    60% { opacity: 0.5; transform: scale(1.4); }
    100% { opacity: 0; transform: scale(1.6); }
  }

  /* -- Lightning/Storm: Ground displacement -- */
  .eg-anim-lightning {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .eg-ground-base {
    position: absolute;
    bottom: 8px;
    left: 4px;
    right: 4px;
    height: 3px;
    background: rgba(255, 140, 0, 0.4);
    border-radius: 1px;
  }

  .eg-ground-shift {
    position: absolute;
    bottom: 8px;
    left: 22px;
    right: 4px;
    height: 3px;
    background: rgba(255, 140, 0, 0.4);
    border-radius: 1px;
    animation: eg-ground-displace 3s ease-in-out infinite;
    transform-origin: left center;
  }

  @keyframes eg-ground-displace {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    40% { transform: translateY(-4px) rotate(-2deg); }
    60% { transform: translateY(-4px) rotate(-2deg); }
  }

  .eg-ground-crack-l,
  .eg-ground-crack-r {
    position: absolute;
    bottom: 8px;
    width: 2px;
    height: 0;
    background: rgba(255, 68, 68, 0.5);
    animation: eg-crack-open 3s ease-in-out infinite;
  }

  .eg-ground-crack-l { left: 20px; transform-origin: bottom; }
  .eg-ground-crack-r { left: 22px; transform-origin: bottom; }

  @keyframes eg-crack-open {
    0%, 20% { height: 0; opacity: 0; }
    40% { height: 16px; opacity: 0.7; }
    60% { height: 16px; opacity: 0.5; }
    100% { height: 0; opacity: 0; }
  }

  /* ---- Interactive Grid Map ---- */
  .eg-map-container {
    position: relative;
    background: linear-gradient(135deg, #0a0c10, #141820);
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
  }

  .eg-map-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .eg-scan-animated {
    stroke: #FF8C00;
    stroke-width: 2;
    stroke-dasharray: 12 8;
    opacity: 0.5;
    animation: eg-scan-move 4s linear infinite;
  }

  .eg-scan-delayed {
    animation-delay: 1.5s;
  }

  .eg-scan-delayed-2 {
    animation-delay: 3s;
  }

  @keyframes eg-scan-move {
    from { stroke-dashoffset: 40; }
    to { stroke-dashoffset: 0; }
  }

  .eg-scan-dot {
    opacity: 0.9;
  }

  .eg-map-anomaly {
    animation: eg-map-anomaly-blink 2s ease-in-out infinite;
  }

  @keyframes eg-map-anomaly-blink {
    0%, 100% { opacity: 0.8; r: 8; }
    50% { opacity: 0.3; r: 14; }
  }

  .eg-map-legend {
    position: absolute;
    bottom: 16px;
    left: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255, 140, 0, 0.1);
  }

  .eg-legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .eg-legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .eg-legend-square {
    width: 8px;
    height: 8px;
    border: 1.5px solid;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .eg-legend-line {
    width: 16px;
    height: 2px;
    background: #FF8C00;
    border-radius: 1px;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .eg-map-stats {
    position: absolute;
    top: 16px;
    right: 16px;
    display: flex;
    gap: 20px;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
    padding: 12px 20px;
    border-radius: 8px;
    border: 1px solid rgba(255, 140, 0, 0.1);
  }

  .eg-map-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: center;
  }

  .eg-map-stat-val {
    font-family: var(--font-headline);
    font-size: 1.125rem;
    font-weight: 700;
    color: #FF8C00;
    line-height: 1;
  }

  .eg-map-stat-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  /* ---- Comparison Timeline ---- */
  .eg-timeline {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 40px;
    align-items: start;
  }

  .eg-timeline-side {}

  .eg-timeline-badge {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 8px 16px;
    border-radius: 8px;
    display: inline-block;
    margin-bottom: 28px;
  }

  .eg-badge-before {
    background: rgba(255, 68, 68, 0.08);
    color: #FF6666;
    border: 1px solid rgba(255, 68, 68, 0.15);
  }

  .eg-badge-after {
    background: rgba(255, 140, 0, 0.08);
    color: #FF8C00;
    border: 1px solid rgba(255, 140, 0, 0.15);
  }

  .eg-timeline-items {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .eg-tl-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .eg-tl-icon {
    flex-shrink: 0;
    font-size: 22px;
    color: rgba(255, 68, 68, 0.5);
    margin-top: 2px;
  }

  .eg-tl-icon-after {
    color: #FF8C00;
  }

  .eg-tl-item h4 {
    font-family: var(--font-headline);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: 6px;
  }

  .eg-tl-item p {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* Timeline center divider */
  .eg-timeline-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    padding-top: 40px;
  }

  .eg-timeline-line {
    width: 2px;
    flex: 1;
    min-height: 80px;
    background: linear-gradient(to bottom, rgba(255, 68, 68, 0.2), rgba(255, 140, 0, 0.3));
  }

  .eg-timeline-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 140, 0, 0.1);
    border: 1px solid rgba(255, 140, 0, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FF8C00;
    animation: eg-arrow-pulse 2s ease-in-out infinite;
  }

  @keyframes eg-arrow-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 140, 0, 0.15); }
    50% { box-shadow: 0 0 0 12px rgba(255, 140, 0, 0); }
  }

  .eg-timeline-arrow .material-symbols-outlined {
    font-size: 20px;
  }

  /* ---- Technology Deep-Dive ---- */
  .eg-tech-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
  }

  .eg-tech-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .eg-tech-panel:hover {
    box-shadow: 0 4px 24px rgba(255, 140, 0, 0.06);
  }

  .eg-tech-panel[open] {
    border-color: rgba(255, 140, 0, 0.2);
  }

  .eg-tech-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px;
    cursor: pointer;
    list-style: none;
    transition: background 0.2s ease;
  }

  .eg-tech-summary::-webkit-details-marker {
    display: none;
  }

  .eg-tech-summary:hover {
    background: rgba(255, 140, 0, 0.03);
  }

  .eg-tech-header {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .eg-tech-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 140, 0, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    position: relative;
    transition: background 0.3s ease, box-shadow 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }

  /* Radial glow behind icon */
  .eg-tech-icon-wrap::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 16px;
    background: radial-gradient(circle, rgba(255, 140, 0, 0.1) 0%, transparent 70%);
    opacity: 0.6;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .eg-tech-summary:hover .eg-tech-icon-wrap::after {
    opacity: 1;
    background: radial-gradient(circle, rgba(255, 140, 0, 0.2) 0%, rgba(255, 107, 53, 0.06) 50%, transparent 70%);
  }

  .eg-tech-summary:hover .eg-tech-icon-wrap {
    background: rgba(255, 140, 0, 0.14);
    box-shadow: 0 0 20px rgba(255, 140, 0, 0.15);
  }

  .eg-tech-icon {
    color: #FF8C00;
    font-size: 24px;
    position: relative;
    z-index: 1;
  }

  /* Connector dots between tech panels */
  .eg-tech-panel:not(:last-child)::after {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #FF8C00;
    opacity: 0.3;
    z-index: 2;
    box-shadow: -10px 0 0 rgba(255, 140, 0, 0.15), 10px 0 0 rgba(255, 140, 0, 0.15);
  }

  .eg-tech-title {
    font-family: var(--font-headline);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
  }

  .eg-tech-subtitle {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
    margin-top: 2px;
    display: block;
  }

  .eg-tech-toggle {
    color: var(--text-tertiary);
    font-size: 24px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .eg-tech-panel[open] .eg-tech-toggle {
    transform: rotate(180deg);
  }

  .eg-tech-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    padding: 0 28px 28px;
    border-top: 1px solid var(--border);
    margin-top: 0;
    padding-top: 24px;
  }

  .eg-tech-body h4 {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #FF8C00;
    margin-bottom: 16px;
  }

  .eg-tech-specs ul,
  .eg-tech-capabilities ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .eg-tech-specs li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  .eg-spec-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #FF8C00;
    flex-shrink: 0;
    opacity: 0.6;
  }

  .eg-tech-capabilities li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .eg-cap-check {
    color: #FF8C00;
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* ---- Why Jinki / Differentiators ---- */
  .eg-diff-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .eg-diff-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .eg-diff-card {
    padding: 32px;
    border-left: none;
    transition: background 0.4s ease,
                box-shadow 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                transform 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
    position: relative;
    border-radius: 12px;
    background: var(--bg-card);
    overflow: hidden;
  }

  /* Gradient border using pseudo-element */
  .eg-diff-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 12px;
    padding: 1px;
    background: linear-gradient(160deg, #FF8C00, rgba(255, 107, 53, 0.3), rgba(255, 140, 0, 0.1), transparent);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    transition: background 0.4s ease;
    pointer-events: none;
  }

  .eg-diff-card:hover::before {
    background: linear-gradient(160deg, #FF6B35, #FF8C00, rgba(255, 140, 0, 0.4), #FF6B35);
  }

  .eg-diff-card:hover {
    background: rgba(255, 140, 0, 0.04);
    box-shadow: 0 8px 32px rgba(255, 140, 0, 0.06);
