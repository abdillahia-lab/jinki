---
/*
  TEAM ALPHA — Round 4
  Energy Grid Vertical | Jinki Aerial Intelligence
  Redesigned with animated power grid hero, risk detection showcase,
  interactive grid map, comparison timeline, and technology deep-dive.
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

const stats = [
  { value: '50+ mi', label: 'corridor coverage per mission', source: 'Platform Capability' },
  { value: '0.5°C', label: 'thermal detection sensitivity', source: 'H30T Sensor Spec' },
  { value: '48hr', label: 'findings report turnaround', source: 'Service Commitment' },
  { value: 'LiDAR', label: 'sub-meter clearance mapping', source: 'L3 LiDAR Sensor' },
];

const detections = [
  {
    id: 'vegetation',
    title: 'Vegetation Encroachment',
    desc: 'LiDAR-measured clearance violations along rights-of-way. Sub-meter accuracy identifies encroachment before contact events.',
    severity: 'high',
    icon: 'forest',
  },
  {
    id: 'insulator',
    title: 'Insulator Damage',
    desc: 'Cracked, chipped, or contaminated insulators detected via high-resolution visual and thermal contrast analysis.',
    severity: 'critical',
    icon: 'bolt',
  },
  {
    id: 'hotjoint',
    title: 'Hot Joints & Connections',
    desc: 'Thermal anomalies at splice points, connectors, and bolted joints. Temperature differentials flagged at 10 degrees C above ambient.',
    severity: 'critical',
    icon: 'local_fire_department',
  },
  {
    id: 'sag',
    title: 'Conductor Sag',
    desc: 'LiDAR-derived sag measurements compared against design clearances. Identifies overloaded spans and thermal elongation.',
    severity: 'medium',
    icon: 'trending_down',
  },
  {
    id: 'corrosion',
    title: 'Corrosion & Wear',
    desc: 'Surface degradation on towers, hardware, and conductors. AI-assisted detection of rust patterns and material loss.',
    severity: 'medium',
    icon: 'water_damage',
  },
  {
    id: 'lightning',
    title: 'Lightning & Storm Damage',
    desc: 'Post-event rapid assessment of arc marks, shattered insulators, bent crossarms, and conductor displacement.',
    severity: 'high',
    icon: 'thunderstorm',
  },
];

const techSections = [
  {
    id: 'lidar',
    title: 'LiDAR Intelligence',
    subtitle: 'L3 LiDAR Sensor',
    icon: 'radar',
    specs: ['5-point-return scanning', '250m effective range', '200,000 points/sec', 'Sub-centimeter accuracy'],
    capabilities: [
      'Vegetation clearance measurement with sub-meter precision',
      'Conductor sag analysis against design tolerances',
      'Tower lean and structural deflection detection',
      'Volumetric terrain modeling for flood-risk assessment',
    ],
  },
  {
    id: 'thermal',
    title: 'Thermal Intelligence',
    subtitle: 'H30T Thermal Payload',
    icon: 'thermostat',
    specs: ['640x512 resolution', 'Radiometric accuracy', '-20 to 150 degrees C range', 'NETD < 30mK'],
    capabilities: [
      'Hot joint and connection fault identification',
      'Transformer thermal profiling under load',
      'Solar panel hotspot and string-failure detection',
      'Substation component health assessment',
    ],
  },
  {
    id: 'visual',
    title: 'Visual Intelligence',
    subtitle: 'Zoom Camera Array',
    icon: 'photo_camera',
    specs: ['200x hybrid zoom (40x optical)', '48MP sensor', '4K video capture', 'AI defect recognition'],
    capabilities: [
      'Insulator crack and chip detection at 80m standoff',
      'Hardware corrosion classification and severity rating',
      'Bird nest and foreign object identification',
      'Asset tagging and component inventory cataloging',
    ],
  },
];
---

<Layout title="Energy & Grid Intelligence — Jinki Aerial Intelligence" description="Predictive aerial intelligence for power lines, transmission towers, solar farms, wind turbines, and substations. Severity-ranked findings delivered within 48 hours." jsonLd={{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Energy Grid Aerial Intelligence",
  "provider": { "@type": "Organization", "name": "Jinki Aerial Intelligence" },
  "description": "Aerial thermal and visual inspection for power lines, substations, solar farms, and transmission infrastructure. 50+ miles of corridor coverage per day.",
  "areaServed": "Mid-Atlantic United States",
  "serviceType": "Aerial Infrastructure Inspection"
}}>
  <Nav />
  <main id="main-content">

    <!-- ============ HERO — Animated Power Grid ============ -->
    <section class="eg-hero" aria-label="Energy Grid Intelligence">
      <div class="eg-hero-inner">
        <div class="eg-hero-content reveal">
          <div class="eg-eyebrow">
            <span class="eg-eyebrow-line"></span>
            <span class="eg-eyebrow-text">Energy &amp; Grid</span>
          </div>
          <h1 class="eg-hero-title">
            Find the Failing Component<br/>
            <span class="gradient-text-energy">Before the Outage Finds You</span>
          </h1>
          <p class="eg-hero-subtitle">
            Transmission towers, power lines, solar farms, and substations — inspected
            across 50+ mile corridors per mission. Jinki delivers severity-ranked findings
            that identify degradation before it becomes downtime.
          </p>
          <div class="eg-hero-actions">
            <a href="#lead-gen" class="btn-premium eg-cta" style="background: linear-gradient(135deg, #FF8C00, #FF6B35);">Get Your Facility Report</a>
            <a href="#risk-detection" class="eg-cta-secondary">
              <span class="material-symbols-outlined" style="font-size: 18px; font-variation-settings: 'FILL' 1;" aria-hidden="true">arrow_downward</span>
              See Detection Types
            </a>
          </div>
        </div>
        <div class="eg-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <div class="eg-grid-container">
            <!-- Real aerial photo as base layer -->
            <img
              src="/images/powerline-aerial.jpg"
              alt=""
              class="eg-hero-photo"
              loading="eager" fetchpriority="high"
              decoding="async"
            />
            <svg viewBox="0 0 500 400" class="eg-grid-svg" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Animated power grid network visualization">
              <!-- Grid lines with flowing electricity -->
              <defs>
                <filter id="glow-orange" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="4" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <filter id="glow-red" x="-50%" y="-50%" width="200%" height="200%">
                  <feGaussianBlur stdDeviation="6" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
                <linearGradient id="line-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#FF8C00" stop-opacity="0.3"/>
                  <stop offset="50%" stop-color="#FF8C00" stop-opacity="0.8"/>
                  <stop offset="100%" stop-color="#FF6B35" stop-opacity="0.3"/>
                </linearGradient>
              </defs>

              <!-- Transmission lines -->
              <line x1="60" y1="80" x2="200" y2="120" class="eg-power-line"/>
              <line x1="200" y1="120" x2="340" y2="70" class="eg-power-line"/>
              <line x1="340" y1="70" x2="440" y2="130" class="eg-power-line"/>
              <line x1="200" y1="120" x2="250" y2="230" class="eg-power-line"/>
              <line x1="250" y1="230" x2="130" y2="300" class="eg-power-line"/>
              <line x1="250" y1="230" x2="400" y2="260" class="eg-power-line"/>
              <line x1="400" y1="260" x2="440" y2="130" class="eg-power-line"/>
              <line x1="130" y1="300" x2="60" y2="80" class="eg-power-line eg-line-long"/>
              <line x1="400" y1="260" x2="350" y2="350" class="eg-power-line"/>
              <line x1="130" y1="300" x2="250" y2="350" class="eg-power-line"/>

              <!-- Flowing electricity dashes -->
              <line x1="60" y1="80" x2="200" y2="120" class="eg-flow-line" style="--flow-dur: 2s;"/>
              <line x1="200" y1="120" x2="340" y2="70" class="eg-flow-line" style="--flow-dur: 1.8s;"/>
              <line x1="340" y1="70" x2="440" y2="130" class="eg-flow-line" style="--flow-dur: 2.2s;"/>
              <line x1="200" y1="120" x2="250" y2="230" class="eg-flow-line" style="--flow-dur: 1.6s;"/>
              <line x1="250" y1="230" x2="130" y2="300" class="eg-flow-line" style="--flow-dur: 2.4s;"/>
              <line x1="250" y1="230" x2="400" y2="260" class="eg-flow-line" style="--flow-dur: 1.9s;"/>
              <line x1="400" y1="260" x2="440" y2="130" class="eg-flow-line" style="--flow-dur: 2.1s;"/>
              <line x1="400" y1="260" x2="350" y2="350" class="eg-flow-line" style="--flow-dur: 1.7s;"/>
              <line x1="130" y1="300" x2="250" y2="350" class="eg-flow-line" style="--flow-dur: 2.3s;"/>

              <!-- Substation nodes — normal (orange pulse) -->
              <circle cx="60" cy="80" r="10" class="eg-node"/>
              <circle cx="60" cy="80" r="16" class="eg-node-pulse"/>
              <circle cx="200" cy="120" r="12" class="eg-node eg-node-large"/>
              <circle cx="200" cy="120" r="20" class="eg-node-pulse" style="animation-delay: 0.5s;"/>
              <circle cx="340" cy="70" r="10" class="eg-node"/>
              <circle cx="340" cy="70" r="16" class="eg-node-pulse" style="animation-delay: 1s;"/>
              <circle cx="440" cy="130" r="10" class="eg-node"/>
              <circle cx="440" cy="130" r="16" class="eg-node-pulse" style="animation-delay: 1.5s;"/>
              <circle cx="130" cy="300" r="10" class="eg-node"/>
              <circle cx="130" cy="300" r="16" class="eg-node-pulse" style="animation-delay: 0.8s;"/>
              <circle cx="350" cy="350" r="9" class="eg-node"/>
              <circle cx="350" cy="350" r="14" class="eg-node-pulse" style="animation-delay: 1.2s;"/>
              <circle cx="250" cy="350" r="9" class="eg-node"/>
              <circle cx="250" cy="350" r="14" class="eg-node-pulse" style="animation-delay: 0.3s;"/>

              <!-- Anomaly node (red pulse) -->
              <circle cx="250" cy="230" r="12" class="eg-node-anomaly"/>
              <circle cx="250" cy="230" r="22" class="eg-node-anomaly-pulse"/>
              <circle cx="250" cy="230" r="34" class="eg-node-anomaly-ring"/>

              <!-- Anomaly label -->
              <rect x="270" y="210" width="110" height="28" rx="4" fill="rgba(255,60,60,0.15)" stroke="rgba(255,60,60,0.4)" stroke-width="1"/>
              <text x="325" y="229" text-anchor="middle" class="eg-anomaly-label">ANOMALY</text>

              <!-- Hub node label -->
              <text x="200" y="150" text-anchor="middle" class="eg-node-label">HUB-01</text>
              <text x="250" y="260" text-anchor="middle" class="eg-node-label eg-label-red">FAULT</text>

              <!-- Tower icons (simplified) -->
              <g class="eg-tower-icon" transform="translate(55, 40)">
                <line x1="5" y1="0" x2="5" y2="30" stroke="#FF8C00" stroke-width="1.5" opacity="0.5"/>
                <line x1="0" y1="10" x2="10" y2="10" stroke="#FF8C00" stroke-width="1" opacity="0.5"/>
                <line x1="1" y1="20" x2="9" y2="20" stroke="#FF8C00" stroke-width="1" opacity="0.5"/>
              </g>
              <g class="eg-tower-icon" transform="translate(335, 30)">
                <line x1="5" y1="0" x2="5" y2="30" stroke="#FF8C00" stroke-width="1.5" opacity="0.5"/>
                <line x1="0" y1="10" x2="10" y2="10" stroke="#FF8C00" stroke-width="1" opacity="0.5"/>
                <line x1="1" y1="20" x2="9" y2="20" stroke="#FF8C00" stroke-width="1" opacity="0.5"/>
              </g>

              <!-- Scan path -->
              <path d="M 80 60 Q 180 40 300 80 T 430 100" class="eg-scan-path" fill="none"/>
              <!-- Thermal scan sweep line -->
              <line x1="0" y1="0" x2="0" y2="400" stroke="rgba(255,140,0,0.15)" stroke-width="2">
                <animate attributeName="x1" values="0;500;0" dur="8s" repeatCount="indefinite"/>
                <animate attributeName="x2" values="0;500;0" dur="8s" repeatCount="indefinite"/>
              </line>
              <!-- Node count -->
              <text x="470" y="385" font-family="monospace" font-size="7" fill="rgba(255,140,0,0.25)" text-anchor="end">NODES: 8 | FAULTS: 1</text>
            </svg>

            <!-- HUD overlay -->
            <div class="eg-hud-readout">
              <span class="eg-hud-label">GRID STATUS</span>
              <span class="eg-hud-value">MONITORING</span>
              <span class="eg-hud-alert">1 ANOMALY DETECTED</span>
            </div>
            <div class="eg-hud-coords">
              <span>37.5407 N / 77.4360 W</span>
              <span>ALT 120m AGL</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ STATS BAR ============ -->
    <div class="eg-stats-bar reveal">
      <div class="eg-stats-inner">
        {stats.map(stat => (
          <div class="eg-stat-item">
            <span class="eg-stat-value">{stat.value}</span>
            <span class="eg-stat-label">{stat.label}</span>
            <span class="eg-stat-source">{stat.source}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ============ RISK DETECTION SHOWCASE ============ -->
    <section id="risk-detection" class="eg-section" aria-label="Risk Detection Types">
      <div class="eg-section-inner">
        <div class="eg-section-header reveal">
          <div class="eg-eyebrow">
            <span class="eg-eyebrow-line"></span>
            <span class="eg-eyebrow-text">Detection Intelligence</span>
          </div>
          <h2>Six Failure Modes.<br/>One Aerial Platform.</h2>
          <p class="eg-section-subtitle">
            Every flight captures thermal, visual, and LiDAR data simultaneously.
            AI-assisted analysis identifies and severity-ranks these critical failure modes
            before they cause outages.
          </p>
        </div>

        <div class="eg-detection-grid">
          {detections.map((det, i) => (
            <div class={`eg-detection-card reveal reveal-delay-${(i % 3) + 1}`} data-severity={det.severity} data-detection={det.id}>
              <div class="eg-det-visual" aria-hidden="true">
                {det.id === 'vegetation' && (
                  <div class="eg-anim-vegetation">
                    <div class="eg-vine eg-vine-1"></div>
                    <div class="eg-vine eg-vine-2"></div>
                    <div class="eg-vine eg-vine-3"></div>
                    <div class="eg-vine-leaf eg-leaf-1"></div>
                    <div class="eg-vine-leaf eg-leaf-2"></div>
                  </div>
                )}
                {det.id === 'insulator' && (
                  <div class="eg-anim-insulator">
                    <div class="eg-crack eg-crack-1"></div>
                    <div class="eg-crack eg-crack-2"></div>
                    <div class="eg-spark eg-spark-1"></div>
                    <div class="eg-spark eg-spark-2"></div>
                    <div class="eg-spark eg-spark-3"></div>
                  </div>
                )}
                {det.id === 'hotjoint' && (
                  <div class="eg-anim-hotjoint">
                    <div class="eg-thermal-core"></div>
                    <div class="eg-thermal-ring eg-thermal-ring-1"></div>
                    <div class="eg-thermal-ring eg-thermal-ring-2"></div>
                    <div class="eg-thermal-ring eg-thermal-ring-3"></div>
                  </div>
                )}
                {det.id === 'sag' && (
                  <div class="eg-anim-sag">
                    <div class="eg-sag-pole eg-sag-pole-l"></div>
                    <div class="eg-sag-pole eg-sag-pole-r"></div>
                    <div class="eg-sag-wire"></div>
                  </div>
                )}
                {det.id === 'corrosion' && (
                  <div class="eg-anim-corrosion">
                    <div class="eg-rust eg-rust-1"></div>
                    <div class="eg-rust eg-rust-2"></div>
                    <div class="eg-rust eg-rust-3"></div>
                    <div class="eg-rust eg-rust-4"></div>
                    <div class="eg-rust eg-rust-5"></div>
                  </div>
                )}
                {det.id === 'lightning' && (
                  <div class="eg-anim-lightning">
                    <div class="eg-ground-base"></div>
                    <div class="eg-ground-shift"></div>
                    <div class="eg-ground-crack-l"></div>
                    <div class="eg-ground-crack-r"></div>
                  </div>
                )}
              </div>
              <div class="eg-det-icon-wrap">
                <span class="material-symbols-outlined eg-det-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{det.icon}</span>
                <svg class="eg-det-ring" viewBox="0 0 60 60" aria-hidden="true">
                  <circle cx="30" cy="30" r="26" fill="none" stroke-width="2" class="eg-det-ring-bg"/>
                  <circle cx="30" cy="30" r="26" fill="none" stroke-width="2" class="eg-det-ring-progress" style={`--ring-delay: ${i * 0.2}s;`}/>
                </svg>
              </div>
              <div class="eg-det-content">
                <div class="eg-det-header">
                  <h3>{det.title}</h3>
                  <span class={`eg-severity eg-severity-${det.severity}`}>{det.severity}</span>
                </div>
                <p>{det.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ INTERACTIVE GRID MAP ============ -->
    <section class="eg-section eg-section-dim" aria-label="Inspection Coverage">
      <div class="eg-section-inner">
        <div class="eg-section-header reveal">
          <div class="eg-eyebrow">
            <span class="eg-eyebrow-line"></span>
            <span class="eg-eyebrow-text">Coverage Intelligence</span>
          </div>
          <h2>Systematic Aerial Coverage<br/>Across Your Service Territory</h2>
          <p class="eg-section-subtitle">
            Automated flight planning covers every span, tower, and substation.
            Real-time progress tracking ensures zero missed assets.
          </p>
        </div>

        <div class="eg-map-container reveal">
          <svg viewBox="0 0 800 450" class="eg-map-svg" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Stylized grid map showing inspection scan paths">
            <defs>
              <pattern id="map-grid" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,140,0,0.06)" stroke-width="0.5"/>
              </pattern>
              <linearGradient id="scan-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#FF8C00" stop-opacity="0"/>
                <stop offset="50%" stop-color="#FF8C00" stop-opacity="0.8"/>
                <stop offset="100%" stop-color="#FF6B35" stop-opacity="0"/>
              </linearGradient>
              <filter id="map-glow" x="-20%" y="-20%" width="140%" height="140%">
                <feGaussianBlur stdDeviation="3" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>

            <rect width="800" height="450" fill="url(#map-grid)"/>

            <!-- Territory boundary -->
            <path d="M 100 60 L 250 40 L 450 55 L 650 45 L 720 100 L 740 200 L 700 320 L 600 380 L 400 400 L 200 370 L 80 280 L 60 160 Z"
                  fill="rgba(255,140,0,0.03)" stroke="rgba(255,140,0,0.15)" stroke-width="1" stroke-dasharray="8 4"/>

            <!-- Transmission corridors -->
            <line x1="120" y1="120" x2="680" y2="100" stroke="rgba(255,140,0,0.12)" stroke-width="2"/>
            <line x1="200" y1="80" x2="250" y2="350" stroke="rgba(255,140,0,0.12)" stroke-width="2"/>
            <line x1="400" y1="60" x2="420" y2="380" stroke="rgba(255,140,0,0.12)" stroke-width="2"/>
            <line x1="150" y1="250" x2="680" y2="230" stroke="rgba(255,140,0,0.12)" stroke-width="2"/>

            <!-- Tower positions -->
            <circle cx="180" cy="110" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="300" cy="105" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="420" cy="95" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="560" cy="100" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="240" cy="180" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="410" cy="200" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="310" cy="280" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="530" cy="270" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="200" cy="320" r="4" fill="#FF8C00" opacity="0.5"/>
            <circle cx="500" cy="340" r="4" fill="#FF8C00" opacity="0.5"/>

            <!-- Substations -->
            <rect x="155" y="95" width="14" height="14" rx="2" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.7"/>
            <rect x="545" y="85" width="14" height="14" rx="2" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.7"/>
            <rect x="395" y="185" width="14" height="14" rx="2" fill="none" stroke="#FF8C00" stroke-width="1.5" opacity="0.7"/>

            <!-- Scan paths (animated) -->
            <path d="M 120 115 C 200 100 300 120 400 95 S 550 110 680 100" class="eg-scan-animated" fill="none"/>
            <path d="M 150 250 C 250 240 350 260 450 235 S 580 245 680 230" class="eg-scan-animated eg-scan-delayed" fill="none"/>
            <path d="M 200 80 C 210 150 230 220 250 350" class="eg-scan-animated eg-scan-delayed-2" fill="none"/>

            <!-- Progress markers -->
            <circle r="5" class="eg-scan-dot" fill="#FF8C00" filter="url(#map-glow)">
              <animateMotion dur="6s" repeatCount="indefinite" path="M 120 115 C 200 100 300 120 400 95 S 550 110 680 100"/>
            </circle>
            <circle r="5" class="eg-scan-dot" fill="#FF8C00" filter="url(#map-glow)">
              <animateMotion dur="7s" repeatCount="indefinite" path="M 150 250 C 250 240 350 260 450 235 S 580 245 680 230"/>
            </circle>

            <!-- Anomaly markers on map -->
            <circle cx="410" cy="200" r="8" fill="none" stroke="#FF4444" stroke-width="1.5" class="eg-map-anomaly"/>
            <circle cx="310" cy="280" r="8" fill="none" stroke="#FF4444" stroke-width="1.5" class="eg-map-anomaly" style="animation-delay: 1s;"/>
          </svg>

          <!-- Map legend -->
          <div class="eg-map-legend">
            <div class="eg-legend-item">
              <span class="eg-legend-dot" style="background: #FF8C00;"></span>
              <span>Tower / Asset</span>
            </div>
            <div class="eg-legend-item">
              <span class="eg-legend-square" style="border-color: #FF8C00;"></span>
              <span>Substation</span>
            </div>
            <div class="eg-legend-item">
              <span class="eg-legend-dot" style="background: #FF4444;"></span>
              <span>Anomaly Detected</span>
            </div>
            <div class="eg-legend-item">
              <span class="eg-legend-line"></span>
              <span>Scan Path</span>
            </div>
          </div>

          <!-- Map stats overlay -->
          <div class="eg-map-stats">
            <div class="eg-map-stat">
              <span class="eg-map-stat-val">847</span>
              <span class="eg-map-stat-label">Assets Cataloged</span>
            </div>
            <div class="eg-map-stat">
              <span class="eg-map-stat-val">98.7%</span>
              <span class="eg-map-stat-label">Coverage</span>
            </div>
            <div class="eg-map-stat">
              <span class="eg-map-stat-val">12</span>
              <span class="eg-map-stat-label">Anomalies Found</span>
            </div>
          </div>
        </div>
      </div>
    </section>

