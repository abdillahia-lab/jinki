---

<Layout title="Data Centers — Jinki Aerial Intelligence" description="Aerial thermal inspection, roof assessment, and autonomous monitoring for data center operations. Identify cooling failures and structural risks before they cause downtime.">
  <Nav />
  <main id="main-content">

    <!-- ============================================================
         SECTION 1: 3D FACILITY FLYTHROUGH HERO
         ============================================================ -->
    <section class="omega-hero" aria-label="Data Center Intelligence">
      <div class="omega-hero-inner">
        <div class="omega-hero-content reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Data Centers</span>
          </div>
          <h1 class="omega-hero-title">
            Find the Hidden Problem<br/>
            <span class="gradient-text-cyan">Before the Outage</span>
          </h1>
          <p class="omega-hero-subtitle">
            Aerial thermal intelligence that turns invisible risks into scheduled maintenance.
            From traditional HVAC arrays to next-gen liquid cooling infrastructure — every
            rooftop system surveyed, classified, and prioritized so your team acts on
            answers, not assumptions.
          </p>
          <div class="omega-hero-actions">
            <a href="#lead-gen" class="btn-premium omega-cta">Request a Demo</a>
            <a href="#problem-explorer" class="omega-cta-secondary">Explore Issues We Find</a>
          </div>
        </div>
        <div class="omega-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <div class="facility-scene">
            <!-- Real data center photo with thermal overlay -->
            <img
              src="/images/dc-rooftop-aerial.jpg"
              alt=""
              class="facility-photo"
              loading="eager"
              decoding="async"
            />
            <!-- Thermal color overlay -->
            <div class="thermal-color-overlay"></div>
            <!-- Grid overlay for intelligence aesthetic -->
            <div class="facility-grid"></div>
            <!-- HUD Overlay badges -->
            <div class="hud-badge hud-tl">
              <span class="hud-indicator hud-critical"></span>
              <span class="hud-label">CRITICAL</span>
              <span class="hud-value">47.3°C</span>
            </div>
            <div class="hud-badge hud-tr">
              <span class="hud-indicator hud-warning"></span>
              <span class="hud-label">WARNING</span>
              <span class="hud-value">HVAC-07</span>
            </div>
            <div class="hud-badge hud-bl">
              <span class="hud-indicator hud-normal"></span>
              <span class="hud-label">NOMINAL</span>
              <span class="hud-value">22.1°C avg</span>
            </div>
            <div class="hud-badge hud-br">
              <span class="hud-indicator hud-live"></span>
              <span class="hud-label">SCAN</span>
              <span class="hud-value">LIVE</span>
            </div>
            <div class="scan-line"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         STATS BAR
         ============================================================ -->
    <div class="omega-stats-bar reveal">
      <div class="omega-stats-inner">
        {stats.map((stat, i) => (
          <div class="omega-stat-item" data-stat-index={i}>
            <div class="stat-glow-bg" aria-hidden="true"></div>
            <span class="omega-stat-value" data-count-target={stat.value}>{stat.value}</span>
            <span class="omega-stat-label">{stat.label}</span>
            <span class="omega-stat-source">{stat.source}</span>
            {i < stats.length - 1 && <div class="stat-divider" aria-hidden="true"><div class="stat-divider-glow"></div></div>}
          </div>
        ))}
      </div>
    </div>

    <!-- ============================================================
         SECTION 2: INTERACTIVE PROBLEM EXPLORER
         ============================================================ -->
    <section id="problem-explorer" class="omega-section" aria-label="Common Data Center Issues">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Problem Explorer</span>
          </div>
          <h2>Six Issues Hiding on<br/>Your Rooftop Right Now</h2>
          <p class="omega-section-subtitle">
            Click any issue to see how aerial thermal intelligence detects it,
            the methodology we use, and the costs we help you avoid.
          </p>
        </div>

        <div class="problem-grid" role="list">
          {problems.map((prob, i) => (
            <div
              class={`problem-card reveal reveal-delay-${(i % 3) + 1}`}
              role="listitem"
              data-problem-id={prob.id}
            >
              <button
                class="problem-trigger"
                aria-expanded="false"
                aria-controls={`problem-detail-${prob.id}`}
                type="button"
              >
                <div class="problem-header">
                  <div class="problem-icon-wrap" data-issue={prob.id}>
                    <div class="issue-anim" aria-hidden="true"></div>
                    <span class="material-symbols-outlined problem-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{prob.icon}</span>
                  </div>
                  <div class="problem-title-group">
                    <h3 class="problem-title">{prob.title}</h3>
                    <p class="problem-summary">{prob.summary}</p>
                  </div>
                  <span class="problem-chevron" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </div>
              </button>
              <div
                class="problem-detail"
                id={`problem-detail-${prob.id}`}
                role="region"
                aria-label={`Details about ${prob.title}`}
                hidden
              >
                <div class="problem-detail-inner">
                  <p class="problem-description">{prob.description}</p>
                  <div class="problem-meta-grid">
                    <div class="problem-meta-item">
                      <span class="problem-meta-label">Detection Method</span>
                      <p class="problem-meta-value">{prob.detection}</p>
                    </div>
                    <div class="problem-meta-item">
                      <span class="problem-meta-label">Impact Avoided</span>
                      <p class="problem-meta-value problem-meta-cost">{prob.cost}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 3: LIVE DASHBOARD MOCKUP
         ============================================================ -->
    <section class="omega-section omega-section-alt" aria-label="Live Dashboard Preview">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Intelligence Platform</span>
          </div>
          <h2>Your Facility, at a Glance</h2>
          <p class="omega-section-subtitle">
            Real-time thermal intelligence delivered through a command center
            your operations team can act on immediately.
          </p>
        </div>

        <div class="dashboard-mockup glass-panel reveal" aria-hidden="true">
          <div class="dash-topbar">
            <div class="dash-dots">
              <span class="dash-dot" style="background:#FF5F57;"></span>
              <span class="dash-dot" style="background:#FFBD2E;"></span>
              <span class="dash-dot" style="background:#28C840;"></span>
            </div>
            <span class="dash-title">Jinki Command Center — Facility Dashboard</span>
            <span class="dash-live-badge">
              <span class="dash-live-dot"></span>
              LIVE
            </span>
          </div>
          <div class="dash-body">
            <div class="dash-sidebar">
              <div class="dash-nav-item dash-nav-active">
                <span class="material-symbols-outlined" style="font-size:18px; font-variation-settings: 'FILL' 1;" aria-hidden="true">dns</span>
                <span>Overview</span>
              </div>
              <div class="dash-nav-item">
                <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">thermostat</span>
                <span>Thermal</span>
              </div>
              <div class="dash-nav-item">
                <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">warning</span>
                <span>Alerts</span>
              </div>
              <div class="dash-nav-item">
                <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">roofing</span>
                <span>Roof</span>
              </div>
              <div class="dash-nav-item">
                <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">security</span>
                <span>Perimeter</span>
              </div>
            </div>
            <div class="dash-main">
              <div class="dash-cards-row">
                <div class="dash-kpi-card">
                  <span class="dash-kpi-label">Active Alerts</span>
                  <span class="dash-kpi-value dash-kpi-alert">3</span>
                  <span class="dash-kpi-change dash-kpi-down">-2 from last week</span>
                </div>
                <div class="dash-kpi-card">
                  <span class="dash-kpi-label">Avg Surface Temp</span>
                  <span class="dash-kpi-value">34.7<small>C</small></span>
                  <span class="dash-kpi-change">Within tolerance</span>
                </div>
                <div class="dash-kpi-card">
                  <span class="dash-kpi-label">Last Patrol</span>
                  <span class="dash-kpi-value">2h <small>ago</small></span>
                  <span class="dash-kpi-change">Mission #147 complete</span>
                </div>
                <div class="dash-kpi-card">
                  <span class="dash-kpi-label">Roof Score</span>
                  <span class="dash-kpi-value dash-kpi-good">94</span>
                  <span class="dash-kpi-change">+3 from baseline</span>
                </div>
              </div>
              <div class="dash-content-row">
                <div class="dash-facility-map">
                  <div class="dash-map-grid"></div>
                  <div class="dash-map-building map-b1">
                    <div class="dash-map-label">Hall A</div>
                  </div>
                  <div class="dash-map-building map-b2">
                    <div class="dash-map-label">Hall B</div>
                  </div>
                  <div class="dash-map-building map-b3">
                    <div class="dash-map-label">Power</div>
                  </div>
                  <div class="dash-map-alert-pin pin-1">
                    <span class="dash-pin-pulse"></span>
                  </div>
                  <div class="dash-map-alert-pin pin-2">
                    <span class="dash-pin-pulse"></span>
                  </div>
                  <div class="dash-map-alert-pin pin-3">
                    <span class="dash-pin-pulse pin-warn"></span>
                  </div>
                </div>
                <div class="dash-alerts-panel">
                  <div class="dash-alerts-title">Recent Alerts</div>
                  <div class="dash-alert-row alert-critical">
                    <span class="dash-alert-severity">CRITICAL</span>
                    <span class="dash-alert-msg">HVAC-07 exceeding thermal envelope</span>
                    <span class="dash-alert-time">14m ago</span>
                  </div>
                  <div class="dash-alert-row alert-warning">
                    <span class="dash-alert-severity">WARNING</span>
                    <span class="dash-alert-msg">Transformer T-3 trending +2.1C/week</span>
                    <span class="dash-alert-time">2h ago</span>
                  </div>
                  <div class="dash-alert-row alert-info">
                    <span class="dash-alert-severity">INFO</span>
                    <span class="dash-alert-msg">Roof Section R-12 moisture flagged</span>
                    <span class="dash-alert-time">1d ago</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 4: CTA — REQUEST A DEMO
         ============================================================ -->
    <section class="omega-section" aria-label="Request a Demo">
      <div class="omega-section-inner" style="text-align: center;">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Next Steps</span>
          </div>
          <h2>Ready to See Your Facility's<br/>Hidden Risks?</h2>
          <p class="omega-section-subtitle">
            Schedule a consultation with our intelligence team. We'll walk through how aerial thermal analysis applies to your specific campus — no obligations, no generic pitch decks.
          </p>
        </div>
        <div class="reveal" style="margin-top: 2rem;">
          <a href="#lead-gen" class="btn-premium" style="display: inline-flex; align-items: center; justify-content: center; font-family: var(--font-label); font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 1rem 2.5rem; border-radius: 12px; text-decoration: none;">Request a Demo</a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 5: TECHNOLOGY STACK SHOWCASE
         ============================================================ -->
    <section class="omega-section omega-section-alt" aria-label="Technology Pipeline">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Technology</span>
          </div>
          <h2>From Flight to Finding<br/>in One Pipeline</h2>
          <p class="omega-section-subtitle">
            Every data point flows through a five-stage intelligence pipeline — from aerial
            capture to prioritized recommendation — with no manual handoffs.
          </p>
        </div>

        <div class="pipeline-track reveal">
          {pipelineSteps.map((step, i) => (
            <div class={`pipeline-step reveal reveal-delay-${i + 1}`}>
              <div class="pipeline-node">
                <div class="pipeline-ring" aria-hidden="true"></div>
                <span class="material-symbols-outlined pipeline-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{step.icon}</span>
              </div>
              {i < pipelineSteps.length - 1 && (
                <div class="pipeline-connector" aria-hidden="true">
                  <div class="pipeline-flow"></div>
                  <div class="pipeline-particle p1"></div>
                  <div class="pipeline-particle p2"></div>
                  <div class="pipeline-particle p3"></div>
                </div>
              )}
              <div class="pipeline-label">{step.label}</div>
              <div class="pipeline-sub">{step.sub}</div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ============================================================
         SECTION 7: FAQ ACCORDION
         ============================================================ -->
    <section class="omega-section omega-section-alt" aria-label="Frequently Asked Questions">
      <div class="omega-section-inner omega-section-narrow">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">FAQ</span>
          </div>
          <h2>Common Questions</h2>
        </div>

        <div class="faq-list" role="list">
          {faqs.map((faq, i) => (
            <div class={`faq-item reveal reveal-delay-${(i % 3) + 1}`} role="listitem">
              <button
                class="faq-trigger"
                type="button"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
              >
                <span class="faq-question">{faq.q}</span>
                <span class="faq-chevron" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>
              <div class="faq-answer" id={`faq-answer-${i}`} role="region" hidden>
                <p>{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <LeadGen />
  </main>
  <Footer />
</Layout>

<!-- ============================================================
     INTERACTIVE SCRIPTS
     ============================================================ -->
<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  // --- Problem Explorer ---
  var problemCards = document.querySelectorAll('.problem-trigger');
  problemCards.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var card = btn.closest('.problem-card');
      var detail = card.querySelector('.problem-detail');
      var isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all other cards
      document.querySelectorAll('.problem-card').forEach(function(c) {
        if (c !== card) {
          c.querySelector('.problem-trigger').setAttribute('aria-expanded', 'false');
          c.querySelector('.problem-detail').hidden = true;
          c.classList.remove('problem-open');
        }
      });

      btn.setAttribute('aria-expanded', String(!isOpen));
      detail.hidden = isOpen;
      card.classList.toggle('problem-open', !isOpen);
    });
  });

  // --- FAQ Accordion ---
  var faqTriggers = document.querySelectorAll('.faq-trigger');
  faqTriggers.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var answer = item.querySelector('.faq-answer');
      var isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all other FAQs
      document.querySelectorAll('.faq-item').forEach(function(f) {
        if (f !== item) {
          f.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
          f.querySelector('.faq-answer').hidden = true;
          f.classList.remove('faq-open');
        }
      });

      btn.setAttribute('aria-expanded', String(!isOpen));
      answer.hidden = isOpen;
      item.classList.toggle('faq-open', !isOpen);
    });
  });

  // --- Testimonial Carousel ---
  var track = document.getElementById('testimonial-track');
  if (!track) return;
  var slides = track.querySelectorAll('.testimonial-slide');
  var dots = document.querySelectorAll('.testimonial-dot');
  var prevBtn = document.querySelector('.testimonial-prev');
  var nextBtn = document.querySelector('.testimonial-next');
  var currentSlide = 0;
  var autoplayInterval;
  var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function goToSlide(index) {
    if (index < 0) index = slides.length - 1;
    if (index >= slides.length) index = 0;
    currentSlide = index;
    track.style.transform = 'translateX(-' + (currentSlide * 100) + '%)';
    dots.forEach(function(d, i) {
      d.classList.toggle('dot-active', i === currentSlide);
      d.setAttribute('aria-selected', String(i === currentSlide));
    });
  }

  function startAutoplay() {
    if (reducedMotion) return;
    stopAutoplay();
    autoplayInterval = setInterval(function() {
      goToSlide(currentSlide + 1);
    }, 5000);
  }

  function stopAutoplay() {
    if (autoplayInterval) clearInterval(autoplayInterval);
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { stopAutoplay(); goToSlide(currentSlide - 1); startAutoplay(); });
  if (nextBtn) nextBtn.addEventListener('click', function() { stopAutoplay(); goToSlide(currentSlide + 1); startAutoplay(); });
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      stopAutoplay();
      goToSlide(parseInt(dot.getAttribute('data-slide'), 10));
      startAutoplay();
    });
  });

  // Pause on hover
  var carousel = document.querySelector('.testimonial-carousel');
  if (carousel) {
    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);
  }

  // Keyboard nav
  if (carousel) {
    carousel.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') { stopAutoplay(); goToSlide(currentSlide - 1); startAutoplay(); }
      if (e.key === 'ArrowRight') { stopAutoplay(); goToSlide(currentSlide + 1); startAutoplay(); }
    });
  }

  startAutoplay();

  // --- Stats Count-Up ---
  var statValues = document.querySelectorAll('.omega-stat-value[data-count-target]');
  var statsObserved = false;
  var statsBar = document.querySelector('.omega-stats-bar');

  function animateCountUp(el) {
    var target = el.getAttribute('data-count-target');
    var prefix = '';
    var suffix = '';
    var numStr = target;

    // Extract prefix ($ etc) and suffix (% + K etc)
    var match = target.match(/^([^0-9]*)([0-9,.]+)(.*)$/);
    if (match) {
      prefix = match[1];
      numStr = match[2];
      suffix = match[3];
    }
    var targetNum = parseFloat(numStr.replace(/,/g, ''));
    var duration = 2000;
    var startTime = null;

    function step(timestamp) {
      if (!startTime) startTime = timestamp;
      var progress = Math.min((timestamp - startTime) / duration, 1);
      // Ease out cubic
      var eased = 1 - Math.pow(1 - progress, 3);
      var current = Math.round(eased * targetNum);
      // Preserve formatting
      if (numStr.includes(',')) {
        el.textContent = prefix + current.toLocaleString() + suffix;
      } else {
        el.textContent = prefix + current + suffix;
      }
      if (progress < 1) {
        requestAnimationFrame(step);
      } else {
        el.textContent = target; // Restore exact original
      }
    }

    el.textContent = prefix + '0' + suffix;
    requestAnimationFrame(step);
  }

  if (statsBar && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    var statsIO = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !statsObserved) {
          statsObserved = true;
          statValues.forEach(function(el) { animateCountUp(el); });
          statsIO.disconnect();
        }
      });
    }, { threshold: 0.3 });
    statsIO.observe(statsBar);
  }
});
</script>

