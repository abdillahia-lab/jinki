  .problem-meta-item {
    padding: 16px;
    background: var(--surface-container-low);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
  }
  .problem-meta-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .problem-meta-value {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .problem-meta-cost {
    color: #FF6B35;
    font-weight: 600;
  }

  /* ============================================================
     DASHBOARD MOCKUP
     ============================================================ */
  .dashboard-mockup {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
  }
  .dash-topbar {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid var(--glass-border);
    gap: 12px;
  }
  .dash-dots {
    display: flex;
    gap: 8px;
  }
  .dash-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dash-title {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    flex: 1;
  }
  .dash-live-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    color: #28C840;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .dash-live-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #28C840;
    animation: blink 2s ease-in-out infinite;
  }
  .dash-body {
    display: flex;
    min-height: 380px;
  }
  .dash-sidebar {
    width: 160px;
    background: rgba(0,0,0,0.2);
    border-right: 1px solid var(--glass-border);
    padding: 12px 0;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .dash-nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    transition: color 0.2s ease, background 0.2s ease, border-left 0.2s ease;
    cursor: default;
  }
  .dash-nav-active {
    color: var(--accent);
    background: var(--accent-glow);
    border-left: 2px solid var(--accent);
  }
  .dash-main {
    flex: 1;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow: hidden;
  }
  .dash-cards-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .dash-kpi-card {
    background: var(--surface-container);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dash-kpi-label {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }
  .dash-kpi-value {
    font-family: var(--font-headline);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }
  .dash-kpi-value small {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  .dash-kpi-alert { color: #FF6B35; }
  .dash-kpi-good { color: #28C840; }
  .dash-kpi-change {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-tertiary);
  }
  .dash-kpi-down { color: #28C840; }
  .dash-content-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    flex: 1;
  }

  /* Dashboard Facility Map */
  .dash-facility-map {
    position: relative;
    background: rgba(0,0,0,0.2);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
  }
  .dash-map-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--accent) 3%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--accent) 3%, transparent) 1px, transparent 1px);
    background-size: 20px 20px;
  }
  .dash-map-building {
    position: absolute;
    border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
    border-radius: 4px;
    background: color-mix(in srgb, var(--accent) 4%, transparent);
  }
  .map-b1 { top: 15%; left: 10%; width: 35%; height: 40%; }
  .map-b2 { top: 20%; right: 10%; width: 30%; height: 35%; }
  .map-b3 { bottom: 10%; left: 25%; width: 20%; height: 25%; }
  .dash-map-label {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .dash-map-alert-pin {
    position: absolute;
    width: 10px;
    height: 10px;
  }
  .pin-1 { top: 25%; left: 30%; }
  .pin-2 { top: 30%; right: 20%; }
  .pin-3 { bottom: 20%; left: 35%; }
  .dash-pin-pulse {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #FF6B35;
    animation: pin-pulse 2s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(255,107,53,0.5);
  }
  .pin-warn {
    background: #FFBD2E;
    box-shadow: 0 0 8px rgba(255,189,46,0.5);
  }
  @keyframes pin-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.5); }
  }

  /* Dashboard Alerts */
  .dash-alerts-panel {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .dash-alerts-title {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-tertiary);
    margin-bottom: 4px;
  }
  .dash-alert-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 12px;
    background: var(--surface-container);
    border-radius: 8px;
    border: 1px solid var(--glass-border);
  }
  .dash-alert-severity {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .alert-critical .dash-alert-severity {
    background: rgba(255,107,53,0.15);
    color: #FF6B35;
  }
  .alert-warning .dash-alert-severity {
    background: rgba(255,189,46,0.15);
    color: #FFBD2E;
  }
  .alert-info .dash-alert-severity {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
  }
  .dash-alert-msg {
    font-size: 0.75rem;
    color: var(--text-secondary);
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .dash-alert-time {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  /* ============================================================
     TESTIMONIAL CAROUSEL
     ============================================================ */
  .testimonial-carousel {
    overflow: hidden;
    position: relative;
  }
  .testimonial-track {
    display: flex;
    transition: transform 0.5s var(--ease-material);
  }
  .testimonial-slide {
    min-width: 100%;
    padding: 0 clamp(0px, 3vw, 40px);
  }
  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    max-width: 720px;
    margin: 0 auto;
  }
  .testimonial-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
  }
  .testimonial-quote {
    margin-bottom: 24px;
  }
  .testimonial-quote p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text-primary);
    font-style: italic;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-glow);
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }
  .testimonial-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .testimonial-name {
    font-family: var(--font-headline);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    font-style: normal;
  }
  .testimonial-role {
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }
  .testimonial-company {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  .testimonial-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
  }
  .testimonial-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .testimonial-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .testimonial-dots {
    display: flex;
    gap: 8px;
  }
  .testimonial-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--text-tertiary);
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s var(--ease-out-premium);
    padding: 0;
  }
  .testimonial-dot.dot-active {
    background: var(--accent);
    transform: scale(1.3);
  }

  /* ============================================================
     TECHNOLOGY PIPELINE
     ============================================================ */
  .pipeline-track {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    overflow-x: auto;
    padding: 20px 0;
  }
  .pipeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    min-width: 140px;
    flex-shrink: 0;
  }
  .pipeline-node {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--surface-container);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    transition: background 0.3s ease, box-shadow 0.3s var(--ease-out-premium), transform 0.3s var(--ease-out-premium);
    box-shadow: 0 0 20px var(--accent-glow);
  }
  .pipeline-step:hover .pipeline-node {
    background: var(--accent-glow);
    box-shadow: 0 0 30px var(--accent-glow-strong);
    transform: scale(1.1);
  }
  .pipeline-icon {
    font-size: 28px;
    color: var(--accent);
  }
  .pipeline-connector {
    position: absolute;
    top: 32px;
    left: calc(50% + 32px);
    width: calc(100% - 64px);
    height: 2px;
    background: var(--border);
    z-index: 1;
    overflow: hidden;
  }
  .pipeline-flow {
    position: absolute;
    top: 0;
    left: -50%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: flow 2s linear infinite;
  }
  @keyframes flow {
    0% { left: -50%; }
    100% { left: 100%; }
  }
  .pipeline-label {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 16px;
  }
  .pipeline-sub {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-tertiary);
    margin-top: 4px;
    letter-spacing: 0.05em;
  }

  /* ============================================================
     PRICING CARDS
     ============================================================ */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }
  @media (min-width: 768px) {
    .pricing-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s var(--ease-out-premium), box-shadow 0.3s var(--ease-out-premium);
    display: flex;
    flex-direction: column;
  }
  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-floating);
  }
  .pricing-highlighted {
    border-color: color-mix(in srgb, var(--accent) 25%, transparent);
    box-shadow: 0 4px 24px color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .pricing-highlighted:hover {
    box-shadow: 0 12px 40px color-mix(in srgb, var(--accent) 20%, transparent);
  }
  .pricing-badge {
    position: absolute;
    top: 0;
    right: 24px;
    background: linear-gradient(135deg, #00b8d4, #00838f);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 8px 12px;
    border-radius: 0 0 8px 8px;
  }
  .pricing-header {
    margin-bottom: 24px;
  }
  .pricing-name {
    font-family: var(--font-headline);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 12px;
  }
  .pricing-amount {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
  }
  .pricing-period {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }
  .pricing-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
    flex: 1;
  }
  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .pricing-feature svg {
    margin-top: 3px;
  }
  .pricing-cta {
    display: block;
    text-align: center;
    padding: 16px 24px;
    border-radius: 12px;
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 1px solid var(--border);
    color: var(--text-primary);
    background: transparent;
    transition: border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s var(--ease-out-premium), transform 0.3s var(--ease-out-premium);
  }
  .pricing-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .pricing-highlighted .pricing-cta {
    background: linear-gradient(135deg, #00b8d4, #00838f);
    color: #fff;
    border-color: transparent;
  }
  .pricing-highlighted .pricing-cta:hover {
    box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 30%, transparent);
    transform: translateY(-2px);
    color: #fff;
  }

  /* ============================================================
     FAQ ACCORDION
     ============================================================ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .faq-item.faq-open {
    border-color: color-mix(in srgb, var(--accent) 15%, transparent);
  }
  .faq-trigger {
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: inherit;
    text-align: left;
  }
  .faq-question {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }
  .faq-chevron {
    color: var(--text-tertiary);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .faq-open .faq-chevron {
    transform: rotate(180deg);
  }
  .faq-answer {
    overflow: hidden;
  }
  .faq-answer p {
    padding: 0 24px 20px;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ============================================================
     STATS BAR ENHANCEMENTS
     ============================================================ */
  .omega-stat-item {
    position: relative;
    overflow: visible;
  }
  .stat-glow-bg {
    position: absolute;
    inset: -8px;
    border-radius: 16px;
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }
  .omega-stat-item:hover .stat-glow-bg {
    opacity: 1;
  }
  .omega-stat-value {
    position: relative;
    z-index: 1;
    background: linear-gradient(135deg, var(--accent), #00b8d4, var(--accent));
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: stat-gradient-shift 4s ease-in-out infinite;
    filter: drop-shadow(0 0 12px color-mix(in srgb, var(--accent) 40%, transparent)) drop-shadow(0 0 24px color-mix(in srgb, var(--accent) 15%, transparent));
  }
  @keyframes stat-gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .stat-divider {
    position: absolute;
    right: -16px;
    top: 10%;
    height: 80%;
    width: 1px;
    background: var(--glass-border);
    z-index: 1;
  }
  .stat-divider-glow {
    position: absolute;
    top: 0;
    left: -1px;
    width: 3px;
    height: 30%;
    background: linear-gradient(180deg, transparent, color-mix(in srgb, var(--accent) 60%, transparent), transparent);
    animation: stat-divider-travel 3s ease-in-out infinite;
    border-radius: 2px;
  }
  @keyframes stat-divider-travel {
    0%, 100% { top: 0%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 70%; opacity: 0; }
  }
  .omega-stat-item[data-stat-index="1"] .stat-divider-glow { animation-delay: 0.8s; }
  .omega-stat-item[data-stat-index="2"] .stat-divider-glow { animation-delay: 1.6s; }

  /* ============================================================
     PROBLEM EXPLORER — ANIMATED ISSUE ICONS
     ============================================================ */
  .problem-icon-wrap {
    position: relative;
    overflow: hidden;
  }
  .issue-anim {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    pointer-events: none;
    z-index: 0;
  }
  .problem-icon {
    position: relative;
    z-index: 1;
  }

  /* HVAC — pulsing heat rings */
  [data-issue="hvac"] .issue-anim {
    background: radial-gradient(circle, rgba(255,100,50,0.25) 20%, transparent 60%);
    animation: hvac-pulse 2s ease-in-out infinite;
  }
  [data-issue="hvac"] .issue-anim::before,
  [data-issue="hvac"] .issue-anim::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    border: 1px solid rgba(255,100,50,0.3);
    transform: translate(-50%, -50%);
    animation: heat-ring 2.5s ease-out infinite;
  }
  [data-issue="hvac"] .issue-anim::before {
    width: 20px; height: 20px;
  }
  [data-issue="hvac"] .issue-anim::after {
    width: 20px; height: 20px;
    animation-delay: 1.2s;
  }
  @keyframes heat-ring {
    0% { width: 10px; height: 10px; opacity: 0.8; border-color: rgba(255,100,50,0.5); }
    100% { width: 44px; height: 44px; opacity: 0; border-color: rgba(255,100,50,0); }
  }
  @keyframes hvac-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.9; }
  }

  /* Roof Moisture — drip effect */
  [data-issue="roof-leak"] .issue-anim::before,
  [data-issue="roof-leak"] .issue-anim::after {
    content: '';
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(0,180,255,0.6);
    left: 50%;
    top: 0;
