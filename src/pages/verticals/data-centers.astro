---
/*
  TEAM OMEGA — Data Centers Vertical Redesign
  Jinki Aerial Intelligence — Round 3

  Sections:
  1. 3D Facility Flythrough Hero
  2. Stats Bar
  3. Interactive Problem Explorer
  4. Live Dashboard Mockup
  5. Request Assessment CTA
  6. Technology Stack Showcase
  7. FAQ Accordion
  8. LeadGen + Footer
*/
import { Image } from 'astro:assets';
import heroImg from '../../assets/images/dc-rooftop-aerial.jpg';
import Layout from '../../layouts/Layout.astro';
import ThermalLens from '../../components/ThermalLens.astro';
import Nav from '../../components/Nav.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

