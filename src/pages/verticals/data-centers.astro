  }
  .dash-alert-time {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  /* ============================================================
     TESTIMONIAL CAROUSEL
     ============================================================ */
  .testimonial-carousel {
    overflow: hidden;
    position: relative;
  }
  .testimonial-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .testimonial-slide {
    min-width: 100%;
    padding: 0 clamp(0px, 3vw, 40px);
  }
  .testimonial-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px;
    max-width: 720px;
    margin: 0 auto;
  }
  .testimonial-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
  }
  .testimonial-quote {
    margin-bottom: 24px;
  }
  .testimonial-quote p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--text-primary);
    font-style: italic;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent-glow);
    border: 1px solid rgba(0,229,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }
  .testimonial-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .testimonial-name {
    font-family: var(--font-headline);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    font-style: normal;
  }
  .testimonial-role {
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }
  .testimonial-company {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  .testimonial-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
  }
  .testimonial-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .testimonial-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .testimonial-dots {
    display: flex;
    gap: 8px;
  }
  .testimonial-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--text-tertiary);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }
  .testimonial-dot.dot-active {
    background: var(--accent);
    transform: scale(1.3);
  }

  /* ============================================================
     TECHNOLOGY PIPELINE
     ============================================================ */
  .pipeline-track {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    overflow-x: auto;
    padding: 20px 0;
  }
  .pipeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    min-width: 140px;
    flex-shrink: 0;
  }
  .pipeline-node {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--surface-container);
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    transition: all 0.3s ease;
    box-shadow: 0 0 20px var(--accent-glow);
  }
  .pipeline-step:hover .pipeline-node {
    background: var(--accent-glow);
    box-shadow: 0 0 30px var(--accent-glow-strong);
    transform: scale(1.1);
  }
  .pipeline-icon {
    font-size: 28px;
    color: var(--accent);
  }
  .pipeline-connector {
    position: absolute;
    top: 32px;
    left: calc(50% + 32px);
    width: calc(100% - 64px);
    height: 2px;
    background: var(--border);
    z-index: 1;
    overflow: hidden;
  }
  .pipeline-flow {
    position: absolute;
    top: 0;
    left: -50%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    animation: flow 2s linear infinite;
  }
  @keyframes flow {
    0% { left: -50%; }
    100% { left: 100%; }
  }
  .pipeline-label {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 16px;
  }
  .pipeline-sub {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-tertiary);
    margin-top: 4px;
    letter-spacing: 0.05em;
  }

  /* ============================================================
     PRICING CARDS
     ============================================================ */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: start;
  }
  @media (min-width: 768px) {
    .pricing-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .pricing-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 36px;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2);
  }
  .pricing-highlighted {
    border-color: rgba(0,229,255,0.25);
    box-shadow: 0 4px 24px rgba(0,229,255,0.1);
  }
  .pricing-highlighted:hover {
    box-shadow: 0 12px 40px rgba(0,229,255,0.2);
  }
  .pricing-badge {
    position: absolute;
    top: 0;
    right: 24px;
    background: linear-gradient(135deg, #00b8d4, #00838f);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 12px;
    border-radius: 0 0 8px 8px;
  }
  .pricing-header {
    margin-bottom: 24px;
  }
  .pricing-name {
    font-family: var(--font-headline);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 12px;
  }
  .pricing-amount {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
  }
  .pricing-period {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }
  .pricing-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
    flex: 1;
  }
  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .pricing-feature svg {
    margin-top: 3px;
  }
  .pricing-cta {
    display: block;
    text-align: center;
    padding: 14px 24px;
    border-radius: 12px;
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border: 1px solid var(--border);
    color: var(--text-primary);
    background: transparent;
    transition: all 0.3s ease;
  }
  .pricing-cta:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .pricing-highlighted .pricing-cta {
    background: linear-gradient(135deg, #00b8d4, #00838f);
    color: #fff;
    border-color: transparent;
  }
  .pricing-highlighted .pricing-cta:hover {
    box-shadow: 0 4px 20px rgba(0,229,255,0.3);
    transform: translateY(-2px);
    color: #fff;
  }

  /* ============================================================
     FAQ ACCORDION
     ============================================================ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }
  .faq-item.faq-open {
    border-color: rgba(0,229,255,0.15);
  }
  .faq-trigger {
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: inherit;
    text-align: left;
  }
  .faq-question {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }
  .faq-chevron {
    color: var(--text-tertiary);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }
  .faq-open .faq-chevron {
    transform: rotate(180deg);
  }
  .faq-answer {
    overflow: hidden;
  }
  .faq-answer p {
    padding: 0 24px 20px;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ============================================================
     STATS BAR ENHANCEMENTS
     ============================================================ */
  .omega-stat-item {
    position: relative;
    overflow: visible;
  }
  .stat-glow-bg {
    position: absolute;
    inset: -8px;
    border-radius: 16px;
    background: radial-gradient(ellipse at center, rgba(0,229,255,0.06) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
    z-index: 0;
  }
  .omega-stat-item:hover .stat-glow-bg {
    opacity: 1;
  }
  .omega-stat-value {
    position: relative;
    z-index: 1;
    background: linear-gradient(135deg, #00E5FF, #00b8d4, #00E5FF);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: stat-gradient-shift 4s ease-in-out infinite;
  }
  @keyframes stat-gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .stat-divider {
    position: absolute;
    right: -16px;
    top: 10%;
    height: 80%;
    width: 1px;
    background: var(--glass-border);
    z-index: 1;
  }
  .stat-divider-glow {
    position: absolute;
    top: 0;
    left: -1px;
    width: 3px;
    height: 30%;
    background: linear-gradient(180deg, transparent, rgba(0,229,255,0.6), transparent);
    animation: stat-divider-travel 3s ease-in-out infinite;
    border-radius: 2px;
  }
  @keyframes stat-divider-travel {
    0%, 100% { top: 0%; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 70%; opacity: 0; }
  }
  .omega-stat-item[data-stat-index="1"] .stat-divider-glow { animation-delay: 0.8s; }
  .omega-stat-item[data-stat-index="2"] .stat-divider-glow { animation-delay: 1.6s; }

  /* ============================================================
     PROBLEM EXPLORER — ANIMATED ISSUE ICONS
     ============================================================ */
  .problem-icon-wrap {
    position: relative;
    overflow: hidden;
  }
  .issue-anim {
    position: absolute;
    inset: 0;
    border-radius: 12px;
    pointer-events: none;
    z-index: 0;
  }
  .problem-icon {
    position: relative;
    z-index: 1;
  }

  /* HVAC — pulsing heat rings */
  [data-issue="hvac"] .issue-anim {
    background: radial-gradient(circle, rgba(255,100,50,0.25) 20%, transparent 60%);
    animation: hvac-pulse 2s ease-in-out infinite;
  }
  [data-issue="hvac"] .issue-anim::before,
  [data-issue="hvac"] .issue-anim::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    border-radius: 50%;
    border: 1px solid rgba(255,100,50,0.3);
    transform: translate(-50%, -50%);
    animation: heat-ring 2.5s ease-out infinite;
  }
  [data-issue="hvac"] .issue-anim::before {
    width: 20px; height: 20px;
  }
  [data-issue="hvac"] .issue-anim::after {
    width: 20px; height: 20px;
    animation-delay: 1.2s;
  }
  @keyframes heat-ring {
    0% { width: 10px; height: 10px; opacity: 0.8; border-color: rgba(255,100,50,0.5); }
    100% { width: 44px; height: 44px; opacity: 0; border-color: rgba(255,100,50,0); }
  }
  @keyframes hvac-pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.9; }
  }

  /* Roof Moisture — drip effect */
  [data-issue="roof-leak"] .issue-anim::before,
  [data-issue="roof-leak"] .issue-anim::after {
    content: '';
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(0,180,255,0.6);
    left: 50%;
    top: 0;
    animation: drip-fall 2s ease-in infinite;
  }
  [data-issue="roof-leak"] .issue-anim::after {
    left: 35%;
    animation-delay: 0.8s;
    width: 2px;
    height: 2px;
    background: rgba(0,180,255,0.4);
  }
  @keyframes drip-fall {
    0% { top: 2px; opacity: 0; transform: translateX(-50%); }
    10% { opacity: 1; }
    70% { opacity: 1; }
    100% { top: 38px; opacity: 0; transform: translateX(-50%) scale(1.5); }
  }

  /* Electrical Hot Spots — spark/arc */
  [data-issue="hot-spots"] .issue-anim::before {
    content: '';
    position: absolute;
    width: 2px;
    height: 12px;
    background: linear-gradient(180deg, #FFD700, #FF8C00, transparent);
    top: 4px;
    left: 50%;
    transform: translateX(-50%) rotate(-15deg);
    animation: spark-flash 1.5s ease-in-out infinite;
    border-radius: 1px;
    filter: blur(0.5px);
  }
  [data-issue="hot-spots"] .issue-anim::after {
    content: '';
    position: absolute;
    width: 2px;
    height: 8px;
    background: linear-gradient(180deg, #FFF, #FFD700, transparent);
    top: 6px;
    left: 60%;
    transform: rotate(20deg);
    animation: spark-flash 1.5s ease-in-out infinite 0.4s;
    border-radius: 1px;
    filter: blur(0.5px);
  }
  @keyframes spark-flash {
    0%, 100% { opacity: 0; transform: translateX(-50%) rotate(-15deg) scaleY(0.5); }
    15% { opacity: 1; transform: translateX(-50%) rotate(-15deg) scaleY(1); }
    30% { opacity: 0; transform: translateX(-50%) rotate(-15deg) scaleY(0.8); }
    45% { opacity: 0.8; transform: translateX(-50%) rotate(10deg) scaleY(1.1); }
    60% { opacity: 0; }
  }

  /* Drainage — water ripple */
  [data-issue="drainage"] .issue-anim::before,
  [data-issue="drainage"] .issue-anim::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 8px;
    height: 4px;
    border: 1px solid rgba(0,180,255,0.4);
    border-radius: 50%;
    transform: translateX(-50%);
    animation: ripple-expand 2.5s ease-out infinite;
  }
  [data-issue="drainage"] .issue-anim::after {
    animation-delay: 1.2s;
  }
  @keyframes ripple-expand {
    0% { width: 4px; height: 2px; opacity: 0.8; }
    100% { width: 36px; height: 14px; opacity: 0; }
  }

  /* Membrane — crack pattern */
  [data-issue="membrane"] .issue-anim {
    background:
      linear-gradient(135deg, transparent 40%, rgba(255,100,50,0.15) 40.5%, transparent 41%),
      linear-gradient(160deg, transparent 55%, rgba(255,100,50,0.1) 55.5%, transparent 56%),
      linear-gradient(120deg, transparent 30%, rgba(255,100,50,0.08) 30.5%, transparent 31%);
    animation: crack-reveal 3s ease-in-out infinite;
  }
  @keyframes crack-reveal {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }

  /* Equipment Overheating — heat shimmer */
  [data-issue="equipment"] .issue-anim {
    background: linear-gradient(0deg,
      rgba(255,120,50,0.2) 0%,
      rgba(255,180,50,0.1) 40%,
      transparent 80%
    );
    animation: shimmer-rise 2s ease-in-out infinite;
  }
  [data-issue="equipment"] .issue-anim::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 20%;
    width: 60%;
    height: 100%;
    background: linear-gradient(0deg, rgba(255,150,50,0.15), transparent);
    animation: shimmer-wave 1.5s ease-in-out infinite alternate;
    filter: blur(2px);
  }
  @keyframes shimmer-rise {
    0%, 100% { opacity: 0.5; transform: scaleY(0.9); }
    50% { opacity: 1; transform: scaleY(1); }
  }
  @keyframes shimmer-wave {
    0% { transform: translateX(-3px) skewX(-2deg); }
    100% { transform: translateX(3px) skewX(2deg); }
  }

  /* ============================================================
     PIPELINE ENHANCEMENTS
     ============================================================ */
  .pipeline-node {
    position: relative;
  }
  .pipeline-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid transparent;
    transition: all 0.4s ease;
    pointer-events: none;
  }
  .pipeline-step:hover .pipeline-ring {
    border-color: rgba(0,229,255,0.3);
    box-shadow: 0 0 20px rgba(0,229,255,0.15), inset 0 0 20px rgba(0,229,255,0.05);
    animation: ring-spin 3s linear infinite;
  }
  @keyframes ring-spin {
    0% { border-color: rgba(0,229,255,0.3); }
    50% { border-color: rgba(0,229,255,0.6); }
    100% { border-color: rgba(0,229,255,0.3); }
  }
  .pipeline-connector {
    height: 3px;
    background: linear-gradient(90deg, var(--border) 0%, rgba(0,229,255,0.15) 50%, var(--border) 100%);
  }
  .pipeline-particle {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    top: 50%;
    transform: translateY(-50%);
    animation: particle-flow 3s linear infinite;
    opacity: 0;
    box-shadow: 0 0 6px rgba(0,229,255,0.6);
  }
  .pipeline-particle.p1 { animation-delay: 0s; }
  .pipeline-particle.p2 { animation-delay: 1s; }
  .pipeline-particle.p3 { animation-delay: 2s; }
  @keyframes particle-flow {
    0% { left: -4px; opacity: 0; }
    5% { opacity: 1; }
    95% { opacity: 1; }
    100% { left: calc(100% + 4px); opacity: 0; }
  }

  /* ============================================================
     PRICING ENHANCEMENTS
     ============================================================ */
  .pricing-card {
    position: relative;
  }
  .pricing-card:hover {
    border-color: rgba(0,229,255,0.15);
    box-shadow: 0 12px 40px rgba(0,0,0,0.2), 0 0 30px rgba(0,229,255,0.06);
  }
  .pricing-highlighted {
    border-color: rgba(0,229,255,0.3);
  }
  .pricing-highlighted:hover {
    border-color: rgba(0,229,255,0.5);
    box-shadow: 0 12px 40px rgba(0,229,255,0.2), 0 0 40px rgba(0,229,255,0.1);
  }
  .pricing-shimmer {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }
  .pricing-shimmer::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(
      from 0deg,
      transparent 0deg,
      rgba(0,229,255,0.06) 60deg,
      transparent 120deg,
      rgba(0,229,255,0.04) 180deg,
      transparent 240deg,
      rgba(0,229,255,0.06) 300deg,
      transparent 360deg
    );
    animation: shimmer-rotate 8s linear infinite;
  }
  @keyframes shimmer-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
  .pricing-shimmer::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(0,229,255,0.04), transparent);
    animation: pricing-shine 4s ease-in-out infinite;
  }
  @keyframes pricing-shine {
    0%, 100% { left: -100%; }
    50% { left: 100%; }
  }
  .pricing-header,
  .pricing-features,
  .pricing-cta {
    position: relative;
    z-index: 1;
  }
  .pricing-badge {
    z-index: 2;
  }

  /* Pricing checkmarks — color-coded by tier */
  .pricing-card:first-child .pricing-feature svg path {
    stroke: rgba(0,229,255,0.6);
  }
  .pricing-highlighted .pricing-feature svg path {
    stroke: #00E5FF;
    filter: drop-shadow(0 0 3px rgba(0,229,255,0.4));
  }
  .pricing-card:last-child .pricing-feature svg path {
    stroke: #28C840;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 1024px) {
    .dash-sidebar { display: none; }
    .dash-cards-row { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .omega-hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .omega-hero {
      min-height: auto;
