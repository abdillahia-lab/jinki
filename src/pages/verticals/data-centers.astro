const pipelineSteps = [
  { icon: 'rocket_launch', label: 'Aerial Platform', sub: 'Piloted or autonomous configuration' },
  { icon: 'thermostat', label: 'Thermal Sensor', sub: 'Radiometric thermal imaging with 0.5°C sensitivity' },
  { icon: 'psychology', label: 'AI Analysis', sub: 'Edge + cloud processing pipeline' },
  { icon: 'hub', label: 'Cloud Intelligence', sub: 'Pattern recognition + ML classification' },
  { icon: 'verified_user', label: 'Actionable Report', sub: 'Prioritized findings within 48hr' },
];

const faqs = [
  {
    q: 'How long does a full facility assessment take?',
    a: 'A typical data center campus can be surveyed in a single day of aerial operations. The prioritized findings report includes severity rankings and recommended next steps. Turnaround time depends on facility size and scope — contact us for specifics.',
  },
  {
    q: 'Do aerial operations disrupt data center operations?',
    a: 'No. All inspections are conducted externally — from rooftops, perimeters, and mechanical equipment areas. There is zero impact on interior operations, no roof access required, and no coordination needed with IT teams. Operations continue uninterrupted.',
  },
  {
    q: 'What compliance requirements do your inspections satisfy?',
    a: 'Our thermal inspections align with NFPA 70B electrical maintenance requirements, ASHRAE temperature monitoring guidelines, and support environmental compliance documentation. Each deliverable maps findings to relevant standards.',
  },
  {
    q: 'How does autonomous monitoring differ from one-time assessment?',
    a: 'Autonomous monitoring uses a permanently stationed aerial platform with an on-site autonomous dock station that conducts 150-200 scheduled missions per month. This enables thermal trend analysis over time — detecting degradation velocity, not just current state.',
  },
  {
    q: 'What is included in the findings report?',
    a: 'Every report includes georeferenced thermal and visual imagery, severity classifications, priority rankings, recommended next steps, and an executive summary suitable for leadership and insurance stakeholders.',
