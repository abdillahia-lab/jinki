    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 10px solid transparent;
    border-bottom: 18px solid rgba(255, 180, 0, 0.4);
  }
  .alert-tri-1 {
    animation: alert-pop 3s ease-in-out infinite;
  }
  .alert-tri-2 {
    transform: translate(-8px, 4px) scale(0.7);
    border-bottom-color: rgba(255, 180, 0, 0.25);
    animation: alert-pop 3s ease-in-out infinite 0.4s;
  }
  .alert-tri-3 {
    transform: translate(10px, 6px) scale(0.6);
    border-bottom-color: rgba(255, 180, 0, 0.2);
    animation: alert-pop 3s ease-in-out infinite 0.8s;
  }
  @keyframes alert-pop {
    0%, 30% { opacity: 1; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(-2px); }
    70%, 100% { opacity: 0.3; transform: translateY(4px); }
  }
  .alert-dismiss-x {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 12px;
    height: 12px;
    opacity: 0;
    animation: dismiss-x 3s ease-in-out infinite;
  }
  .alert-dismiss-x::before, .alert-dismiss-x::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: rgba(255, 60, 60, 0.6);
    border-radius: 1px;
  }
  .alert-dismiss-x::before { transform: rotate(45deg); }
  .alert-dismiss-x::after { transform: rotate(-45deg); }
  @keyframes dismiss-x {
    0%, 60% { opacity: 0; }
    70% { opacity: 1; }
    85% { opacity: 1; transform: scale(1); }
    100% { opacity: 0; transform: scale(0.6); }
  }

  /* Fence breach visualization */
  .pain-anim-fence {
    background: rgba(123, 97, 255, 0.04);
    border-radius: 8px;
  }
  .fence-seg {
    position: absolute;
    top: 50%;
    height: 2px;
    background: rgba(123, 97, 255, 0.3);
    transform: translateY(-1px);
  }
  .fence-seg-1 { left: 4px; width: 14px; }
  .fence-seg-2 { left: 26px; width: 6px; }
  .fence-seg-3 { right: 4px; width: 14px; }
  .fence-breach-point {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 10px;
    height: 10px;
    margin: -5px 0 0 -5px;
    border-radius: 50%;
    background: rgba(255, 60, 60, 0.5);
    animation: fence-breach-pulse 2s ease-in-out infinite;
  }
  @keyframes fence-breach-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255, 60, 60, 0.4); transform: scale(1); }
    50% { box-shadow: 0 0 12px 4px rgba(255, 60, 60, 0.15); transform: scale(1.2); }
  }
  .fence-intruder {
    position: absolute;
    bottom: 10px;
    width: 6px;
    height: 12px;
    background: rgba(255, 60, 60, 0.5);
    border-radius: 3px 3px 1px 1px;
    animation: intruder-move 4s ease-in-out infinite;
  }
  @keyframes intruder-move {
    0% { left: 10px; opacity: 0; }
    20% { opacity: 0.7; }
    50% { left: 50%; opacity: 0.9; }
    80% { opacity: 0.7; }
    100% { left: calc(100% - 16px); opacity: 0; }
  }

  /* ================================================================
     2. INTERACTIVE PERIMETER MAP
     ================================================================ */
  .perimeter-wrap {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--glass-shadow);
  }
  .perimeter-svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .facility-bg {
    fill: rgba(123, 97, 255, 0.03);
    stroke: rgba(123, 97, 255, 0.08);
    stroke-width: 1;
  }
  .building {
    fill: rgba(123, 97, 255, 0.06);
    stroke: rgba(123, 97, 255, 0.15);
    stroke-width: 1;
  }
  .bldg-label {
    font-family: var(--font-mono);
    font-size: 8px;
    fill: var(--text-tertiary);
    text-anchor: middle;
    letter-spacing: 0.1em;
    dominant-baseline: middle;
  }
  .fence-line {
    fill: none;
    stroke: rgba(123, 97, 255, 0.25);
    stroke-width: 2;
    stroke-dasharray: 8 4;
    transition: stroke 0.5s ease, filter 0.5s ease;
  }
  .fence-line.fence-breach {
    stroke: #ff3c3c;
    filter: drop-shadow(0 0 8px rgba(255, 60, 60, 0.6));
    stroke-dasharray: none;
    animation: fence-alarm 0.5s ease-in-out 3;
  }
  @keyframes fence-alarm {
    0%, 100% { stroke: #ff3c3c; }
    50% { stroke: #ff8c00; }
  }
  .patrol-path {
    fill: none;
    stroke: rgba(123, 97, 255, 0.12);
    stroke-width: 1.5;
    stroke-dasharray: 6 3;
  }
  .patrol-dot {
    fill: #7B61FF;
    filter: drop-shadow(0 0 6px rgba(123, 97, 255, 0.8));
  }
  .patrol-trail {
    fill: rgba(123, 97, 255, 0.15);
  }
  /* Click zones */
  .zone-hit {
    fill: rgba(123, 97, 255, 0.04);
    stroke: rgba(123, 97, 255, 0.1);
    stroke-width: 1;
    cursor: pointer;
    transition: fill 0.3s ease, stroke 0.3s ease;
  }
  .zone:hover .zone-hit, .zone:focus .zone-hit {
    fill: rgba(123, 97, 255, 0.12);
    stroke: rgba(123, 97, 255, 0.4);
  }
  .zone:focus { outline: none; }
  .zone:focus-visible .zone-hit { stroke: #7B61FF; stroke-width: 2; }
  .zone-label {
    font-family: var(--font-mono);
    font-size: 9px;
    fill: var(--text-tertiary);
    text-anchor: middle;
    letter-spacing: 0.15em;
    pointer-events: none;
  }
  .breach-flash {
    fill: rgba(255, 60, 60, 0.6);
    opacity: 0;
    transition: r 0.5s ease, opacity 0.5s ease;
  }
  .breach-flash.active {
    opacity: 1;
    r: 30;
  }

  /* Breach info overlay */
  .breach-info {
    position: absolute;
    bottom: 24px;
    left: 24px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(12px);
    padding: 16px 20px;
    border-radius: 12px;
    border: 1px solid rgba(255, 60, 60, 0.3);
    max-width: 340px;
    animation: breach-fadein 0.4s ease;
  }
  @keyframes breach-fadein {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .breach-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #ff3c3c;
    text-transform: uppercase;
  }
  .breach-detail {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
  }
  .breach-response {
    font-family: var(--font-mono);
    font-size: 10px;
    color: #7B61FF;
    letter-spacing: 0.05em;
  }

  /* ================================================================
     3. ALERT CASCADE
     ================================================================ */
  .alert-cascade {
    background: #0a0a10;
    border: 1px solid rgba(123, 97, 255, 0.12);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }
  .alert-header-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: rgba(123, 97, 255, 0.06);
    border-bottom: 1px solid rgba(123, 97, 255, 0.1);
  }
  .alert-header-dot-live {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ff3c3c;
    box-shadow: 0 0 8px rgba(255, 60, 60, 0.5);
    animation: status-blink 1s ease-in-out infinite;
  }
  .alert-header-title {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--text-tertiary);
    flex: 1;
  }
  .alert-header-ts {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: rgba(123, 97, 255, 0.6);
  }

  .alert-feed {
    max-height: 360px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(123, 97, 255, 0.2) transparent;
  }
  .alert-feed::-webkit-scrollbar { width: 4px; }
  .alert-feed::-webkit-scrollbar-track { background: transparent; }
  .alert-feed::-webkit-scrollbar-thumb { background: rgba(123, 97, 255, 0.2); border-radius: 2px; }

  .alert-row {
    display: grid;
    grid-template-columns: 72px 72px 1fr 1fr 1.2fr;
    gap: 12px;
    align-items: center;
    padding: 12px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    opacity: 0;
    transform: translateX(-20px);
    animation: alert-slide-in 0.4s ease forwards;
    animation-play-state: paused;
  }
  .alert-row.animate { animation-play-state: running; }
  @keyframes alert-slide-in {
    to { opacity: 1; transform: translateX(0); }
  }
  .alert-time {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }
  .alert-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    text-align: center;
  }
  .alert-badge-red { background: rgba(255, 60, 60, 0.15); color: #ff3c3c; }
  .alert-badge-yellow { background: rgba(255, 180, 0, 0.15); color: #ffb400; }
  .alert-badge-green { background: rgba(0, 200, 80, 0.15); color: #00c850; }
  .alert-type {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .alert-location {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
  }
  .alert-detail {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-tertiary);
  }

  /* ================================================================
     4. RESPONSE TIME CHART
     ================================================================ */
  .response-chart {
    max-width: 800px;
  }
  .chart-row {
    margin-bottom: 32px;
  }
  .chart-label {
    display: block;
    font-family: var(--font-headline);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 10px;
  }
  .chart-bar-wrap {
    background: rgba(123, 97, 255, 0.06);
    border-radius: 8px;
    height: 44px;
    overflow: hidden;
    position: relative;
  }
  .chart-bar {
    height: 100%;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 16px;
    width: 0%;
    transition: width 1.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .chart-bar.animate { width: var(--bar-pct); }
  .chart-bar-jinki {
    background: linear-gradient(90deg, #7B61FF, #4F46E5);
    box-shadow: 0 0 20px rgba(123, 97, 255, 0.3);
    min-width: 80px;
  }
  .chart-bar-guard {
    background: linear-gradient(90deg, #ff8c00, #cc6600);
    box-shadow: 0 0 20px rgba(255, 140, 0, 0.2);
  }
  .chart-bar-camera {
    background: linear-gradient(90deg, #ff3c3c, #cc2222);
    box-shadow: 0 0 20px rgba(255, 60, 60, 0.2);
  }
  .chart-bar-value {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }
  .chart-legend {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--glass-border);
  }
  .chart-legend-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-tertiary);
    letter-spacing: 0.08em;
  }

  /* ================================================================
     5. NIGHT OPERATIONS SHOWCASE
     ================================================================ */
  .night-showcase {
    max-width: 960px;
    margin: 0 auto;
  }
  .night-toggle-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }
  .night-toggle {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 9999px;
    padding: 8px 24px;
    cursor: pointer;
    transition: border-color 0.3s ease;
    position: relative;
  }
  .night-toggle:hover { border-color: rgba(123, 97, 255, 0.3); }
  .night-toggle-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--text-tertiary);
    transition: color 0.3s ease;
  }
  .night-toggle-day { color: #ffb400; }
  .night-toggle[aria-pressed="true"] .night-toggle-day { color: var(--text-tertiary); }
  .night-toggle[aria-pressed="true"] .night-toggle-night { color: #7B61FF; }
  .night-toggle-thumb {
    width: 28px;
    height: 16px;
    border-radius: 8px;
    background: #7B61FF;
    position: relative;
    transition: background 0.3s ease;
  }
  .night-toggle-thumb::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #fff;
    transition: transform 0.3s ease;
  }
  .night-toggle[aria-pressed="true"] .night-toggle-thumb::after {
    transform: translateX(12px);
  }

  .night-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    transition: gap 0.5s ease;
  }
  .night-split.night-mode .night-panel-day { opacity: 0.4; transform: scale(0.96); }
  .night-split.night-mode .night-panel-night { opacity: 1; transform: scale(1); box-shadow: 0 0 40px rgba(123, 97, 255, 0.15); }

  .night-panel {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    background: var(--bg-card);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.5s ease;
  }
  .night-panel-night { opacity: 0.6; transform: scale(0.96); }

  .night-scene {
    position: relative;
    height: 220px;
    overflow: hidden;
  }
  .night-scene-sky {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
  }
  .night-sky-day { background: linear-gradient(180deg, #87CEEB, #B0E0E6); }
  .night-sky-night { background: linear-gradient(180deg, #0a0a18, #141428); }
  .night-scene-ground {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 50%;
  }
  .night-ground-day { background: linear-gradient(180deg, #4a7c59, #3d6b4e); }
  .night-ground-night { background: linear-gradient(180deg, #0f1a14, #0a120e); }

  .night-fence {
    position: absolute;
    bottom: 40%;
    left: 10%;
    right: 10%;
    height: 3px;
    background: rgba(150, 150, 150, 0.4);
  }
  .night-fence-thermal {
    background: rgba(123, 97, 255, 0.3);
    box-shadow: 0 0 8px rgba(123, 97, 255, 0.2);
  }

  .night-building {
    position: absolute;
    bottom: 40%;
    left: 15%;
    width: 25%;
    height: 40%;
    border-radius: 4px 4px 0 0;
  }
  .night-bldg-day { background: #8899aa; }
  .night-bldg-night { background: #1a1a2e; border: 1px solid rgba(123, 97, 255, 0.1); }

  .night-figure {
    position: absolute;
    bottom: 42%;
    width: 16px;
    height: 32px;
    border-radius: 8px 8px 4px 4px;
    left: 42%;
  }
  .night-figure-visible { background: #555; }
  .night-figure-hidden { background: #555; }
  .night-figure-thermal {
    background: linear-gradient(180deg, #ff4444, #ff8800);
    box-shadow: 0 0 12px rgba(255, 68, 68, 0.5);
  }

  .thermal-tag {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    color: #ff4444;
    text-shadow: 0 0 4px rgba(255, 68, 68, 0.5);
    pointer-events: none;
  }

  .night-caption {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 16px 20px;
    border-top: 1px solid var(--glass-border);
  }
  .night-caption-icon { font-size: 20px; color: #7B61FF; flex-shrink: 0; margin-top: 2px; }
  .night-caption-title {
    display: block;
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }
  .night-caption-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* ---- Services Grid ---- */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    position: relative;
  }
  .services-grid::before {
    content: '';
    position: absolute;
    inset: -40px;
    background-image:
      linear-gradient(rgba(123, 97, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(123, 97, 255, 0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }
  @media (min-width: 768px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }
  .service-card {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 32px;
    transition: transform 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)), border-color 0.3s ease, box-shadow 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
    position: relative;
    overflow: hidden;
    z-index: 1;
  }
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }
  .service-card::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    border: 1px solid transparent;
    background: linear-gradient(135deg, rgba(123, 97, 255, 0), rgba(123, 97, 255, 0)) border-box;
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    -webkit-mask-composite: xor;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .service-card:hover {
    transform: translateY(-4px);
    border-color: rgba(123, 97, 255, 0.35);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2), 0 0 40px rgba(123, 97, 255, 0.12), 0 0 80px rgba(123, 97, 255, 0.05);
  }
  .service-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(123, 97, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    transition: box-shadow 0.3s ease, background 0.3s ease;
    position: relative;
  }
  .service-icon-wrap::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 16px;
    border: 1.5px solid rgba(123, 97, 255, 0);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .service-card:hover .service-icon-wrap {
    box-shadow: 0 0 24px rgba(123, 97, 255, 0.2);
    background: rgba(123, 97, 255, 0.12);
  }
  .service-card:hover .service-icon-wrap::after {
    border-color: rgba(123, 97, 255, 0.3);
    animation: icon-ring-pulse 1.5s ease-out infinite;
  }
  @keyframes icon-ring-pulse {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(1.4); opacity: 0; }
  }
  .service-icon { color: #7B61FF; font-size: 24px; }
  .service-title {
    font-family: var(--font-headline);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .service-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ================================================================
     6. INTEGRATION ECOSYSTEM
     ================================================================ */
  .integration-diagram {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    aspect-ratio: 3 / 2;
  }
  .integ-ring {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .integ-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(123, 97, 255, 0.15), rgba(79, 70, 229, 0.08));
    border: 2px solid rgba(123, 97, 255, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    z-index: 2;
    box-shadow: 0 0 40px rgba(123, 97, 255, 0.15);
    animation: center-glow 3s ease-in-out infinite;
  }
  @keyframes center-glow {
    0%, 100% { box-shadow: 0 0 40px rgba(123, 97, 255, 0.15); }
    50% { box-shadow: 0 0 60px rgba(123, 97, 255, 0.3); }
  }
  .integ-center-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #7B61FF;
  }
  .integ-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .integ-line {
    stroke: rgba(123, 97, 255, 0.15);
    stroke-width: 1.5;
    stroke-dasharray: 6 4;
    animation: line-dash 2s linear infinite;
  }
  .integ-line-1 { animation-delay: 0s; }
  .integ-line-2 { animation-delay: 0.5s; }
  .integ-line-3 { animation-delay: 1s; }
  .integ-line-4 { animation-delay: 1.5s; }
  @keyframes line-dash {
    0% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -20; }
  }
  .integ-node {
    position: absolute;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    z-index: 2;
  }
  .integ-node-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
    color: var(--text-secondary);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .integ-node:hover .integ-node-icon {
    border-color: rgba(123, 97, 255, 0.3);
    box-shadow: 0 0 20px rgba(123, 97, 255, 0.12);
  }
  .integ-node-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--text-tertiary);
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Data flow pulses */
  .integ-pulse-track {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 3;
  }
  .integ-pulse {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #7B61FF;
    box-shadow: 0 0 8px rgba(123, 97, 255, 0.6);
    opacity: 0;
  }
  .integ-pulse-1 { animation: pulse-tl 3s ease-in-out infinite 0s; }
  .integ-pulse-2 { animation: pulse-bl 3s ease-in-out infinite 0.8s; }
  .integ-pulse-3 { animation: pulse-tr 3s ease-in-out infinite 1.5s; }
  .integ-pulse-4 { animation: pulse-br 3s ease-in-out infinite 2.2s; }
  @keyframes pulse-tl {
    0% { top: 50%; left: 50%; opacity: 0; }
    10% { opacity: 1; }
    50% { top: 25%; left: 15%; opacity: 1; }
    60% { opacity: 0; }
    100% { top: 25%; left: 15%; opacity: 0; }
  }
  @keyframes pulse-bl {
    0% { top: 50%; left: 50%; opacity: 0; }
    10% { opacity: 1; }
    50% { top: 75%; left: 15%; opacity: 1; }
    60% { opacity: 0; }
    100% { top: 75%; left: 15%; opacity: 0; }
  }
  @keyframes pulse-tr {
    0% { top: 50%; left: 50%; opacity: 0; }
    10% { opacity: 1; }
    50% { top: 25%; left: 85%; opacity: 1; }
    60% { opacity: 0; }
    100% { top: 25%; left: 85%; opacity: 0; }
  }
  @keyframes pulse-br {
    0% { top: 50%; left: 50%; opacity: 0; }
    10% { opacity: 1; }
    50% { top: 75%; left: 85%; opacity: 1; }
    60% { opacity: 0; }
    100% { top: 75%; left: 85%; opacity: 0; }
  }

  /* ---- Differentiators (Mission Briefing Cards) ---- */
  .diff-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) { .diff-grid { grid-template-columns: repeat(2, 1fr); } }
  .diff-card {
    padding: 32px;
    border-left: none;
    border: 1px solid rgba(123, 97, 255, 0.1);
    border-radius: 12px;
    background: var(--surface-container-low);
    position: relative;
    overflow: hidden;
    transition: border-color 0.4s ease,
                box-shadow 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                background 0.4s ease,
                transform 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .diff-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #7B61FF, #4F46E5, #7B61FF);
    background-size: 200% 100%;
    animation: diff-accent-shift 4s ease infinite;
  }
  @keyframes diff-accent-shift {
    0%, 100% { background-position: 0% 0%; }
    50% { background-position: 100% 0%; }
  }
  .diff-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(123, 97, 255, 0.06), transparent);
    transition: left 0.5s ease;
    pointer-events: none;
  }
  .diff-card:hover::after {
    left: 100%;
  }
  .diff-card:hover {
    border-color: rgba(123, 97, 255, 0.25);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15), 0 0 24px rgba(123, 97, 255, 0.08);
    background: rgba(123, 97, 255, 0.03);
    transform: translateY(-3px);
  }
  .diff-number {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: #7B61FF;
    letter-spacing: 0.15em;
    margin-bottom: 12px;
    display: inline-block;
    padding: 3px 10px;
    background: rgba(123, 97, 255, 0.08);
    border-radius: 4px;
    border: 1px solid rgba(123, 97, 255, 0.12);
  }
  .diff-card h3 {
    font-family: var(--font-headline);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .diff-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ================================================================
     RESPONSIVE
     ================================================================ */
  @media (max-width: 768px) {
    .sec-hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .sec-hero { min-height: auto; padding-top: 120px; }
    .stats-bar-inner { grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .sec-hero-actions { flex-direction: column; align-items: flex-start; gap: 16px; }
    .alert-row { grid-template-columns: 60px 60px 1fr; gap: 8px; }
    .alert-location, .alert-detail { display: none; }
    .night-split { grid-template-columns: 1fr; }
    .integ-node-icon { width: 44px; height: 44px; font-size: 22px; }
    .integ-center { width: 72px; height: 72px; }
    .integ-center .material-symbols-outlined { font-size: 28px !important; }
  }

  /* ================================================================
     LIGHT MODE OVERRIDES
     ================================================================ */
  :global([data-theme="light"]) .hud-container {
    background: #e8eee8;
    border-color: rgba(79, 70, 229, 0.15);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
  }
  :global([data-theme="light"]) .hud-nightvision {
    background: radial-gradient(ellipse at center, rgba(0, 180, 50, 0.04) 0%, rgba(200, 220, 200, 0.3) 100%);
  }
  :global([data-theme="light"]) .hud-scanlines {
    background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 100, 30, 0.02) 2px, rgba(0, 100, 30, 0.02) 4px);
  }
  :global([data-theme="light"]) .crosshair-h,
  :global([data-theme="light"]) .crosshair-v { background: rgba(0, 120, 40, 0.3); }
  :global([data-theme="light"]) .crosshair-circle { border-color: rgba(0, 120, 40, 0.2); }
  :global([data-theme="light"]) .hud-bracket { border-color: rgba(0, 120, 40, 0.3); }
  :global([data-theme="light"]) .hud-ts-label { color: rgba(0, 100, 30, 0.4); }
  :global([data-theme="light"]) .hud-ts-time { color: rgba(0, 100, 30, 0.6); }
  :global([data-theme="light"]) .hud-status-dot { background: #00a030; box-shadow: 0 0 8px rgba(0, 160, 48, 0.4); }
  :global([data-theme="light"]) .hud-status-text { color: rgba(0, 100, 30, 0.6); }
  :global([data-theme="light"]) .hud-telemetry span { color: rgba(0, 100, 30, 0.3); }

  :global([data-theme="light"]) .alert-cascade {
    background: #f8f9fa;
    border-color: rgba(79, 70, 229, 0.1);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.08);
  }
  :global([data-theme="light"]) .alert-header-bar {
    background: rgba(79, 70, 229, 0.04);
    border-bottom-color: rgba(79, 70, 229, 0.08);
  }
  :global([data-theme="light"]) .alert-row { border-bottom-color: rgba(0, 0, 0, 0.04); }

  :global([data-theme="light"]) .perimeter-wrap {
    background: var(--bg-card);
    box-shadow: var(--glass-shadow);
  }
  :global([data-theme="light"]) .facility-bg { fill: rgba(79, 70, 229, 0.03); stroke: rgba(79, 70, 229, 0.08); }
  :global([data-theme="light"]) .building { fill: rgba(79, 70, 229, 0.06); stroke: rgba(79, 70, 229, 0.12); }

  :global([data-theme="light"]) .breach-info {
    background: rgba(255, 255, 255, 0.95);
    border-color: rgba(255, 60, 60, 0.2);
  }
</style>

<script>
  // ---- HUD Clock ----
  function updateHudClock() {
    const el = document.getElementById('hud-clock');
    if (!el) return;
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    el.textContent = `${h}:${m}:${s}`;
  }
  setInterval(updateHudClock, 1000);
  updateHudClock();

  // ---- Perimeter breach simulation ----
  const breachData: Record<string, { cx: string; cy: string; title: string; detail: string; response: string }> = {
    north: { cx: '400', cy: '84', title: 'BREACH — NORTH GATE', detail: 'Vehicle approaching gate without credentials', response: 'Aerial unit dispatched — ETA 22s' },
    east: { cx: '654', cy: '260', title: 'BREACH — EAST FENCE', detail: 'Thermal signature — 2 individuals scaling fence', response: 'Aerial unit dispatched — ETA 28s' },
    south: { cx: '400', cy: '424', title: 'BREACH — SOUTH LOT', detail: 'Unauthorized vehicle in restricted zone', response: 'Aerial unit dispatched — ETA 19s' },
    west: { cx: '146', cy: '260', title: 'BREACH — WEST FENCE', detail: 'Thermal anomaly — possible cut in fence line', response: 'Aerial unit dispatched — ETA 25s' },
  };

  document.querySelectorAll('.zone').forEach(zone => {
    const handler = () => {
      const key = (zone as HTMLElement).dataset.zone;
      if (!key || !breachData[key]) return;
      const data = breachData[key];

      // Flash
      const flash = document.querySelector('.breach-flash') as SVGCircleElement;
      if (flash) {
        flash.setAttribute('cx', data.cx);
        flash.setAttribute('cy', data.cy);
        flash.classList.add('active');
        setTimeout(() => flash.classList.remove('active'), 1500);
      }

      // Fence alarm
      const fence = document.querySelector('.fence-line') as SVGRectElement;
      if (fence) {
        fence.classList.add('fence-breach');
        setTimeout(() => fence.classList.remove('fence-breach'), 3000);
      }

      // Info overlay
      const info = document.getElementById('breach-info');
      const titleEl = document.getElementById('breach-title');
      const detailEl = document.getElementById('breach-detail');
      const responseEl = document.getElementById('breach-response');
      if (info && titleEl && detailEl && responseEl) {
        titleEl.textContent = data.title;
        detailEl.textContent = data.detail;
        responseEl.textContent = data.response;
        info.hidden = false;
        setTimeout(() => { info.hidden = true; }, 5000);
      }
    };
    zone.addEventListener('click', handler);
    zone.addEventListener('keydown', (e: Event) => {
      if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
        (e as KeyboardEvent).preventDefault();
        handler();
      }
    });
  });

  // ---- Alert cascade auto-scroll ----
  const alertRows = document.querySelectorAll('.alert-row');
  let alertIndex = 0;
  function showNextAlert() {
    if (alertIndex < alertRows.length) {
      (alertRows[alertIndex] as HTMLElement).style.animationDelay = `${alertIndex * 0.15}s`;
      alertRows[alertIndex].classList.add('animate');
      alertIndex++;
    }
  }

  const alertObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const interval = setInterval(() => {
          showNextAlert();
          if (alertIndex >= alertRows.length) clearInterval(interval);
        }, 400);
        alertObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  const alertFeed = document.querySelector('.alert-cascade');
  if (alertFeed) alertObserver.observe(alertFeed);

  // ---- Response time bar chart ----
  const chartObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        document.querySelectorAll('.chart-bar').forEach((bar, i) => {
          setTimeout(() => bar.classList.add('animate'), i * 300);
        });
        chartObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  const chart = document.querySelector('.response-chart');
  if (chart) chartObserver.observe(chart);

  // ---- Night toggle ----
  const nightToggle = document.getElementById('night-toggle');
  const nightSplit = document.getElementById('night-split');
  if (nightToggle && nightSplit) {
    nightToggle.addEventListener('click', () => {
      const pressed = nightToggle.getAttribute('aria-pressed') === 'true';
      nightToggle.setAttribute('aria-pressed', String(!pressed));
      nightSplit.classList.toggle('night-mode', !pressed);
    });
  }
</script>
