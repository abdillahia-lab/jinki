---
/*
  TEAM OMEGA — Round 5: Security Vertical Redesign
  Jinki Aerial Intelligence — Perimeter Security

  Features:
  1. Surveillance HUD hero with crosshairs, night-vision, timestamp, MONITORING blink
  2. Interactive perimeter map with animated patrol + click-to-breach zones
  3. Alert cascade animation — auto-scrolling real-time feed
  4. Response time bar chart race — Jinki vs guard vs camera-only
  5. Night operations showcase — day/night toggle
  6. Integration ecosystem — animated connection diagram
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

const stats = [
  { value: '500+', label: 'acre perimeter coverage per mission', source: 'Platform Capability' },
  { value: '<90s', label: 'dock-to-airborne response', source: 'DJI Dock 3 Spec' },
  { value: 'Thermal', label: 'day and night detection capability', source: 'H30T Sensor' },
  { value: '24/7', label: 'persistent autonomous patrol', source: 'Dock 3 Automation' },
];

const services = [
  {
    icon: 'radar',
    title: 'Perimeter Thermal Surveillance',
    desc: 'Complete thermal and HD coverage of your facility perimeter. Identify blind spots, assess coverage gaps, and detect intrusion attempts that fixed cameras miss.',
  },
  {
    icon: 'speed',
    title: 'Event-Triggered Response',
    desc: 'Automated aerial response to perimeter alerts. When sensors detect activity, the DJI Dock 3 launches aerial assets to verify, classify, and stream live thermal video to your SOC.',
  },
  {
    icon: 'shield',
    title: 'Vulnerability Assessment',
    desc: 'Comprehensive aerial evaluation of your physical security posture. Identifies sight-line gaps, lighting deficiencies, and monitoring blind spots with remediation priorities.',
  },
  {
    icon: 'lock',
    title: 'VMS & Access Control Integration',
    desc: 'Aerial surveillance connecting with your existing video management system, access control, and perimeter sensors. Complete Alert-Response-Verify workflow.',
  },
  {
    icon: 'verified_user',
    title: 'Executive Protection & Events',
    desc: 'Temporary aerial overwatch for high-value events, executive visits, and elevated threat periods. Real-time situational awareness for your security team.',
  },
  {
    icon: 'security',
    title: 'Post-Incident Documentation',
    desc: 'Rapid aerial documentation of security incidents for investigation, insurance claims, and law enforcement. HD and thermal evidence with GPS-tagged imagery.',
  },
];

const painPoints = [
  {
    problem: 'Guard patrols cannot cover large campuses fast enough',
    solution: 'Aerial thermal surveillance covers your entire perimeter in minutes. Threats detected and verified before ground teams reach the location.',
  },
  {
    problem: 'Fixed cameras have inherent blind spots',
    solution: 'Aerial vantage significantly reduces coverage gaps caused by terrain, structures, and vegetation. Thermal imaging is designed to detect concealed activity that visible cameras may miss.',
  },
  {
    problem: 'False alarm response wastes security resources',
    solution: 'Aerial verification classifies alerts before dispatching ground teams. Reduce unnecessary responses while ensuring real threats get immediate attention.',
  },
  {
    problem: 'Perimeter monitoring costs escalate with facility size',
    solution: 'Scale coverage without scaling headcount. One aerial system covers more ground than multiple fixed camera installations and guard posts.',
  },
];

const alertEvents = [
  { time: '22:41:07', severity: 'red', type: 'PERIMETER BREACH', location: 'Sector 7 — East Fence', detail: 'Thermal signature detected, 2 individuals' },
  { time: '22:41:12', severity: 'yellow', type: 'AERIAL UNIT DISPATCHED', location: 'Dock 3 — Auto-launch', detail: 'ETA to target: 28 seconds' },
  { time: '22:41:38', severity: 'green', type: 'VISUAL CONFIRMED', location: 'Sector 7 — East Fence', detail: 'HD + thermal lock acquired' },
  { time: '22:41:44', severity: 'red', type: 'THREAT CLASSIFIED', location: 'Sector 7 — East Fence', detail: 'Unauthorized personnel — SOC notified' },
  { time: '22:42:01', severity: 'yellow', type: 'GROUND TEAM DISPATCHED', location: 'Patrol Unit 3', detail: 'ETA 4 min — aerial overwatch active' },
  { time: '22:42:15', severity: 'green', type: 'TRACKING ACTIVE', location: 'Sector 7 → Sector 8', detail: 'Subjects moving northwest, speed 1.2 m/s' },
  { time: '22:43:02', severity: 'green', type: 'PERIMETER SECURED', location: 'Sector 7–8', detail: 'Ground team on-site, subjects detained' },
  { time: '22:43:18', severity: 'green', type: 'INCIDENT DOCUMENTED', location: 'All sectors', detail: 'HD evidence package generated, GPS-tagged' },
];

const integrations = [
  { id: 'cctv', label: 'CCTV / NVR', icon: 'videocam', x: 15, y: 25 },
  { id: 'access', label: 'Access Control', icon: 'badge', x: 15, y: 75 },
  { id: 'alarm', label: 'Alarm Systems', icon: 'notification_important', x: 85, y: 25 },
  { id: 'siem', label: 'SIEM / SOC', icon: 'hub', x: 85, y: 75 },
];
---

<Layout title="Security — Jinki Aerial Intelligence" description="Aerial perimeter surveillance and thermal threat detection for critical infrastructure. 24/7 autonomous patrol covering 500+ acre perimeters.">
  <Nav />
  <main id="main-content">

    <!-- ==================== 1. SURVEILLANCE HUD HERO ==================== -->
    <section class="sec-hero" aria-label="Security Intelligence">
      <div class="sec-hero-inner">
        <div class="sec-hero-content reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">Perimeter Security</span>
          </div>
          <h1 class="sec-hero-title">
            Aerial Threat Detection for<br/>
            <span class="gradient-text-violet">Critical Perimeters</span>
          </h1>
          <p class="sec-hero-subtitle">
            Fixed cameras have blind spots. Guard patrols take minutes. Jinki's aerial
            thermal surveillance covers your entire perimeter in seconds — verifying threats
            before they become incidents. A force multiplier, not a replacement.
          </p>
          <div class="sec-hero-actions">
            <a href="#lead-gen" class="btn-premium sec-cta">Request a Demo</a>
            <a href="#services" class="sec-cta-secondary">View Capabilities</a>
          </div>
        </div>

        <!-- HUD Visual -->
        <div class="sec-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <div class="hud-container">
            <!-- Real facility photo as base layer -->
            <img
              src="/images/facility-night-aerial.jpg"
              alt=""
              class="hud-photo"
              loading="eager"
              decoding="async"
            />
            <!-- Night vision green overlay -->
            <div class="hud-nightvision"></div>
            <!-- Grid scanlines -->
            <div class="hud-scanlines"></div>
            <!-- Crosshairs -->
            <div class="hud-crosshair">
              <div class="crosshair-h"></div>
              <div class="crosshair-v"></div>
              <div class="crosshair-circle"></div>
              <div class="crosshair-circle crosshair-circle-inner"></div>
            </div>
            <!-- Corner brackets -->
            <div class="hud-bracket hud-bracket-tl"></div>
            <div class="hud-bracket hud-bracket-tr"></div>
            <div class="hud-bracket hud-bracket-bl"></div>
            <div class="hud-bracket hud-bracket-br"></div>
            <!-- Timestamp -->
            <div class="hud-timestamp">
              <span class="hud-ts-label">CAM-07 // SECTOR EAST</span>
              <span class="hud-ts-time" id="hud-clock">22:41:07</span>
            </div>
            <!-- Monitoring status -->
            <div class="hud-status">
              <span class="hud-status-dot"></span>
              <span class="hud-status-text">MONITORING</span>
            </div>
            <!-- Thermal target boxes -->
            <div class="hud-target hud-target-1">
              <span class="hud-target-label">SUBJ-01</span>
            </div>
            <div class="hud-target hud-target-2">
              <span class="hud-target-label">SUBJ-02</span>
            </div>
            <!-- Telemetry readout bottom-right -->
            <div class="hud-telemetry">
              <span>ALT 120m</span>
              <span>SPD 8.2 m/s</span>
              <span>HDG 047&deg;</span>
              <span>THERM ON</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== STATS BAR ==================== -->
    <div class="stats-bar reveal">
      <div class="stats-bar-inner">
        {stats.map(stat => (
          <div class="stat-item">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
            <span class="stat-source">{stat.source}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ==================== PAIN / SOLUTION ==================== -->
    <section class="section" aria-label="Challenges We Solve">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">The Challenge</span>
          </div>
          <h2>Your Perimeter Has<br/>More Gaps Than You Think</h2>
          <p class="section-subtitle">
            Facility security teams face expanding perimeters, sophisticated threats,
            and shrinking budgets. Static cameras and guard patrols leave critical
            vulnerabilities that adversaries know how to exploit.
          </p>
        </div>
        <div class="pain-grid">
          <!-- Card 1: Guard patrols — radar sweep with gaps -->
          <div class="pain-card reveal reveal-delay-1">
            <div class="pain-visual-row">
              <div class="pain-anim pain-anim-radar" aria-hidden="true">
                <div class="radar-ring"></div>
                <div class="radar-ring radar-ring-2"></div>
                <div class="radar-sweep"></div>
                <div class="radar-gap radar-gap-1"></div>
                <div class="radar-gap radar-gap-2"></div>
                <div class="radar-dot"></div>
              </div>
            </div>
            <div class="pain-problem">
              <span class="pain-icon material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">warning</span>
              <h3>{painPoints[0].problem}</h3>
            </div>
            <div class="pain-solution">
              <span class="pain-arrow">&rarr;</span>
              <p>{painPoints[0].solution}</p>
            </div>
          </div>
          <!-- Card 2: Blind spots — ticking clock with urgency -->
          <div class="pain-card reveal reveal-delay-2">
            <div class="pain-visual-row">
              <div class="pain-anim pain-anim-clock" aria-hidden="true">
                <div class="clock-face"></div>
                <div class="clock-hand clock-hand-min"></div>
                <div class="clock-hand clock-hand-sec"></div>
                <div class="clock-center-dot"></div>
                <div class="clock-pulse"></div>
              </div>
            </div>
            <div class="pain-problem">
              <span class="pain-icon material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">warning</span>
              <h3>{painPoints[1].problem}</h3>
            </div>
            <div class="pain-solution">
              <span class="pain-arrow">&rarr;</span>
              <p>{painPoints[1].solution}</p>
            </div>
          </div>
          <!-- Card 3: False alarms — alert dismiss -->
          <div class="pain-card reveal reveal-delay-3">
            <div class="pain-visual-row">
              <div class="pain-anim pain-anim-alert" aria-hidden="true">
                <div class="alert-icon-stack">
                  <div class="alert-tri alert-tri-1"></div>
                  <div class="alert-tri alert-tri-2"></div>
                  <div class="alert-tri alert-tri-3"></div>
                </div>
                <div class="alert-dismiss-x"></div>
              </div>
            </div>
            <div class="pain-problem">
              <span class="pain-icon material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">warning</span>
              <h3>{painPoints[2].problem}</h3>
            </div>
            <div class="pain-solution">
              <span class="pain-arrow">&rarr;</span>
              <p>{painPoints[2].solution}</p>
            </div>
          </div>
          <!-- Card 4: Costs escalate — perimeter breach viz -->
          <div class="pain-card reveal reveal-delay-4">
            <div class="pain-visual-row">
              <div class="pain-anim pain-anim-fence" aria-hidden="true">
                <div class="fence-seg fence-seg-1"></div>
                <div class="fence-seg fence-seg-2"></div>
                <div class="fence-seg fence-seg-3"></div>
                <div class="fence-breach-point"></div>
                <div class="fence-intruder"></div>
              </div>
            </div>
            <div class="pain-problem">
              <span class="pain-icon material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">warning</span>
              <h3>{painPoints[3].problem}</h3>
            </div>
            <div class="pain-solution">
              <span class="pain-arrow">&rarr;</span>
              <p>{painPoints[3].solution}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== 2. INTERACTIVE PERIMETER MAP ==================== -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Perimeter Intelligence">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">Perimeter Intelligence</span>
          </div>
          <h2>Autonomous Patrol Coverage</h2>
          <p class="section-subtitle">
            Click any zone to simulate a breach scenario. Watch how Jinki's aerial
            intelligence responds in real time — from detection to resolution.
          </p>
        </div>
        <div class="perimeter-wrap reveal" role="img" aria-label="Interactive facility perimeter map showing autonomous patrol routes and breach detection zones">
          <svg class="perimeter-svg" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
            <!-- Facility outline -->
            <rect class="facility-bg" x="150" y="80" width="500" height="340" rx="8" />
            <!-- Buildings -->
            <rect class="building" x="250" y="150" width="120" height="80" rx="4" />
            <text class="bldg-label" x="310" y="196">DATA CENTER A</text>
            <rect class="building" x="430" y="150" width="100" height="80" rx="4" />
            <text class="bldg-label" x="480" y="196">POWER</text>
            <rect class="building" x="280" y="280" width="160" height="70" rx="4" />
            <text class="bldg-label" x="360" y="320">DATA CENTER B</text>
            <rect class="building" x="490" y="280" width="80" height="70" rx="4" />
            <text class="bldg-label" x="530" y="320">SOC</text>
            <!-- Perimeter fence -->
            <rect class="fence-line" x="150" y="80" width="500" height="340" rx="8" />
            <!-- Patrol path -->
            <path class="patrol-path" d="M 180,100 L 620,100 L 630,110 L 630,400 L 620,410 L 180,410 L 170,400 L 170,110 Z" />
            <!-- Animated patrol dot -->
            <circle class="patrol-dot" r="6">
              <animateMotion dur="12s" repeatCount="indefinite" path="M 180,100 L 620,100 L 630,110 L 630,400 L 620,410 L 180,410 L 170,400 L 170,110 Z" />
            </circle>
            <!-- Patrol trail -->
            <circle class="patrol-trail" r="12" opacity="0.3">
              <animateMotion dur="12s" repeatCount="indefinite" path="M 180,100 L 620,100 L 630,110 L 630,400 L 620,410 L 180,410 L 170,400 L 170,110 Z" />
            </circle>
            <!-- Click zones -->
            <g class="zone zone-north" data-zone="north" tabindex="0" role="button" aria-label="Simulate breach at north perimeter">
              <rect x="300" y="72" width="200" height="24" rx="4" class="zone-hit" />
              <text class="zone-label" x="400" y="68">NORTH GATE</text>
            </g>
            <g class="zone zone-east" data-zone="east" tabindex="0" role="button" aria-label="Simulate breach at east perimeter">
              <rect x="642" y="200" width="24" height="120" rx="4" class="zone-hit" />
              <text class="zone-label" x="680" y="265">EAST FENCE</text>
            </g>
            <g class="zone zone-south" data-zone="south" tabindex="0" role="button" aria-label="Simulate breach at south perimeter">
              <rect x="300" y="412" width="200" height="24" rx="4" class="zone-hit" />
              <text class="zone-label" x="400" y="452">SOUTH LOT</text>
            </g>
            <g class="zone zone-west" data-zone="west" tabindex="0" role="button" aria-label="Simulate breach at west perimeter">
              <rect x="134" y="200" width="24" height="120" rx="4" class="zone-hit" />
              <text class="zone-label" x="120" y="265">WEST FENCE</text>
            </g>
            <!-- Breach flash (hidden by default) -->
            <circle class="breach-flash" cx="400" cy="84" r="0" />
          </svg>
          <!-- Breach info overlay -->
          <div class="breach-info" id="breach-info" hidden>
            <span class="breach-title" id="breach-title">BREACH DETECTED</span>
            <span class="breach-detail" id="breach-detail">Thermal signature — 1 individual</span>
            <span class="breach-response" id="breach-response">Aerial unit dispatched — ETA 28s</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== 3. ALERT CASCADE ==================== -->
    <section class="section" aria-label="Real-Time Alert Feed">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">Live Intelligence</span>
          </div>
          <h2>From Detection to Resolution<br/>in Under Two Minutes</h2>
          <p class="section-subtitle">
            Watch a complete threat response sequence. Every event is classified,
            tracked, and documented — automatically.
          </p>
        </div>
        <div class="alert-cascade reveal" role="log" aria-label="Simulated security alert feed" aria-live="polite">
          <div class="alert-header-bar">
            <span class="alert-header-dot alert-header-dot-live"></span>
            <span class="alert-header-title">JINKI SOC FEED — LIVE</span>
            <span class="alert-header-ts" id="alert-header-ts">22:41:07</span>
          </div>
          <div class="alert-feed" id="alert-feed">
            {alertEvents.map((evt) => (
              <div class={`alert-row alert-severity-${evt.severity}`} data-severity={evt.severity}>
                <span class="alert-time">{evt.time}</span>
                <span class={`alert-badge alert-badge-${evt.severity}`}>{evt.severity === 'red' ? 'CRITICAL' : evt.severity === 'yellow' ? 'ACTION' : 'INFO'}</span>
                <span class="alert-type">{evt.type}</span>
                <span class="alert-location">{evt.location}</span>
                <span class="alert-detail">{evt.detail}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== 4. RESPONSE TIME COMPARISON ==================== -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Response Time Comparison">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">Performance</span>
          </div>
          <h2>Speed Changes Everything</h2>
          <p class="section-subtitle">
            Seconds matter in perimeter security. Compare Jinki's autonomous response
            against traditional security measures.
          </p>
        </div>
        <div class="response-chart reveal" role="img" aria-label="Coverage comparison: Jinki autonomous aerial vs traditional security methods">
          <div class="chart-row">
            <span class="chart-label">Jinki Aerial Intelligence</span>
            <div class="chart-bar-wrap">
              <div class="chart-bar chart-bar-jinki" style="--bar-pct: 100%;">
                <span class="chart-bar-value">Autonomous, 24/7, Thermal</span>
              </div>
            </div>
          </div>
          <div class="chart-row">
            <span class="chart-label">Guard Patrol</span>
            <div class="chart-bar-wrap">
              <div class="chart-bar chart-bar-guard" style="--bar-pct: 35%;">
                <span class="chart-bar-value">Scheduled, Limited Coverage</span>
              </div>
            </div>
          </div>
          <div class="chart-row">
            <span class="chart-label">Fixed Cameras</span>
            <div class="chart-bar-wrap">
              <div class="chart-bar chart-bar-camera" style="--bar-pct: 50%;">
                <span class="chart-bar-value">Static, Blind Spots</span>
              </div>
            </div>
          </div>
          <div class="chart-legend">
            <span class="chart-legend-label">Relative perimeter coverage capability</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== 5. NIGHT OPERATIONS SHOWCASE ==================== -->
    <section class="section sec-night-ops" aria-label="Night Operations">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">24/7 Capability</span>
          </div>
          <h2>Darkness Is Not an Obstacle</h2>
          <p class="section-subtitle">
            Thermal imaging turns night into an advantage. Concealment, darkness, and
            visual obstructions become irrelevant when you see heat.
          </p>
        </div>
        <div class="night-showcase reveal">
          <div class="night-toggle-wrap">
            <button class="night-toggle" id="night-toggle" type="button" aria-pressed="false" aria-label="Toggle between day and night view">
              <span class="night-toggle-label night-toggle-day">DAY</span>
              <span class="night-toggle-thumb"></span>
              <span class="night-toggle-label night-toggle-night">NIGHT</span>
            </button>
          </div>
          <div class="night-split" id="night-split">
            <!-- Day panel -->
            <div class="night-panel night-panel-day" id="night-panel-day">
              <div class="night-scene">
                <div class="night-scene-sky night-sky-day"></div>
                <div class="night-scene-ground night-ground-day"></div>
                <div class="night-fence"></div>
                <div class="night-building night-bldg-day"></div>
                <div class="night-figure night-figure-visible"></div>
                <div class="night-figure night-figure-hidden" style="left: 68%; opacity: 0.15;"></div>
              </div>
              <div class="night-caption">
                <span class="night-caption-icon material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">light_mode</span>
                <div>
                  <span class="night-caption-title">Visible Light — Daytime</span>
                  <span class="night-caption-desc">1 of 2 subjects visible. Second subject concealed behind vegetation.</span>
                </div>
              </div>
            </div>
            <!-- Night panel -->
            <div class="night-panel night-panel-night" id="night-panel-night">
              <div class="night-scene night-scene-dark">
                <div class="night-scene-sky night-sky-night"></div>
                <div class="night-scene-ground night-ground-night"></div>
                <div class="night-fence night-fence-thermal"></div>
                <div class="night-building night-bldg-night"></div>
                <div class="night-figure night-figure-thermal" style="left: 42%;"></div>
                <div class="night-figure night-figure-thermal" style="left: 68%;"></div>
                <div class="thermal-tag" style="left: 40%; top: 30%;">37.2&deg;C</div>
                <div class="thermal-tag" style="left: 66%; top: 30%;">36.8&deg;C</div>
              </div>
              <div class="night-caption">
                <span class="night-caption-icon material-symbols-outlined" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">thermostat</span>
                <div>
                  <span class="night-caption-title">Thermal Imaging — Nighttime</span>
                  <span class="night-caption-desc">Both subjects clearly visible. Heat signatures cannot be concealed.</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== SERVICES GRID ==================== -->
    <section id="services" class="section" style="background: var(--surface-dim);" aria-label="Services">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">Services</span>
          </div>
          <h2>Complete Perimeter Intelligence<br/>from Alert to Resolution</h2>
          <p class="section-subtitle">
            Every engagement delivers actionable security intelligence — not raw video feeds.
            Threat classifications, vulnerability assessments, and remediation priorities
            your team can act on immediately.
          </p>
        </div>
        <div class="services-grid">
          {services.map((svc, i) => (
            <div class={`service-card metallic-gloss reveal reveal-delay-${(i % 3) + 1}`}>
              <div class="service-icon-wrap">
                <span class="material-symbols-outlined service-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{svc.icon}</span>
              </div>
              <h3 class="service-title">{svc.title}</h3>
              <p class="service-desc">{svc.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ==================== 6. INTEGRATION ECOSYSTEM ==================== -->
