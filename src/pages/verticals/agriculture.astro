---
/*
  TEAM ALPHA — Round 6
  Agriculture Vertical Redesign | Jinki Aerial Intelligence

  NDVI heatmap hero, crop health dashboard, season timeline,
  ROI calculator, technology pipeline, field comparison slider.
  Green accent (#34D399 / #10B981). Dark/light theme. Fully responsive.
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Footer from '../../components/Footer.astro';

const stats = [
  { value: 'NDVI', label: 'Multispectral Crop Health Mapping', icon: 'trending_up' },
  { value: '0.1m', label: 'Spatial Resolution', icon: 'water_drop' },
  { value: 'AI', label: 'Anomaly Detection & Classification', icon: 'biotech' },
  { value: '1000+', label: 'Acres Per Mission', icon: 'landscape' },
];

const seasons = [
  {
    season: 'Spring',
    months: 'Mar — May',
    icon: 'park',
    color: '#6EE7B7',
    tasks: [
      'Pre-plant soil moisture mapping',
      'Stand count & emergence analysis',
      'Early weed pressure detection',
    ],
    metric: 'Baseline field health score established',
  },
  {
    season: 'Summer',
    months: 'Jun — Aug',
    icon: 'wb_sunny',
    color: '#34D399',
    tasks: [
      'Weekly NDVI crop health scans',
      'Irrigation efficiency analysis',
      'Pest & disease early detection',
    ],
    metric: 'Active monitoring — 4-8 flights/month',
  },
  {
    season: 'Fall',
    months: 'Sep — Nov',
    icon: 'eco',
    color: '#F59E0B',
    tasks: [
      'Yield forecasting & harvest planning',
      'Variable rate prescription maps',
      'Post-harvest residue analysis',
    ],
    metric: 'Data-driven harvest timing recommendations',
  },
  {
    season: 'Winter',
    months: 'Dec — Feb',
    icon: 'ac_unit',
    color: '#93C5FD',
    tasks: [
      'Cover crop health assessment',
      'Drainage & erosion mapping',
      'Season-over-season trend reports',
    ],
    metric: 'Data-driven planting plan for next season',
  },
];

const pipelineSteps = [
  {
    icon: 'satellite_alt',
    title: 'Multispectral Capture',
    desc: 'DJI M400 RTK platform with thermal and visual sensors captures high-resolution aerial data for NDVI analysis and crop health assessment.',
    color: '#60A5FA',
  },
  {
    icon: 'image',
    title: 'NDVI Processing',
    desc: 'Raw spectral data processed into normalized difference vegetation indices, chlorophyll maps, and moisture stress layers.',
    color: '#34D399',
  },
  {
    icon: 'thermostat',
    title: 'Thermal Analysis',
    desc: 'Thermal imaging identifies irrigation inefficiencies, drainage problems, and canopy temperature anomalies invisible to the eye.',
    color: '#F59E0B',
  },
  {
    icon: 'psychology',
    title: 'AI Intelligence',
    desc: 'Machine learning models synthesize all data layers into zone-level prescriptions, alerts, and actionable recommendations.',
    color: '#A78BFA',
  },
];

/* cropOptions removed — fabricated yield/water/pest metrics had no sourcing */
---

<Layout title="Agriculture — Jinki Aerial Intelligence" description="Precision agriculture intelligence: NDVI crop health mapping, irrigation analysis, pest detection, and yield forecasting. Aerial multispectral intelligence that transforms how you manage your operation.">
  <Nav />
  <main id="main-content">

    <!-- ============ NDVI HEATMAP HERO ============ -->
    <section class="ag-hero" aria-label="Agriculture Intelligence">
      <div class="ag-hero-bg" aria-hidden="true">
        <div class="ndvi-field">
          <div class="ndvi-row" style="--row: 0"></div>
          <div class="ndvi-row" style="--row: 1"></div>
          <div class="ndvi-row" style="--row: 2"></div>
          <div class="ndvi-row" style="--row: 3"></div>
          <div class="ndvi-row" style="--row: 4"></div>
          <div class="ndvi-row" style="--row: 5"></div>
          <div class="ndvi-row" style="--row: 6"></div>
          <div class="ndvi-row" style="--row: 7"></div>
        </div>
        <div class="scan-sweep"></div>
        <div class="field-grid-overlay"></div>
      </div>

      <div class="ag-hero-inner">
        <div class="ag-hero-content reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Precision Agriculture</span>
          </div>
          <h1 class="ag-hero-title">
            See Every Acre.<br />
            <span class="gradient-text-green">Optimize Every Row.</span>
          </h1>
          <p class="ag-hero-subtitle">
            Multispectral aerial intelligence replaces weeks of manual scouting
            with field-level NDVI maps, irrigation prescriptions, and yield
            forecasts across your entire operation.
          </p>
          <div class="ag-hero-actions" style="display: flex; align-items: center; gap: 24px; margin-top: 32px;">
            <a href="#lead-gen" class="btn-premium ag-cta">Request a Demo</a>
            <a href="#roi-calculator" class="ag-cta-secondary">See Capabilities</a>
          </div>
        </div>

        <div class="ag-hero-hud reveal reveal-delay-1" aria-hidden="true">
          <div class="hud-panel">
            <div class="hud-header">
              <span class="hud-dot hud-dot--live"></span>
              <span class="hud-label">FIELD SCAN — LIVE</span>
            </div>
            <div class="hud-ndvi-bar">
              <div class="ndvi-gradient-bar"></div>
              <div class="ndvi-scale">
                <span>0.0</span><span>0.25</span><span>0.50</span><span>0.75</span><span>1.0</span>
              </div>
              <div class="ndvi-labels">
                <span style="color: #EF4444;">Bare</span>
                <span style="color: #F59E0B;">Stress</span>
                <span style="color: #34D399;">Healthy</span>
              </div>
            </div>
            <div class="hud-metrics">
              <div class="hud-metric">
                <span class="hud-metric-val">0.82</span>
                <span class="hud-metric-lbl">Avg NDVI</span>
              </div>
              <div class="hud-metric">
                <span class="hud-metric-val">94%</span>
                <span class="hud-metric-lbl">Canopy Cover</span>
              </div>
              <div class="hud-metric">
                <span class="hud-metric-val">2.1%</span>
                <span class="hud-metric-lbl">Stress Area</span>
              </div>
            </div>
            <div class="hud-alert">
              <span class="material-symbols-outlined" style="font-size: 16px; color: #F59E0B; font-variation-settings: 'FILL' 1;">warning</span>
              <span>Zone B4: Moisture stress detected — irrigation recommended</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ STATS BAR ============ -->
    <div class="ag-stats-bar reveal">
      <div class="ag-stats-inner">
        {stats.map(stat => (
          <div class="ag-stat">
            <span class="material-symbols-outlined ag-stat-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{stat.icon}</span>
            <span class="ag-stat-value">{stat.value}</span>
            <span class="ag-stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ============ CROP HEALTH DASHBOARD ============ -->
    <section class="ag-section" aria-label="Crop Health Dashboard">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Intelligence Dashboard</span>
          </div>
          <h2>Your Fields at a Glance</h2>
          <p class="ag-section-sub">
            Every flight produces a comprehensive field health dashboard with
            zone-level scores, trend analysis, and actionable alerts. No
            interpretation required.
          </p>
        </div>

        <div class="dashboard-mockup reveal reveal-delay-1" aria-label="Interactive crop health dashboard mockup" role="img">
          <div class="dash-topbar">
            <div class="dash-topbar-left">
              <span class="material-symbols-outlined" style="font-size: 18px; color: #34D399; font-variation-settings: 'FILL' 1;">agriculture</span>
              <span class="dash-title">Jinki Field Intelligence</span>
            </div>
            <div class="dash-topbar-right">
              <span class="dash-date">March 18, 2026</span>
              <span class="dash-badge dash-badge--good">All Systems Normal</span>
            </div>
          </div>

          <div class="dash-body">
            <div class="dash-sidebar">
              <div class="dash-field-list">
                <div class="dash-field-item dash-field-item--active">
                  <span class="dash-field-name">North Field</span>
                  <span class="dash-field-score" style="color: #34D399;">0.84</span>
                </div>
                <div class="dash-field-item">
                  <span class="dash-field-name">East Pivot</span>
                  <span class="dash-field-score" style="color: #34D399;">0.79</span>
                </div>
                <div class="dash-field-item">
                  <span class="dash-field-name">South Bottoms</span>
                  <span class="dash-field-score" style="color: #F59E0B;">0.61</span>
                </div>
                <div class="dash-field-item">
                  <span class="dash-field-name">West Ridge</span>
                  <span class="dash-field-score" style="color: #34D399;">0.77</span>
                </div>
              </div>
              <div class="dash-alerts-panel">
                <span class="dash-alerts-title">Active Alerts</span>
                <div class="dash-alert-item dash-alert-item--warn">
                  <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'FILL' 1;">water_drop</span>
                  <span>South Bottoms: Low moisture</span>
                </div>
                <div class="dash-alert-item dash-alert-item--info">
                  <span class="material-symbols-outlined" style="font-size: 14px; font-variation-settings: 'FILL' 1;">bug_report</span>
                  <span>East Pivot: Pest activity</span>
                </div>
              </div>
            </div>

            <div class="dash-main">
              <div class="dash-grid-map">
                <div class="dash-zone" style="background: rgba(52,211,153,0.5); grid-area: 1/1/2/3;" data-zone="A1-A2" data-score="0.88"></div>
                <div class="dash-zone" style="background: rgba(52,211,153,0.4); grid-area: 1/3/2/5;" data-zone="A3-A4" data-score="0.82"></div>
                <div class="dash-zone" style="background: rgba(52,211,153,0.6); grid-area: 2/1/3/2;" data-zone="B1" data-score="0.91"></div>
                <div class="dash-zone" style="background: rgba(245,158,11,0.4); grid-area: 2/2/3/4;" data-zone="B2-B3" data-score="0.64"></div>
                <div class="dash-zone" style="background: rgba(52,211,153,0.45); grid-area: 2/4/3/5;" data-zone="B4" data-score="0.80"></div>
                <div class="dash-zone" style="background: rgba(239,68,68,0.35); grid-area: 3/1/4/2;" data-zone="C1" data-score="0.42"></div>
                <div class="dash-zone" style="background: rgba(245,158,11,0.35); grid-area: 3/2/4/3;" data-zone="C2" data-score="0.58"></div>
                <div class="dash-zone" style="background: rgba(52,211,153,0.5); grid-area: 3/3/4/5;" data-zone="C3-C4" data-score="0.85"></div>
              </div>
              <div class="dash-trend">
                <span class="dash-trend-title">NDVI Trend — 30 Days</span>
                <div class="dash-trend-chart" aria-label="NDVI trend line showing improvement over 30 days">
                  <svg viewBox="0 0 300 80" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Upward trending chart line">
                    <defs>
                      <linearGradient id="trendFill" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#34D399" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="#34D399" stop-opacity="0"/>
                      </linearGradient>
                    </defs>
                    <path d="M0,60 Q30,55 60,50 T120,42 T180,35 T240,25 T300,18" stroke="#34D399" stroke-width="2" fill="none"/>
                    <path d="M0,60 Q30,55 60,50 T120,42 T180,35 T240,25 T300,18 L300,80 L0,80 Z" fill="url(#trendFill)"/>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SEASON TIMELINE ============ -->
    <section class="ag-section" style="background: var(--surface-dim);" aria-label="Growing Season Timeline">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Season Timeline</span>
          </div>
          <h2>Intelligence Across<br />Every Growing Phase</h2>
          <p class="ag-section-sub">
            Continuous aerial monitoring throughout the growing season builds a
            data history that compounds in value year over year.
          </p>
        </div>

        <div class="timeline-scroll" role="list" aria-label="Seasonal monitoring timeline">
          <div class="timeline-track">
            {seasons.map((s, i) => (
              <div class={`timeline-card reveal reveal-delay-${i + 1}`} role="listitem" style={`--card-color: ${s.color};`}>
                <div class="timeline-season-badge">
                  <span class="material-symbols-outlined" style={`font-size: 20px; color: ${s.color}; font-variation-settings: 'FILL' 1;`} aria-hidden="true">{s.icon}</span>
                  <span class="timeline-season-name" style={`color: ${s.color};`}>{s.season}</span>
                </div>
                <span class="timeline-months">{s.months}</span>
                <ul class="timeline-tasks">
                  {s.tasks.map(task => (
                    <li>
                      <span class="material-symbols-outlined" style={`font-size: 14px; color: ${s.color}; font-variation-settings: 'FILL' 1;`} aria-hidden="true">check_circle</span>
                      <span>{task}</span>
                    </li>
                  ))}
                </ul>
                <div class="timeline-metric">
                  <span class="material-symbols-outlined" style="font-size: 14px; color: var(--text-tertiary); font-variation-settings: 'FILL' 1;" aria-hidden="true">insights</span>
                  <span>{s.metric}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ TECHNOLOGY PIPELINE ============ -->
    <section class="ag-section" aria-label="Technology Pipeline">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Technology</span>
          </div>
          <h2>From Sensor to<br /><span class="gradient-text-green">Actionable Prescription</span></h2>
          <p class="ag-section-sub">
            Raw spectral data transforms through a multi-stage pipeline into
            zone-level recommendations your agronomist can act on immediately.
          </p>
        </div>

        <div class="pipeline-grid">
          {pipelineSteps.map((step, i) => (
            <div class={`pipeline-step reveal reveal-delay-${i + 1}`}>
              <div class="pipeline-node" style={`--node-color: ${step.color};`}>
                <span class="material-symbols-outlined" style={`font-size: 28px; color: ${step.color}; font-variation-settings: 'FILL' 1;`} aria-hidden="true">{step.icon}</span>
              </div>
              {i < pipelineSteps.length - 1 && (
                <div class="pipeline-connector" aria-hidden="true">
                  <div class="connector-line"></div>
                  <div class="connector-dot"></div>
                </div>
              )}
              <div class="pipeline-info">
                <span class="pipeline-step-num" style={`color: ${step.color};`}>0{i + 1}</span>
                <h3 class="pipeline-title">{step.title}</h3>
                <p class="pipeline-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FIELD COMPARISON SLIDER ============ -->
    <section class="ag-section" style="background: var(--surface-dim);" aria-label="Before and After Comparison">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Intelligence Overlay</span>
          </div>
          <h2>Raw Aerial vs.<br /><span class="gradient-text-green">Analyzed Intelligence</span></h2>
          <p class="ag-section-sub">
            Drag the slider to see how Jinki transforms raw aerial captures into
            actionable intelligence overlays with zone-level health scoring.
          </p>
        </div>

        <div class="comparison-container reveal reveal-delay-1" role="img" aria-label="Comparison slider showing raw field view versus NDVI analysis overlay">
          <div class="comparison-slider" id="comparisonSlider">
            <div class="comparison-side comparison-before">
              <div class="comp-field comp-field--raw">
                <div class="comp-field-rows">
                  <div class="comp-row" style="background: #3a5a2e;"></div>
                  <div class="comp-row" style="background: #4a6a3e;"></div>
                  <div class="comp-row" style="background: #3d5e31;"></div>
                  <div class="comp-row" style="background: #4b6b40;"></div>
                  <div class="comp-row" style="background: #3e5f32;"></div>
                  <div class="comp-row" style="background: #446838;"></div>
                  <div class="comp-row" style="background: #3b5b2f;"></div>
                  <div class="comp-row" style="background: #4d6d42;"></div>
                </div>
              </div>
              <span class="comparison-label">Raw Aerial</span>
            </div>

            <div class="comparison-side comparison-after">
              <div class="comp-field comp-field--analyzed">
                <div class="comp-field-rows">
                  <div class="comp-row" style="background: linear-gradient(90deg, #34D399 0%, #34D399 60%, #F59E0B 80%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #34D399 0%, #10B981 40%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #10B981 0%, #F59E0B 30%, #EF4444 50%, #F59E0B 70%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #34D399 0%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #34D399 0%, #F59E0B 40%, #F59E0B 60%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #10B981 0%, #34D399 30%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #34D399 0%, #34D399 50%, #EF4444 60%, #F59E0B 80%, #34D399 100%);"></div>
                  <div class="comp-row" style="background: linear-gradient(90deg, #34D399 0%, #10B981 100%);"></div>
                </div>
                <div class="comp-zone-labels">
                  <span class="comp-zone-tag" style="top: 15%; left: 25%; color: #34D399;">0.88</span>
                  <span class="comp-zone-tag" style="top: 40%; left: 45%; color: #EF4444;">0.31</span>
                  <span class="comp-zone-tag" style="top: 60%; left: 55%; color: #F59E0B;">0.62</span>
                  <span class="comp-zone-tag" style="top: 80%; left: 20%; color: #34D399;">0.85</span>
                </div>
              </div>
              <span class="comparison-label">NDVI Analysis</span>
            </div>

            <div class="comparison-handle" id="comparisonHandle" role="slider" aria-label="Comparison slider handle" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" tabindex="0">
              <div class="handle-line"></div>
              <div class="handle-grip">
                <span class="material-symbols-outlined" style="font-size: 20px; color: #fff; font-variation-settings: 'FILL' 1;">drag_indicator</span>
              </div>
              <div class="handle-line"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ CUSTOM ANALYSIS CTA ============ -->
    <section id="roi-calculator" class="ag-section" aria-label="Request Custom Analysis">
      <div class="ag-section-inner">
        <div class="ag-section-header reveal">
          <div class="ag-eyebrow">
            <span class="ag-eyebrow-line"></span>
            <span class="ag-eyebrow-text">Custom Analysis</span>
          </div>
          <h2>Your Operation.<br />Your <span class="gradient-text-green">Intelligence Plan.</span></h2>
          <p class="ag-section-sub">
            Every farm is different. Tell us about your acreage, crops, and challenges — we'll design an aerial intelligence approach tailored to your operation.
          </p>
        </div>

        <div class="roi-calculator reveal reveal-delay-1">
          <div style="display: flex; flex-direction: column; align-items: center; gap: 2rem; padding: 2rem 0;">
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; width: 100%; max-width: 600px;">
              <div class="roi-result-card">
                <span class="material-symbols-outlined roi-result-icon" style="color: #34D399; font-variation-settings: 'FILL' 1;" aria-hidden="true">satellite_alt</span>
                <span class="roi-result-label" style="font-size: 0.8125rem;">NDVI Crop Health</span>
                <span class="roi-result-detail">Field-level stress mapping</span>
              </div>
              <div class="roi-result-card">
                <span class="material-symbols-outlined roi-result-icon" style="color: #60A5FA; font-variation-settings: 'FILL' 1;" aria-hidden="true">water_drop</span>
                <span class="roi-result-label" style="font-size: 0.8125rem;">Irrigation Analysis</span>
                <span class="roi-result-detail">Distribution uniformity</span>
              </div>
              <div class="roi-result-card">
                <span class="material-symbols-outlined roi-result-icon" style="color: #F59E0B; font-variation-settings: 'FILL' 1;" aria-hidden="true">bug_report</span>
                <span class="roi-result-label" style="font-size: 0.8125rem;">Early Detection</span>
                <span class="roi-result-detail">Pest & disease anomalies</span>
            </div>
            </div>
            <a href="#lead-gen" class="btn-premium ag-cta" style="display: inline-flex; align-items: center; gap: 0.5rem;">
              <span class="material-symbols-outlined" style="font-size: 18px; font-variation-settings: 'FILL' 1;" aria-hidden="true">arrow_forward</span>
              Request a Custom Analysis
            </a>
          </div>
        </div>
      </div>
    </section>

    <LeadGen />
  </main>
  <Footer />
</Layout>

<style>
  /* ===== HERO ===== */
  .ag-hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 140px clamp(20px, 5vw, 80px) 80px;
    overflow: hidden;
  }

  .ag-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .ndvi-field {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 8% 10%;
    opacity: 0.15;
  }

  .ndvi-row {
    flex: 1;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      rgba(16, 52, 36, 0.9) 0%,
      rgba(22, 78, 48, 0.85) 15%,
      rgba(26, 96, 55, 0.8) 30%,
      rgba(30, 115, 62, 0.75) 50%,
      rgba(22, 90, 50, 0.8) 65%,
      rgba(34, 130, 70, 0.7) 80%,
      rgba(20, 70, 42, 0.85) 100%
    );
    animation: ndvi-shift 10s ease-in-out infinite alternate;
    animation-delay: calc(var(--row) * 0.4s);
  }

  .ndvi-row:nth-child(3) {
    background: linear-gradient(
      90deg,
      rgba(26, 96, 55, 0.8) 0%,
      rgba(80, 50, 20, 0.6) 35%,
      rgba(120, 65, 25, 0.5) 50%,
      rgba(26, 96, 55, 0.8) 70%,
      rgba(22, 78, 48, 0.85) 100%
    );
  }

  .ndvi-row:nth-child(6) {
    background: linear-gradient(
      90deg,
      rgba(30, 115, 62, 0.75) 0%,
      rgba(34, 130, 70, 0.7) 40%,
      rgba(90, 55, 22, 0.55) 60%,
      rgba(110, 60, 24, 0.5) 75%,
      rgba(26, 96, 55, 0.8) 100%
    );
  }

  @keyframes ndvi-shift {
    0% { opacity: 0.7; }
    50% { opacity: 1; }
    100% { opacity: 0.8; }
  }

  .scan-sweep {
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(52, 211, 153, 0.08) 45%,
      rgba(52, 211, 153, 0.15) 50%,
      rgba(52, 211, 153, 0.08) 55%,
      transparent 100%
    );
    animation: scan-move 6s ease-in-out infinite;
  }

  @keyframes scan-move {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  .field-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(52, 211, 153, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(52, 211, 153, 0.03) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  .ag-hero-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .ag-hero-content {
    position: relative;
  }
  .ag-hero-content::before {
    content: '';
    position: absolute;
    inset: -2rem -3rem;
    border-radius: 1.5rem;
    background: radial-gradient(ellipse at 30% 50%, rgba(5,5,8,0.85), rgba(5,5,8,0.6) 60%, transparent 85%);
    z-index: -1;
    pointer-events: none;
  }

  /* Eyebrow */
  .ag-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .ag-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: #34D399;
  }

  .ag-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #34D399;
  }

  .ag-hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2.25rem, 4.5vw + 0.5rem, 3.75rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .gradient-text-green {
    background: linear-gradient(90deg, #34D399, #10B981, #34D399);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShimmer 3s ease-in-out 1;
  }
  @keyframes gradientShimmer {
    0% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .ag-hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 520px;
  }

  .ag-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.875rem 2rem;
    border-radius: 12px;
    color: #fff;
    background: linear-gradient(135deg, #10B981, #059669);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .ag-cta:hover {
    box-shadow: 0 0 30px rgba(52, 211, 153, 0.3);
  }

  .ag-cta-secondary {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .ag-cta-secondary:hover { color: #34D399; transform: translateX(2px); }
  .ag-cta-secondary { transition: color 0.3s ease, transform 0.3s ease; }

  /* Hero HUD */
  .hud-panel {
    background: rgba(10, 16, 12, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(52, 211, 153, 0.12);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .hud-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hud-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #34D399;
  }

  .hud-dot--live {
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(52, 211, 153, 0); }
  }

  .hud-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #34D399;
  }

  .ndvi-gradient-bar {
    height: 12px;
    border-radius: 8px;
    background: linear-gradient(90deg, #8B4513, #EF4444, #F59E0B, #FDE68A, #6EE7B7, #34D399, #059669);
  }

  .ndvi-scale {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
  }

  .ndvi-scale span {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-tertiary);
  }

  .ndvi-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 2px;
  }

  .ndvi-labels span {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hud-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .hud-metric {
    text-align: center;
    padding: 12px 8px;
    background: rgba(52, 211, 153, 0.05);
    border-radius: 10px;
    border: 1px solid rgba(52, 211, 153, 0.08);
  }

  .hud-metric-val {
    display: block;
    font-family: var(--font-mono);
    font-size: 1.375rem;
    font-weight: 700;
    color: #34D399;
    line-height: 1;
  }

  .hud-metric-lbl {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--text-tertiary);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .hud-alert {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: rgba(245, 158, 11, 0.06);
    border: 1px solid rgba(245, 158, 11, 0.15);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: #F59E0B;
  }

  /* ===== STATS BAR ===== */
  .ag-stats-bar {
    background: var(--surface-container-low);
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    position: relative;
    overflow: hidden;
  }

  .ag-stats-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(52, 211, 153, 0.015) 3px,
        rgba(52, 211, 153, 0.015) 4px
      );
    pointer-events: none;
  }

  .ag-stats-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px clamp(20px, 5vw, 80px);
    gap: 32px;
    position: relative;
  }

  .ag-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
    position: relative;
    padding: 20px 12px;
    border-radius: 12px;
    background: rgba(52, 211, 153, 0.03);
    border: 1px solid rgba(52, 211, 153, 0.06);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ag-stat:hover {
    border-color: rgba(52, 211, 153, 0.15);
    box-shadow: 0 0 20px rgba(52, 211, 153, 0.06);
  }

  /* Leaf growth accents */
  .ag-stat::before {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 3px;
    border-radius: 0 0 4px 4px;
    background: linear-gradient(90deg, transparent, #34D399, transparent);
    opacity: 0.5;
    animation: stat-leaf-pulse 3s ease-in-out infinite;
    animation-delay: calc(var(--stat-i, 0) * 0.4s);
  }

  .ag-stat:nth-child(1) { --stat-i: 0; }
  .ag-stat:nth-child(2) { --stat-i: 1; }
  .ag-stat:nth-child(3) { --stat-i: 2; }
  .ag-stat:nth-child(4) { --stat-i: 3; }

  @keyframes stat-leaf-pulse {
    0%, 100% { opacity: 0.3; width: 30px; }
    50% { opacity: 0.7; width: 50px; }
  }

  /* Sensor readout corners */
  .ag-stat::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 12px;
    pointer-events: none;
    background:
      linear-gradient(to right, rgba(52,211,153,0.2) 0%, transparent 8%) top left / 100% 1px no-repeat,
      linear-gradient(to bottom, rgba(52,211,153,0.2) 0%, transparent 15%) top left / 1px 100% no-repeat,
      linear-gradient(to left, rgba(52,211,153,0.2) 0%, transparent 8%) bottom right / 100% 1px no-repeat,
      linear-gradient(to top, rgba(52,211,153,0.2) 0%, transparent 15%) bottom right / 1px 100% no-repeat;
  }

  .ag-stat-icon {
    font-size: 24px;
    color: #34D399;
    margin-bottom: 4px;
    filter: drop-shadow(0 0 6px rgba(52, 211, 153, 0.3));
    animation: icon-float 4s ease-in-out infinite;
    animation-delay: calc(var(--stat-i, 0) * 0.5s);
  }

  @keyframes icon-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  .ag-stat-value {
    font-family: var(--font-mono);
    font-size: 2.25rem;
    font-weight: 700;
    color: #34D399;
    line-height: 1;
    text-shadow: 0 0 20px rgba(52, 211, 153, 0.4), 0 0 40px rgba(52, 211, 153, 0.15);
    letter-spacing: -0.02em;
  }

  .ag-stat-label {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  /* ===== SECTIONS ===== */
  .ag-section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .ag-section { padding: 7rem clamp(20px, 5vw, 80px); }
  }

  .ag-section-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .ag-section-header {
    margin-bottom: 56px;
  }

  .ag-section-header h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.75rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.12;
    margin-top: 8px;
  }

  .ag-section-sub {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-top: 16px;
  }

  /* ===== DASHBOARD MOCKUP ===== */
  .dashboard-mockup {
    background: var(--surface-container-lowest);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--glass-shadow), 0 0 60px rgba(52, 211, 153, 0.04);
    position: relative;
  }

  /* Subtle scanning line across the dashboard */
  .dashboard-mockup::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(52, 211, 153, 0.02) 48%,
      rgba(52, 211, 153, 0.04) 50%,
      rgba(52, 211, 153, 0.02) 52%,
      transparent 100%
    );
    animation: dash-scan 8s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes dash-scan {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  .dash-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    background: var(--surface-container-low);
    border-bottom: 1px solid var(--glass-border);
  }

  .dash-topbar-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dash-title {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .dash-topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .dash-date {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
  }

  .dash-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    padding: 4px 10px;
    border-radius: 20px;
    letter-spacing: 0.05em;
  }

  .dash-badge--good {
    background: rgba(52, 211, 153, 0.1);
    color: #34D399;
    border: 1px solid rgba(52, 211, 153, 0.2);
  }

  .dash-body {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 320px;
  }

  .dash-sidebar {
    padding: 16px;
    border-right: 1px solid var(--glass-border);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .dash-field-list {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .dash-field-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 12px;
    border-radius: 8px;
    cursor: default;
    transition: background 0.2s ease;
  }

  .dash-field-item:hover {
    background: var(--surface-container-high);
  }

  .dash-field-item--active {
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.12);
  }

  .dash-field-name {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-primary);
  }

  .dash-field-score {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
  }

  .dash-alerts-panel {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .dash-alerts-title {
    font-family: var(--font-label);
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-tertiary);
    margin-bottom: 4px;
  }

  .dash-alert-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
  }

  .dash-alert-item--warn {
    background: rgba(245, 158, 11, 0.06);
    color: #F59E0B;
    border: 1px solid rgba(245, 158, 11, 0.12);
  }

  .dash-alert-item--info {
    background: rgba(96, 165, 250, 0.06);
    color: #60A5FA;
    border: 1px solid rgba(96, 165, 250, 0.12);
  }

  .dash-main {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .dash-grid-map {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 3px;
    flex: 1;
    border-radius: 10px;
    overflow: hidden;
  }

  .dash-zone {
    position: relative;
    min-height: 60px;
    transition: opacity 0.3s ease, filter 0.3s ease;
    cursor: default;
    animation: zone-breathe 5s ease-in-out infinite;
  }

  .dash-zone:nth-child(1) { animation-delay: 0s; }
  .dash-zone:nth-child(2) { animation-delay: 0.6s; }
  .dash-zone:nth-child(3) { animation-delay: 1.2s; }
  .dash-zone:nth-child(4) { animation-delay: 0.3s; }
  .dash-zone:nth-child(5) { animation-delay: 0.9s; }
  .dash-zone:nth-child(6) { animation-delay: 1.5s; }
  .dash-zone:nth-child(7) { animation-delay: 0.5s; }
  .dash-zone:nth-child(8) { animation-delay: 1.1s; }

  @keyframes zone-breathe {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.15); }
  }

  .dash-zone:hover {
    opacity: 0.8;
    filter: brightness(1.3) !important;
  }

  .dash-zone::after {
    content: attr(data-score);
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  .dash-trend {
    padding: 12px 16px;
    background: var(--surface-container);
    border-radius: 10px;
    border: 1px solid var(--glass-border);
  }

  .dash-trend-title {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    display: block;
    margin-bottom: 8px;
  }

  .dash-trend-chart svg {
    width: 100%;
    height: 60px;
  }

  .dash-trend-chart svg path:first-child {
    stroke-dasharray: 400;
    stroke-dashoffset: 400;
    animation: draw-trend 2.5s ease-out forwards;
    animation-delay: 0.5s;
  }

  .dash-trend-chart svg path:last-child {
    opacity: 0;
    animation: fade-trend-fill 1s ease-out forwards;
    animation-delay: 2s;
  }

  @keyframes draw-trend {
    to { stroke-dashoffset: 0; }
  }

  @keyframes fade-trend-fill {
    to { opacity: 1; }
  }

  /* ===== SEASON TIMELINE ===== */
  .timeline-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: #34D399 var(--surface-container);
    padding-bottom: 16px;
  }

  .timeline-track {
    display: grid;
    grid-template-columns: repeat(4, minmax(260px, 1fr));
    gap: 20px;
    min-width: min-content;
  }

  .timeline-card {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 28px 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .timeline-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--card-color);
    opacity: 0.6;
  }

  .timeline-card:hover {
    border-color: var(--card-color);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  /* Animated background visual per season card */
  .timeline-card::after {
    content: '';
    position: absolute;
    bottom: 12px;
    right: 12px;
    width: 50px;
    height: 50px;
    opacity: 0.12;
    pointer-events: none;
    border-radius: 50%;
    transition: opacity 0.3s ease;
  }

  .timeline-card:hover::after {
    opacity: 0.22;
  }

  /* Spring — sprouting seedling animation */
  .timeline-card:nth-child(1)::after {
    background: none;
    border-radius: 0;
    width: 40px;
    height: 50px;
    opacity: 0.18;
  }

  .timeline-card:nth-child(1) {
    --spring-color: #6EE7B7;
  }

  /* Summer — pulsing sun / heat shimmer */
  .timeline-card:nth-child(2)::after {
    background: radial-gradient(circle, #34D399 0%, transparent 70%);
    animation: summer-pulse 3s ease-in-out infinite;
    width: 60px;
    height: 60px;
  }

  @keyframes summer-pulse {
    0%, 100% { transform: scale(0.8); opacity: 0.1; }
    50% { transform: scale(1.2); opacity: 0.2; }
  }

  /* Fall — falling leaf effect */
  .timeline-card:nth-child(3)::after {
    background: radial-gradient(ellipse at 30% 30%, #F59E0B 0%, transparent 60%);
    animation: fall-drift 5s ease-in-out infinite;
    width: 40px;
    height: 40px;
  }

  @keyframes fall-drift {
    0% { transform: translate(0, -8px) rotate(0deg); opacity: 0.15; }
    33% { transform: translate(6px, 4px) rotate(15deg); opacity: 0.2; }
    66% { transform: translate(-4px, 8px) rotate(-10deg); opacity: 0.12; }
    100% { transform: translate(0, -8px) rotate(0deg); opacity: 0.15; }
  }

  /* Winter — snowflake / frost crystal */
  .timeline-card:nth-child(4)::after {
    background: radial-gradient(circle, #93C5FD 0%, transparent 70%);
    animation: frost-glow 4s ease-in-out infinite;
    width: 50px;
    height: 50px;
  }

  @keyframes frost-glow {
    0%, 100% { opacity: 0.08; filter: blur(2px); }
    50% { opacity: 0.2; filter: blur(0px); }
  }

  /* Season card ambient glow on hover */
  .timeline-card:hover::before {
    opacity: 1;
    box-shadow: 0 0 20px var(--card-color);
  }

