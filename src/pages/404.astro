---
/*
  404 — "Signal Lost" radar-themed 404 page
  Jinki Aerial Intelligence
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout ogImage="/images/og-homepage.png" title="404 — Signal Lost | Jinki Aerial Intelligence" description="Page not found. Our aerial systems scanned everywhere.">
  <Nav />
  <main id="main-content" class="error-page">

    <!-- Grid background -->
    <div class="grid-bg" aria-hidden="true"></div>
    <!-- Scanlines -->
    <div class="scanlines" aria-hidden="true"></div>

    <!-- Radar -->
    <div class="radar-wrap" aria-hidden="true" role="presentation">
      <div class="radar-trail"></div>
      <div class="radar-ring"></div>
      <div class="radar-ring"></div>
      <div class="radar-ring"></div>
      <div class="radar-crosshair-h"></div>
      <div class="radar-crosshair-v"></div>
      <div class="radar-sweep"></div>
      <div class="radar-center"></div>
      <div class="radar-blip"></div>
      <div class="radar-blip"></div>
      <div class="radar-blip"></div>
      <div class="radar-blip"></div>
      <div class="radar-blip"></div>
      <div class="radar-blip"></div>
    </div>

    <!-- Grid line pulse -->
    <div class="grid-pulse" aria-hidden="true"></div>

    <!-- Glitch 404 -->
    <div class="glitch-wrap">
      <h1 class="glitch-404" data-text="404" aria-label="Error 404">404</h1>
      <p class="subtitle">Signal Lost</p>
      <p class="message">
        Our aerial systems scanned everywhere. This page wasn't found.<br>
        <span class="mono">ERR::TARGET_NOT_ACQUIRED</span>
      </p>
    </div>

    <!-- Search -->
    <div class="search-section">
      <form class="search-bar" role="search" aria-label="Search the site" onsubmit="event.preventDefault(); var q = this.querySelector('input').value.trim().replace(/[<>\"']/g, ''); if(q && q.length <= 100) window.open('https://www.google.com/search?q=site:jinki.ai+' + encodeURIComponent(q), '_blank', 'noopener');">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" placeholder="Search Jinki.ai..." aria-label="Search" autocomplete="off" maxlength="100" />
        <button type="submit">Search</button>
      </form>
    </div>

    <!-- Action buttons -->
    <nav class="actions" aria-label="Error page navigation">
      <a href="/" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Return Home
      </a>
      <a href="/blog" class="btn btn-ghost">Blog</a>
      <a href="/careers" class="btn btn-ghost">Careers</a>
    </nav>

    <!-- Suggested pages -->
    <section class="suggestions" aria-label="Suggested pages">
      <p class="suggestions-label">Popular destinations</p>
      <div class="suggestions-grid">
        <a href="/verticals/data-centers" class="suggestion-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/></svg>
          </div>
          <div class="info">
            <div class="title">Data Centers</div>
            <div class="path">/verticals/data-centers</div>
          </div>
        </a>
        <a href="/verticals/energy-grid" class="suggestion-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div class="info">
            <div class="title">Energy Grid</div>
            <div class="path">/verticals/energy-grid</div>
          </div>
        </a>
        <a href="/verticals/security" class="suggestion-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <div class="info">
            <div class="title">Security</div>
            <div class="path">/verticals/security</div>
          </div>
        </a>
        <a href="/services/audit" class="suggestion-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <div class="info">
            <div class="title">Intelligence Scan</div>
            <div class="path">/services/audit</div>
          </div>
        </a>
        <a href="/services/deployment" class="suggestion-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          </div>
          <div class="info">
            <div class="title">Deployment</div>
            <div class="path">/services/deployment</div>
          </div>
        </a>
        <a href="/about" class="suggestion-card">
          <div class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          </div>
          <div class="info">
            <div class="title">About</div>
            <div class="path">/about</div>
          </div>
        </a>
      </div>
    </section>

    <!-- Status bar -->
    <div class="status-bar" aria-hidden="true">
      <span><span class="status-dot"></span>SIGNAL LOST</span>
      <span id="error-timestamp"></span>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
    padding: 120px 24px 80px;
  }

  /* Animated grid background */
  .grid-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      linear-gradient(var(--glass-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--glass-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.4;
    animation: gridScroll 20s linear infinite;
  }
  @keyframes gridScroll { to { background-position: 60px 60px; } }

  /* Radar container */
  .radar-wrap {
    position: relative;
    width: 320px;
    height: 320px;
    margin: 0 auto 40px;
    flex-shrink: 0;
    z-index: 2;
  }
  @media (max-width: 600px) {
    .radar-wrap { width: 200px; height: 200px; margin-bottom: 24px; }
    .error-page { min-height: auto; padding: 100px 20px 100px; justify-content: flex-start; }
    .glitch-404 { font-size: clamp(3rem, 15vw, 5rem); }
  }

  .radar-ring {
    position: absolute;
    border-radius: 50%;
    border: 1px solid var(--accent);
    opacity: 0.25;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
  .radar-ring:nth-child(2) { width: 100%; height: 100%; }
  .radar-ring:nth-child(3) { width: 66%; height: 66%; opacity: 0.35; }
  .radar-ring:nth-child(4) { width: 33%; height: 33%; opacity: 0.5; }

  .radar-crosshair-h,
  .radar-crosshair-v {
    position: absolute;
    background: var(--accent);
    opacity: 0.12;
  }
  .radar-crosshair-h { width: 100%; height: 1px; top: 50%; left: 0; }
  .radar-crosshair-v { height: 100%; width: 1px; left: 50%; top: 0; }

  /* Sweep arm */
  .radar-sweep {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 50%;
    height: 2px;
    transform-origin: 0 50%;
    background: linear-gradient(90deg, var(--accent), transparent);
    animation: sweep 3s linear infinite;
    filter: drop-shadow(0 0 6px var(--accent));
  }
  @keyframes sweep { to { transform: rotate(360deg); } }

  /* Sweep trail (conic gradient) */
  .radar-trail {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: conic-gradient(from 0deg, transparent 0deg, rgba(0, 229, 255, 0.12) 0deg, transparent 60deg);
    animation: sweep 3s linear infinite;
  }
  :global([data-theme="light"]) .radar-trail {
    background: conic-gradient(from 0deg, transparent 0deg, rgba(0, 131, 143, 0.1) 0deg, transparent 60deg);
  }

  /* Center dot */
  .radar-center {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 12px var(--accent), 0 0 24px var(--accent-glow);
  }

  /* Blips that appear and fade */
  .radar-blip {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    animation: blipFade 3s ease-out infinite;
  }
  .radar-blip:nth-child(8) { top: 25%; left: 60%; animation-delay: 0.5s; }
  .radar-blip:nth-child(9) { top: 70%; left: 35%; animation-delay: 1.2s; }
  .radar-blip:nth-child(10) { top: 40%; left: 75%; animation-delay: 2.1s; }
  .radar-blip:nth-child(11) { top: 15%; left: 30%; animation-delay: 0.8s; }
  .radar-blip:nth-child(12) { top: 60%; left: 70%; animation-delay: 1.7s; }
  .radar-blip:nth-child(13) { top: 80%; left: 55%; animation-delay: 2.5s; }
  @keyframes blipFade {
    0% { opacity: 0; transform: scale(0); }
    20% { opacity: 0.7; transform: scale(1); }
    100% { opacity: 0; transform: scale(2); }
  }

  /* Glitch heading */
  .glitch-wrap { text-align: center; position: relative; z-index: 2; }

  .glitch-404 {
    font-family: var(--font-headline);
    font-size: clamp(80px, 15vw, 160px);
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    position: relative;
    display: inline-block;
    text-shadow: 0 0 30px var(--accent-glow);
  }
  .glitch-404::before,
  .glitch-404::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .glitch-404::before {
    animation: glitch1 2.5s infinite;
    color: var(--accent);
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
    transform: translate(-2px, -1px);
    opacity: 0.7;
  }
  .glitch-404::after {
    animation: glitch2 2.5s infinite;
    color: #ffb4ab;
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
    transform: translate(2px, 1px);
    opacity: 0.7;
  }
  @keyframes glitch1 {
    0%,100% { transform: translate(0); }
    20% { transform: translate(-3px, 2px); }
    40% { transform: translate(3px, -1px); }
    60% { transform: translate(-1px, 1px); }
    80% { transform: translate(2px, -2px); }
  }
  @keyframes glitch2 {
    0%,100% { transform: translate(0); }
    25% { transform: translate(2px, 1px); }
    50% { transform: translate(-3px, -1px); }
    75% { transform: translate(1px, 2px); }
  }

  .subtitle {
    font-family: var(--font-headline);
    font-size: clamp(20px, 3vw, 32px);
    color: var(--text-primary);
    font-weight: 600;
    margin: 16px 0 0;
  }

  .message {
    font-family: var(--font-body);
    font-size: clamp(14px, 1.8vw, 18px);
    color: var(--text-tertiary);
    max-width: 480px;
    margin: 12px auto 0;
    line-height: 1.6;
  }
  .message .mono {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 0.85em;
  }

  /* Search bar */
  .search-section {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 480px;
    margin: 32px auto 0;
  }
  .search-bar {
    display: flex;
    align-items: center;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--glass-shadow, 0 8px 32px rgba(0,0,0,.3));
    transition: border-color 0.2s;
  }
  .search-bar:focus-within { border-color: var(--accent); }
  .search-bar svg { margin: 0 0 0 16px; color: var(--text-tertiary); flex-shrink: 0; }
  .search-bar input {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 16px;
    padding: 16px 16px;
    outline: none;
  }
  .search-bar input::placeholder { color: var(--text-tertiary); }
  .search-bar button {
    background: var(--accent);
    color: #000;
    border: none;
    font-family: var(--font-headline);
    font-weight: 600;
    font-size: 14px;
    padding: 16px 20px;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .search-bar button:hover { opacity: 0.85; }

  /* Actions row */
  .actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 24px 0 0;
    position: relative;
    z-index: 2;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-headline);
    font-size: 14px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 12px;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                background 0.3s ease;
    border: none;
  }
  .btn-primary {
    background: var(--accent);
    color: #000;
    box-shadow: 0 0 20px var(--accent-glow);
  }
  .btn-primary:hover { box-shadow: 0 0 30px var(--accent-glow), 0 0 60px var(--accent-glow); transform: translateY(-2px); }
  .btn-ghost {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--glass-border);
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

  /* Suggested pages */
  .suggestions {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 640px;
    margin: 48px auto 0;
  }
  .suggestions-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
    margin: 0 0 16px;
    text-align: center;
  }
  .suggestions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
  }
  .suggestion-card {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 16px;
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)), box-shadow 0.25s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
    position: relative;
    overflow: hidden;
  }
  .suggestion-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--glossy-shine);
    pointer-events: none;
  }
  .suggestion-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--accent-glow);
  }
  .suggestion-card .icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    font-size: 18px;
    flex-shrink: 0;
  }
  .suggestion-card .info .title {
    font-family: var(--font-headline);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .suggestion-card .info .path {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
  }

  /* Status bar (bottom) */
  .status-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    background: var(--surface-container-highest);
    border-top: 1px solid var(--glass-border);
    z-index: 10;
  }
  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ffb4ab;
    margin: 0 8px 0 0;
    animation: statusPulse 2s ease infinite;
  }
  @keyframes statusPulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

  /* Scanline overlay */
  .scanlines {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 2px, rgba(0,0,0,.03) 2px, rgba(0,0,0,.03) 4px
    );
  }

  /* Suggestion card stagger entrance */
  .suggestion-card {
    opacity: 0;
    transform: translateY(12px);
    animation: cardEnter 0.4s ease forwards;
  }
  .suggestion-card:nth-child(1) { animation-delay: 0ms; }
  .suggestion-card:nth-child(2) { animation-delay: 30ms; }
  .suggestion-card:nth-child(3) { animation-delay: 60ms; }
  .suggestion-card:nth-child(4) { animation-delay: 90ms; }
  .suggestion-card:nth-child(5) { animation-delay: 120ms; }
  .suggestion-card:nth-child(6) { animation-delay: 150ms; }
  @keyframes cardEnter {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Grid line pulse — horizontal line sweeps down */
  .grid-pulse {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }
  .grid-pulse::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 10%, var(--accent) 50%, transparent 90%);
    opacity: 0;
    animation: gridPulseSweep 6s ease-in-out infinite;
  }
  @keyframes gridPulseSweep {
    0% { top: -1px; opacity: 0; }
    5% { opacity: 0.4; }
    50% { opacity: 0.15; }
    95% { opacity: 0; }
    100% { top: 100%; opacity: 0; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .suggestion-card { opacity: 1; transform: none; }
    .grid-pulse::before { animation: none; opacity: 0; }
  }

  /* Focus */
  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
</style>

<script>
  // Live timestamp
  function updateTimestamp() {
    const el = document.getElementById('error-timestamp');
    if (el) el.textContent = new Date().toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
  }
  updateTimestamp();
  // Update every 10s instead of every 1s to reduce CPU usage
  setInterval(updateTimestamp, 10000);
</script>
