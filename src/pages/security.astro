---
/*
  Security Services — Jinki Aerial Intelligence
  Physical security services overview: event security, resort/hospitality,
  private estates, critical facilities, construction sites.
  Violet/blue accent (#7B61FF / #4F46E5).
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import LeadGen from '../components/LeadGen.astro';
import Footer from '../components/Footer.astro';

const useCases = [
  {
    icon: 'downhill_skiing',
    title: 'Ski Resorts & Recreation',
    metric: '1,000+',
    metricLabel: 'acres per patrol',
    desc: 'Terrain-aware aerial patrols across slopes, lodges, and backcountry. Thermal detection in whiteout conditions when traditional cameras fail.',
    capabilities: ['Slope monitoring', 'Lodge perimeter', 'Night thermal', 'Search support'],
  },
  {
    icon: 'school',
    title: 'Private Schools & Campuses',
    metric: '24/7',
    metricLabel: 'campus coverage',
    desc: 'Discreet autonomous surveillance protecting students and staff across sprawling campus grounds, athletic fields, and parking areas.',
    capabilities: ['Campus perimeter', 'Event security', 'After-hours patrol', 'Parent pickup monitoring'],
  },
  {
    icon: 'construction',
    title: 'Construction Sites',
    metric: '200+',
    metricLabel: 'missions per month',
    desc: 'After-hours theft prevention and equipment monitoring with autonomous patrol routes and time-stamped evidence capture.',
    capabilities: ['Theft deterrence', 'Equipment monitoring', 'Progress docs', 'Evidence capture'],
  },
  {
    icon: 'dns',
    title: 'Data Centers',
    metric: '<90s',
    metricLabel: 'alert to verification',
    desc: 'Multi-layered perimeter protection for facilities housing critical digital infrastructure. Thermal anomaly detection at the fence line.',
    capabilities: ['Perimeter patrol', 'Thermal fence-line', 'Alarm verification', 'SOC integration'],
  },
  {
    icon: 'stadium',
    title: 'Events & Gatherings',
    metric: '500+',
    metricLabel: 'acres per event',
    desc: 'Real-time crowd monitoring and perimeter surveillance from above — providing situational awareness ground teams cannot achieve alone.',
    capabilities: ['Crowd analysis', 'Perimeter breach', 'Incident response', 'Post-event sweep'],
  },
  {
    icon: 'villa',
    title: 'Resorts & Hospitality',
    metric: '0',
    metricLabel: 'visible infrastructure',
    desc: 'Protecting guests across expansive luxury grounds without the visible security presence that disrupts the experience.',
    capabilities: ['Guest safety', 'Waterfront', 'Night thermal', 'Perimeter coverage'],
  },
];

const steps = [
  {
    number: '01',
    title: 'Intelligence Scan',
    desc: 'We assess your site — footprint, terrain, existing security infrastructure, threat profile, and coverage gaps. This becomes the foundation for your custom aerial security plan.',
    icon: 'search',
  },
  {
    number: '02',
    title: 'Deploy & Integrate',
    desc: 'An autonomous dock station is positioned on-site and integrated with your existing alarm systems, VMS, and security operations center. Patrol routes are programmed to your specifications.',
    icon: 'rocket_launch',
  },
  {
    number: '03',
    title: 'Persistent Protection',
    desc: 'Autonomous thermal patrols run continuously — day and night. Real-time alerts stream directly to your SOC with classified threat data, GPS coordinates, and HD evidence.',
    icon: 'shield',
  },
];

const differentiators = [
  {
    icon: 'dark_mode',
    title: 'Night Operations Advantage',
    desc: 'Thermal imaging detects human presence through complete darkness, fog, and vegetation. No lighting infrastructure required — the aerial platform sees what cameras cannot.',
  },
  {
    icon: 'trending_down',
    title: 'Reduce Headcount, Increase Coverage',
    desc: 'One autonomous aerial system covers ground that would require multiple guard posts and camera installations. Scale coverage without scaling payroll or overtime.',
  },
  {
    icon: 'timer',
    title: 'Response in Seconds, Not Minutes',
    desc: 'Under 90 seconds from alert to airborne verification. Traditional guard response averages 15-20 minutes. Aerial verification classifies threats before ground teams are dispatched.',
  },
  {
    icon: 'hub',
    title: 'Integrates With What You Have',
    desc: 'Connects with your existing VMS, alarm panels, access control, and SIEM platforms. Aerial intelligence becomes another input to your security operations center — not a replacement.',
  },
  {
    icon: 'visibility_off',
    title: 'Eliminate Blind Spots',
    desc: 'Fixed cameras are limited by mounting position, field of view, and obstructions. Aerial vantage provides coverage across terrain, rooftops, and perimeter zones that ground-level systems miss.',
  },
  {
    icon: 'savings',
    title: '24/7 Without Overtime',
    desc: 'Autonomous operations run continuously without shift changes, fatigue, or overtime costs. Persistent coverage at a fraction of the cost of round-the-clock manned patrols.',
  },
];
---

<Layout ogImage="/images/og-security-page.png" title="Security Services — Jinki Aerial Intelligence" description="Aerial security intelligence for facilities, estates, and events. Thermal surveillance, autonomous patrol, and SOC integration." jsonLd={{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Aerial Security Services",
  "provider": { "@type": "Organization", "name": "Jinki Aerial Intelligence" },
  "description": "Physical security services powered by autonomous aerial thermal surveillance. Event security, estate protection, critical facility monitoring, and construction site coverage.",
  "areaServed": "Mid-Atlantic United States",
  "serviceType": "Aerial Physical Security"
}}>
  <Nav />
  <Breadcrumb items={[{ label: "Services" }, { label: "Security Services" }]} />
  <main id="main-content">

    <!-- ==================== 1. HERO (IMMERSIVE DARK) ==================== -->
    <section class="sec-hero sec-dark-force" aria-label="Security Services">
      <div aria-hidden="true" class="sec-hero-glow"></div>
      <!-- Tactical display as background -->
      <div class="sec-hero-bg" aria-hidden="true">
        <svg viewBox="0 0 800 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="sec-bg-svg">
          <!-- Subtle grid -->
          <defs>
            <pattern id="sec-grid" width="40" height="40" patternUnits="userSpaceOnUse">
              <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(123,97,255,0.04)" stroke-width="0.5"/>
            </pattern>
          </defs>
          <rect width="800" height="500" fill="url(#sec-grid)"/>
          <!-- Property perimeter -->
          <polygon points="120,80 680,60 720,160 740,380 620,440 180,450 80,340 100,140"
            fill="rgba(123,97,255,0.02)" stroke="rgba(123,97,255,0.15)" stroke-width="1" stroke-linejoin="round"/>
          <!-- Zone dividers -->
          <line x1="400" y1="60" x2="400" y2="445" stroke="rgba(123,97,255,0.06)" stroke-dasharray="4 6"/>
          <line x1="90" y1="250" x2="730" y2="260" stroke="rgba(123,97,255,0.06)" stroke-dasharray="4 6"/>
          <!-- Patrol path -->
          <path d="M160,100 L640,80 L700,250 L600,420 L200,430 L120,250 Z"
            fill="none" stroke="rgba(123,97,255,0.1)" stroke-width="0.5" stroke-dasharray="6 8"/>
          <!-- Moving unit -->
          <circle r="4" fill="#7B61FF" opacity="0.8">
            <animateMotion dur="18s" repeatCount="indefinite" path="M160,100 L640,80 L700,250 L600,420 L200,430 L120,250 Z"/>
          </circle>
          <circle r="30" fill="rgba(123,97,255,0.03)" stroke="rgba(123,97,255,0.06)" stroke-width="0.5">
            <animateMotion dur="18s" repeatCount="indefinite" path="M160,100 L640,80 L700,250 L600,420 L200,430 L120,250 Z"/>
          </circle>
          <!-- Detection events (subtle) -->
          <circle cx="620" cy="200" r="3" fill="#FF4444" opacity="0.6">
            <animate attributeName="opacity" values="0.6;0.2;0.6" dur="2s" repeatCount="indefinite"/>
          </circle>
          <circle cx="150" cy="320" r="2" fill="#FFaa00" opacity="0.4">
            <animate attributeName="opacity" values="0.4;0.1;0.4" dur="3s" repeatCount="indefinite"/>
          </circle>
        </svg>
      </div>
      <div class="sec-hero-inner">
        <div class="sec-hero-content reveal">
          <div class="sec-eyebrow">
            <span class="sec-eyebrow-line"></span>
            <span class="sec-eyebrow-text">Security Services</span>
          </div>
          <h1 class="sec-hero-title">
            Your Property Never Sleeps.<br/>
            <span class="gradient-text-violet">Neither Do We.</span>
          </h1>
          <p class="sec-hero-subtitle">
            Autonomous aerial thermal surveillance. Hundreds of acres.
            Total darkness. Threats detected in seconds.
            A force multiplier — not a replacement.
          </p>
          <div class="sec-hero-actions">
            <a href="#lead-gen" class="btn-premium sec-cta">Get a Security Assessment</a>
            <a href="#use-cases" class="sec-cta-secondary">View Use Cases</a>
          </div>
        </div>

        <!-- HUD stats strip overlaid at bottom of hero -->
        <div class="sec-hero-stats reveal reveal-delay-2" aria-hidden="true">
          <div class="sec-hud-stat">
            <span class="sec-hud-val">98.7<span class="sec-hud-unit">%</span></span>
            <span class="sec-hud-lbl">COVERAGE</span>
          </div>
          <div class="sec-hud-divider"></div>
          <div class="sec-hud-stat">
            <span class="sec-hud-val">&lt;90<span class="sec-hud-unit">s</span></span>
            <span class="sec-hud-lbl">RESPONSE</span>
          </div>
          <div class="sec-hud-divider"></div>
          <div class="sec-hud-stat">
            <span class="sec-hud-val">24/7</span>
            <span class="sec-hud-lbl">AUTONOMOUS</span>
          </div>
          <div class="sec-hud-divider"></div>
          <div class="sec-hud-stat">
            <span class="sec-hud-val">0</span>
            <span class="sec-hud-lbl">BLIND SPOTS</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== 2. USE CASES ==================== -->
    <section id="use-cases" class="section" style="background: var(--surface-dim);" aria-label="Use Cases">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="vert-eyebrow">
            <span class="vert-eyebrow-line"></span>
            <span class="vert-eyebrow-text">Use Cases</span>
          </div>
          <h2>Aerial Security for Every Environment</h2>
          <p class="section-subtitle">
            From single-night events to persistent facility protection,
            aerial intelligence adapts to your security requirements.
          </p>
        </div>
        <div class="uc-grid-v3">
          {useCases.map((uc, i) => (
            <div class={`uc-card-v3 reveal reveal-delay-${(i % 3) + 1}`}>
              <div class="uc-card-top">
                <div class="uc-card-icon-wrap">
                  <span class="material-symbols-outlined" style="font-size:22px;color:var(--accent-secondary);font-variation-settings:'FILL' 1;" aria-hidden="true">{uc.icon}</span>
                </div>
                <div class="uc-card-metric">
                  <span class="uc-metric-val">{uc.metric}</span>
                  <span class="uc-metric-lbl">{uc.metricLabel}</span>
                </div>
              </div>
              <h3 class="uc-card-title">{uc.title}</h3>
              <p class="uc-card-desc">{uc.desc}</p>
              <div class="uc-card-caps">
                {uc.capabilities.map(c => (
                  <span class="uc-cap-tag">{c}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ==================== 4. HOW IT WORKS ==================== -->
    <section class="section" aria-label="How It Works">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="vert-eyebrow">
            <span class="vert-eyebrow-line"></span>
            <span class="vert-eyebrow-text">Process</span>
          </div>
          <h2>How It Works</h2>
          <p class="section-subtitle">
            From initial assessment to persistent protection in three steps.
          </p>
        </div>
        <div class="steps-grid">
          {steps.map((step, i) => (
            <div class={`step-card reveal reveal-delay-${i + 1}`}>
              <div class="step-number">{step.number}</div>
              <div class="step-icon-wrap">
                <span class="material-symbols-outlined" style="font-size:28px;color:var(--accent-secondary);font-variation-settings:'FILL' 1;" aria-hidden="true">{step.icon}</span>
              </div>
              <h3>{step.title}</h3>
              <p>{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ==================== 5. WHY AERIAL SECURITY ==================== -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Why Aerial Security">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="vert-eyebrow">
            <span class="vert-eyebrow-line"></span>
            <span class="vert-eyebrow-text">Advantages</span>
          </div>
          <h2>Why Aerial Security</h2>
          <p class="section-subtitle">
            Traditional physical security was designed for a world of fences and fixed cameras.
            The threat landscape has evolved. Your coverage should too.
          </p>
        </div>
        <div class="diff-grid">
          {differentiators.map((d, i) => (
            <div class={`diff-card reveal reveal-delay-${(i % 3) + 1}`}>
              <div class="diff-icon-wrap">
                <span class="material-symbols-outlined diff-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{d.icon}</span>
              </div>
              <h3>{d.title}</h3>
              <p>{d.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ==================== 6. CROSS-LINKS ==================== -->
    <section class="section" aria-label="Related Services">
      <div class="section-inner">
        <div class="section-header reveal" style="text-align:center;">
          <h2>Explore Our Services</h2>
          <p class="section-subtitle" style="margin-left:auto;margin-right:auto;">
            Security is one dimension of aerial intelligence. See how we deploy.
          </p>
        </div>
        <div class="xlinks-grid">
          <a href="/services/intelligence-scan" class="xlink-card reveal reveal-delay-1">
            <div class="xlink-icon-wrap">
              <span class="material-symbols-outlined" style="font-size:28px;color:var(--accent);font-variation-settings:'FILL' 1;" aria-hidden="true">search_insights</span>
            </div>
            <h3>Intelligence Scan</h3>
            <p>One-time aerial AI assessment of your facility. Thermal, visual, and analytical deliverables.</p>
            <span class="xlink-arrow">
              <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">arrow_forward</span>
            </span>
          </a>
          <a href="/services/deployment" class="xlink-card reveal reveal-delay-2">
            <div class="xlink-icon-wrap">
              <span class="material-symbols-outlined" style="font-size:28px;color:var(--accent);font-variation-settings:'FILL' 1;" aria-hidden="true">rocket_launch</span>
            </div>
            <h3>Autonomous Deployment</h3>
            <p>Persistent on-site aerial operations. Autonomous dock station, scheduled patrols, real-time alerts.</p>
            <span class="xlink-arrow">
              <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">arrow_forward</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Data Security Trust Callout -->
    <section class="reveal" style="max-width: 800px; margin: 0 auto; padding: 0 1.5rem 3rem;">
      <div style="background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 16px; padding: 2rem 2.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; backdrop-filter: blur(12px);">
        <span class="material-symbols-outlined" style="font-size: 2.5rem; color: var(--accent-tertiary); font-variation-settings: 'FILL' 1;" aria-hidden="true">verified_user</span>
        <div style="flex: 1; min-width: 200px;">
          <h3 style="font-family: var(--font-headline); font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin: 0 0 0.25rem;">Your Data Is Protected</h3>
          <p style="font-family: var(--font-body); font-size: 0.9rem; color: var(--text-secondary); margin: 0; line-height: 1.5;">AES-256 encryption, SOC 2 Type I preparation, NIST 800-53 alignment, and NDA-by-default on every engagement.</p>
        </div>
        <a href="/data-security" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; border-radius: 10px; background: rgba(52,211,153,0.08); border: 1px solid rgba(52,211,153,0.2); color: var(--accent-tertiary); font-family: var(--font-label); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.25s ease; white-space: nowrap;">
          View Data Security
          <span class="material-symbols-outlined" style="font-size: 16px;" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </section>

    <!-- ==================== 7. LEADGEN ==================== -->
    <LeadGen />

  </main>
  <Footer />
</Layout>

<style>
  /* Force dark aesthetic on the entire security page */
  .sec-dark-force, .sec-dark-force ~ * {
    --surface-container-lowest: #06060e;
    --surface-dim: #0a0a18;
    --surface-container-low: #0e0e1a;
    --glass-bg: rgba(12, 12, 24, 0.85);
    --glass-border: rgba(123,97,255,0.12);
    --text-primary: #e8e8f0;
    --text-secondary: #a0a0b8;
    --text-tertiary: #6a6a82;
    color-scheme: dark;
  }

  /* === HERO === */
  .sec-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px clamp(20px, 5vw, 80px) 80px;
    background: #06060e;
    position: relative;
    overflow: hidden;
  }

  .sec-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.6;
  }

  .sec-bg-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sec-hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 30% 40%, rgba(123,97,255,0.1) 0%, transparent 55%),
      radial-gradient(ellipse at 70% 60%, rgba(79,70,229,0.06) 0%, transparent 50%);
    filter: blur(60px);
  }

  .sec-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    z-index: 1;
    width: 100%;
  }

  @media (max-width: 960px) {
    .sec-hero { min-height: auto; padding-top: 100px; padding-bottom: 48px; }
  }

  /* HUD stats strip at bottom of hero */
  .sec-hero-stats {
    display: flex;
    align-items: center;
    gap: 32px;
    margin-top: 48px;
    padding: 16px 32px;
    background: rgba(123,97,255,0.04);
    border: 1px solid rgba(123,97,255,0.12);
    border-radius: 12px;
    backdrop-filter: blur(8px);
  }

  .sec-hud-stat { text-align: center; }

  .sec-hud-val {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: #e0e0ff;
    letter-spacing: 0.02em;
    display: block;
  }

  .sec-hud-unit {
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(123,97,255,0.6);
  }

  .sec-hud-lbl {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: rgba(123,97,255,0.4);
    text-transform: uppercase;
    display: block;
    margin-top: 4px;
  }

  .sec-hud-divider {
    width: 1px;
    height: 32px;
    background: rgba(123,97,255,0.12);
  }

  @media (max-width: 640px) {
    .sec-hero-stats { gap: 16px; padding: 12px 16px; flex-wrap: wrap; justify-content: center; }
    .sec-hud-val { font-size: 1.125rem; }
    .sec-hud-divider { display: none; }
  }

  .sec-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    justify-content: center;
  }

  .sec-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent-secondary);
  }

  .sec-eyebrow-text {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(123,97,255,0.7);
  }

  .sec-hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .gradient-text-violet {
    color: var(--accent-secondary);
  }

  .sec-hero-subtitle {
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    line-height: 1.75;
    color: rgba(160, 160, 184, 0.9);
    max-width: 560px;
    margin: 0 auto 32px;
  }

  .sec-hero-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .sec-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.75rem 2rem;
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
    display: inline-block;
  }

  .sec-cta-secondary {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--accent-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(123,97,255,0.3);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .sec-cta-secondary:hover {
    background: rgba(123,97,255,0.08);
    border-color: rgba(123,97,255,0.5);
  }

  /* Radar Visual */
  @media (prefers-reduced-motion: reduce) {
    .sec-bg-svg circle, .sec-bg-svg animate { animation: none !important; }
  }

  /* === SECTIONS === */
  .section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .section { padding: 6rem clamp(20px, 5vw, 80px); }
  }

  .section-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 56px;
  }

  .section-header h2, .section h2 {
    color: #ffffff !important;
  }

  .section-header h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.15;
    margin-top: 8px;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-top: 16px;
  }

  /* === EYEBROW (reused) === */
  .vert-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .vert-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent-secondary);
  }

  .vert-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.75rem;
