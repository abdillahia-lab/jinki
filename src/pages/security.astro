---
/*
  Security Architecture — Jinki Aerial Intelligence
  Enterprise-grade security posture and data protection overview.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const pillars = [
  { icon: 'lock', title: 'Data Protection', desc: 'AES-256 encryption at rest, TLS 1.3 for all data in transit, and air-gapped processing options for classified or highly sensitive engagements. Your data never touches shared infrastructure unless you authorize it.' },
  { icon: 'shield', title: 'Access Control', desc: 'Role-based access with principle of least privilege enforced at every layer. Multi-factor authentication is mandatory — no exceptions. Every action is logged, timestamped, and available for client audit review.' },
  { icon: 'verified_user', title: 'Compliance', desc: 'SOC 2 Type II readiness with controls mapped to NIST 800-53. All engagements operate under NDA by default. We align with the frameworks your compliance team already trusts.' },
  { icon: 'security', title: 'Operational Security', desc: 'Security-cleared personnel on every mission. Full chain-of-custody documentation for all captured data — from sensor to deliverable. Secure handoff protocols ensure data integrity from field to client.' },
  { icon: 'dns', title: 'Infrastructure Security', desc: 'Hardened cloud architecture with network segmentation, automated vulnerability scanning, and a tested incident response plan. Infrastructure is continuously monitored and patched against emerging threats.' },
  { icon: 'warning', title: 'Client Data Handling', desc: 'Defined data retention policies with secure deletion upon project completion. Client-owned data principles mean you maintain full ownership — we process, deliver, and purge on your terms.' },
];

const commitments = [
  'Founded by a CISSP/CCSP-certified security professional',
  'Security architecture reviewed before every engagement',
  'Zero-trust network principles across all operations',
  'Annual third-party penetration testing',
  'Documented incident response with defined SLAs',
  'Continuous security training for all personnel',
];
---

<Layout title="Security Architecture — Jinki Aerial Intelligence" description="Enterprise-grade security posture. AES-256 encryption, SOC 2 readiness, NIST alignment, and security-cleared personnel on every engagement.">
  <Nav />
  <main id="main-content">

    <!-- Hero -->
    <section class="security-hero" aria-label="Security Architecture">
      <div class="security-hero-inner">
        <div class="vert-eyebrow reveal">
          <span class="vert-eyebrow-line"></span>
          <span class="vert-eyebrow-text">Security</span>
        </div>
        <h1 class="reveal reveal-delay-1">Security Is Not a Feature.<br/><span class="gradient-text-cyan">It's the Foundation.</span></h1>
        <p class="security-subtitle reveal reveal-delay-2">
          Jinki was founded by a CISSP/CCSP-certified security professional. Enterprise-grade
          data protection, access control, and operational security aren't bolted on after the
          fact — they are embedded in every layer of how we operate.
        </p>
      </div>
    </section>

    <!-- Security Pillars -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Security Pillars">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="vert-eyebrow">
            <span class="vert-eyebrow-line"></span>
            <span class="vert-eyebrow-text">Architecture</span>
          </div>
          <h2>Six Pillars of Protection</h2>
          <p class="section-subtitle">
            Every engagement is governed by a security architecture designed for
            the most demanding enterprise and government clients.
          </p>
        </div>
        <div class="perks-grid">
          {pillars.map((pillar, i) => (
            <div class={`perk-card reveal reveal-delay-${(i % 4) + 1}`}>
              <div class="perk-icon-wrap">
                <span class="material-symbols-outlined perk-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{pillar.icon}</span>
              </div>
              <h3>{pillar.title}</h3>
              <p>{pillar.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Commitments -->
    <section class="section" aria-label="Security Commitments">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="vert-eyebrow">
            <span class="vert-eyebrow-line"></span>
            <span class="vert-eyebrow-text">Commitments</span>
          </div>
          <h2>Our Security Commitments</h2>
          <p class="section-subtitle">
            Security is a continuous discipline, not a checkbox. These commitments
            govern every project we undertake.
          </p>
        </div>
        <div class="commitments-grid">
          {commitments.map((item, i) => (
            <div class={`commitment-item reveal reveal-delay-${(i % 3) + 1}`}>
              <span class="material-symbols-outlined commitment-check" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">check_circle</span>
              <span class="commitment-text">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Request Security Review">
      <div class="section-inner" style="text-align: center; max-width: 640px;">
        <div class="reveal">
          <h2>Need Our Security Documentation?</h2>
          <p class="section-subtitle" style="margin: 16px auto 32px;">
            We provide detailed security architecture documentation, compliance
            attestations, and data handling procedures under NDA. Contact us to
            begin the review process.
          </p>
          <a href="/#lead-gen" class="btn-premium security-cta">Request Security Review</a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .security-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px clamp(20px, 5vw, 80px) 80px;
    text-align: center;
    background: var(--surface-container-lowest);
    position: relative;
  }

  .security-hero-inner {
    max-width: 800px;
  }

  .security-hero h1 {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .gradient-text-cyan {
    background: linear-gradient(135deg, #00E5FF, #00a8b5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .security-subtitle {
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .vert-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    justify-content: center;
  }

  .section-header .vert-eyebrow {
    justify-content: flex-start;
  }

  .vert-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .vert-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
  }

  .section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .section { padding: 8rem clamp(20px, 5vw, 80px); }
  }

  .section-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 56px;
  }

  .section-header h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.15;
    margin-top: 8px;
  }

  .section-subtitle {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 640px;
    margin-top: 16px;
  }

  .section h2 {
    margin-bottom: 0;
  }

  /* Security Pillars Grid */
  .perks-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (min-width: 1024px) {
    .perks-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .perks-grid { grid-template-columns: 1fr; }
  }

  .perk-card {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 32px;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .perk-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .perk-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 229, 255, 0.15);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2), 0 0 30px var(--accent-glow);
  }

  .perk-icon-wrap {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .perk-icon {
    color: var(--accent);
    font-size: 24px;
  }

  .perk-card h3 {
    font-family: var(--font-headline);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 10px;
  }

  .perk-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Commitments */
  .commitments-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (max-width: 768px) {
    .commitments-grid { grid-template-columns: 1fr; }
  }

  .commitment-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px 24px;
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    transition: all 0.3s ease;
  }

  .commitment-item:hover {
    border-color: rgba(0, 229, 255, 0.15);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .commitment-check {
    color: var(--accent);
    font-size: 22px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .commitment-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-primary);
    line-height: 1.6;
    font-weight: 500;
  }

  /* CTA */
  .security-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.75rem 2rem;
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
    display: inline-block;
  }
</style>
