    .shield-container, .trust-strip { display: none !important; }
    .pillar-details { max-height: none !important; padding: 0 28px 28px !important; }
    .sec-hero { min-height: auto; padding: 40px 20px; }
    .timeline-upcoming { opacity: 1; }
  }
</style>

<script>
  // Expandable pillar cards
  document.querySelectorAll('.pillar-card').forEach(card => {
    const header = card.querySelector('.pillar-header');
    const toggle = card.querySelector('.pillar-toggle');
    const details = card.querySelector('.pillar-details');

    if (header && toggle && details) {
      header.addEventListener('click', () => {
        const isExpanded = card.classList.contains('expanded');
        card.classList.toggle('expanded');
        toggle.setAttribute('aria-expanded', String(!isExpanded));
        details.setAttribute('aria-hidden', String(isExpanded));
      });
    }
  });
</script>
