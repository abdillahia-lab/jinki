---
/*
  Home Page — Jinki | Aerial Intelligence for Critical Infrastructure

  Layout: Nav → Hero (globe) → TrustBar → Verticals →
  Bento Stats → Process → Lead Gen → Footer.

  6 content sections. No dividers. Premium spacing.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Verticals from '../components/Verticals.astro';
import BentoStats from '../components/BentoStats.astro';
import Process from '../components/Process.astro';
import LeadGen from '../components/LeadGen.astro';
import Footer from '../components/Footer.astro';
---

<Layout ogImage="/images/og-homepage.png" jsonLd={{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Jinki Aerial Intelligence",
  "url": "https://jinki.ai",
  "description": "Aerial intelligence platform for critical infrastructure — data centers, energy grids, security perimeters, and agriculture."
}}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a Facility Intelligence Scan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A one-time aerial assessment that delivers a prioritized report with thermal, structural, and environmental findings — typically within 48 hours."
        }
      },
      {
        "@type": "Question",
        "name": "What industries does Jinki serve?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Jinki provides aerial intelligence for data centers, energy and utility infrastructure, perimeter security, and agricultural operations across the Mid-Atlantic United States."
        }
      },
      {
        "@type": "Question",
        "name": "What equipment does Jinki use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Jinki operates a piloted aerial platform with radiometric thermal sensors for assessment missions and an autonomous aerial platform with on-site dock station for persistent monitoring — capable of 150-200 missions per month."
        }
      },
      {
        "@type": "Question",
        "name": "How is my facility data protected?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All data is encrypted with AES-256 at rest and TLS 1.3 in transit. Every engagement begins with a mutual NDA. SOC 2 Type I certification targeted for Spring 2027."
        }
      }
    ]
  })} />
  <Nav />
  <main id="main-content">
    <Hero />
    <TrustBar />
    <Verticals />
    <BentoStats />
    <Process />
    <LeadGen />
  </main>
  <Footer />
</Layout>
