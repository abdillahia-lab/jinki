---
/*
  Home Page — Tactical Jinki | Aerial Intelligence & Infrastructure

  Single-page layout: Nav → Hero (globe) → Verticals → Thermal HUD →
  Bento Stats → Lead Gen → Footer.

  Design spec: docs/superpowers/specs/2026-03-19-jinki-landing-page-transformation.md
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SocialProof from '../components/SocialProof.astro';
import Verticals from '../components/Verticals.astro';
import ThermalHUD from '../components/ThermalHUD.astro';
import BentoStats from '../components/BentoStats.astro';
import Process from '../components/Process.astro';
import LeadGen from '../components/LeadGen.astro';
import Footer from '../components/Footer.astro';
---

<Layout ogImage="/images/og-homepage.png" jsonLd={{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Jinki Aerial Intelligence",
  "url": "https://jinki.ai",
  "description": "Aerial intelligence platform for critical infrastructure — data centers, energy grids, security perimeters, and agriculture."
}}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is a Facility Intelligence Scan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A one-time aerial assessment that delivers a prioritized report with thermal, structural, and environmental findings — typically within 48 hours."
        }
      },
      {
        "@type": "Question",
        "name": "What industries does Jinki serve?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Jinki provides aerial intelligence for data centers, energy and utility infrastructure, perimeter security, and agricultural operations across the Mid-Atlantic United States."
        }
      },
      {
        "@type": "Question",
        "name": "What equipment does Jinki use?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Jinki operates the DJI M400 RTK with H30T thermal sensor for piloted missions and the DJI M4TD with Dock 3 for autonomous persistent monitoring — capable of 150-200 missions per month."
        }
      },
      {
        "@type": "Question",
        "name": "How is my facility data protected?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All data is encrypted with AES-256 at rest and TLS 1.3 in transit. Every engagement begins with a mutual NDA. SOC 2 Type I certification targeted for Q3 2026."
        }
      }
    ]
  })} />
  <Nav />
  <main id="main-content">
    <Hero />
    <TrustBar />
    <SocialProof />
    <Verticals />
    <div class="section-fade" aria-hidden="true"></div>
    <ThermalHUD />
    <div class="section-fade" aria-hidden="true"></div>
    <BentoStats />
    <div class="section-fade" aria-hidden="true"></div>
    <Process />
    <div class="section-fade" aria-hidden="true"></div>
    <LeadGen />
  </main>
  <Footer />
</Layout>

<style>
  .section-fade {
    height: 1px;
    background: linear-gradient(to right, transparent 10%, rgba(0,229,255,0.06) 30%, rgba(0,229,255,0.1) 50%, rgba(0,229,255,0.06) 70%, transparent 90%);
    max-width: 64rem;
    margin: 0 auto;
  }
</style>
