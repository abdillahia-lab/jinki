---
/*
  Privacy Policy — Jinki Aerial Intelligence
  Data privacy and handling practices.
*/
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    id: 'information-collection',
    title: 'Information We Collect',
    content: [
      'We collect information you provide directly when you request a consultation, submit a contact form, or communicate with our team. This includes your name, email address, phone number, company name, and details about your infrastructure or facility.',
      'When you visit our website, we automatically collect technical data such as your IP address, browser type, operating system, referring URL, pages viewed, and timestamps. This data helps us understand how visitors use our site and improve the experience.',
      'In the course of delivering aerial intelligence services, we collect geospatial data, thermal imagery, visual spectrum imagery, and derived analytics related to client facilities and infrastructure. This operational data is governed by individual client service agreements.',
    ],
  },
  {
    id: 'use-of-data',
    title: 'How We Use Your Data',
    content: [
      'We use contact information to respond to inquiries, deliver requested services, provide project updates, and send relevant communications about our aerial intelligence capabilities.',
      'Website analytics data is used to monitor site performance, identify technical issues, understand visitor behavior, and improve our content and user experience.',
      'Aerial survey data and derived analytics are processed exclusively for the purposes outlined in each client engagement — such as infrastructure condition assessment, thermal anomaly detection, perimeter monitoring, and asset documentation. We do not use client operational data for any purpose beyond the contracted scope without explicit written consent.',
    ],
  },
  {
    id: 'data-sharing',
    title: 'Data Sharing',
    content: [
      'We do not sell, rent, or trade your personal information to third parties.',
      'We may share data with trusted service providers who assist in operating our website, conducting our business, or delivering services to you — provided those parties agree to keep your information confidential. These include cloud hosting providers, analytics platforms, and email delivery services.',
      'We may disclose information when required by law, regulation, or legal process, or when we believe disclosure is necessary to protect our rights, your safety, or the safety of others.',
      'Client aerial survey data is never shared with third parties unless explicitly authorized by the client in writing.',
    ],
  },
  {
    id: 'security',
    title: 'Security',
    content: [
      'We implement industry-standard technical and organizational measures to protect your data against unauthorized access, alteration, disclosure, or destruction. These measures include encryption in transit and at rest, access controls, regular security assessments, and secure data storage practices.',
      'Aerial survey data and client deliverables are stored in encrypted environments with role-based access controls. Our security practices reflect the sensitive nature of infrastructure intelligence — our founding team holds CISSP and CCSP certifications, and security is embedded in our operations from the ground up.',
      'No method of transmission or storage is completely secure. While we strive to protect your information, we cannot guarantee absolute security.',
    ],
  },
  {
    id: 'cookies',
    title: 'Cookies',
    content: [
      'Our website uses cookies and similar technologies to enhance your browsing experience, remember your preferences (such as theme selection), and collect aggregate analytics data.',
      'Essential cookies are required for basic site functionality. Analytics cookies help us understand traffic patterns and site usage. You can control cookie preferences through your browser settings.',
      'We do not use cookies for advertising or cross-site tracking purposes.',
    ],
  },
  {
    id: 'third-party-services',
    title: 'Third-Party Services',
    content: [
      'Our website may contain links to third-party websites or services that are not operated by us. We have no control over the content, privacy policies, or practices of third-party sites and accept no responsibility for them.',
      'We use third-party tools for website analytics, form processing, and email communications. These services have their own privacy policies governing their use of your data.',
    ],
  },
  {
    id: 'data-retention',
    title: 'Data Retention',
    content: [
      'We retain personal information for as long as necessary to fulfill the purposes described in this policy, comply with legal obligations, resolve disputes, and enforce our agreements.',
      'Contact form submissions and inquiry records are retained for up to three years unless you request earlier deletion.',
      'Client aerial survey data is retained according to the terms of each service agreement. Upon contract completion or termination, data is either returned to the client or securely destroyed, per the agreed-upon terms.',
    ],
  },
  {
    id: 'your-rights',
    title: 'Your Rights',
    content: [
      'Depending on your jurisdiction, you may have the right to access, correct, delete, or port your personal data. You may also have the right to restrict or object to certain processing activities.',
      'To exercise any of these rights, contact us at the email address below. We will respond to verified requests within 30 days.',
      'If you are a Virginia resident, you have specific rights under the Virginia Consumer Data Protection Act (VCDPA), including the right to access, correct, delete, and obtain a copy of your personal data, as well as the right to opt out of targeted advertising and profiling.',
    ],
  },
  {
    id: 'contact',
    title: 'Contact',
    content: [
      'If you have questions about this Privacy Policy or our data practices, contact us at:',
    ],
  },
];
---

<Layout title="Privacy Policy — Jinki Aerial Intelligence" description="Privacy policy for Jinki Aerial Intelligence. How we collect, use, and protect your data.">
  <Nav />
  <main id="main-content">

    <!-- Hero -->
    <section class="privacy-hero" aria-label="Privacy Policy">
      <div class="privacy-hero-inner">
        <div class="vert-eyebrow reveal">
          <span class="vert-eyebrow-line"></span>
          <span class="vert-eyebrow-text">Legal</span>
        </div>
        <h1 class="reveal reveal-delay-1">Privacy Policy</h1>
        <p class="privacy-subtitle reveal reveal-delay-2">
          Effective March 2026. This policy describes how Jinki Aerial Intelligence
          collects, uses, and protects your information.
        </p>
      </div>
    </section>

    <!-- Policy Content -->
    <section class="section" style="background: var(--surface-dim);" aria-label="Privacy Policy Details">
      <div class="section-inner">
        <div class="policy-body">
          {sections.map((section, i) => (
            <div id={section.id} class={`policy-section reveal reveal-delay-${(i % 3) + 1}`}>
              <h2>{section.title}</h2>
              {section.content.map((para) => (
                <p>{para}</p>
              ))}
              {section.id === 'contact' && (
                <div class="contact-block">
                  <a href="mailto:privacy@jinki.ai" class="privacy-email">privacy@jinki.ai</a>
                  <p class="contact-address">Jinki Aerial Intelligence<br />Virginia, USA</p>
                </div>
              )}
            </div>
          ))}
        </div>

        <div class="policy-footer reveal">
          <p>This policy may be updated periodically. Changes will be posted on this page with a revised effective date. Continued use of our website or services after changes constitutes acceptance of the updated policy.</p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .privacy-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px clamp(20px, 5vw, 80px) 64px;
    text-align: center;
    background: var(--surface-container-lowest);
    position: relative;
  }

  .privacy-hero-inner {
    max-width: 720px;
  }

  .privacy-hero h1 {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .privacy-subtitle {
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.75;
    color: var(--text-secondary);
  }

  .vert-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    justify-content: center;
  }

  .vert-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--accent);
  }

  .vert-eyebrow-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
  }

  .section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .section { padding: 6rem clamp(20px, 5vw, 80px); }
  }

  .section-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  /* Policy body */
  .policy-body {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .policy-section {
    padding: 40px 0;
    border-bottom: 1px solid var(--glass-border);
  }

  .policy-section:first-child {
    padding-top: 0;
  }

  .policy-section:last-child {
    border-bottom: none;
  }

  .policy-section h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.25rem, 2vw + 0.25rem, 1.5rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 20px;
  }

  .policy-section p {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 14px;
  }

  .policy-section p:last-of-type {
    margin-bottom: 0;
  }

  /* Contact block */
  .contact-block {
    margin-top: 20px;
  }

  .privacy-email {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    color: var(--accent);
    text-decoration: none;
    padding: 10px 20px;
    border: 1px solid var(--accent);
    border-radius: 12px;
    display: inline-block;
    transition: all 0.3s ease;
  }

  .privacy-email:hover {
    background: var(--accent-glow);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .contact-address {
    margin-top: 16px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-tertiary);
    line-height: 1.7;
  }

  /* Policy footer */
  .policy-footer {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--glass-border);
  }

  .policy-footer p {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    line-height: 1.8;
  }
</style>
