    background: rgba(0, 201, 167, 0.1);
    overflow: hidden;
  }

  .seq-step:last-child .seq-connector { display: none; }

  .seq-connector-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #00C9A7, rgba(0, 201, 167, 0.4));
    transition: width 0.6s ease;
    position: relative;
  }

  /* Pulsing data-flow particle along connector */
  .seq-connector-fill::after {
    content: '';
    position: absolute;
    top: -3px;
    right: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00C9A7;
    box-shadow: 0 0 10px rgba(0, 201, 167, 0.6), 0 0 20px rgba(0, 201, 167, 0.3);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .seq-step.active .seq-connector-fill {
    width: 100%;
  }

  .seq-step.active .seq-connector-fill::after {
    opacity: 1;
    animation: data-flow-pulse 1.5s ease-in-out infinite;
  }

  @keyframes data-flow-pulse {
    0%, 100% { box-shadow: 0 0 6px rgba(0, 201, 167, 0.4); transform: scale(0.8); }
    50% { box-shadow: 0 0 16px rgba(0, 201, 167, 0.8), 0 0 30px rgba(0, 201, 167, 0.3); transform: scale(1.2); }
  }

  /* Sequential animation delays for ring activation */
  .seq-step[data-seq="1"].active .seq-icon-wrap::before { animation-delay: 0s; }
  .seq-step[data-seq="2"].active .seq-icon-wrap::before { animation-delay: 0.2s; }
  .seq-step[data-seq="3"].active .seq-icon-wrap::before { animation-delay: 0.4s; }
  .seq-step[data-seq="4"].active .seq-icon-wrap::before { animation-delay: 0.6s; }
  .seq-step[data-seq="5"].active .seq-icon-wrap::before { animation-delay: 0.8s; }

  .seq-step-label {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .seq-step-desc {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    color: var(--text-tertiary);
    line-height: 1.4;
    max-width: 120px;
  }

  /* ============================================================
     SPECS GRID
     ============================================================ */
  .specs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (min-width: 768px) {
    .specs-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (min-width: 1024px) {
    .specs-grid { grid-template-columns: repeat(6, 1fr); }
  }

  .spec-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 24px 12px;
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    text-align: center;
    transition: border-color 0.3s ease, transform 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)), box-shadow 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
    position: relative;
    overflow: hidden;
  }

  .spec-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at 50% 30%, rgba(0, 201, 167, 0.08), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .spec-card:hover {
    border-color: rgba(0, 201, 167, 0.25);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15), 0 0 20px rgba(0, 201, 167, 0.1);
  }

  .spec-card:hover::after {
    opacity: 1;
  }

  .spec-card-icon {
    font-size: 24px;
    color: #00C9A7;
    transition: filter 0.3s ease;
  }

  .spec-card:hover .spec-card-icon {
    filter: drop-shadow(0 0 8px rgba(0, 201, 167, 0.5));
  }

  .spec-card-value {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    display: block;
  }

  .spec-card-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    display: block;
  }

  /* ============================================================
     COVERAGE CALCULATOR
     ============================================================ */
  .calc-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: start;
  }

  @media (min-width: 768px) {
    .calc-layout {
      grid-template-columns: 1fr 1.2fr;
      gap: 64px;
      align-items: center;
    }
  }

  .calc-text h2 {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 3vw + 0.5rem, 2.75rem);
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.12;
    margin-top: 8px;
  }

  .calc-lead {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-top: 16px;
  }

  .calc-card-inner {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 32px;
    position: relative;
    overflow: hidden;
  }

  .calc-card-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .calc-perimeter-viz {
    position: absolute;
    top: 50%;
    right: 20px;
    transform: translateY(-50%);
    width: 120px;
    height: 120px;
    opacity: 0.5;
    pointer-events: none;
    z-index: 0;
  }

  .calc-perimeter-svg {
    width: 100%;
    height: 100%;
  }

  #calc-perimeter-ring,
  #calc-perimeter-glow {
    transition: r 0.3s ease;
    transform-origin: center;
    animation: perimeter-rotate 20s linear infinite;
  }

  @keyframes perimeter-rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .calc-input-label {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    margin-bottom: 16px;
  }

  .calc-input-wrap {
    margin-bottom: 32px;
  }

  .calc-slider {
    width: 100%;
    height: 6px;
    border-radius: 4px;
    background: linear-gradient(90deg, rgba(0, 201, 167, 0.25), rgba(0, 201, 167, 0.06));
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
    position: relative;
  }

  .calc-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, #10F0C0, #00C9A7);
    box-shadow: 0 0 16px rgba(0, 201, 167, 0.5), 0 0 40px rgba(0, 201, 167, 0.15);
    cursor: pointer;
    border: 3px solid var(--surface-container-low);
    transition: box-shadow 0.2s ease;
  }

  .calc-slider::-webkit-slider-thumb:hover {
    box-shadow: 0 0 20px rgba(0, 201, 167, 0.7), 0 0 50px rgba(0, 201, 167, 0.25);
  }

  .calc-slider::-moz-range-thumb {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, #10F0C0, #00C9A7);
    box-shadow: 0 0 16px rgba(0, 201, 167, 0.5), 0 0 40px rgba(0, 201, 167, 0.15);
    cursor: pointer;
    border: 3px solid var(--surface-container-low);
  }

  .calc-input-display {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 12px;
  }

  .calc-perimeter-value {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 700;
    color: #00C9A7;
  }

  .calc-unit {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
  }

  .calc-results {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  @media (max-width: 480px) {
    .calc-results { grid-template-columns: 1fr; }
  }

  .calc-result {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: rgba(0, 201, 167, 0.06);
    border: 1px solid rgba(0, 201, 167, 0.1);
    border-radius: 12px;
    transition: border-color 0.4s ease, box-shadow 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .calc-result.value-changed {
    border-color: rgba(0, 201, 167, 0.45);
    box-shadow: 0 0 20px rgba(0, 201, 167, 0.18), 0 0 40px rgba(0, 201, 167, 0.06);
  }

  .calc-result-value {
    font-family: var(--font-headline);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    display: block;
    transition: transform 0.2s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                color 0.15s ease,
                text-shadow 0.3s ease;
  }

  .calc-result-value.animating {
    transform: scale(1.15);
    color: #00C9A7;
    text-shadow: 0 0 12px rgba(0, 201, 167, 0.5), 0 0 24px rgba(0, 201, 167, 0.2);
  }

  .calc-result-label {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    display: block;
  }

  .calc-note {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    line-height: 1.5;
  }

  /* ============================================================
     DAY/NIGHT VISUALIZATION
     ============================================================ */
  .daynight-visual {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
  }

  .daynight-track {
    position: relative;
    display: flex;
    height: 240px;
  }

  .daynight-cycle {
    display: flex;
    width: 100%;
  }

  .dn-segment {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 24px 20px;
    position: relative;
  }

  .day-segment {
    background: linear-gradient(180deg, #1a2a3a 0%, #0d1a26 100%);
    position: relative;
    overflow: hidden;
  }

  /* Warm amber ambient glow for day */
  .day-segment::before {
    content: '';
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 189, 46, 0.15), transparent 70%);
    animation: day-glow-pulse 4s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes day-glow-pulse {
    0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
    50% { opacity: 1; transform: translateX(-50%) scale(1.15); }
  }

  .night-segment {
    background: linear-gradient(180deg, #0a0c14 0%, #050608 100%);
    position: relative;
    overflow: hidden;
  }

  /* Cool blue ambient glow for night */
  .night-segment::before {
    content: '';
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(100, 140, 200, 0.12), transparent 70%);
    animation: night-glow-pulse 5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes night-glow-pulse {
    0%, 100% { opacity: 0.5; transform: translateX(-50%) scale(1); }
    50% { opacity: 0.9; transform: translateX(-50%) scale(1.1); }
  }

  /* Animated mission activity dots */
  .day-segment::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #FFBD2E;
    box-shadow:
      30px 20px 0 rgba(255, 189, 46, 0.4),
      -20px 30px 0 rgba(255, 189, 46, 0.3),
      15px -10px 0 rgba(255, 189, 46, 0.25);
    top: 55%;
    left: 40%;
    animation: mission-dots-day 3s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes mission-dots-day {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }

  .night-segment::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #00C9A7;
    box-shadow:
      25px 15px 0 rgba(0, 201, 167, 0.5),
      -15px 25px 0 rgba(0, 201, 167, 0.35),
      10px -15px 0 rgba(0, 201, 167, 0.3);
    top: 55%;
    left: 45%;
    animation: mission-dots-night 2.5s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes mission-dots-night {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  .dn-sky {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .day-sky .dn-celestial {
    font-size: 36px;
    color: #FFBD2E;
    filter: drop-shadow(0 0 12px rgba(255, 189, 46, 0.4));
    animation: sun-glow 3s ease-in-out infinite;
  }

  @keyframes sun-glow {
    0%, 100% { filter: drop-shadow(0 0 12px rgba(255, 189, 46, 0.4)); }
    50% { filter: drop-shadow(0 0 24px rgba(255, 189, 46, 0.6)) drop-shadow(0 0 48px rgba(255, 189, 46, 0.2)); }
  }

  .night-sky .dn-celestial {
    font-size: 36px;
    color: #B0BEC5;
    filter: drop-shadow(0 0 8px rgba(176, 190, 197, 0.3));
    animation: moon-glow 4s ease-in-out infinite;
  }

  @keyframes moon-glow {
    0%, 100% { filter: drop-shadow(0 0 8px rgba(176, 190, 197, 0.3)); }
    50% { filter: drop-shadow(0 0 16px rgba(176, 190, 197, 0.5)) drop-shadow(0 0 36px rgba(100, 140, 200, 0.15)); }
  }

  .dn-transition {
    width: 2px;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .dn-transition-line {
    width: 2px;
    height: 100%;
    background: linear-gradient(180deg,
      rgba(255, 189, 46, 0.4),
      rgba(255, 189, 46, 0.1) 40%,
      rgba(100, 140, 200, 0.1) 60%,
      rgba(100, 140, 200, 0.4));
    position: relative;
  }

  .dn-transition-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: -4px;
    width: 10px;
    height: 100%;
    background: linear-gradient(180deg,
      rgba(255, 189, 46, 0.08),
      transparent 30%,
      transparent 70%,
      rgba(100, 140, 200, 0.08));
    pointer-events: none;
  }

  .dn-ops {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
  }

  .dn-mission-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: rgba(0, 201, 167, 0.1);
    border: 1px solid rgba(0, 201, 167, 0.15);
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: #00C9A7;
  }

  .dn-mission-tag.night-tag {
    background: rgba(0, 201, 167, 0.15);
    border-color: rgba(0, 201, 167, 0.25);
  }

  .dn-time-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  .dn-cursor {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    z-index: 2;
    pointer-events: none;
  }

  .dn-cursor-line {
    width: 2px;
    height: 100%;
    background: #00C9A7;
    box-shadow: 0 0 8px rgba(0, 201, 167, 0.5);
  }

  .dn-cursor-label {
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #00C9A7;
    background: rgba(0, 0, 0, 0.7);
    padding: 3px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* Ops Stats */
  .ops-stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (min-width: 768px) {
    .ops-stats-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .ops-stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 28px 16px;
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ops-stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #00C9A7, transparent);
    opacity: 0;
    transition: opacity 0.4s ease, width 0.4s ease;
  }

  .ops-stat-card:hover {
    border-color: rgba(0, 201, 167, 0.2);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1), 0 0 20px rgba(0, 201, 167, 0.06);
  }

  .ops-stat-card:hover::before {
    opacity: 1;
    width: 100%;
  }

  .ops-sc-value {
    font-family: var(--font-headline);
    font-size: 2rem;
    font-weight: 700;
    color: #00C9A7;
    line-height: 1;
  }

  .ops-sc-value.counted {
    animation: count-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes count-pop {
    0% { transform: scale(0.6); opacity: 0; }
    60% { transform: scale(1.08); }
    100% { transform: scale(1); opacity: 1; }
  }

  .ops-sc-label {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-secondary);
  }

  /* ============================================================
     INTEGRATION ARCHITECTURE
     ============================================================ */
  .arch-diagram {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 40px 32px;
    overflow: hidden;
    position: relative;
  }

  .arch-diagram::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
  }

  .arch-flow {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    margin-bottom: 32px;
  }

  .arch-flow::-webkit-scrollbar { display: none; }

  .arch-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    min-width: 120px;
    flex: 1;
    position: relative;
    padding: 0 8px;
  }

  .arch-node-icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 201, 167, 0.1);
    border: 1px solid rgba(0, 201, 167, 0.2);
    color: #00C9A7;
    margin-bottom: 12px;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease;
    position: relative;
    animation: arch-node-pulse 3s ease-in-out infinite;
  }

  .arch-node:nth-child(1) .arch-node-icon { animation-delay: 0s; }
  .arch-node:nth-child(2) .arch-node-icon { animation-delay: 0.6s; }
  .arch-node:nth-child(3) .arch-node-icon { animation-delay: 1.2s; }
  .arch-node:nth-child(4) .arch-node-icon { animation-delay: 1.8s; }
  .arch-node:nth-child(5) .arch-node-icon { animation-delay: 2.4s; }

  @keyframes arch-node-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 201, 167, 0); }
    50% { box-shadow: 0 0 16px rgba(0, 201, 167, 0.12), 0 0 4px rgba(0, 201, 167, 0.08); }
  }

  .arch-node:hover .arch-node-icon {
    background: rgba(0, 201, 167, 0.15);
    box-shadow: 0 0 24px rgba(0, 201, 167, 0.25);
    animation: none;
  }

  .arch-node-label {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    display: block;
    margin-bottom: 4px;
  }

  .arch-node-desc {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--text-tertiary);
    letter-spacing: 0.03em;
  }

  .arch-arrow {
    position: absolute;
    top: 20px;
    right: -12px;
    color: rgba(0, 201, 167, 0.3);
    z-index: 1;
  }

  /* Data flow particle animation on connectors */
  .arch-arrow::before {
    content: '';
    position: absolute;
    top: 50%;
    left: -18px;
    width: 36px;
    height: 2px;
    background: rgba(0, 201, 167, 0.08);
    transform: translateY(-50%);
    overflow: hidden;
  }

  .arch-arrow::after {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00C9A7;
    box-shadow: 0 0 8px rgba(0, 201, 167, 0.5);
    animation: arch-particle-flow 2s ease-in-out infinite;
    opacity: 0.6;
  }

  .arch-node:nth-child(1) .arch-arrow::after { animation-delay: 0s; }
