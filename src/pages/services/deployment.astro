---
/*
  TEAM ALPHA — Autonomous Deployment | Jinki Aerial Intelligence

  Redesigned service page with:
  1. Animated flight path SVG hero circling a facility
  2. Autonomous dock station showcase with animated deployment sequence
  3. Interactive coverage calculator
  4. 24/7 day/night cycle visualization
  5. Integration architecture diagram
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';

const dockSpecs = [
  { label: 'Dimensions', value: '1075 x 891 x 525mm', icon: 'straighten' },
  { label: 'Weight', value: '34.5 kg', icon: 'scale' },
  { label: 'Operating Temp', value: '-20 to 50 C', icon: 'device_thermostat' },
  { label: 'IP Rating', value: 'IP55 Weatherproof', icon: 'water_drop' },
  { label: 'Charging', value: '25 min full charge', icon: 'bolt' },
  { label: 'Connectivity', value: '4G LTE + WiFi 6', icon: 'cell_tower' },
];

const deploySequence = [
  { step: 1, label: 'Dock Opens', icon: 'door_open', desc: 'Automated lid opens, platform prepares for launch' },
  { step: 2, label: 'Platform Launches', icon: 'flight_takeoff', desc: 'Vertical takeoff, GPS lock confirmed' },
  { step: 3, label: 'Patrol Active', icon: 'radar', desc: 'Autonomous route execution with real-time telemetry' },
  { step: 4, label: 'Data Captured', icon: 'photo_camera', desc: 'Thermal + visual data streamed to analytics pipeline' },
  { step: 5, label: 'Return & Dock', icon: 'flight_land', desc: 'Precision landing, auto-charging begins' },
];

const integrationNodes = [
  { id: 'dock', label: 'Dock Station', icon: 'home', desc: 'On-site autonomous station' },
  { id: 'platform', label: 'Aerial Platform', icon: 'flight', desc: 'Autonomous capture platform' },
  { id: 'cloud', label: 'Cloud AI', icon: 'cloud', desc: 'Processing & analytics' },
  { id: 'dashboard', label: 'Dashboard', icon: 'dashboard', desc: 'Operations visibility' },
  { id: 'alerts', label: 'Alerts', icon: 'notification_important', desc: 'Real-time notifications' },
];

const capabilities = [
  {
    icon: 'thermostat',
    title: 'Scheduled Thermal Patrols',
    desc: 'Nightly thermal sweeps of every rooftop, mechanical system, and exterior surface. AI anomaly detection triggers alerts before failures escalate.',
  },
  {
    icon: 'security',
    title: 'Event-Triggered Response',
    desc: 'Autonomous launch on alarm activation. The platform reaches the alert zone in under 90 seconds, capturing thermal and visual evidence for your SOC.',
  },
  {
    icon: 'monitor_heart',
    title: 'Asset Health Tracking',
    desc: 'Continuous trend analysis across every data point. Machine learning models predict maintenance needs weeks before they become emergencies.',
  },
  {
    icon: 'construction',
    title: 'Progress Monitoring',
    desc: 'Automated orthomosaic capture and volumetric analysis for construction sites. Daily flyovers keep stakeholders informed without disrupting work zones.',
  },
  {
    icon: 'eco',
    title: 'Environmental Compliance',
    desc: 'Thermal plume monitoring, noise documentation, and visual compliance records on schedule. Automated regulatory reporting generation.',
  },
  {
    icon: 'hub',
    title: 'System Integration',
    desc: 'Intelligence delivered to SCADA, VMS, BMS, and digital twin environments. No new dashboards. No manual data transfers.',
  },
];
---

<Layout ogImage="/images/og-deployment.png" title="Autonomous Deployment — Jinki Aerial Intelligence" description="Persistent autonomous aerial intelligence for facilities that need continuous visibility. On-site autonomous dock station capable of 150-200 missions per month with 24/7 autonomous operation." jsonLd={{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Autonomous Deployment",
  "provider": { "@type": "Organization", "name": "Jinki Aerial Intelligence" },
  "description": "Persistent autonomous aerial monitoring with on-site autonomous dock station capable of 150-200 missions per month with 24/7 operation.",
  "areaServed": "Mid-Atlantic United States",
  "serviceType": "Autonomous Aerial Monitoring",
}}>
  <Nav />
  <Breadcrumb items={[{ label: "Services" }, { label: "Autonomous Deployment" }]} />
  <main id="main-content">

    <!-- ============ HERO — FLIGHT PATH ============ -->
    <section class="deploy-hero" aria-label="Autonomous Deployment">
      <div class="flight-path-bg" aria-hidden="true">
        <!-- Facility outline -->
        <svg class="facility-svg" viewBox="0 0 800 500" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- Grid lines for context -->
          <line x1="200" y1="0" x2="200" y2="500" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"/>
          <line x1="400" y1="0" x2="400" y2="500" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"/>
          <line x1="600" y1="0" x2="600" y2="500" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"/>
          <line x1="0" y1="150" x2="800" y2="150" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"/>
          <line x1="0" y1="250" x2="800" y2="250" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"/>
          <line x1="0" y1="350" x2="800" y2="350" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"/>
          <!-- Facility building -->
          <rect x="300" y="180" width="200" height="140" rx="4" stroke="rgba(0, 201, 167, 0.3)" stroke-width="1.5" fill="rgba(0, 201, 167, 0.12)"/>
          <rect x="320" y="200" width="60" height="40" rx="2" stroke="rgba(0, 201, 167, 0.3)" stroke-width="1" fill="rgba(0, 201, 167, 0.06)"/>
          <rect x="420" y="200" width="60" height="40" rx="2" stroke="rgba(0, 201, 167, 0.3)" stroke-width="1" fill="rgba(0, 201, 167, 0.06)"/>
          <rect x="320" y="260" width="60" height="40" rx="2" stroke="rgba(0, 201, 167, 0.3)" stroke-width="1" fill="rgba(0, 201, 167, 0.06)"/>
          <rect x="420" y="260" width="60" height="40" rx="2" stroke="rgba(0, 201, 167, 0.3)" stroke-width="1" fill="rgba(0, 201, 167, 0.06)"/>
          <!-- Building labels -->
          <text x="350" y="224" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.25)" text-anchor="middle">B1</text>
          <text x="450" y="224" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.25)" text-anchor="middle">B2</text>
          <text x="350" y="284" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.25)" text-anchor="middle">B3</text>
          <text x="450" y="284" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.25)" text-anchor="middle">B4</text>
          <!-- Perimeter -->
          <rect x="200" y="100" width="400" height="300" rx="8" stroke="rgba(0, 201, 167, 0.15)" stroke-width="1" stroke-dasharray="8 4" fill="none"/>
          <text x="400" y="92" font-family="monospace" font-size="8" fill="rgba(0, 201, 167, 0.2)" text-anchor="middle" letter-spacing="2">PERIMETER</text>
          <!-- Coverage radius circle -->
          <circle cx="400" cy="250" r="180" stroke="rgba(0, 201, 167, 0.06)" stroke-width="1" stroke-dasharray="3 6" fill="none"/>
          <circle cx="400" cy="250" r="120" stroke="rgba(0, 201, 167, 0.12)" stroke-width="1" stroke-dasharray="3 6" fill="none"/>
          <!-- Dock position -->
          <rect x="220" y="360" width="30" height="20" rx="4" fill="rgba(0, 201, 167, 0.2)" stroke="rgba(0, 201, 167, 0.5)" stroke-width="1.5"/>
          <text x="235" y="395" font-family="monospace" font-size="9" fill="rgba(0, 201, 167, 0.45)" text-anchor="middle" font-weight="bold">DOCK 3</text>
          <!-- Scan zones -->
          <circle cx="350" cy="220" r="8" fill="none" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5"><animate attributeName="r" values="8;16;8" dur="3s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.5;0;0.5" dur="3s" repeatCount="indefinite"/></circle>
          <circle cx="450" cy="280" r="8" fill="none" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5"><animate attributeName="r" values="8;16;8" dur="3s" begin="1s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.5;0;0.5" dur="3s" begin="1s" repeatCount="indefinite"/></circle>
          <circle cx="350" cy="280" r="6" fill="none" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"><animate attributeName="r" values="6;14;6" dur="3s" begin="2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.4;0;0.4" dur="3s" begin="2s" repeatCount="indefinite"/></circle>
          <circle cx="450" cy="220" r="6" fill="none" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5"><animate attributeName="r" values="6;14;6" dur="3s" begin="0.5s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.4;0;0.4" dur="3s" begin="0.5s" repeatCount="indefinite"/></circle>
          <!-- Flight path with animated stroke -->
          <path d="M235,360 L235,120 L580,120 L580,380 L220,380 L220,200 L400,200" stroke="rgba(0, 201, 167, 0.15)" stroke-width="1.5" stroke-dasharray="6 3" fill="none"/>
          <path d="M235,360 L235,120 L580,120 L580,380 L220,380 L220,200 L400,200" stroke="rgba(0, 201, 167, 0.4)" stroke-width="1.5" stroke-dasharray="12 1800" fill="none">
            <animate attributeName="stroke-dashoffset" values="0;-1800" dur="12s" repeatCount="indefinite"/>
          </path>
          <!-- Data uplink beam from dock -->
          <line x1="235" y1="355" x2="235" y2="330" stroke="rgba(0, 201, 167, 0.15)" stroke-width="1">
            <animate attributeName="y2" values="355;320;355" dur="2s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0;0.4;0" dur="2s" repeatCount="indefinite"/>
          </line>
          <!-- Animated platform dot -->
          <circle r="6" fill="#00C9A7" opacity="1" filter="url(#glow)">
            <animateMotion dur="12s" repeatCount="indefinite" path="M235,360 L235,120 L580,120 L580,380 L220,380 L220,200 L400,200 L235,360"/>
          </circle>
          <circle r="14" fill="none" stroke="#00C9A7" opacity="0.4">
            <animateMotion dur="12s" repeatCount="indefinite" path="M235,360 L235,120 L580,120 L580,380 L220,380 L220,200 L400,200 L235,360"/>
            <animate attributeName="r" values="10;20;10" dur="2s" repeatCount="indefinite"/>
            <animate attributeName="opacity" values="0.4;0.1;0.4" dur="2s" repeatCount="indefinite"/>
          </circle>
          <!-- Waypoints with pulse rings + scale pulse -->
          <g class="waypoint-group">
            <circle cx="235" cy="120" r="4" fill="rgba(0, 201, 167, 0.35)" stroke="rgba(0, 201, 167, 0.6)" stroke-width="1">
              <animate attributeName="r" values="4;5.5;4" dur="2s" repeatCount="indefinite"/>
            </circle>
            <circle cx="235" cy="120" r="4" fill="none" stroke="rgba(0, 201, 167, 0.3)" stroke-width="0.5">
              <animate attributeName="r" values="4;14;4" dur="3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0;0.5" dur="3s" repeatCount="indefinite"/>
            </circle>
            <circle cx="235" cy="120" r="7" fill="none" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5">
              <animate attributeName="r" values="7;18;7" dur="3s" begin="0.3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.3;0;0.3" dur="3s" begin="0.3s" repeatCount="indefinite"/>
            </circle>
          </g>
          <g class="waypoint-group">
            <circle cx="580" cy="120" r="4" fill="rgba(0, 201, 167, 0.35)" stroke="rgba(0, 201, 167, 0.6)" stroke-width="1">
              <animate attributeName="r" values="4;5.5;4" dur="2s" begin="0.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="580" cy="120" r="4" fill="none" stroke="rgba(0, 201, 167, 0.3)" stroke-width="0.5">
              <animate attributeName="r" values="4;14;4" dur="3s" begin="0.75s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0;0.5" dur="3s" begin="0.75s" repeatCount="indefinite"/>
            </circle>
            <circle cx="580" cy="120" r="7" fill="none" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5">
              <animate attributeName="r" values="7;18;7" dur="3s" begin="1.05s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.3;0;0.3" dur="3s" begin="1.05s" repeatCount="indefinite"/>
            </circle>
          </g>
          <g class="waypoint-group">
            <circle cx="580" cy="380" r="4" fill="rgba(0, 201, 167, 0.35)" stroke="rgba(0, 201, 167, 0.6)" stroke-width="1">
              <animate attributeName="r" values="4;5.5;4" dur="2s" begin="1s" repeatCount="indefinite"/>
            </circle>
            <circle cx="580" cy="380" r="4" fill="none" stroke="rgba(0, 201, 167, 0.3)" stroke-width="0.5">
              <animate attributeName="r" values="4;14;4" dur="3s" begin="1.5s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0;0.5" dur="3s" begin="1.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="580" cy="380" r="7" fill="none" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5">
              <animate attributeName="r" values="7;18;7" dur="3s" begin="1.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.3;0;0.3" dur="3s" begin="1.8s" repeatCount="indefinite"/>
            </circle>
          </g>
          <g class="waypoint-group">
            <circle cx="220" cy="380" r="4" fill="rgba(0, 201, 167, 0.35)" stroke="rgba(0, 201, 167, 0.6)" stroke-width="1">
              <animate attributeName="r" values="4;5.5;4" dur="2s" begin="1.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="220" cy="380" r="4" fill="none" stroke="rgba(0, 201, 167, 0.3)" stroke-width="0.5">
              <animate attributeName="r" values="4;14;4" dur="3s" begin="2.25s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.5;0;0.5" dur="3s" begin="2.25s" repeatCount="indefinite"/>
            </circle>
            <circle cx="220" cy="380" r="7" fill="none" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5">
              <animate attributeName="r" values="7;18;7" dur="3s" begin="2.55s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.3;0;0.3" dur="3s" begin="2.55s" repeatCount="indefinite"/>
            </circle>
          </g>
          <!-- Waypoint labels -->
          <text x="235" y="112" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.3)" text-anchor="middle">WP1</text>
          <text x="580" y="112" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.3)" text-anchor="middle">WP2</text>
          <text x="592" y="385" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.3)" text-anchor="middle">WP3</text>
          <text x="208" y="375" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.3)" text-anchor="middle">WP4</text>
          <!-- Telemetry data overlay -->
          <text x="610" y="250" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.18)" text-anchor="start">ALT: 120m</text>
          <text x="610" y="262" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.18)" text-anchor="start">SPD: 8.2m/s</text>
          <text x="610" y="274" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.18)" text-anchor="start">BAT: 78%
            <animate attributeName="fill" values="rgba(0,201,167,0.18);rgba(0,201,167,0.35);rgba(0,201,167,0.18)" dur="4s" repeatCount="indefinite"/>
          </text>
          <!-- Status HUD -->
          <g opacity="0.6">
            <rect x="15" y="15" width="90" height="22" rx="4" fill="rgba(0, 201, 167, 0.08)" stroke="rgba(0, 201, 167, 0.2)" stroke-width="0.5"/>
            <circle cx="28" cy="26" r="6" fill="none" stroke="#00C9A7" opacity="0.15">
              <animate attributeName="r" values="5;9;5" dur="2.5s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0.2;0;0.2" dur="2.5s" repeatCount="indefinite"/>
            </circle>
            <circle cx="28" cy="26" r="3" fill="#00C9A7">
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
              <animate attributeName="r" values="3;3.8;3" dur="2s" repeatCount="indefinite"/>
            </circle>
            <text x="36" y="29" font-family="monospace" font-size="8" fill="rgba(0, 201, 167, 0.6)" font-weight="bold" letter-spacing="1">LIVE</text>
            <text x="66" y="29" font-family="monospace" font-size="7" fill="rgba(0, 201, 167, 0.35)">M-147</text>
          </g>
          <!-- Mission counter HUD -->
          <g opacity="0.5">
            <rect x="645" y="440" width="140" height="42" rx="4" fill="rgba(0, 201, 167, 0.05)" stroke="rgba(0, 201, 167, 0.15)" stroke-width="0.5"/>
            <text x="660" y="455" font-family="monospace" font-size="6" fill="rgba(0, 201, 167, 0.4)" letter-spacing="1">MISSIONS TODAY</text>
            <text x="660" y="473" font-family="monospace" font-size="14" fill="rgba(0, 201, 167, 0.7)" font-weight="bold">12 / 12</text>
            <rect x="730" y="462" width="40" height="4" rx="2" fill="rgba(0, 201, 167, 0.1)"/>
            <rect x="730" y="462" width="40" height="4" rx="2" fill="rgba(0, 201, 167, 0.4)"/>
          </g>
          <!-- Glow filter -->
          <defs>
            <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
        </svg>
      </div>

      <div class="hero-inner">
        <div class="hero-content reveal">
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">Autonomous Deployment</span>
          </div>
          <h1 class="hero-title">
            Persistent Intelligence.<br/>
            <span class="gradient-text-teal">Zero Intervention.</span>
          </h1>
          <p class="hero-subtitle">
            For facilities that need continuous visibility, not periodic snapshots.
            Jinki stations an autonomous aerial platform on your site that launches,
            captures, analyzes, and delivers intelligence — 150 to 200 missions per
            month, around the clock, with no operator required.
          </p>
          <div class="hero-actions">
            <a href="#lead-gen" class="btn-premium hero-cta">Get Your Facility Report</a>
            <a href="#dock" class="hero-cta-secondary">
              <span class="material-symbols-outlined" style="font-size: 18px; font-variation-settings: 'FILL' 1;" aria-hidden="true">arrow_downward</span>
              Explore the Platform
            </a>
          </div>
        </div>
        <div class="hero-stats-bar reveal reveal-delay-1">
          <div class="hero-stat">
            <span class="hero-stat-value">150-200</span>
            <span class="hero-stat-label">Missions / Month</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">24/7</span>
            <span class="hero-stat-label">Autonomous Operation</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">IR</span>
            <span class="hero-stat-label">Thermal + Visual</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat">
            <span class="hero-stat-value">&lt;90s</span>
            <span class="hero-stat-label">Dock-to-Airborne</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ DOCK 3 SHOWCASE ============ -->
    <section id="dock" class="section" style="background: var(--surface-dim);" aria-label="Autonomous Dock Station">
      <div class="section-inner">
        <div class="section-header reveal">
          <div class="eyebrow">
            <span class="eyebrow-line"></span>
            <span class="eyebrow-text">The Platform</span>
          </div>
          <h2>Autonomous Dock +<br/>Aerial Platform</h2>
          <p class="section-subtitle">
            A permanent on-site installation that launches, operates, and recovers
            aerial systems without human intervention. All-weather. All-hours.
          </p>
        </div>

        <!-- Deployment Sequence Animation -->
        <div class="sequence-strip reveal">
          <div class="sequence-label">DEPLOYMENT SEQUENCE</div>
          <div class="sequence-steps">
            {deploySequence.map((seq) => (
              <div class="seq-step" data-seq={seq.step}>
                <div class="seq-icon-wrap">
                  <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 28px;" aria-hidden="true">{seq.icon}</span>
                </div>
                <div class="seq-connector" aria-hidden="true">
                  <div class="seq-connector-fill"></div>
                </div>
                <span class="seq-step-label">{seq.label}</span>
                <span class="seq-step-desc">{seq.desc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Specs Grid -->
        <div class="specs-grid" style="margin-top: 48px;">
          {dockSpecs.map((spec, i) => (
            <div class={`spec-card reveal reveal-delay-${(i % 3) + 1}`}>
              <span class="material-symbols-outlined spec-card-icon" style="font-variation-settings: 'FILL' 1;" aria-hidden="true">{spec.icon}</span>
              <div class="spec-card-content">
                <span class="spec-card-value">{spec.value}</span>
                <span class="spec-card-label">{spec.label}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ COVERAGE CALCULATOR ============ -->
    <section class="section" aria-label="Coverage Calculator">
      <div class="section-inner">
        <div class="calc-layout">
          <div class="calc-text reveal">
            <div class="eyebrow">
              <span class="eyebrow-line"></span>
              <span class="eyebrow-text">Coverage Calculator</span>
            </div>
            <h2>Size Your<br/>Deployment</h2>
            <p class="calc-lead">
              Enter your facility perimeter to estimate missions per month,
              coverage percentage, and typical response time. Results are based
              on standard autonomous dock operating parameters.
            </p>
          </div>
          <div class="calc-card reveal reveal-delay-2">
            <div class="calc-card-inner">
              <div class="calc-perimeter-viz" aria-hidden="true">
                <svg viewBox="0 0 120 120" class="calc-perimeter-svg">
                  <circle cx="60" cy="60" r="50" fill="none" stroke="rgba(0, 201, 167, 0.06)" stroke-width="1" stroke-dasharray="4 3"/>
                  <circle cx="60" cy="60" r="35" fill="none" stroke="rgba(0, 201, 167, 0.12)" stroke-width="0.5" stroke-dasharray="3 4"/>
                  <circle cx="60" cy="60" id="calc-perimeter-ring" fill="none" stroke="#00C9A7" stroke-width="1.5" stroke-dasharray="6 3" opacity="0.3" r="20"/>
                  <circle cx="60" cy="60" id="calc-perimeter-glow" fill="none" stroke="#00C9A7" stroke-width="4" stroke-dasharray="6 3" opacity="0.06" r="20" filter="url(#calc-glow)"/>
