<script>
  // Coverage Calculator
  const slider = document.getElementById('perimeter-input') as HTMLInputElement;
  const perimeterDisplay = document.getElementById('perimeter-display');
  const missionsResult = document.getElementById('missions-result');
  const coverageResult = document.getElementById('coverage-result');
  const responseResult = document.getElementById('response-result');

  const perimeterRing = document.getElementById('calc-perimeter-ring');
  const perimeterGlow = document.getElementById('calc-perimeter-glow');
  const calcResults = document.querySelectorAll('.calc-result');
  const calcValues = document.querySelectorAll('.calc-result-value');

  function animateValueChange() {
    calcResults.forEach(r => {
      r.classList.add('value-changed');
      setTimeout(() => r.classList.remove('value-changed'), 400);
    });
    calcValues.forEach(v => {
      v.classList.add('animating');
      setTimeout(() => v.classList.remove('animating'), 200);
    });
  }

  function updateCalculator() {
    if (!slider || !perimeterDisplay || !missionsResult || !coverageResult || !responseResult) return;
    const perimeter = parseInt(slider.value);
    perimeterDisplay.textContent = perimeter.toLocaleString();

    // Missions: base 200 for small, scales down as perimeter grows (longer routes = fewer missions)
    const missions = Math.round(200 - (perimeter - 500) * 0.005);
    const clampedMissions = Math.max(150, Math.min(200, missions));
    missionsResult.textContent = String(clampedMissions);

    // Coverage: 99% for small, decreasing slightly for very large
    const coverage = Math.max(92, Math.round(99 - (perimeter - 500) * 0.0008));
    coverageResult.textContent = coverage + '%';

    // Response time: increases with perimeter
    const response = Math.round(45 + (perimeter / 200));
    responseResult.textContent = response + 's';

    // Animate value pop
    animateValueChange();

    // Scale perimeter visualization ring (20-48 based on slider)
    const ringR = 20 + ((perimeter - 500) / 9500) * 28;
    if (perimeterRing) perimeterRing.setAttribute('r', String(ringR));
    if (perimeterGlow) perimeterGlow.setAttribute('r', String(ringR));
  }

  if (slider) {
    slider.addEventListener('input', updateCalculator);
    updateCalculator();
  }

  // Deployment sequence animation
  const sequenceSteps = document.querySelectorAll('.seq-step');
  let currentSeq = 0;

  function animateSequence() {
    sequenceSteps.forEach((step, i) => {
      step.classList.toggle('active', i <= currentSeq);
    });
    currentSeq = (currentSeq + 1) % sequenceSteps.length;
  }

  if (sequenceSteps.length > 0) {
    animateSequence();
    setInterval(animateSequence, 2000);
  }

  // Ops stats count-up animation on scroll reveal
  const opsValues = document.querySelectorAll('.ops-sc-value');
  const opsGrid = document.querySelector('.ops-stats-grid');
  let opsAnimated = false;

  function animateCountUp() {
    if (opsAnimated) return;
    opsAnimated = true;
    opsValues.forEach((el, i) => {
      const htmlEl = el as HTMLElement;
      const finalText = htmlEl.textContent || '';
      htmlEl.style.opacity = '0';
      setTimeout(() => {
        htmlEl.style.opacity = '1';
        htmlEl.classList.add('counted');
        htmlEl.addEventListener('animationend', () => htmlEl.classList.remove('counted'), { once: true });
      }, i * 150);
    });
  }

  if (opsGrid) {
    const opsObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCountUp();
          opsObs.disconnect();
        }
      });
    }, { threshold: 0.3 });
    opsObs.observe(opsGrid);
  }

  // Day/Night cursor animation
  const dnCursor = document.querySelector('.dn-cursor') as HTMLElement;
  if (dnCursor) {
    let cursorPos = 0;
    function moveCursor() {
      cursorPos = (cursorPos + 0.15) % 100;
      dnCursor.style.left = cursorPos + '%';
      requestAnimationFrame(moveCursor);
    }
    moveCursor();
  }
</script>

