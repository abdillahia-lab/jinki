    transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)), transform 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
