    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }

  .wheel-center-icon {
    color: var(--accent);
    font-size: 28px;
  }

  .wheel-center-step {
    font-family: var(--font-mono);
