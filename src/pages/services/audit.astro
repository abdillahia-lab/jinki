    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .wheel-center-title {
    font-family: var(--font-headline);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-primary);
    max-width: 100px;
    line-height: 1.2;
  }

  .wheel-node {
    position: absolute;
    width: 72px;
    height: 72px;
    margin-left: -36px;
    margin-top: -36px;
    border-radius: 50%;
