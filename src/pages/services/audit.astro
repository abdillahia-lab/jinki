                      </div>
                      <div class="report-panel-right" aria-hidden="true">
                        {tab.id === 'executive' && (
                          <div class="report-viz report-viz-score">
                            <div class="health-ring">
                              <svg viewBox="0 0 100 100">
                                <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="8" />
                                <circle cx="50" cy="50" r="42" fill="none" stroke="url(#scoreGrad)" stroke-width="8" stroke-dasharray="198 264" stroke-linecap="round" transform="rotate(-90 50 50)" class="health-ring-fill" />
                                <defs><linearGradient id="scoreGrad"><stop offset="0%" stop-color="#00E5FF" /><stop offset="100%" stop-color="#27C93F" /></linearGradient></defs>
                              </svg>
                              <div class="health-ring-label">
                                <span class="health-score">B+</span>
                                <span class="health-text">Health</span>
                              </div>
                            </div>
                            <div class="severity-breakdown">
                              <div class="severity-row"><span class="sev-dot" style="background:#FF3B30;"></span><span class="sev-label">Critical</span><span class="sev-count">2</span></div>
                              <div class="severity-row"><span class="sev-dot" style="background:#FF6B35;"></span><span class="sev-label">High</span><span class="sev-count">5</span></div>
                              <div class="severity-row"><span class="sev-dot" style="background:#FFBD2E;"></span><span class="sev-label">Medium</span><span class="sev-count">8</span></div>
                              <div class="severity-row"><span class="sev-dot" style="background:#00E5FF;"></span><span class="sev-label">Low</span><span class="sev-count">12</span></div>
                            </div>
                          </div>
                        )}
                        {tab.id === 'thermal' && (
                          <div class="report-viz report-viz-thermal">
                            <div class="mini-thermal-map">
                              <div class="mt-row"><div class="mt-c" style="background:#1a237e;"></div><div class="mt-c" style="background:#1565c0;"></div><div class="mt-c" style="background:#1565c0;"></div><div class="mt-c" style="background:#2e7d32;"></div><div class="mt-c" style="background:#f57c00;"></div><div class="mt-c" style="background:#e65100;"></div></div>
                              <div class="mt-row"><div class="mt-c" style="background:#1a237e;"></div><div class="mt-c" style="background:#1565c0;"></div><div class="mt-c" style="background:#2e7d32;"></div><div class="mt-c" style="background:#f57c00;"></div><div class="mt-c" style="background:#d84315;"></div><div class="mt-c" style="background:#ff1744;"></div></div>
                              <div class="mt-row"><div class="mt-c" style="background:#1565c0;"></div><div class="mt-c" style="background:#2e7d32;"></div><div class="mt-c" style="background:#f57c00;"></div><div class="mt-c" style="background:#d84315;"></div><div class="mt-c" style="background:#ff1744;"></div><div class="mt-c" style="background:#d84315;"></div></div>
                              <div class="mt-row"><div class="mt-c" style="background:#1a237e;"></div><div class="mt-c" style="background:#1a237e;"></div><div class="mt-c" style="background:#2e7d32;"></div><div class="mt-c" style="background:#f57c00;"></div><div class="mt-c" style="background:#d84315;"></div><div class="mt-c" style="background:#f57c00;"></div></div>
                            </div>
                            <div class="thermal-scale">
                              <div class="thermal-scale-bar"></div>
                              <div class="thermal-scale-labels"><span>18°C</span><span>42°C</span></div>
                            </div>
                          </div>
                        )}
                        {tab.id === 'structural' && (
                          <div class="report-viz report-viz-structural">
                            <div class="condition-bars">
                              <div class="cond-item"><span class="cond-label">Roof A</span><div class="cond-track"><div class="cond-fill" style="width:92%;background:linear-gradient(90deg,#27C93F,#2e7d32);"></div></div><span class="cond-val">A</span></div>
                              <div class="cond-item"><span class="cond-label">Roof B</span><div class="cond-track"><div class="cond-fill" style="width:68%;background:linear-gradient(90deg,#FFBD2E,#f57c00);"></div></div><span class="cond-val">C+</span></div>
                              <div class="cond-item"><span class="cond-label">Roof C</span><div class="cond-track"><div class="cond-fill" style="width:35%;background:linear-gradient(90deg,#FF6B35,#FF3B30);"></div></div><span class="cond-val">D+</span></div>
                              <div class="cond-item"><span class="cond-label">Facade</span><div class="cond-track"><div class="cond-fill" style="width:85%;background:linear-gradient(90deg,#27C93F,#2e7d32);"></div></div><span class="cond-val">B+</span></div>
                            </div>
                          </div>
                        )}
                        {tab.id === 'security' && (
                          <div class="report-viz report-viz-security">
                            <div class="coverage-stat">
                              <span class="coverage-pct">73%</span>
                              <span class="coverage-label">Perimeter Covered</span>
                            </div>
                            <div class="gap-list">
                              <div class="gap-item"><span class="gap-dot" style="background:#FF3B30;"></span>NE Gate — No coverage</div>
                              <div class="gap-item"><span class="gap-dot" style="background:#FFBD2E;"></span>Loading dock — Partial</div>
                              <div class="gap-item"><span class="gap-dot" style="background:#FFBD2E;"></span>South fence — Low-light</div>
                            </div>
                          </div>
                        )}
                        {tab.id === 'compliance' && (
                          <div class="report-viz report-viz-compliance">
                            <div class="compliance-checks">
                              <div class="comp-row"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:16px;color:#27C93F;">check_circle</span><span>ASHRAE Temp Verification</span></div>
                              <div class="comp-row"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:16px;color:#27C93F;">check_circle</span><span>Environmental Records</span></div>
                              <div class="comp-row"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:16px;color:#27C93F;">check_circle</span><span>Inspection Certificates</span></div>
                              <div class="comp-row"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:16px;color:#FFBD2E;">pending</span><span>NFPA 70B Status</span></div>
                              <div class="comp-row"><span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1;font-size:16px;color:#27C93F;">check_circle</span><span>Full Audit Trail</span></div>
                            </div>
                          </div>
                        )}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <LeadGen />
  </main>
  <Footer />
</Layout>

<style>
  /* ================ HERO ================ */
  .omega-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 140px clamp(20px, 5vw, 80px) 60px;
    background: var(--surface-container-lowest);
    position: relative;
    overflow: hidden;
  }

  .omega-hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
