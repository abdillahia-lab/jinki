</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ====== Process Wheel Interaction ======
    const wheelNodes = document.querySelectorAll('.wheel-node');
    const wheelIcon = document.getElementById('wheel-icon');
    const wheelStep = document.getElementById('wheel-step');
    const wheelTitle = document.getElementById('wheel-title');
    const wheelDesc = document.getElementById('wheel-desc');

    wheelNodes.forEach(node => {
      node.addEventListener('click', () => {
        wheelNodes.forEach(n => {
          n.classList.remove('active');
          n.setAttribute('aria-selected', 'false');
        });
        node.classList.add('active');
        node.setAttribute('aria-selected', 'true');

        if (wheelIcon) wheelIcon.textContent = node.dataset.icon || '';
        if (wheelStep) wheelStep.textContent = node.dataset.num || '';
        if (wheelTitle) wheelTitle.textContent = node.dataset.title || '';
        if (wheelDesc) {
          wheelDesc.style.opacity = '0';
          setTimeout(() => {
            wheelDesc.textContent = node.dataset.desc || '';
            wheelDesc.style.opacity = '1';
          }, 150);
        }
      });
    });

    // ====== Report Tabs ======
    const reportTabs = document.querySelectorAll('.report-tab');
    const reportPanels = document.querySelectorAll('.report-panel');

    reportTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        reportTabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        reportPanels.forEach(p => p.classList.remove('active'));

        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panel = document.getElementById(`report-panel-${target}`);
        if (panel) panel.classList.add('active');
      });
    });

    // ====== Findings Carousel (mobile) ======
    const carousel = document.getElementById('findings-carousel');
    const prevBtn = document.getElementById('findings-prev');
    const nextBtn = document.getElementById('findings-next');
    const dots = document.querySelectorAll('.findings-dot');
    let currentSlide = 0;
    const totalSlides = dots.length;

    function updateCarousel() {
      if (!carousel) return;
      const cards = carousel.querySelectorAll('.finding-card');
      if (window.innerWidth >= 1024) return;

      cards.forEach((card, i) => {
        const el = /** @type {HTMLElement} */ (card);
        if (window.innerWidth >= 600) {
          el.style.display = (i === currentSlide || i === currentSlide + 1) ? 'block' : 'none';
        } else {
          el.style.display = i === currentSlide ? 'block' : 'none';
        }
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentSlide);
      });
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        updateCarousel();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentSlide = (currentSlide + 1) % totalSlides;
        updateCarousel();
      });
    }

    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        currentSlide = parseInt(dot.dataset.slide || '0', 10);
        updateCarousel();
      });
    });

    // Reset on resize
    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const cards = carousel?.querySelectorAll('.finding-card');
        if (window.innerWidth >= 1024 && cards) {
          cards.forEach(card => {
            /** @type {HTMLElement} */ (card).style.display = '';
          });
        } else {
          updateCarousel();
        }
      }, 250);
    });
  });
</script>
