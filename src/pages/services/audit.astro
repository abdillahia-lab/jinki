    max-width: 640px;
    margin-top: 16px;
  }

  /* ================ PROCESS WHEEL ================ */
  .process-wheel-container {
    position: relative;
  }

  .process-wheel {
    display: none;
    position: relative;
    width: 480px;
    height: 480px;
    margin: 0 auto 40px;
  }

  @media (min-width: 768px) {
    .process-wheel { display: block; }
    .process-mobile-list { display: none !important; }
  }

  .wheel-ring-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .wheel-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 140px;
    height: 140px;
    border-radius: 50%;
