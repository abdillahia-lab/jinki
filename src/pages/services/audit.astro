    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }

  .omega-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .omega-eyebrow-line {
    display: block;
    width: 32px;
    height: 1px;
