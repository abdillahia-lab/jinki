  }

  .omega-hero-title {
    font-family: var(--font-headline);
    font-size: clamp(2rem, 4vw + 0.5rem, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .gradient-text-cyan {
    background: linear-gradient(135deg, #00E5FF, #00a8b5);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .omega-hero-subtitle {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.2vw + 0.5rem, 1.125rem);
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 540px;
    margin-bottom: 32px;
  }

  .omega-hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .omega-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.875rem 2rem;
    border-radius: 12px;
    color: #fff;
    text-decoration: none;
  }

  .omega-cta-secondary {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .omega-cta-secondary:hover { color: var(--accent); }

  /* Mission Briefing Card */
  .mission-briefing-card {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #0a0c10, #141820);
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
    box-shadow: var(--glass-shadow);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mission-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  .countdown-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
  }

  .countdown-svg {
    width: 100%;
    height: 100%;
    animation: countdown-rotate 12s linear infinite;
  }

  .countdown-progress {
    transform-origin: center;
    animation: countdown-dash 6s ease-in-out infinite alternate;
  }

  @keyframes countdown-rotate {
    from { transform: rotate(-90deg); }
    to { transform: rotate(270deg); }
  }

  @keyframes countdown-dash {
    0% { stroke-dashoffset: 200; }
    100% { stroke-dashoffset: 20; }
  }

  .mission-center-icon {
    position: relative;
    z-index: 2;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: glow-pulse 4s ease-in-out infinite;
  }

  .mission-stat-badge {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(8px);
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid rgba(0, 229, 255, 0.12);
    z-index: 2;
  }

  .badge-tl { top: 16px; left: 16px; }
  .badge-tr { top: 16px; right: 16px; }
  .badge-bl { bottom: 16px; left: 16px; }
  .badge-br { bottom: 16px; right: 16px; }

  .mission-stat-label {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .mission-stat-val {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .status-ready {
    color: #27C93F;
  }

  .mission-scan-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.3;
    animation: scan-move 5s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes scan-move {
    0%, 100% { top: 10%; }
    50% { top: 90%; }
  }

  /* ================ SECTIONS ================ */
  .omega-section {
    padding: 5rem clamp(20px, 5vw, 80px);
  }

  @media (min-width: 768px) {
    .omega-section { padding: 7rem clamp(20px, 5vw, 80px); }
