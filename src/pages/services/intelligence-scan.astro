---
/*
  TEAM OMEGA — Facility Intelligence Scan | Jinki Aerial Intelligence
  Redesigned: cinematic mission-briefing aesthetic with interactive process wheel,
  findings gallery, comparison, and tabbed deliverable preview.
*/
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import LeadGen from '../../components/LeadGen.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';

const process = [
  { step: '01', title: 'Scoping Call', desc: 'We learn your facility, your priorities, and your pain points. A real conversation about what matters to your operations team.', icon: 'call' },
  { step: '02', title: 'Flight Planning', desc: 'Airspace authorization, safety planning, and mission design tailored to your site geometry and inspection requirements.', icon: 'flight_takeoff' },
  { step: '03', title: 'Data Capture', desc: 'On-site aerial operations. Thermal and high-resolution visual data across every structure — typically completed in a single day.', icon: 'satellite_alt' },
  { step: '04', title: 'AI Analysis', desc: 'Our analytics pipeline processes thousands of data points: anomaly detection, severity classification, and automated damage assessment.', icon: 'model_training' },
  { step: '05', title: 'Report', desc: 'The Facility Intelligence Report: severity-ranked findings, remediation priorities, cost estimates, and suggested timelines.', icon: 'assignment' },
  { step: '06', title: 'Review & Handoff', desc: 'We walk your team through every finding. Questions answered, priorities confirmed, and a clear path forward.', icon: 'groups' },
];

const findings = [
  { type: 'CRITICAL', label: 'Cooling Unit Thermal Anomaly', category: 'Thermal', color: '#FF3B30', img: 'thermostat' },
  { type: 'HIGH', label: 'Roof Membrane Degradation', category: 'Structural', color: '#FF6B35', img: 'roofing' },
  { type: 'MEDIUM', label: 'Camera Blind Spot — NE Gate', category: 'Security', color: '#FFBD2E', img: 'security' },
  { type: 'LOW', label: 'Insulation Gap — Mech Room 2', category: 'Efficiency', color: '#00E5FF', img: 'electric_bolt' },
];

const reportTabs = [
  { id: 'executive', label: 'Executive Summary', icon: 'summarize', content: 'High-level facility health score, total findings by severity, estimated remediation budget, and recommended priority actions for leadership review.' },
  { id: 'thermal', label: 'Thermal Analysis', icon: 'thermostat', content: 'Complete thermal mapping with anomaly locations, delta-T measurements, equipment identification, and NFPA 70B compliance status for every inspected system.' },
  { id: 'structural', label: 'Structural Report', icon: 'roofing', content: 'AI-classified damage assessment with visual evidence, area measurements, degradation ratings, and projected repair costs for every roof section and exterior surface.' },
  { id: 'security', label: 'Security Evaluation', icon: 'security', content: 'Perimeter coverage analysis, camera blind spot mapping, lighting gap identification, and access vulnerability documentation with remediation recommendations.' },
  { id: 'compliance', label: 'Compliance Package', icon: 'verified', content: 'Regulatory-ready documentation including ASHRAE temperature verification, environmental records, inspection certificates, and audit trail for every data point collected.' },
];
---

<Layout ogImage="/images/og-audit.png" title="Facility Intelligence Scan — Jinki Aerial Intelligence" description="Comprehensive aerial assessment of your facility. One mission. One report. Clear next steps." jsonLd={{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Facility Intelligence Scan",
  "provider": { "@type": "Organization", "name": "Jinki Aerial Intelligence" },
  "description": "Comprehensive aerial thermal and visual assessment of facility infrastructure with prioritized intelligence report delivered within 48 hours.",
  "areaServed": "Mid-Atlantic United States",
  "serviceType": "Aerial Infrastructure Inspection",
}}>
  <Nav />
  <Breadcrumb items={[{ label: "Services" }, { label: "Facility Intelligence Scan" }]} />
  <main id="main-content">

    <!-- ============ HERO — Mission Briefing ============ -->
    <section class="omega-hero" aria-label="Facility Intelligence Scan">
      <div class="omega-hero-inner">
        <div class="omega-hero-content reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">Mission Briefing</span>
          </div>
          <h1 class="omega-hero-title">
            One Mission.<br/>
            <span class="gradient-text-cyan">Total Facility Intelligence.</span>
          </h1>
          <p class="omega-hero-subtitle">
            Jinki's Facility Intelligence Scan combines thermal diagnostics, structural assessment,
            and security evaluation into a single engagement. You receive a prioritized recommendations
            report — not raw data. Clear findings. Clear next steps.
          </p>
          <div class="omega-hero-actions">
            <a href="#lead-gen" class="btn-premium omega-cta">Request Assessment</a>
            <a href="#process-wheel" class="omega-cta-secondary">See the Process</a>
          </div>
        </div>
        <div class="omega-hero-visual reveal reveal-delay-1" aria-hidden="true">
          <div class="scan-interface">
            <!-- Top toolbar -->
            <div class="si-toolbar">
              <div class="si-toolbar-left">
                <span class="si-rec-dot"></span>
                <span class="si-rec-label">REC</span>
                <span class="si-divider"></span>
                <span class="si-mode">THERMAL + VISUAL</span>
              </div>
              <div class="si-toolbar-right">
                <span class="si-coord">38.9536°N 77.4484°W</span>
                <span class="si-divider"></span>
                <span class="si-alt">ALT 120m</span>
              </div>
            </div>

            <!-- Main scan viewport -->
            <div class="si-viewport">
              <svg class="si-svg" viewBox="0 0 600 420" fill="none" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <filter id="si-glow"><feGaussianBlur stdDeviation="3"/></filter>
                  <filter id="si-hot"><feGaussianBlur stdDeviation="10"/></filter>
                  <filter id="si-warm"><feGaussianBlur stdDeviation="6"/></filter>
                  <radialGradient id="therm-crit" cx="50%" cy="50%"><stop offset="0%" stop-color="#FF3C3C" stop-opacity="0.5"/><stop offset="60%" stop-color="#FF6B35" stop-opacity="0.15"/><stop offset="100%" stop-color="transparent"/></radialGradient>
                  <radialGradient id="therm-warn" cx="50%" cy="50%"><stop offset="0%" stop-color="#FFB400" stop-opacity="0.4"/><stop offset="60%" stop-color="#FF8C00" stop-opacity="0.1"/><stop offset="100%" stop-color="transparent"/></radialGradient>
                  <radialGradient id="therm-mod" cx="50%" cy="50%"><stop offset="0%" stop-color="#FF8C00" stop-opacity="0.3"/><stop offset="50%" stop-color="#FF6B35" stop-opacity="0.08"/><stop offset="100%" stop-color="transparent"/></radialGradient>
                  <radialGradient id="therm-cool" cx="50%" cy="50%"><stop offset="0%" stop-color="#00E5FF" stop-opacity="0.06"/><stop offset="100%" stop-color="transparent"/></radialGradient>
                </defs>
                <!-- Subtle grid -->
                <g opacity="0.3" stroke="rgba(0,229,255,0.08)" stroke-width="0.5">
                  <line x1="0" y1="0" x2="0" y2="420"/><line x1="60" y1="0" x2="60" y2="420"/><line x1="120" y1="0" x2="120" y2="420"/><line x1="180" y1="0" x2="180" y2="420"/><line x1="240" y1="0" x2="240" y2="420"/><line x1="300" y1="0" x2="300" y2="420"/><line x1="360" y1="0" x2="360" y2="420"/><line x1="420" y1="0" x2="420" y2="420"/><line x1="480" y1="0" x2="480" y2="420"/><line x1="540" y1="0" x2="540" y2="420"/><line x1="600" y1="0" x2="600" y2="420"/>
                  <line x1="0" y1="0" x2="600" y2="0"/><line x1="0" y1="60" x2="600" y2="60"/><line x1="0" y1="120" x2="600" y2="120"/><line x1="0" y1="180" x2="600" y2="180"/><line x1="0" y1="240" x2="600" y2="240"/><line x1="0" y1="300" x2="600" y2="300"/><line x1="0" y1="360" x2="600" y2="360"/><line x1="0" y1="420" x2="600" y2="420"/>
                </g>
                <!-- ===== FACILITY COMPLEX ===== -->
                <!-- Main building -->
                <rect x="50" y="50" width="380" height="280" rx="3" fill="rgba(0,229,255,0.02)" stroke="rgba(0,229,255,0.18)" stroke-width="1.5"/>
                <!-- Roof sections with thermal base colors -->
                <rect x="65" y="65" width="170" height="120" rx="2" fill="rgba(0,229,255,0.04)" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <rect x="245" y="65" width="170" height="120" rx="2" fill="rgba(0,229,255,0.04)" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <rect x="65" y="200" width="170" height="115" rx="2" fill="rgba(0,229,255,0.04)" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <rect x="245" y="200" width="170" height="115" rx="2" fill="rgba(0,229,255,0.04)" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <!-- Annex building -->
                <rect x="460" y="100" width="110" height="170" rx="3" fill="rgba(0,229,255,0.02)" stroke="rgba(0,229,255,0.12)" stroke-width="1"/>
                <rect x="472" y="115" width="86" height="60" rx="2" fill="rgba(0,229,255,0.03)" stroke="rgba(0,229,255,0.08)" stroke-width="0.5"/>
                <rect x="472" y="190" width="86" height="60" rx="2" fill="rgba(0,229,255,0.03)" stroke="rgba(0,229,255,0.08)" stroke-width="0.5"/>
                <!-- Parking / pad area -->
                <rect x="460" y="300" width="110" height="50" rx="2" fill="none" stroke="rgba(0,229,255,0.06)" stroke-width="0.5" stroke-dasharray="4 3"/>
                <!-- Section labels -->
                <text x="150" y="130" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(0,229,255,0.15)" letter-spacing="2">HALL A</text>
                <text x="330" y="130" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(0,229,255,0.15)" letter-spacing="2">HALL B</text>
                <text x="150" y="260" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(0,229,255,0.15)" letter-spacing="2">MECH PLANT</text>
                <text x="330" y="260" text-anchor="middle" font-family="monospace" font-size="7" fill="rgba(0,229,255,0.15)" letter-spacing="2">COOLING</text>
                <text x="515" y="150" text-anchor="middle" font-family="monospace" font-size="6" fill="rgba(0,229,255,0.12)" letter-spacing="1.5">GENSET</text>
                <text x="515" y="224" text-anchor="middle" font-family="monospace" font-size="6" fill="rgba(0,229,255,0.12)" letter-spacing="1.5">SWITCH</text>
                <text x="515" y="328" text-anchor="middle" font-family="monospace" font-size="6" fill="rgba(0,229,255,0.12)" letter-spacing="1.5">LOADING</text>
                <!-- HVAC units row — Hall A -->
                <rect x="80" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="102" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="124" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="146" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="168" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="190" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <!-- HVAC units — Hall B -->
                <rect x="260" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="282" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="304" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="326" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="348" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <rect x="370" y="78" width="14" height="9" rx="1" fill="rgba(0,229,255,0.06)" stroke="rgba(0,229,255,0.12)" stroke-width="0.5"/>
                <!-- Cooling tower circles -->
                <circle cx="280" cy="240" r="15" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <circle cx="320" cy="240" r="15" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <circle cx="360" cy="240" r="15" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <circle cx="280" cy="280" r="15" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <circle cx="320" cy="280" r="15" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>
                <circle cx="360" cy="280" r="15" fill="none" stroke="rgba(0,229,255,0.1)" stroke-width="0.8"/>

                <!-- ===== THERMAL SIGNATURES ===== -->
                <!-- Critical: HVAC-05 running hot -->
                <circle cx="170" cy="83" r="28" fill="url(#therm-crit)"/>
                <circle cx="170" cy="83" r="16" fill="url(#therm-crit)">
                  <animate attributeName="r" values="14;20;14" dur="2s" repeatCount="indefinite"/>
                </circle>
                <circle cx="170" cy="83" r="6" fill="rgba(255,60,60,0.7)">
                  <animate attributeName="opacity" values="1;0.5;1" dur="1.5s" repeatCount="indefinite"/>
                </circle>
                <!-- Warning: membrane degradation area -->
                <ellipse cx="130" cy="240" rx="40" ry="25" fill="url(#therm-warn)" opacity="0.7">
                  <animate attributeName="opacity" values="0.5;0.8;0.5" dur="4s" repeatCount="indefinite"/>
                </ellipse>
                <circle cx="120" cy="235" r="5" fill="rgba(255,180,0,0.5)"/>
                <circle cx="140" cy="245" r="3" fill="rgba(255,180,0,0.35)"/>
                <!-- Moderate: cooling tower delta -->
                <circle cx="320" cy="260" r="45" fill="url(#therm-mod)" opacity="0.6">
                  <animate attributeName="opacity" values="0.4;0.7;0.4" dur="5s" repeatCount="indefinite"/>
                </circle>
                <circle cx="320" cy="240" r="4" fill="rgba(255,140,0,0.4)"/>
                <circle cx="360" cy="280" r="3" fill="rgba(255,140,0,0.3)"/>
                <!-- Info: slight warm spot on genset -->
                <circle cx="515" cy="145" r="20" fill="url(#therm-cool)" opacity="0.8"/>
                <!-- Normal thermal: ambient zones -->
                <circle cx="100" cy="110" r="30" fill="url(#therm-cool)"/>
                <circle cx="350" cy="110" r="25" fill="url(#therm-cool)"/>

                <!-- ===== FINDING CALLOUTS ===== -->
                <!-- F1: Critical HVAC -->
                <g class="finding-tag ft-1">
                  <line x1="185" y1="75" x2="260" y2="32" stroke="rgba(255,60,60,0.5)" stroke-width="0.8"/>
                  <circle cx="260" cy="32" r="2" fill="#FF3C3C"/>
                  <rect x="265" y="18" width="140" height="30" rx="4" fill="rgba(20,10,10,0.85)" stroke="rgba(255,60,60,0.5)" stroke-width="0.8"/>
                  <circle cx="278" cy="28" r="3.5" fill="#FF3C3C"><animate attributeName="opacity" values="1;0.3;1" dur="1.2s" repeatCount="indefinite"/></circle>
                  <text x="287" y="27" font-family="monospace" font-size="6.5" fill="#FF6B6B" letter-spacing="0.8">CRITICAL</text>
                  <text x="340" y="27" font-family="monospace" font-size="6" fill="rgba(255,255,255,0.35)">F-001</text>
                  <text x="278" y="40" font-family="monospace" font-size="7.5" fill="rgba(255,255,255,0.7)">HVAC-05</text>
                  <text x="330" y="40" font-family="monospace" font-size="7.5" fill="#FF6B6B" font-weight="bold">47.3°C</text>
                </g>
                <!-- F2: Warning membrane -->
                <g class="finding-tag ft-2">
                  <line x1="110" y1="258" x2="48" y2="355" stroke="rgba(255,180,0,0.4)" stroke-width="0.8"/>
                  <circle cx="48" cy="355" r="2" fill="#FFB400"/>
                  <rect x="15" y="358" width="150" height="30" rx="4" fill="rgba(15,12,5,0.85)" stroke="rgba(255,180,0,0.4)" stroke-width="0.8"/>
                  <circle cx="28" cy="368" r="3.5" fill="#FFB400"><animate attributeName="opacity" values="1;0.3;1" dur="1.2s" begin="0.4s" repeatCount="indefinite"/></circle>
                  <text x="37" y="367" font-family="monospace" font-size="6.5" fill="#FFD060" letter-spacing="0.8">WARNING</text>
                  <text x="92" y="367" font-family="monospace" font-size="6" fill="rgba(255,255,255,0.35)">F-004</text>
                  <text x="28" y="380" font-family="monospace" font-size="7.5" fill="rgba(255,255,255,0.7)">Membrane split 12m</text>
                </g>
                <!-- F3: Moderate cooling -->
                <g class="finding-tag ft-3">
                  <line x1="345" y1="235" x2="440" y2="185" stroke="rgba(255,140,0,0.35)" stroke-width="0.8"/>
                  <circle cx="440" cy="185" r="2" fill="#FF8C00"/>
                  <rect x="445" y="172" width="145" height="30" rx="4" fill="rgba(15,10,5,0.85)" stroke="rgba(255,140,0,0.3)" stroke-width="0.8"/>
                  <circle cx="458" cy="182" r="3.5" fill="#FF8C00"><animate attributeName="opacity" values="1;0.3;1" dur="1.2s" begin="0.8s" repeatCount="indefinite"/></circle>
                  <text x="467" y="181" font-family="monospace" font-size="6.5" fill="#FFB060" letter-spacing="0.8">MODERATE</text>
                  <text x="530" y="181" font-family="monospace" font-size="6" fill="rgba(255,255,255,0.35)">F-007</text>
                  <text x="458" y="194" font-family="monospace" font-size="7.5" fill="rgba(255,255,255,0.7)">CT-3 ΔT +8.2°C</text>
                </g>
                <!-- F4: Info genset -->
                <g class="finding-tag ft-4">
                  <line x1="530" y1="140" x2="545" y2="90" stroke="rgba(0,229,255,0.2)" stroke-width="0.8"/>
                  <circle cx="545" cy="90" r="2" fill="#00E5FF"/>
                  <rect x="448" y="72" width="140" height="22" rx="4" fill="rgba(5,15,20,0.8)" stroke="rgba(0,229,255,0.2)" stroke-width="0.8"/>
                  <text x="458" y="86" font-family="monospace" font-size="6.5" fill="rgba(0,229,255,0.6)" letter-spacing="0.8">INFO</text>
                  <text x="485" y="86" font-family="monospace" font-size="7" fill="rgba(255,255,255,0.5)">Genset exhaust nominal</text>
                </g>

                <!-- ===== SCAN ELEMENTS ===== -->
                <!-- Horizontal scan line -->
                <line x1="0" y1="0" x2="600" y2="0" stroke="rgba(0,229,255,0.3)" stroke-width="1.5" class="si-scanline">
                  <animate attributeName="y1" values="-10;430;-10" dur="8s" repeatCount="indefinite"/>
                  <animate attributeName="y2" values="-10;430;-10" dur="8s" repeatCount="indefinite"/>
                </line>
                <!-- Scan line glow trail -->
                <rect x="0" y="0" width="600" height="30" fill="url(#scan-grad-v)" opacity="0.4" class="si-scantrail">
                  <animate attributeName="y" values="-40;430;-40" dur="8s" repeatCount="indefinite"/>
                </rect>
                <linearGradient id="scan-grad-v" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="transparent"/><stop offset="80%" stop-color="#00E5FF" stop-opacity="0.08"/><stop offset="100%" stop-color="#00E5FF" stop-opacity="0.15"/></linearGradient>

                <!-- Aerial platform with FOV cone -->
                <g class="si-platform-group">
                  <animateMotion dur="14s" repeatCount="indefinite" path="M50,45 L430,45 L430,175 L50,175 L50,200 L430,320 L430,345 L50,345 L50,45"/>
                  <!-- FOV cone -->
                  <polygon points="0,0 -20,30 20,30" fill="rgba(0,229,255,0.04)" stroke="rgba(0,229,255,0.08)" stroke-width="0.5"/>
                  <!-- Platform body -->
                  <circle r="4" fill="#00E5FF" filter="url(#si-glow)"/>
                  <circle r="9" fill="none" stroke="#00E5FF" stroke-width="0.8" opacity="0.35">
                    <animate attributeName="r" values="8;14;8" dur="1.8s" repeatCount="indefinite"/>
                    <animate attributeName="opacity" values="0.35;0.08;0.35" dur="1.8s" repeatCount="indefinite"/>
                  </circle>
                </g>

                <!-- Crosshair center -->
                <g opacity="0.1">
                  <line x1="295" y1="200" x2="305" y2="200" stroke="#00E5FF" stroke-width="0.5"/>
                  <line x1="300" y1="195" x2="300" y2="205" stroke="#00E5FF" stroke-width="0.5"/>
                </g>
              </svg>

              <!-- Thermal scale bar (CSS overlay) -->
              <div class="si-thermal-scale">
                <div class="si-scale-gradient"></div>
                <div class="si-scale-labels">
                  <span>18°C</span><span>28°</span><span>38°</span><span>48°C</span>
                </div>
              </div>
            </div>

            <!-- Bottom panel — findings summary -->
            <div class="si-bottom-panel">
              <div class="si-finding-pills">
                <span class="si-pill si-pill-crit"><span class="si-pill-dot"></span>3 Critical</span>
                <span class="si-pill si-pill-warn"><span class="si-pill-dot"></span>5 Warning</span>
                <span class="si-pill si-pill-mod"><span class="si-pill-dot"></span>4 Moderate</span>
                <span class="si-pill si-pill-info"><span class="si-pill-dot"></span>2 Info</span>
              </div>
              <div class="si-summary">
                <span class="si-total">14 findings</span>
                <span class="si-est">Est. $51,500</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ INTERACTIVE PROCESS WHEEL ============ -->
    <section id="process-wheel" class="omega-section" style="background: var(--surface-dim);" aria-label="The Process">
      <div class="omega-section-inner">
        <div class="omega-section-header reveal">
          <div class="omega-eyebrow">
            <span class="omega-eyebrow-line"></span>
            <span class="omega-eyebrow-text">The Process</span>
          </div>
          <h2>Six Steps to<br/>Actionable Intelligence</h2>
          <p class="omega-section-subtitle">Click any step to learn more. Most facilities complete the entire process in two to three weeks.</p>
        </div>

        <div class="process-wheel-container reveal">
          <!-- Circular wheel for desktop -->
          <div class="process-wheel" role="tablist" aria-label="Scan process steps">
            <div class="wheel-center">
              <div class="wheel-center-content" id="wheel-center-content">
                <span class="material-symbols-outlined wheel-center-icon" style="font-variation-settings: 'FILL' 1;" id="wheel-icon" aria-hidden="true">call</span>
                <span class="wheel-center-step" id="wheel-step">01</span>
                <span class="wheel-center-title" id="wheel-title">Scoping Call</span>
              </div>
            </div>
            {process.map((p, i) => {
              const angle = (i * 60) - 90;
              const rad = angle * Math.PI / 180;
              const radius = 42;
              const x = 50 + radius * Math.cos(rad);
              const y = 50 + radius * Math.sin(rad);
              return (
                <button
                  class={`wheel-node ${i === 0 ? 'active' : ''}`}
                  role="tab"
                  aria-selected={i === 0 ? 'true' : 'false'}
                  aria-controls="wheel-detail-panel"
                  data-step={i}
                  data-icon={p.icon}
                  data-title={p.title}
                  data-desc={p.desc}
                  data-num={p.step}
                  style={`left: ${x}%; top: ${y}%;`}
                >
                  <span class="wheel-node-num">{p.step}</span>
                  <span class="wheel-node-label">{p.title}</span>
                </button>
              );
            })}
            <!-- SVG connector ring with animated dash + outer step labels -->
            <svg class="wheel-ring-svg" viewBox="0 0 100 100" aria-hidden="true">
              <defs>
                <linearGradient id="wheelRingGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#00E5FF" stop-opacity="0.8"/>
                  <stop offset="100%" stop-color="#00E5FF" stop-opacity="0.1"/>
                </linearGradient>
                <filter id="wheelGlowFilter" x="-20%" y="-20%" width="140%" height="140%">
                  <feGaussianBlur in="SourceGraphic" stdDeviation="1.2" result="blur"/>
                  <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                </filter>
              </defs>
              <!-- Pulsing glow ring: expands from r=48 to r=52 over 3s -->
              <circle cx="50" cy="50" r="48" fill="none" stroke="rgba(0,229,255,0.5)" stroke-width="0.6" opacity="0.5">
                <animate attributeName="r" values="48;52;48" dur="3s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.5;0.15;0.5" dur="3s" repeatCount="indefinite"/>
                <animate attributeName="stroke-width" values="0.6;1.2;0.6" dur="3s" repeatCount="indefinite"/>
              </circle>
              <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(0,229,255,0.06)" stroke-width="0.3" />
              <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(0,229,255,0.25)" stroke-width="0.5" stroke-dasharray="4,8" class="wheel-ring-animated" />
              <circle cx="50" cy="50" r="42" fill="none" stroke="url(#wheelRingGrad)" stroke-width="1" stroke-dasharray="22,242" stroke-linecap="round" class="wheel-ring-progress" />
              <!-- Particle dots orbiting the wheel ring clockwise -->
              <!-- Particle 1 — starts at 0deg (top), full orbit 8s -->
              <circle r="1.4" fill="#00E5FF" opacity="0.85" filter="url(#wheelGlowFilter)">
                <animateMotion dur="8s" repeatCount="indefinite"
                  path="M 50,8 A 42,42 0 1 1 49.99,8 Z"/>
              </circle>
              <!-- Particle 2 — starts 120deg ahead (offset by begin) -->
              <circle r="1.2" fill="#00E5FF" opacity="0.7" filter="url(#wheelGlowFilter)">
                <animateMotion dur="8s" begin="-2.667s" repeatCount="indefinite"
                  path="M 50,8 A 42,42 0 1 1 49.99,8 Z"/>
              </circle>
              <!-- Particle 3 — starts 240deg ahead -->
              <circle r="1.0" fill="#00E5FF" opacity="0.55" filter="url(#wheelGlowFilter)">
                <animateMotion dur="8s" begin="-5.333s" repeatCount="indefinite"
                  path="M 50,8 A 42,42 0 1 1 49.99,8 Z"/>
              </circle>
              <!-- Outer step labels positioned beyond the ring -->
              {(() => {
                const labels = ['Scope', 'Plan', 'Fly', 'Analyze', 'Report', 'Handoff'];
                const outerR = 48.5;
                return labels.map((label, i) => {
                  const angle = (i * 60 - 90) * Math.PI / 180;
                  const lx = 50 + outerR * Math.cos(angle);
                  const ly = 50 + outerR * Math.sin(angle);
                  return (
                    <text
                      x={lx}
                      y={ly}
                      text-anchor="middle"
                      dominant-baseline="central"
                      class="wheel-outer-label"
                    >{label}</text>
                  );
                });
              })()}
            </svg>
          </div>

          <!-- Detail panel -->
          <div class="wheel-detail-panel" id="wheel-detail-panel" role="tabpanel" aria-live="polite">
            <p class="wheel-detail-desc" id="wheel-desc">We learn your facility, your priorities, and your pain points. A real conversation about what matters to your operations team.</p>
          </div>

          <!-- Mobile fallback: vertical timeline -->
          <div class="process-mobile-list">
            {process.map((p, i) => (
              <div class={`process-mobile-item reveal reveal-delay-${(i % 4) + 1}`}>
                <div class="process-mobile-marker">
                  <span class="process-mobile-step">{p.step}</span>
                  {i < process.length - 1 && <div class="process-mobile-connector"></div>}
                </div>
                <div class="process-mobile-body">
                  <div class="process-mobile-icon-wrap">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 20px;" aria-hidden="true">{p.icon}</span>
                  </div>
                  <h3>{p.title}</h3>
                  <p>{p.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

