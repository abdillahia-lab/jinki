  }

  /* Mobile process list */
  .process-mobile-list {
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .process-mobile-list { display: none; }
  }

  .process-mobile-item {
    display: flex;
    gap: 20px;
    padding: 20px 0;
  }

  .process-mobile-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .process-mobile-step {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
  }

  .process-mobile-connector {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--accent), transparent);
    min-height: 24px;
  }

  .process-mobile-icon-wrap {
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    color: var(--accent);
  }

  .process-mobile-body h3 {
    font-family: var(--font-headline);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }

  .process-mobile-body p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ================ FINDINGS GALLERY ================ */
  .findings-gallery {
    position: relative;
  }

  .findings-carousel {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 600px) {
    .findings-carousel { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .findings-carousel { grid-template-columns: repeat(4, 1fr); }
  }

  .finding-card {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out-premium),
                box-shadow 0.4s var(--ease-out-premium),
                border-color 0.4s ease;
  }

  .finding-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2), 0 0 20px color-mix(in srgb, var(--accent) 5%, transparent);
    border-color: color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .finding-image-area {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, #0a0c10, #141820);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .finding-visual {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* --- Thermal Heatmap --- */
  .thermal-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
    width: 85%;
    height: 75%;
    padding: 8px;
  }
  .thermal-cell {
    border-radius: 4px;
    transition: opacity 0.3s;
  }
  .t-cool { background: linear-gradient(135deg, #1a237e, #283593); }
  .t-warm { background: linear-gradient(135deg, #e65100, #f57c00); }
  .t-hot { background: linear-gradient(135deg, #d84315, #ff3d00); }
  .t-critical {
    background: linear-gradient(135deg, #b71c1c, #ff1744);
    animation: thermal-pulse 2s ease-in-out infinite;
  }
  .thermal-crosshair {
    position: absolute;
    top: 35%;
    right: 28%;
    width: 40px;
    height: 40px;
    border: 1.5px solid rgba(255, 59, 48, 0.7);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(255, 59, 48, 0.3);
  }
  .thermal-crosshair::before,
  .thermal-crosshair::after {
    content: '';
    position: absolute;
    background: rgba(255, 59, 48, 0.5);
  }
  .thermal-crosshair::before {
    top: 50%;
    left: -8px;
    right: -8px;
    height: 1px;
  }
  .thermal-crosshair::after {
    left: 50%;
    top: -8px;
    bottom: -8px;
    width: 1px;
  }
  .thermal-readout {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }
  .thermal-temp {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: #FF3B30;
    text-shadow: 0 0 8px rgba(255, 59, 48, 0.4);
  }
  .thermal-label {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.12em;
    color: rgba(255, 59, 48, 0.6);
  }
  @keyframes thermal-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  /* --- Structural Degradation --- */
  .structural-svg {
    width: 85%;
    height: 85%;
  }
  .structural-badge {
    position: absolute;
    bottom: 12px;
    right: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(255, 107, 53, 0.1);
    border: 1px solid rgba(255, 107, 53, 0.25);
    border-radius: 8px;
    padding: 8px 12px;
  }
  .structural-rating {
    font-family: var(--font-mono);
    font-size: 18px;
    font-weight: 800;
    color: #FF6B35;
  }
  .structural-label {
    font-family: var(--font-mono);
    font-size: 7px;
    letter-spacing: 0.12em;
    color: rgba(255, 107, 53, 0.6);
  }

  /* --- Security Radar --- */
  .radar-container {
    position: relative;
    width: 85%;
    height: 85%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .radar-svg {
    width: 100%;
    height: 100%;
  }
  .radar-sweep {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 50%;
    height: 2px;
    transform-origin: left center;
    background: linear-gradient(90deg, rgba(255, 189, 46, 0.6), transparent);
    animation: radar-spin 3s linear infinite;
  }
  @keyframes radar-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* --- Efficiency / Insulation --- */
  .efficiency-svg {
    width: 85%;
    height: 85%;
  }
  .efficiency-readout {
    position: absolute;
    bottom: 12px;
    left: 12px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .efficiency-loss {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
  }
  .efficiency-label {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.12em;
    color: color-mix(in srgb, var(--accent) 50%, transparent);
  }

  .finding-severity-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 8px;
    border: 1px solid;
  }

  .finding-category-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.5);
    color: var(--text-secondary);
    backdrop-filter: blur(4px);
  }

  .finding-info {
    padding: 16px;
  }

  .finding-info h3 {
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .finding-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .finding-meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  .findings-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 32px;
  }

  @media (min-width: 1024px) {
    .findings-nav { display: none; }
  }

  .findings-nav-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--surface-container);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .findings-nav-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .findings-dots {
    display: flex;
    gap: 8px;
  }

  .findings-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--glass-border);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, box-shadow 0.3s var(--ease-out-premium), transform 0.3s var(--ease-out-premium);
  }

  .findings-dot.active {
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }

  /* ================ COMPARISON ================ */
  .comparison-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .comparison-container {
      grid-template-columns: 1fr auto 1fr;
      gap: 0;
    }
  }

  .comparison-side {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out-premium),
                box-shadow 0.4s var(--ease-out-premium);
  }

  .comparison-side:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-elevated);
  }

  .comparison-header-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 24px;
  }

  .comparison-header-bar h3 {
    font-family: var(--font-headline);
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .traditional-bar {
    background: rgba(255, 59, 48, 0.08);
    border-bottom: 1px solid rgba(255, 59, 48, 0.15);
    color: #FF6B6B;
  }

  .traditional-bar h3 { color: #FF6B6B; }

  .jinki-bar {
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
  }

  .jinki-bar h3 { color: var(--accent); }

  .comparison-list {
    list-style: none;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .comparison-list li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .cmp-icon {
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .comparison-negative .cmp-icon { color: #FF6B6B; }
  .comparison-positive .cmp-icon { color: #27C93F; }

  .comparison-list li strong {
    display: block;
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 2px;
  }

  .comparison-list li span {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .comparison-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 20px;
  }

  .comparison-vs {
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-tertiary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: var(--surface-dim);
    padding: 8px 16px;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
  }

  @media (max-width: 767px) {
    .comparison-divider {
      padding: 0;
    }
  }

  .report-disclaimer {
    display: flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin-top: 16px;
  }
  .report-disclaimer .material-symbols-outlined {
    font-size: 16px;
    font-variation-settings: 'FILL' 1;
  }

  /* ================ REPORT TABS ================ */
  .sample-report-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    padding: 12px 20px;
    border-radius: 10px;
    border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
    background: color-mix(in srgb, var(--accent) 4%, transparent);
    color: var(--accent);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .sample-report-cta:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 10%, transparent);
    transform: translateY(-1px);
  }

  .sample-report-meta {
    color: var(--text-tertiary);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    text-transform: none;
  }

  :global([data-theme="light"]) .sample-report-cta {
    border-color: rgba(0, 151, 167, 0.2);
    background: rgba(0, 151, 167, 0.04);
    color: #0097A7;
  }

  :global([data-theme="light"]) .sample-report-cta:hover {
    background: rgba(0, 151, 167, 0.1);
    border-color: rgba(0, 151, 167, 0.35);
    box-shadow: 0 0 20px rgba(0, 151, 167, 0.08);
  }

  .report-tabs-container {
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
  }

  .report-tabs {
    display: flex;
    overflow-x: auto;
    border-bottom: 1px solid var(--glass-border);
    scrollbar-width: none;
  }

  .report-tabs::-webkit-scrollbar { display: none; }

  .report-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px 20px;
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease, border-bottom-color 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .report-tab:hover {
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--accent) 3%, transparent);
  }

  .report-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .report-tab-label {
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    color: inherit;
  }

  .report-panels {
    padding: 32px;
  }

  .report-panel {
    display: none;
  }

  .report-panel.active {
    display: block;
  }

  .report-panel-mockup {
    background: linear-gradient(135deg, #0a0c10, #141820);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    overflow: hidden;
  }

  .report-panel-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid var(--glass-border);
  }

  .report-panel-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .report-panel-title {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-tertiary);
    letter-spacing: 0.05em;
    margin-left: 8px;
  }

  .report-panel-body {
    padding: 32px;
  }

  .report-panel-content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    align-items: start;
  }

  .report-panel-left {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .report-panel-right {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
  }

  .report-panel-icon-area {
    width: 52px;
    height: 52px;
    border-radius: 16px;
    background: var(--accent-glow);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .report-panel-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* --- Report Visualizations --- */
  .report-viz { width: 100%; }

  /* Executive: Health ring + severity breakdown */
  .report-viz-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .health-ring {
    position: relative;
    width: 120px;
    height: 120px;
  }
  .health-ring svg { width: 100%; height: 100%; }
  .health-ring-fill {
    animation: ring-draw 1.5s ease-out forwards;
    stroke-dashoffset: 264;
  }
  @keyframes ring-draw {
    to { stroke-dashoffset: 66; }
  }
  .health-ring-label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .health-score {
    font-family: var(--font-headline);
    font-size: 24px;
    font-weight: 800;
    color: var(--text-primary);
  }
  .health-text {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .severity-breakdown {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    max-width: 180px;
  }
  .severity-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
  }
  .sev-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .sev-label { flex: 1; }
  .sev-count {
    font-weight: 700;
    color: var(--text-primary);
  }

  /* Thermal: Mini heatmap */
  .report-viz-thermal {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mini-thermal-map {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-radius: 8px;
    overflow: hidden;
  }
  .mt-row {
    display: flex;
    gap: 2px;
  }
  .mt-c {
    flex: 1;
    height: 28px;
    border-radius: 2px;
    opacity: 0.85;
  }
  .thermal-scale {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .thermal-scale-bar {
    height: 6px;
    border-radius: 4px;
    background: linear-gradient(90deg, #1a237e, #1565c0, #2e7d32, #f57c00, #d84315, #ff1744);
  }
  .thermal-scale-labels {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-tertiary);
  }

  /* Structural: Condition bars */
  .condition-bars {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
  }
  .cond-item {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .cond-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
    width: 52px;
    flex-shrink: 0;
  }
  .cond-track {
    flex: 1;
    height: 8px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
    overflow: hidden;
  }
  .cond-fill {
    height: 100%;
    border-radius: 4px;
    animation: bar-grow 1.2s ease-out forwards;
    transform: scaleX(0);
    transform-origin: left;
  }
  .cond-val {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--text-primary);
    width: 24px;
    text-align: right;
  }
  @keyframes bar-grow {
    to { transform: scaleX(1); }
  }

  /* Security: Coverage stat + gap list */
  .report-viz-security {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
  }
  .coverage-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .coverage-pct {
    font-family: var(--font-headline);
    font-size: 40px;
    font-weight: 800;
    color: #FFBD2E;
    line-height: 1;
  }
  .coverage-label {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-top: 4px;
  }
  .gap-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }
  .gap-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
