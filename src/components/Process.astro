---
/*
  Process Section — How an engagement works

  Three-step visual process showing the journey from
  initial contact to actionable intelligence delivery.
  No fabricated claims — this is the actual service flow.
*/
const steps = [
  {
    num: '01',
    title: 'Scope & Plan',
    desc: 'We assess your facility, define the inspection area, and build a mission plan tailored to your infrastructure — rooftops, perimeters, corridors, or fields.',
    icon: 'assignment',
  },
  {
    num: '02',
    title: 'Capture & Analyze',
    desc: 'Our aerial platform executes the mission — thermal and high-resolution visual sensors capture every surface. AI classifies findings by severity during post-flight analysis.',
    icon: 'precision_manufacturing',
  },
  {
    num: '03',
    title: 'Deliver & Act',
    desc: 'You receive a prioritized intelligence report within 48 hours — not raw data, but clear recommendations your maintenance team can execute immediately.',
    icon: 'verified',
  },
];
---

<section id="process" style="padding-top: 7rem; padding-bottom: 7rem; position: relative; overflow: hidden;" aria-label="How It Works">
  <div aria-hidden="true" style="position: absolute; bottom: 10%; left: 30%; width: 400px; height: 350px; background: radial-gradient(ellipse, rgba(123,97,255,0.04) 0%, transparent 60%); filter: blur(60px); pointer-events: none;"></div>
  <div style="max-width: var(--container-max); margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem; position: relative; z-index: 1;">

    <!-- Header -->
    <div class="reveal" style="text-align: center; max-width: 40rem; margin-left: auto; margin-right: auto; margin-bottom: 4rem;">
      <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-bottom: 1rem;">
        <span style="display: block; height: 1px; width: 2rem; background: var(--accent);"></span>
        <span class="section-eyebrow">Process</span>
        <span style="display: block; height: 1px; width: 2rem; background: var(--accent);"></span>
      </div>
      <h2 style="font-family: var(--font-headline); font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; line-height: 1.12; letter-spacing: -0.02em;">
        From Contact to Intelligence<br/>in <span style="color: var(--accent);">Three Steps</span>
      </h2>
      <p style="font-family: var(--font-body); font-size: 1.0625rem; color: var(--text-secondary); line-height: 1.65;">
        No complex procurement cycles. No multi-month onboarding. We move at the speed your operations demand.
      </p>
    </div>

    <!-- Steps -->
    <div class="process-grid">
      {steps.map((step, i) => (
        <div class={`process-step reveal ${i > 0 ? `reveal-delay-${i}` : ''}`}>
          <div class="process-step-header">
            <span class="process-num-circle" aria-hidden="true">{step.num}</span>
            <span class="material-symbols-outlined process-icon" aria-hidden="true">{step.icon}</span>
          </div>
          <h3 class="process-title">{step.title}</h3>
          <p class="process-desc">{step.desc}</p>
          {i < steps.length - 1 && (
            <div class="process-connector" aria-hidden="true">
              <svg width="48" height="2" viewBox="0 0 48 2" class="process-connector-line">
                <line x1="0" y1="1" x2="48" y2="1" stroke="var(--accent)" stroke-width="2" stroke-dasharray="48" stroke-dashoffset="48" stroke-linecap="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- What You Receive -->
    <div class="reveal" style="margin-top: 4rem; text-align: center;">
      <h3 style="font-family: var(--font-headline); font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem;">Your Report Includes</h3>
      <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; max-width: 700px; margin: 0 auto;">
        <span class="deliverable-tag"><span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">pin_drop</span> GPS-located findings</span>
        <span class="deliverable-tag"><span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">thermostat</span> Annotated thermal imagery</span>
        <span class="deliverable-tag"><span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">priority_high</span> Severity rankings</span>
        <span class="deliverable-tag"><span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">payments</span> Estimated repair costs</span>
        <span class="deliverable-tag"><span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">calendar_month</span> Maintenance timeline</span>
        <span class="deliverable-tag"><span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">summarize</span> Executive summary</span>
      </div>
      <a href="#lead-gen" class="sample-report-link" style="display: inline-flex; align-items: center; gap: 8px; margin-top: 20px; padding: 12px 20px; border-radius: 8px; border: 1px solid color-mix(in srgb, var(--accent) 15%, transparent); font-family: var(--font-label); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); text-decoration: none; transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s var(--ease-out-premium);">
        <span class="material-symbols-outlined" style="font-size: 16px; font-variation-settings: 'FILL' 1;" aria-hidden="true">description</span>
        Request Sample Report
      </a>
    </div>

  </div>
</section>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    position: relative;
  }

  @media (min-width: 768px) {
    .process-grid { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }

  .process-step {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 2rem;
    overflow: hidden;
    box-shadow: var(--inset-highlight), var(--shadow-rest);
    transition: border-color 0.4s ease,
                box-shadow 0.4s var(--ease-out-premium),
                transform 0.4s var(--ease-out-premium);
  }
  .process-step::after {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent 10%, var(--accent) 50%, transparent 90%);
    opacity: 0.3;
  }

  .process-step:hover {
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
    box-shadow: var(--inset-highlight-strong), 0 8px 24px rgba(0, 0, 0, 0.15), 0 0 24px color-mix(in srgb, var(--accent) 6%, transparent);
    transform: translateY(-3px);
  }

  .process-step-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .process-num-circle {
    width: 2.5rem; height: 2.5rem; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 0.8rem; font-weight: 700;
    color: var(--text-on-accent); letter-spacing: 0.05em;
    background: conic-gradient(from 135deg, var(--accent), var(--accent-secondary), var(--accent-tertiary), var(--accent));
    flex-shrink: 0;
  }

  .process-icon {
    font-size: 24px;
    color: var(--accent);
    opacity: 0.5;
  }

  .process-title {
    font-family: var(--font-headline);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .process-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .process-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .process-connector {
      display: flex;
      position: absolute;
      right: -1.5rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
    }
  }
  .process-connector-line line {
    transition: stroke-dashoffset 0.8s ease;
  }
  .process-step.revealed .process-connector-line line {
    stroke-dashoffset: 0;
  }

  @media (max-width: 767px) {
    .process-grid { gap: 1rem; }
    .process-step { padding: 1.25rem; border-radius: 12px; }
    .process-num-circle { width: 2rem; height: 2rem; font-size: 0.7rem; }
    .process-title { font-size: 1.1rem; }
    .process-desc { font-size: 0.875rem; }
    .deliverable-tag { padding: 6px 12px; font-size: 0.7rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-step { transition: none; }
    .process-connector-line line { transition: none; stroke-dashoffset: 0; }
    .deliverable-tag { transition: none; }
  }

  .deliverable-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 12%, transparent);
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--accent);
    white-space: nowrap;
    transition: transform 0.25s var(--ease-out-premium),
                box-shadow 0.25s var(--ease-out-premium),
                border-color 0.25s ease;
    cursor: default;
  }
  .deliverable-tag:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--accent) 15%, transparent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .sample-report-link:hover {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  :global([data-theme="light"]) .process-num-circle {
    color: #fff;
  }
  :global([data-theme="light"]) .deliverable-tag {
    background: rgba(0, 131, 143, 0.06);
    border-color: rgba(0, 131, 143, 0.15);
    color: #00838f;
  }
  :global([data-theme="light"]) .deliverable-tag:hover {
    box-shadow: 0 4px 12px rgba(0, 131, 143, 0.12);
    border-color: rgba(0, 131, 143, 0.3);
  }

  :global([data-theme="light"]) .sample-report-link {
    color: #00838f;
    border-color: rgba(0, 131, 143, 0.2);
  }
  :global([data-theme="light"]) .sample-report-link:hover {
    background: rgba(0, 131, 143, 0.06);
    border-color: rgba(0, 131, 143, 0.3);
  }
</style>
