---
/*
  GlobeCanvas v5.10 — Optimization pass: shared uSweepAngle uniform (9 shaders), smooth ring fade,
  remove dead .opacity writes, stale comments, hardcoded resolution fix.

  Architecture:
  - Fibonacci sphere sampling (100k desktop, 38k tablet)
  - Texture-based land detection via canvas getImageData (256×128 land mask)
  - 8-direction coastal edge detection for crisp continental outlines
  - Anti-aliased bokeh dot shader (Gaussian + inverse-square halo)
  - 2-shell atmosphere: outer halo (BackSide) + inner rim (FrontSide)
  - Day/night hemisphere with single scanning sweep
  - Scroll-driven spiral sand dispersal (signature interaction)
  - Post-processing: bloom + FXAA + chroma/vignette + color grade
  - Staggered entrance animation (dolly + scale)
  - CSS mask for hero text readability
  - position: fixed — persists across full page scroll
  - Dynamic import('three') — zero initial bundle cost
  - MutationObserver for theme sync
  - v4.87: IntersectionObserver rendering skip when off-screen
  - v4.87: Cached DOM reads — zero layout thrash per frame
  - v4.87: Slow uniform batching — sun/atmosphere update every 3rd frame
  - v4.88: Half-resolution bloom — 4× fewer fragment ops for the most expensive pass
  - v4.89: Anamorphic lens streak — horizontal light smear from bright highlights
  - v4.90: Volumetric god rays — radial light shafts from sun screen position
  - v4.91: Milky Way galactic band — 1200 stars with concentrated galactic plane + nebula glow
  - v4.92: Optimization pass — restored dynamic contrast/saturation/tint after LUT (was silently dead)
  - v4.86: Optimization pass — zero-alloc raycast, unified bloom pipeline, eliminated all hash noise
  - v4.97: Tighter backface culling (3.2/2.1) + atmospheric rim luminance for cleaner silhouette
  - v4.98: Cinematic DOF — deeper bokeh sigma range + DOF size swell at silhouette
  - v4.99: Concentrated sun specular hotspot — tight bright catch at sun-facing apex
  - v5.00: Prismatic specular dispersion — rainbow fringing on sun specular like light through a lens
  - v5.01: Camera FOV breathing — slow focal length oscillation for organic cinematic depth
  - v5.02: Optimization pass — fix entrance bloom/exposure overwrite, GPU memory leaks, noise dedup, dead code
  - v5.03: Cinematic sun disk — multi-layer glow billboard with chromatic halo, anamorphic streak, globe occlusion
  - v5.04: Heat distortion — convective shimmer radiating from globe, 3-frequency rising haze
  - v5.05: Orbital data ring — 400-particle tilted constellation ring, sun-lit, twinkle, slow orbit
  - v5.06: Dynamic sun color temperature — golden hour amber ↔ neutral white based on sun elevation
  - v5.07: Golden hour color grading — full-frame warmth shift in midtones/highlights + warmer halation
  - v5.08: Eclipse corona expansion + mouse star parallax — dynamic corona scale, responsive starfield
  - v5.09: Micro-clarity — post-process unsharp mask for dot field definition, midtone-gated
  - v5.10: Optimization pass — shared uSweepAngle uniform, smooth ring uFade, dead opacity cleanup
  - v5.11: Golden hour lens effects — god rays, lens flare, anamorphic streak all warm with sun elevation
  - v5.12: Film gate weave + lamp flicker — 35mm projector micro-drift and brightness variation
  - v5.13: Precessing sun orbit — orbital plane tilts over ~35min cycle for non-repeating lighting
  - v5.14: Bloom accent tint — neutral bright pixels shift toward brand accent for cohesive glow
  - v5.15: Radial DOF — globe-centered oval focus replaces vertical tilt-shift for cinematic depth
  - v5.16: Premium scroll fade — smoothstep ease-out curve, lower ambient floor at 15%
  - v5.17: Wire up HUD Active Routes counter — was showing static 0 since v5.02 cleanup
  - v5.18: Star field smooth fade-in — uFade uniform, 1.5s entrance before globe coalesces
  - v5.19: Sun disk entrance fade — appears 0.5s after stars over 2s ramp
  - v5.20: HUD connector beam — thin glowing line linking data readout to globe surface
  - v5.21: Composite viewport mask — radial vignette intersected with left fade for cinematic framing
  - v5.22: Deep core heartbeat — ~42s cubic pulse visible at rim, rewards prolonged observation
  - v5.23: Enhanced scroll dispersal — bloom threshold drop, wider radius, desaturation, chroma spike

  Mobile (<768px): No WebGL. CSS mesh gradient fallback.
*/
---

<div class="globe-wrap" aria-hidden="true">
  <canvas id="globe-canvas"></canvas>
  <div class="hud-connector" aria-hidden="true"></div>
  <div class="globe-hud">
    <div class="hud-status">
      <span class="hud-status-dot"></span>
      <span class="hud-status-text">LIVE</span>
    </div>
    <div class="hud-metric">
      <span class="hud-label">NODES ONLINE</span>
      <span class="hud-value" id="hud-nodes">0</span>
    </div>
    <div class="hud-metric">
      <span class="hud-label">DATA THROUGHPUT</span>
      <span class="hud-value" id="hud-throughput">0<span class="hud-unit"> TB/s</span></span>
    </div>
    <div class="hud-metric">
      <span class="hud-label">LATENCY</span>
      <span class="hud-value" id="hud-latency">0<span class="hud-unit"> ms</span></span>
    </div>
    <div class="hud-metric">
      <span class="hud-label">ACTIVE ROUTES</span>
      <span class="hud-value" id="hud-routes">0</span>
    </div>
  </div>
</div>

<style>
  .globe-wrap {
    position: fixed;
    top: 0;
    right: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    will-change: opacity;
    transition: opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    /* v5.21: Composite mask — left fade + radial vignette for cinematic viewport */
    mask-image:
      linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%),
      radial-gradient(ellipse 85% 80% at 62% 48%, black 30%, rgba(0,0,0,0.7) 60%, transparent 85%);
    mask-composite: intersect;
    -webkit-mask-image:
      linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%),
      radial-gradient(ellipse 85% 80% at 62% 48%, black 30%, rgba(0,0,0,0.7) 60%, transparent 85%);
    -webkit-mask-composite: source-in;
  }
  .globe-wrap.ready { opacity: 1; }
  :global([data-theme="light"]) .globe-wrap.ready { opacity: 0.55; }
  #globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
    background:
      radial-gradient(
        ellipse 55% 50% at 65% 45%,
        rgba(0, 20, 40, 0.55) 0%,
        rgba(0, 10, 22, 0.35) 30%,
        rgba(2, 5, 12, 0.15) 55%,
        transparent 80%
      ),
      radial-gradient(
        ellipse 80% 70% at 60% 50%,
        rgba(0, 8, 20, 0.12) 0%,
        transparent 70%
      );
  }
  :global([data-theme="light"]) #globe-canvas {
    background: radial-gradient(
      ellipse 60% 55% at 65% 45%,
      rgba(200, 220, 240, 0.08) 0%,
      rgba(180, 200, 220, 0.04) 40%,
      transparent 70%
    );
  }
  /* Cinematic vignette */
  .globe-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: radial-gradient(
      ellipse 75% 70% at 55% 45%,
      transparent 40%,
      rgba(0, 0, 0, 0.15) 70%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }
  :global([data-theme="light"]) .globe-wrap::before {
    background: radial-gradient(
      ellipse 75% 70% at 55% 45%,
      transparent 40%,
      rgba(255, 255, 255, 0.1) 70%,
      rgba(255, 255, 255, 0.3) 100%
    );
  }
  /* v5.20: Connection beam — links HUD to globe surface */
  .hud-connector {
    position: absolute;
    bottom: calc(12% + 98px); /* Aligns to top of HUD */
    right: calc(8% + 10px);
    width: 1px;
    height: 50px;
    opacity: 0;
    transition: opacity 2s ease 2.8s;
    pointer-events: none;
    background: linear-gradient(to bottom, transparent 0%, rgba(0, 228, 255, 0.15) 30%, rgba(0, 228, 255, 0.4) 100%);
    box-shadow: 0 0 6px rgba(0, 228, 255, 0.08), 0 0 2px rgba(0, 228, 255, 0.2);
    transform: rotate(-15deg);
    transform-origin: bottom center;
  }
  .hud-connector::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: -2px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(0, 228, 255, 0.5);
    box-shadow: 0 0 8px rgba(0, 228, 255, 0.3);
  }
  .globe-wrap.ready .hud-connector { opacity: 0.6; }
  :global([data-theme="light"]) .hud-connector { display: none; }
  @media (max-width: 1023px) { .hud-connector { display: none; } }
  .globe-hud {
    position: absolute;
    bottom: 12%;
    right: 8%;
    display: flex;
    flex-direction: column;
    gap: 6px;
    opacity: 0;
    transition: opacity 2s ease 2.5s;
    pointer-events: none;
    background: linear-gradient(135deg, rgba(0, 12, 24, 0.45) 0%, rgba(0, 6, 14, 0.3) 100%);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    padding: 10px 14px 10px 12px;
    border: 1px solid rgba(0, 228, 255, 0.08);
    border-right: 1px solid rgba(0, 228, 255, 0.2);
    border-radius: 4px;
    box-shadow:
      0 0 15px rgba(0, 228, 255, 0.04),
      inset 0 0 20px rgba(0, 228, 255, 0.02);
    overflow: hidden;
  }
  /* Animated scan line sweeping across HUD */
  .globe-hud::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 228, 255, 0.06) 48%,
      rgba(0, 228, 255, 0.12) 50%,
      rgba(0, 228, 255, 0.06) 52%,
      transparent 100%
    );
    animation: hudScanLine 4s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes hudScanLine {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(200%); }
  }
  .globe-wrap.ready .globe-hud { opacity: 0.65; }
  :global([data-theme="light"]) .globe-hud {
    opacity: 0.35 !important;
    border-color: rgba(0, 0, 0, 0.06);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, rgba(240, 245, 250, 0.2) 100%);
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.03);
  }
  :global([data-theme="light"]) .globe-hud::after {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 0, 0, 0.02) 48%,
      rgba(0, 0, 0, 0.04) 50%,
      rgba(0, 0, 0, 0.02) 52%,
      transparent 100%
    );
  }
  .hud-metric {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-family: 'JetBrains Mono Variable', monospace;
  }
  .hud-label {
    font-size: 0.5rem;
    letter-spacing: 0.18em;
    color: var(--accent, #00e5ff);
    opacity: 0.45;
    text-transform: uppercase;
  }
  .hud-value {
    font-size: 0.9rem;
    color: var(--accent, #00e5ff);
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
    text-shadow: 0 0 8px rgba(0, 228, 255, 0.15);
  }
  .hud-unit {
    font-size: 0.6rem;
    opacity: 0.45;
  }
  .hud-status {
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: flex-end;
    margin-bottom: 4px;
  }
  .hud-status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent, #00e5ff);
    animation: hudBlink 2.5s ease-in-out infinite;
    box-shadow: 0 0 6px var(--accent, #00e5ff), 0 0 12px rgba(0, 228, 255, 0.15);
  }
  @keyframes hudBlink {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 1; }
  }
  .hud-status-text {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.2em;
    color: var(--accent, #00e5ff);
    opacity: 0.55;
    text-shadow: 0 0 6px rgba(0, 228, 255, 0.1);
  }
  @media (max-width: 1023px) {
    .globe-hud { display: none; }
  }
  @media (max-width: 767px) {
    .globe-wrap { display: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .globe-wrap {
      mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
      -webkit-mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
    }
  }
</style>

<script>
  (function () {
    if (window.innerWidth < 768) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const start = () => initGlobe(reduced).catch(e => console.error('[Globe] Init failed:', e));
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 2000 });
    } else {
      setTimeout(start, 300);
    }
  })();

  async function initGlobe(reducedMotion: boolean) {
    const wrap = document.querySelector('.globe-wrap') as HTMLDivElement;
    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
    if (!wrap || !canvas) return;

    const THREE = await import('three');
    const { EffectComposer } = await import('three/examples/jsm/postprocessing/EffectComposer.js');
    const { RenderPass } = await import('three/examples/jsm/postprocessing/RenderPass.js');
    const { UnrealBloomPass } = await import('three/examples/jsm/postprocessing/UnrealBloomPass.js');
    const { OutputPass } = await import('three/examples/jsm/postprocessing/OutputPass.js');
    const { FXAAPass } = await import('three/examples/jsm/postprocessing/FXAAPass.js');
    const { ShaderPass } = await import('three/examples/jsm/postprocessing/ShaderPass.js');

    // ── Theme colors via MutationObserver ──
    let themeColors = readThemeColors();
    function readThemeColors() {
      const s = getComputedStyle(document.documentElement);
      return {
        accent: s.getPropertyValue('--accent').trim() || '#00e5ff',
        accentSecondary: s.getPropertyValue('--accent-secondary').trim() || '#7B61FF',
        isLight: document.documentElement.getAttribute('data-theme') === 'light',
      };
    }
    const themeObserver = new MutationObserver(() => {
      themeColors = readThemeColors();
      outerAtmosMat.uniforms.uColor.value.set(themeColors.accent);
      outerAtmosMat.uniforms.uColorSecondary.value.set(themeColors.accentSecondary);
      innerRimMat.uniforms.uColor.value.set(themeColors.accent);
      dotMat.uniforms.uAccentColor.value.set(themeColors.accent);
      coreMat.uniforms.uAccent.value.set(themeColors.accent);
      coreMat.uniforms.uColor.value.set(themeColors.isLight ? '#e8eaed' : '#020208');
      arcMat.uniforms.uColor.value.set(themeColors.accent);
      sweepRingMat.uniforms.uColor.value.set(themeColors.accent);
      nodeMat.uniforms.uColor.value.set(themeColors.accent);
      coronaMat.uniforms.uColor.value.set(themeColors.accent);
      ringMat.uniforms.uColor.value.set(themeColors.accent);
      // v5.14: Sync accent to color grade pass for bloom tinting
      const accentCol = new THREE.Color(themeColors.accent);
      colorGradePass.uniforms.uAccentColor.value.set(accentCol.r, accentCol.g, accentCol.b);
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ── Scene ──
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, wrap.clientWidth / wrap.clientHeight, 0.1, 50);
    camera.position.set(0, 0, 2.8);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: false,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(wrap.clientWidth, wrap.clientHeight);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.4;

    // ── Post-Processing ──
    const composer = new EffectComposer(renderer);
    composer.addPass(new RenderPass(scene, camera));

    // v4.88: Half-resolution bloom — bloom is inherently soft, full-res wastes GPU
    // Internally UnrealBloomPass downsamples further for blur MIPs, so half-res input is visually identical
    const bloomRes = new THREE.Vector2(Math.floor(wrap.clientWidth / 2), Math.floor(wrap.clientHeight / 2));
    // v4.80: Richer bloom — lower threshold catches arcs/nodes/cities, wider radius for ethereal glow
    const bloomPass = new UnrealBloomPass(bloomRes, 0.22, 0.75, 0.62);
    composer.addPass(bloomPass);

    const fxaaPass = new FXAAPass();
    const pixelRatio = renderer.getPixelRatio();
    fxaaPass.uniforms['resolution'].value.set(1 / (wrap.clientWidth * pixelRatio), 1 / (wrap.clientHeight * pixelRatio));
    composer.addPass(fxaaPass);

    // Chromatic aberration + vignette (simplified — no streak, no DOF)
    const ChromaticAberrationShader = {
      name: 'ChromaticAberrationShader',
      uniforms: {
        tDiffuse: { value: null },
        uIntensity: { value: 0.003 },
        uTime: { value: 0 },
        uVignetteShift: { value: new THREE.Vector2(0, 0) },
        uSunScreenPos: { value: new THREE.Vector2(0.7, 0.4) },
        uGodRayIntensity: { value: 0.0 },
        uSunWarmth: { value: 0 },
      },
      vertexShader: `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform sampler2D tDiffuse;
        uniform float uIntensity;
        uniform float uTime;
        uniform vec2 uVignetteShift;
        uniform vec2 uSunScreenPos;
        uniform float uGodRayIntensity;
        uniform float uSunWarmth;
        varying vec2 vUv;
        void main() {
          vec2 center = vec2(0.5);
          vec2 dir = vUv - center;
          float dist = length(dir);
          float barrel = 1.0 + dist * dist * 0.03;
          vec2 warpedUv = center + dir * barrel;
          // v5.12: Film gate weave — imperceptible 35mm projector micro-drift
          warpedUv.y += sin(uTime * 0.7) * 0.00025 + sin(uTime * 1.1) * 0.00015;
          warpedUv.x += sin(uTime * 0.5 + 1.3) * 0.00012;
          // v5.04: Heat distortion — convective shimmer radiating from globe center
          // Concentrated in globe region, dissipates toward edges
          float heatMask = exp(-dist * dist * 6.0); // Strong near center, fades to edges
          float heatFreq1 = sin(vUv.y * 80.0 + uTime * 1.8) * cos(vUv.x * 60.0 + uTime * 1.2);
          float heatFreq2 = sin(vUv.y * 45.0 - uTime * 2.5 + vUv.x * 20.0) * 0.6;
          float heatFreq3 = cos(vUv.y * 120.0 + uTime * 3.2) * sin(vUv.x * 90.0 - uTime * 0.8) * 0.3;
          vec2 heatOffset = vec2(
            (heatFreq1 + heatFreq2 * 0.5) * 0.0006,
            (heatFreq1 + heatFreq3) * 0.0008  // Stronger vertical — heat rises
          ) * heatMask;
          warpedUv += heatOffset;
          float strength = dist * dist * uIntensity;
          vec2 offset = dir * strength;
          // v11.11: Enhanced edge separation — radial + tangential fringe
          vec2 tangent = vec2(-dir.y, dir.x) * strength * 0.3;
          float r = texture2D(tDiffuse, warpedUv + offset + tangent * 0.15).r;
          float g = texture2D(tDiffuse, warpedUv).g;
          float b = texture2D(tDiffuse, warpedUv - offset - tangent * 0.15).b;
          float a = texture2D(tDiffuse, warpedUv).a;
          // v11.55: Asymmetric sun-tracking vignette — opens toward sunlit side
          vec2 vigCenter = vec2(0.5) + uVignetteShift;
          vec2 vigDir = (vUv - vigCenter) * vec2(0.85, 1.1); // Widescreen oval
          float vigDist = length(vigDir);
          // v12.50: Enhanced tunnel vision — stronger vignette tightening during interaction
          float energyVignette = uIntensity * 35.0; // Stronger tunnel vision (was *25)
          // v12.12: Sun-responsive vignette intensity — darker when shadow side faces camera
          float sunVigShift = length(uVignetteShift) * 1.5; // Stronger vignette shift = sun more to the side
          float vignetteBreathe = 0.42 + sin(uTime * 0.3) * 0.03 + sin(uTime * 0.17) * 0.015 + energyVignette + sunVigShift * 0.06;
          float vignette = 1.0 - vigDist * vigDist * vignetteBreathe;
          vignette = max(vignette, 0.0);
          // Soft outer ring — darker at corners with deep falloff
          float cornerDark = smoothstep(0.35, 0.72, vigDist) * 0.2;
          float deepCorner = smoothstep(0.55, 0.85, vigDist) * 0.12;
          vignette -= cornerDark + deepCorner;
          vec3 col = vec3(r, g, b) * max(vignette, 0.0);
          // Chromatic vignette tint — warm center, cool blue edges
          float vignetteAmount = vigDist * vigDist * 0.12;
          col.r += vignetteAmount * 0.012;
          col.g -= vignetteAmount * 0.005;
          col.b -= vignetteAmount * 0.018;
          // Deep space blue in dark corners — cinematic atmosphere
          float cornerBlue = smoothstep(0.5, 0.85, vigDist) * 0.02;
          col.b += cornerBlue;
          // v11.31: Warm center spot — subtle golden radiance at frame center
          float centerWarm = exp(-vigDist * vigDist * 6.0) * 0.008;
          col.r += centerWarm;
          col.g += centerWarm * 0.5;
          // v5.15: Radial DOF — globe center sharp, periphery soft (replaces vertical tilt-shift)
          vec2 focusCenter = vec2(0.6, 0.47); // Globe center (offset right on desktop)
          float focusDist = length((vUv - focusCenter) * vec2(1.0, 1.3)); // Oval focus region
          float dofStrength = smoothstep(0.28, 0.65, focusDist) * 0.0016;
          if (dofStrength > 0.0001) {
            vec2 dofDir = normalize(vUv - focusCenter + 0.001); // Radial blur direction
            vec3 dofBlur = col;
            for (int j = 1; j <= 4; j++) {
              float fj = float(j);
              float w = exp(-fj * fj * 0.3);
              dofBlur += texture2D(tDiffuse, warpedUv + dofDir * dofStrength * fj).rgb * w;
              dofBlur += texture2D(tDiffuse, warpedUv - dofDir * dofStrength * fj).rgb * w;
            }
            dofBlur /= 3.235;
            col = mix(col, dofBlur, smoothstep(0.28, 0.65, focusDist));
          }
          // v4.89: Anamorphic lens streak — horizontal light smear from bright highlights
          // Samples along horizontal axis with exponential falloff, only from bright pixels
          vec3 streak = vec3(0.0);
          float streakLum = dot(col, vec3(0.299, 0.587, 0.114));
          // Only compute streak near bright areas (early exit saves GPU on dark pixels)
          if (streakLum > 0.08) {
            float pixelW = 1.0 / 1920.0; // Approximate — works at any resolution
            // 7-tap horizontal blur with wide spacing for cinematic stretch
            for (int i = 1; i <= 7; i++) {
              float fi = float(i);
              float weight = exp(-fi * fi * 0.08); // Gaussian falloff
              float spread = fi * pixelW * 28.0; // Wide spread for anamorphic look
              vec3 sL = texture2D(tDiffuse, vec2(warpedUv.x - spread, warpedUv.y)).rgb;
              vec3 sR = texture2D(tDiffuse, vec2(warpedUv.x + spread, warpedUv.y)).rgb;
              // Threshold — only bright pixels contribute to streak
              float lumL = max(dot(sL, vec3(0.299, 0.587, 0.114)) - 0.45, 0.0);
              float lumR = max(dot(sR, vec3(0.299, 0.587, 0.114)) - 0.45, 0.0);
              streak += sL * lumL * weight + sR * lumR * weight;
            }
            streak *= 0.06; // Subtle blend — premium, not garish
            // v5.11: Streak responds to golden hour — shifts from cool teal to warm amber
            vec3 streakTint = mix(vec3(0.7, 0.9, 1.0), vec3(1.0, 0.8, 0.5), uSunWarmth * 0.6);
            col += streak * streakTint;
          }
          // v4.90: Volumetric god rays — radial light shafts from sun screen position
          if (uGodRayIntensity > 0.01) {
            vec2 sunDir2D = vUv - uSunScreenPos;
            float sunDist2D = length(sunDir2D);
            vec2 rayDir = normalize(sunDir2D);
            vec3 godRay = vec3(0.0);
            float rayDecay = 1.0;
            float stepSize = 0.008; // Step toward sun
            vec2 samplePos = warpedUv;
            // 12 samples along ray toward sun — accumulate bright pixels
            for (int i = 0; i < 12; i++) {
              samplePos -= rayDir * stepSize;
              vec3 raySample = texture2D(tDiffuse, samplePos).rgb;
              float rayLum = dot(raySample, vec3(0.299, 0.587, 0.114));
              // Only bright pixels create god rays
              float rayContrib = max(rayLum - 0.35, 0.0);
              godRay += raySample * rayContrib * rayDecay;
              rayDecay *= 0.88; // Exponential falloff along ray
              stepSize *= 1.08; // Progressively wider steps
            }
            // Fade god rays with distance from sun (stronger near limb)
            float rayFalloff = exp(-sunDist2D * sunDist2D * 3.0);
            // v5.11: Golden hour god rays — richer amber during low sun, neutral at elevation
            vec3 rayNeutral = vec3(1.0, 0.88, 0.65);
            vec3 rayGolden = vec3(1.0, 0.68, 0.3); // Deep amber for golden hour
            vec3 rayTint = mix(rayNeutral, rayGolden, uSunWarmth);
            float goldenBoost = 1.0 + uSunWarmth * 0.5; // +50% stronger during golden hour
            col += godRay * rayTint * uGodRayIntensity * rayFalloff * 0.035 * goldenBoost;
          }
          // v4.93: Cinematic lens flare — ghost circles along sun→center axis
          if (uGodRayIntensity > 0.02) {
            vec2 flareAxis = vec2(0.5) - uSunScreenPos;
            float sunGlow = exp(-length(vUv - uSunScreenPos) * length(vUv - uSunScreenPos) * 18.0);
            vec3 sunGlowCol = mix(vec3(1.0, 0.92, 0.7), vec3(1.0, 0.78, 0.4), uSunWarmth);
            col += sunGlowCol * sunGlow * uGodRayIntensity * 0.04 * (1.0 + uSunWarmth * 0.3);
            for (int i = 1; i <= 3; i++) {
              float fi = float(i);
              vec2 ghostPos = uSunScreenPos + flareAxis * (fi * 0.35);
              float ghostDist = length(vUv - ghostPos);
              float ghostSize = 0.04 + fi * 0.02;
              float ghost = exp(-ghostDist * ghostDist / (ghostSize * ghostSize * 0.5));
              vec3 ghostTint = vec3(
                0.4 + 0.3 * sin(fi * 2.1),
                0.5 + 0.3 * sin(fi * 2.1 + 2.094),
                0.6 + 0.3 * sin(fi * 2.1 + 4.189)
              );
              col += ghostTint * ghost * uGodRayIntensity / (fi + 1.0) * 0.012;
            }
          }
          gl_FragColor = vec4(col, a);
        }
      `,
    };
    const chromaPass = new ShaderPass(ChromaticAberrationShader);
    composer.addPass(chromaPass);

    // Cinematic color grading — teal shadows / warm highlights
    const ColorGradeShader = {
      name: 'ColorGradeShader',
      uniforms: {
        tDiffuse: { value: null },
        uShadowTint: { value: new THREE.Vector3(0.0, 0.1, 0.18) },
        uHighlightTint: { value: new THREE.Vector3(0.08, 0.035, 0.0) },
        uContrast: { value: 1.12 },
        uSaturation: { value: 1.18 },
        uTime: { value: 0 },
        uSweepPulse: { value: 0 },
        uEntranceTemp: { value: 0 },
        uSunWarmth: { value: 0 },
        uAccentColor: { value: (() => { const c = new THREE.Color(themeColors.accent); return new THREE.Vector3(c.r, c.g, c.b); })() },
        uNoiseAtlas: { value: null },
        uColorLUT: { value: null },
      },
      vertexShader: `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform sampler2D tDiffuse;
        uniform vec3 uShadowTint;
        uniform vec3 uHighlightTint;
        uniform float uContrast;
        uniform float uSaturation;
        uniform float uTime;
        uniform float uSweepPulse;
        uniform float uEntranceTemp;
        uniform float uSunWarmth;
        uniform vec3 uAccentColor;
        uniform sampler2D uNoiseAtlas;
        uniform sampler2D uColorLUT;
        varying vec2 vUv;
        // v4.86: DGX GPU-baked 3D LUT sampling (64^3 in 8×8 grid = 512×512)
        vec3 sampleLUT(sampler2D lut, vec3 color) {
          float lutSize = 64.0;
          vec3 c = clamp(color, 0.0, 1.0) * (lutSize - 1.0);
          float blueSlice = floor(c.b);
          float blueSliceNext = min(blueSlice + 1.0, lutSize - 1.0);
          float blueFrac = c.b - blueSlice;
          // 8×8 grid layout
          float gridCols = 8.0;
          vec2 sliceUV = vec2(c.r, c.g) / lutSize;
          // First slice
          float row1 = floor(blueSlice / gridCols);
          float col1 = mod(blueSlice, gridCols);
          vec2 uv1 = (vec2(col1, row1) + sliceUV) / vec2(gridCols, lutSize / gridCols);
          // Second slice
          float row2 = floor(blueSliceNext / gridCols);
          float col2 = mod(blueSliceNext, gridCols);
          vec2 uv2 = (vec2(col2, row2) + sliceUV) / vec2(gridCols, lutSize / gridCols);
          // Trilinear interpolation
          vec3 lut1 = texture2D(lut, uv1).rgb;
          vec3 lut2 = texture2D(lut, uv2).rgb;
          return mix(lut1, lut2, blueFrac);
        }
        void main() {
          vec4 tex = texture2D(tDiffuse, vUv);
          vec3 col = tex.rgb;
          float lum = dot(col, vec3(0.2126, 0.7152, 0.0722));
          // v12.62: Entrance cold-to-warm arc — global blue shift during cold boot
          col.r *= 1.0 - uEntranceTemp * 0.25;
          col.g *= 1.0 + uEntranceTemp * 0.03;
          col.b *= 1.0 + uEntranceTemp * 0.18;
          // v4.86: DGX GPU-baked 3D color grading LUT — replaces manual math
          // LUT encodes: shadow/highlight tint, contrast, saturation, lift,
          // teal push, tone curve, ACES enhancement, shoulder compression
          vec3 lutGraded = sampleLUT(uColorLUT, col);
          // Blend 70% LUT (static grading) + 30% original (preserve headroom for dynamic effects)
          col = mix(col, lutGraded, 0.7);
          // v4.92: Restore dynamic grading on top of LUT — contrast, saturation, shadow/highlight tints
          // These animate during entrance, interaction, sweep, and backlit conditions
          float postLum = dot(col, vec3(0.2126, 0.7152, 0.0722));
          col = mix(vec3(postLum), col, uSaturation / 1.18); // Dynamic saturation (1.18 = neutral)
          col = mix(vec3(0.5), col, uContrast / 1.12); // Dynamic contrast (1.12 = neutral)
          col += uShadowTint * max(1.0 - postLum * 2.0, 0.0) * 0.3; // Shadow tint on darks
          col += uHighlightTint * max(postLum * 2.0 - 1.0, 0.0) * 0.5; // Highlight tint on brights
          // Dynamic warmth — subtle temperature shift that breathes (TIME-DEPENDENT, kept in shader)
          float warmBreathe = sin(uTime * 0.08) * 0.004;
          col.r += warmBreathe;
          col.b -= warmBreathe * 0.7;
          // v12.77: Blue-hour mood cycle — ultra-slow palette shift (golden hour ↔ blue hour)
          float moodPhase = sin(uTime * 0.025) * 0.5 + 0.5;
          float moodMask = smoothstep(0.1, 0.4, lum) * smoothstep(0.7, 0.4, lum);
          col.r += moodMask * (moodPhase - 0.5) * 0.006;
          col.b += moodMask * (0.5 - moodPhase) * 0.005;
          // v5.07: Golden hour global color grade — entire frame warms when sun is low
          // Shadows shift from teal toward amber, highlights warm, midtones gain golden tint
          float ghMid = smoothstep(0.08, 0.35, postLum) * smoothstep(0.7, 0.35, postLum); // Midtone mask
          float ghHighlight = smoothstep(0.4, 0.8, postLum); // Highlight mask
          col.r += uSunWarmth * (ghMid * 0.008 + ghHighlight * 0.005); // Golden midtones + warm highlights
          col.g += uSunWarmth * ghMid * 0.002; // Slight green boost for natural warmth
          col.b -= uSunWarmth * (ghMid * 0.006 + ghHighlight * 0.004); // Pull blue from entire frame
          // v11.14: Sweep-responsive warmth (TIME-DEPENDENT, kept in shader)
          float midMask = exp(-(lum - 0.35) * (lum - 0.35) * 12.0);
          float sweepWarm = uSweepPulse * 0.006;
          col.g -= midMask * sweepWarm * 0.5;
          col.b -= midMask * sweepWarm;
          col.r += midMask * sweepWarm;
          // v11.24: Accent glow preservation
          float chromaAmount = length(col - vec3(lum));
          float glowBoost = smoothstep(0.04, 0.12, chromaAmount) * smoothstep(0.15, 0.45, lum);
          col *= 1.0 + glowBoost * 0.10;
          // v5.14: Bloom accent tint — neutral bright pixels shift toward brand accent
          float bloomZone = smoothstep(0.35, 0.7, postLum); // Only affect bright areas
          float isNeutral = 1.0 - smoothstep(0.02, 0.08, chromaAmount); // Target achromatic bloom
          vec3 accentNudge = normalize(uAccentColor + 0.001) * postLum; // Accent-tinted luminance
          col = mix(col, mix(col, accentNudge, 0.08), bloomZone * isNeutral);
          // v12.43: Film halation
          float halationLum = max(col.r, max(col.g, col.b));
          float halationMask = smoothstep(0.5, 0.9, halationLum);
          vec3 halationWarm = mix(vec3(1.0, 0.82, 0.55), vec3(1.0, 0.72, 0.35), uSunWarmth); // Warmer halation during golden hour
          col = mix(col, col + halationWarm * halationMask * 0.04, halationMask);
          // v5.09: Micro-clarity — subtle unsharp mask for dot field definition
          // Sample neighbors and sharpen based on local contrast (enhances texture without ringing)
          float texelW = 1.0 / 1920.0;
          float texelH = 1.0 / 1080.0;
          vec3 nT = texture2D(tDiffuse, vUv + vec2(0.0, texelH)).rgb;
          vec3 nB = texture2D(tDiffuse, vUv - vec2(0.0, texelH)).rgb;
          vec3 nL = texture2D(tDiffuse, vUv - vec2(texelW, 0.0)).rgb;
          vec3 nR = texture2D(tDiffuse, vUv + vec2(texelW, 0.0)).rgb;
          vec3 blur = (nT + nB + nL + nR) * 0.25;
          vec3 sharp = col - blur; // High-frequency detail
          float sharpLum = dot(abs(sharp), vec3(0.333));
          // Only sharpen moderate detail (avoids boosting noise or halos)
          float clarityGate = smoothstep(0.002, 0.015, sharpLum) * smoothstep(0.06, 0.025, sharpLum);
          // Stronger clarity in midtones, subtler in darks/highlights
          float midtoneMask = smoothstep(0.05, 0.2, postLum) * smoothstep(0.8, 0.5, postLum);
          col += sharp * clarityGate * midtoneMask * 0.35;
          // v5.12: Film projector lamp flicker — imperceptible brightness micro-variation
          float lampFlicker = 1.0 + sin(uTime * 4.7) * 0.0015 + sin(uTime * 7.3) * 0.001;
          col *= lampFlicker;
          // v4.86: GPU blue noise film grain — perceptually uniform from DGX noise atlas
          vec2 grainUV = gl_FragCoord.xy / 1024.0 + vec2(fract(uTime * 7.3), fract(uTime * 3.1));
          float grain = texture2D(uNoiseAtlas, grainUV).r; // Blue noise channel
          float grain2 = texture2D(uNoiseAtlas, grainUV * 1.7 + 0.3).g; // Curl noise channel
          float grainVal = (grain + grain2 - 1.0) * 0.5; // Gaussian-ish distribution
          // v12.61: Sweep-responsive grain — sensor noise spikes during bright sweep flash
          float sweepGrainBoost = 1.0 + uSweepPulse * uSweepPulse * 1.5; // Up to 2.5x during sweep
          float grainResponse = mix(2.5, 1.0, smoothstep(0.0, 0.5, lum)) * sweepGrainBoost;
          col += grainVal * (grainResponse / 255.0);
          gl_FragColor = vec4(max(col, 0.0), tex.a);
        }
      `,
    };
    const colorGradePass = new ShaderPass(ColorGradeShader);
    composer.addPass(colorGradePass);

    composer.addPass(new OutputPass());

    const globeGroup = new THREE.Group();
    scene.add(globeGroup);

    // ── Pre-baked Globe Geometry (quantized v2 format) ──
    const isTablet = wrap.clientWidth < 1024;
    const binUrl = isTablet ? '/globe-tablet.bin' : '/globe-desktop.bin';
    const binData = await fetch(binUrl).then(r => r.arrayBuffer());
    const binView = new DataView(binData);
    const DOT_COUNT = binView.getUint32(0, true);
    const binVersion = binView.getUint16(4, true);
    let off: number;
    let dotPositions: Float32Array, dotSizes: Float32Array, dotOpacities: Float32Array;
    let dotPhases: Float32Array, dotColors: Float32Array, dotCityGlow: Float32Array;
    let dotRandom: Float32Array;

    if (binVersion === 2) {
      // Quantized format — dequantize to Float32 for GPU
      const posScale = binView.getFloat32(6, true);
      const sizeScale = binView.getFloat32(10, true);
      const sizeOffset = binView.getFloat32(14, true);
      off = 18;
      const TWO_PI = Math.PI * 2;

      // Positions: Int16 → Float32
      const rawPos = new Int16Array(binData, off, DOT_COUNT * 3); off += DOT_COUNT * 6;
      dotPositions = new Float32Array(DOT_COUNT * 3);
      const posInv = posScale / 32767;
      for (let i = 0; i < rawPos.length; i++) dotPositions[i] = rawPos[i] * posInv;

      // Sizes: Uint16 → Float32
      const rawSizes = new Uint16Array(binData, off, DOT_COUNT); off += DOT_COUNT * 2;
      dotSizes = new Float32Array(DOT_COUNT);
      const sizeInv = sizeScale / 65535;
      for (let i = 0; i < DOT_COUNT; i++) dotSizes[i] = rawSizes[i] * sizeInv + sizeOffset;

      // Opacities: Uint8 → Float32
      const rawOpac = new Uint8Array(binData, off, DOT_COUNT); off += DOT_COUNT;
      dotOpacities = new Float32Array(DOT_COUNT);
      for (let i = 0; i < DOT_COUNT; i++) dotOpacities[i] = rawOpac[i] / 255;

      // Phases: Uint16 → Float32
      const rawPhases = new Uint16Array(binData, off, DOT_COUNT); off += DOT_COUNT * 2;
      dotPhases = new Float32Array(DOT_COUNT);
      const phaseInv = TWO_PI / 65535;
      for (let i = 0; i < DOT_COUNT; i++) dotPhases[i] = rawPhases[i] * phaseInv;

      // Colors: Uint8 → Float32
      const rawColors = new Uint8Array(binData, off, DOT_COUNT * 3); off += DOT_COUNT * 3;
      dotColors = new Float32Array(DOT_COUNT * 3);
      for (let i = 0; i < rawColors.length; i++) dotColors[i] = rawColors[i] / 255;

      // CityGlow: Uint8 → Float32
      const rawGlow = new Uint8Array(binData, off, DOT_COUNT); off += DOT_COUNT;
      dotCityGlow = new Float32Array(DOT_COUNT);
      for (let i = 0; i < DOT_COUNT; i++) dotCityGlow[i] = rawGlow[i] / 255;

      // Random: Int8 → Float32
      const rawRand = new Int8Array(binData, off, DOT_COUNT * 3);
      dotRandom = new Float32Array(DOT_COUNT * 3);
      for (let i = 0; i < rawRand.length; i++) dotRandom[i] = rawRand[i] / 127;
    } else {
      // Legacy Float32 format (v1)
      off = 4;
      dotPositions = new Float32Array(binData, off, DOT_COUNT * 3); off += DOT_COUNT * 12;
      dotSizes = new Float32Array(binData, off, DOT_COUNT); off += DOT_COUNT * 4;
      dotOpacities = new Float32Array(binData, off, DOT_COUNT); off += DOT_COUNT * 4;
      dotPhases = new Float32Array(binData, off, DOT_COUNT); off += DOT_COUNT * 4;
      dotColors = new Float32Array(binData, off, DOT_COUNT * 3); off += DOT_COUNT * 12;
      dotCityGlow = new Float32Array(binData, off, DOT_COUNT); off += DOT_COUNT * 4;
      dotRandom = new Float32Array(binData, off, DOT_COUNT * 3);
    }

    const dotGeo = new THREE.BufferGeometry();
    dotGeo.setAttribute('position', new THREE.BufferAttribute(dotPositions, 3));
    dotGeo.setAttribute('aSize', new THREE.BufferAttribute(dotSizes, 1));
    dotGeo.setAttribute('aOpacity', new THREE.BufferAttribute(dotOpacities, 1));
    dotGeo.setAttribute('aPhase', new THREE.BufferAttribute(dotPhases, 1));
    dotGeo.setAttribute('aColor', new THREE.BufferAttribute(dotColors, 3));
    dotGeo.setAttribute('aCityGlow', new THREE.BufferAttribute(dotCityGlow, 1));
    dotGeo.setAttribute('aRandom', new THREE.BufferAttribute(dotRandom, 3));

    // ── Load Pre-Computed Textures (generated on DGX Spark) ──
    const texLoader = new THREE.TextureLoader();
    const nightLightsTex = texLoader.load('/textures/night-lights-2048.webp');
    nightLightsTex.minFilter = THREE.LinearFilter;
    nightLightsTex.magFilter = THREE.LinearFilter;
    nightLightsTex.wrapS = THREE.RepeatWrapping;
    nightLightsTex.wrapT = THREE.ClampToEdgeWrapping;
    const terrainNormalsTex = texLoader.load('/textures/terrain-normals-2048.webp');
    terrainNormalsTex.minFilter = THREE.LinearFilter;
    terrainNormalsTex.magFilter = THREE.LinearFilter;
    terrainNormalsTex.wrapS = THREE.RepeatWrapping;
    terrainNormalsTex.wrapT = THREE.ClampToEdgeWrapping;
    const noiseAtlasTex = texLoader.load('/textures/noise-atlas-1024.webp');
    noiseAtlasTex.minFilter = THREE.LinearFilter;
    noiseAtlasTex.magFilter = THREE.LinearFilter;
    noiseAtlasTex.wrapS = THREE.RepeatWrapping;
    noiseAtlasTex.wrapT = THREE.RepeatWrapping;
    const atmosLutTex = texLoader.load('/textures/atmosphere-lut.webp');
    atmosLutTex.minFilter = THREE.LinearFilter;
    atmosLutTex.magFilter = THREE.LinearFilter;
    atmosLutTex.wrapS = THREE.ClampToEdgeWrapping;
    atmosLutTex.wrapT = THREE.ClampToEdgeWrapping;
    const colorLutTex = texLoader.load('/textures/color-lut-64.webp');
    colorLutTex.minFilter = THREE.LinearFilter;
    colorLutTex.magFilter = THREE.LinearFilter;
    colorLutTex.wrapS = THREE.ClampToEdgeWrapping;
    colorLutTex.wrapT = THREE.ClampToEdgeWrapping;
    // Assign textures to color grade post-process (defined earlier)
    colorGradePass.uniforms.uNoiseAtlas.value = noiseAtlasTex;
    colorGradePass.uniforms.uColorLUT.value = colorLutTex;

    // v5.10: Shared sweep angle — computed once on CPU, passed to all 8 materials
    const sharedSweepAngle = { value: 0 };

    // ── Shared GLSL snippets (deduplicated from 3 identical copies) ──
    const GLSL_VALUE_NOISE = `
      float _nhash(vec3 p) {
        p = fract(p * vec3(443.897, 441.423, 437.195));
        p += dot(p, p.yzx + 19.19);
        return fract((p.x + p.y) * p.z);
      }
      float vnoise(vec3 p) {
        vec3 i = floor(p);
        vec3 f = fract(p);
        f = f * f * (3.0 - 2.0 * f);
        return mix(
          mix(mix(_nhash(i), _nhash(i + vec3(1,0,0)), f.x),
              mix(_nhash(i + vec3(0,1,0)), _nhash(i + vec3(1,1,0)), f.x), f.y),
          mix(mix(_nhash(i + vec3(0,0,1)), _nhash(i + vec3(1,0,1)), f.x),
              mix(_nhash(i + vec3(0,1,1)), _nhash(i + vec3(1,1,1)), f.x), f.y), f.z);
      }
    `;

    // ── Dot Vertex Shader ──
    const dotVertSrc = `
      attribute float aSize;
      attribute float aOpacity;
      attribute float aPhase;
      attribute vec3 aColor;
      attribute float aCityGlow;
      attribute vec3 aRandom;
      uniform float uTime;
      uniform float uBaseSize;
      uniform vec3 uAccentColor;
      uniform float uScroll;
      uniform vec3 uSunDir;
      uniform sampler2D uNightLights;
      uniform sampler2D uTerrainNormals;
      uniform sampler2D uNoiseAtlas;
      uniform vec3 uMouseWorld;
      uniform vec3 uSunColor;
      uniform float uSweepAngle;
      varying float vOpacity;
      varying vec3 vColor;
      varying float vMouseGlow;
      varying float vScanBoost;
      varying float vFresnel;
      varying float vSunLight;
      varying float vSunDotRaw;
      varying float vCityGlow;
      varying float vDepthHaze;
      varying float vCoastalHalo;
      varying float vTerminator;
      varying float vOceanGlint;
      varying float vDataPulse;
      varying float vPulseDistance;
      varying float vScanTrail;
      varying float vBacklit;
      varying float vIsOcean;
      varying float vNightLight;
      varying float vTerrainSlope;
      varying vec2 vGeoUV;
      void main() {
        vColor = aColor;
        float breath = sin(uTime * 0.3 + aPhase) * 0.025;
        float isCoastal = step(1.5, aSize) * step(1.0, aOpacity);
        vCoastalHalo = isCoastal;
        float coastWave = sin(aPhase * 8.0 + uTime * 1.8) * 0.003 * isCoastal;
        vec3 pos = position * (1.0 + breath + coastWave);

        // ── DGX Pre-Computed Texture Sampling ──
        // Equirectangular UV from sphere position (for texture lookups)
        vec3 posN = normalize(position);
        float geoU = atan(posN.z, posN.x) / (2.0 * 3.14159) + 0.5;
        float geoV = asin(clamp(posN.y, -1.0, 1.0)) / 3.14159 + 0.5;
        vGeoUV = vec2(geoU, 1.0 - geoV); // Flip V for texture convention

        // NASA night lights — real city data replacing 8 hardcoded cities
        float nightLightRaw = texture2D(uNightLights, vGeoUV).r;
        // Threshold to suppress sensor noise — only bright city areas
        vNightLight = smoothstep(0.25, 0.7, nightLightRaw);

        // Terrain normal map — adjust lighting based on surface slope
        vec3 terrainNormal = texture2D(uTerrainNormals, vGeoUV).rgb * 2.0 - 1.0;
        vTerrainSlope = 1.0 - abs(terrainNormal.z); // 0 = flat, 1 = steep slope (coastlines)
        // Terrain-adjusted sunlight: slopes facing sun are brighter
        float terrainSunMod = dot(terrainNormal, normalize(vec3(uSunDir.x, uSunDir.z, uSunDir.y))) * 0.15;

        // v11.87: Micro-turbulence — dots swim subtly, giving organic life to the surface
        float turbPhase = aPhase * 6.28 + uTime * 0.6;
        vec3 turbDir = normalize(cross(normalize(position), vec3(0.0, 1.0, 0.0)));
        pos += turbDir * sin(turbPhase) * 0.0015 + vec3(0.0, 1.0, 0.0) * cos(turbPhase * 1.3) * 0.001;

        vec4 mv = modelViewMatrix * vec4(pos, 1.0);
        float depth = -mv.z;

        // v4.97: Tighter backface culling — cleaner silhouette with 200k dots
        float backFade = smoothstep(3.2, 2.1, depth);
        // Atmospheric perspective + optical DOF fade
        vDepthHaze = smoothstep(1.8, 3.4, depth);

        vec3 posNorm = normalize(pos);
        vec3 camDir = vec3(0.0, 0.0, 1.0);
        float facing = dot(posNorm, camDir);
        float rimFade = smoothstep(-0.05, 0.25, facing);
        float faceDim = 0.12 + 0.88 * pow(1.0 - facing, 0.55);

        // Fresnel
        vFresnel = pow(1.0 - max(facing, 0.0), 2.2);

        // Day/night hemisphere
        vec3 sunDir = uSunDir; // Already normalized on CPU
        float sunDot = dot(posNorm, sunDir);
        vSunLight = smoothstep(-0.15, 0.5, sunDot);
        vSunDotRaw = sunDot; // v4.99: Raw sun dot for specular hotspot

        // Depth fog
        float depthFog = smoothstep(4.2, 2.0, depth);

        // Terminator glow — atmospheric scattering at day/night boundary
        float terminatorGlow = exp(-(sunDot - 0.1) * (sunDot - 0.1) / 0.025) * 0.6;
        vTerminator = terminatorGlow;

        // v4.83: Razor-sharp sweep for 200k density — tighter edge, richer afterglow
        float scanAngle = atan(posNorm.x, posNorm.z);
        float sweepAngle = uSweepAngle;
        float scanDist = mod(scanAngle - sweepAngle + 6.28318, 6.28318);
        // Leading edge — ultra-tight razor, cuts through dense surface
        float razorEdge = smoothstep(0.05, 0.0, scanDist) * 1.6;
        float leadEdge = smoothstep(0.4, 0.0, scanDist) * 1.1;
        // Primary trail — smooth accent decay
        float trail = smoothstep(2.5, 0.15, scanDist) * 0.50;
        // Phosphor persistence — wide afterglow
        float phosphor = smoothstep(4.2, 1.2, scanDist) * 0.16;
        float deepPersist = smoothstep(5.5, 2.8, scanDist) * 0.05;
        float scanRaw = max(max(razorEdge, leadEdge), max(trail, max(phosphor, deepPersist)));
        // v11.56: Sweep-sun interaction — brighter in sunlit hemisphere, dimmer in shadow
        float sweepSunMod = 0.85 + vSunLight * 0.3; // 0.85 in shadow, 1.15 in sun
        scanRaw *= sweepSunMod;
        vScanBoost = scanRaw * max(facing, 0.15);
        // Separate trail varying for color shifting in fragment
        vScanTrail = max(trail, max(phosphor, deepPersist)) * max(facing, 0.15);

        // Hemisphere brightness + terminator — raised night floor with blue moonlight
        // v11.46: Enhanced hemisphere contrast — brighter sun, dimmer shadow
        float nightAmbient = 0.15;
        float sunBoost = (0.38 + nightAmbient) + vSunLight * 0.50 + terminatorGlow + terrainSunMod;
        // Blue moonlight tint on night-side land — Earth-at-night atmospheric scatter
        float nightBlue = max(1.0 - vSunLight, 0.0) * 0.08;
        vColor = mix(vColor, vColor + vec3(-0.01, 0.01, 0.04), nightBlue);

        // Ocean sun glint — Blinn-Phong specular on water dots
        float isOcean = 1.0 - step(0.1, aOpacity);
        vIsOcean = isOcean;
        vec3 viewDir3 = normalize(cameraPosition - (modelMatrix * vec4(pos, 1.0)).xyz);
        vec3 halfDir = normalize(sunDir + viewDir3);
        float specAngle = max(dot(normalize(position), halfDir), 0.0);
        float glintSpec = pow(specAngle, 96.0) * 8.0;
        float glintBroad = pow(specAngle, 24.0) * 1.2;
        // v11.32: Wide sun reflection pool — visible sun mirror on ocean
        float glintPool = pow(specAngle, 8.0) * 0.4;
        // v12.51: Micro-facet glitter — individual ocean dots flash at stochastic angles
        float facetHash = texture2D(uNoiseAtlas, vGeoUV * 3.7 + vec2(uTime * 0.05, 0.0)).r;
        float microFacet = step(0.97, facetHash) * pow(specAngle, 4.0) * 15.0; // Rare, intense flashes
        vOceanGlint = (glintSpec + glintBroad + glintPool + microFacet) * isOcean * max(sunDot, 0.0);
        // v11.80: Ocean luminescence — animated wave-like brightness on ocean surface
        float oceanWave = sin(posNorm.x * 8.0 + uTime * 0.4) * cos(posNorm.z * 6.0 + uTime * 0.3) * 0.5 + 0.5;
        float oceanLum = isOcean * oceanWave * 0.03 * vSunLight; // Only visible on sunlit ocean
        // v12.32: Sub-surface caustics — interfering wave patterns create bright caustic ripples
        float caustic1 = sin(posNorm.x * 18.0 + posNorm.z * 12.0 + uTime * 0.7);
        float caustic2 = sin(posNorm.x * 14.0 - posNorm.z * 16.0 + uTime * 0.5);
        float causticPattern = pow(max(caustic1 * caustic2, 0.0), 2.0); // Sharp bright peaks
        // v12.85: Sweep-amplified caustics — scan beam energizes ocean caustic patterns
        float causticSweepAmp = 1.0 + scanRaw * 2.0; // Up to 3× during sweep
        float oceanCaustic = isOcean * causticPattern * 0.06 * vSunLight * causticSweepAmp;
        float glintBoost = 1.0 + vOceanGlint * 4.0 + oceanLum * 8.0 + oceanCaustic * 12.0;

        // v11.49: Backlit translucency — golden glow on silhouette dots when sun is behind globe
        float backlitSun = max(-sunDot, 0.0); // Strong when sun behind this dot
        float backlitRim = pow(1.0 - max(facing, 0.0), 2.5); // Only at silhouette edge
        vBacklit = backlitSun * backlitRim * 0.8;

        // City glow — NASA night lights + pre-baked city data on night side
        float nightFactor = 1.0 - vSunLight;
        float nightSquared = nightFactor * nightFactor; // Sharper night transition
        // Merge pre-baked 8-city glow with NASA worldwide night lights
        float nasaGlow = vNightLight * 0.7; // NASA texture (worldwide coverage)
        float mergedGlow = max(aCityGlow, nasaGlow); // Take strongest source
        vCityGlow = mergedGlow * (0.2 + nightSquared * 0.8);
        // v11.98: Urban flicker — irregular electrical activity simulation
        float flickerHash = texture2D(uNoiseAtlas, vGeoUV * 5.3).r;
        float urbanFlicker = 1.0 + (fract(sin(flickerHash * 43.7 + uTime * (3.0 + flickerHash * 8.0)) * 17.3) - 0.5) * vCityGlow * 0.3;
        float cityBoost = (1.0 + vCityGlow * (2.5 + nightSquared * 3.5)) * urbanFlicker;

        // v4.83: Data pulse waves — expanding rings from 5 global hubs (staggered timing)
        vec3 city0 = normalize(vec3(-0.527, 0.653, -0.543)); // NYC
        vec3 city1 = normalize(vec3(-0.001, 0.788, 0.616));  // London
        vec3 city2 = normalize(vec3(0.772, 0.579, -0.264));  // Tokyo
        vec3 city3 = normalize(vec3(0.554, 0.427, -0.712));  // Dubai
        vec3 city4 = normalize(vec3(-0.423, 0.614, 0.666));  // San Francisco
        float geodist0 = acos(clamp(dot(posNorm, city0), -1.0, 1.0));
        float geodist1 = acos(clamp(dot(posNorm, city1), -1.0, 1.0));
        float geodist2 = acos(clamp(dot(posNorm, city2), -1.0, 1.0));
        float geodist3 = acos(clamp(dot(posNorm, city3), -1.0, 1.0));
        float geodist4 = acos(clamp(dot(posNorm, city4), -1.0, 1.0));
        // Sharper wavefronts with wider reach and stronger gating
        float wave0 = sin(geodist0 * 10.0 - uTime * 1.8);
        float pulse0 = max(0.0, wave0) * exp(-geodist0 * 1.5) * (0.5 + 0.5 * sin(uTime * 0.3));
        pulse0 += max(0.0, -wave0) * exp(-geodist0 * 2.5) * 0.15;
        float wave1 = sin(geodist1 * 10.0 - uTime * 1.8 + 2.1);
        float pulse1 = max(0.0, wave1) * exp(-geodist1 * 1.5) * (0.5 + 0.5 * sin(uTime * 0.3 + 2.1));
        pulse1 += max(0.0, -wave1) * exp(-geodist1 * 2.5) * 0.15;
        float wave2 = sin(geodist2 * 10.0 - uTime * 1.8 + 4.2);
        float pulse2 = max(0.0, wave2) * exp(-geodist2 * 1.5) * (0.5 + 0.5 * sin(uTime * 0.3 + 4.2));
        pulse2 += max(0.0, -wave2) * exp(-geodist2 * 2.5) * 0.15;
        float wave3 = sin(geodist3 * 10.0 - uTime * 1.8 + 1.05);
        float pulse3 = max(0.0, wave3) * exp(-geodist3 * 1.5) * (0.5 + 0.5 * sin(uTime * 0.3 + 1.05));
        pulse3 += max(0.0, -wave3) * exp(-geodist3 * 2.5) * 0.15;
        float wave4 = sin(geodist4 * 10.0 - uTime * 1.8 + 3.15);
        float pulse4 = max(0.0, wave4) * exp(-geodist4 * 1.5) * (0.5 + 0.5 * sin(uTime * 0.3 + 3.15));
        pulse4 += max(0.0, -wave4) * exp(-geodist4 * 2.5) * 0.15;
        float rawPulse = max(max(max(pulse0, pulse1), max(pulse2, pulse3)), pulse4) * 0.65;
        // v11.10: Track closest city distance for pulse color gradient
        float maxP = max(max(max(pulse0, pulse1), max(pulse2, pulse3)), pulse4);
        float closestDist = pulse0 >= maxP - 0.001 ? geodist0 : (pulse1 >= maxP - 0.001 ? geodist1 : (pulse2 >= maxP - 0.001 ? geodist2 : (pulse3 >= maxP - 0.001 ? geodist3 : geodist4)));
        vPulseDistance = closestDist;
        // Gate: only land/coastal dots get full pulse (ocean too faint — pulse makes them visible noise)
        float pulseGate = smoothstep(0.05, 0.3, aOpacity);
        vDataPulse = rawPulse * pulseGate;
        float pulseBoost = 1.0 + vDataPulse * 1.5;

        // v4.84: Cursor proximity glow — dots near mouse brighten with accent spotlight
        float mouseDist = distance(posNorm, normalize(uMouseWorld));
        vMouseGlow = exp(-mouseDist * mouseDist * 60.0) * 0.8; // Tight Gaussian spotlight
        float mouseBoost = 1.0 + vMouseGlow * 2.0;

        // Per-dot shimmer — hash-driven twinkling at unique frequencies
        float shimmerHash = texture2D(uNoiseAtlas, vGeoUV * 7.1).r;
        float shimmerFreq = 0.8 + shimmerHash * 2.4; // 0.8-3.2 Hz variation
        float shimmerPhase = shimmerHash * 6.283;
        float shimmer = 0.88 + 0.12 * sin(uTime * shimmerFreq + shimmerPhase);
        // v12.74: Terminator shimmer amplification — twilight zone dots twinkle faster/stronger
        float termShimmerBoost = terminatorGlow * 0.15 * sin(uTime * (4.0 + shimmerHash * 6.0) + shimmerPhase);
        shimmer += termShimmerBoost;
        // City dots shimmer more — data activity flicker
        float cityShimmer = 1.0 + vCityGlow * (0.15 * sin(uTime * 4.5 + shimmerPhase) + 0.08 * sin(uTime * 7.2 + shimmerPhase * 2.3));

        // v10.94: Scan luminance wake — extended brightness trail behind sweep
        float scanWake = 1.0 + vScanTrail * 0.6; // Trail dots glow 60% brighter
        // v12.01: Altitude breathing layers — dots at different heights breathe at different rates
        float altBreathRate = 0.15 + shimmerHash * 0.2; // 0.15-0.35 Hz per dot
        float altBreathe = 0.96 + 0.04 * sin(uTime * altBreathRate + aPhase * 2.0);
        vOpacity = aOpacity * backFade * rimFade * depthFog * max(faceDim, vScanBoost * 1.5) * sunBoost * cityBoost * glintBoost * pulseBoost * shimmer * cityShimmer * scanWake * altBreathe * mouseBoost;

        float citySize = 1.0 + vCityGlow * 1.8;
        // v4.80: Refined depth perspective for 200k density — steeper falloff, tighter near
        float depthSize = 18.0 / (depth * depth * 0.42 + depth * 0.58);
        // v4.98: Stronger DOF size swell — edge dots grow for cinematic bokeh circles
        float dofSoften = smoothstep(2.0, 3.2, depth) * 0.35;
        depthSize *= (1.0 + dofSoften);
        float shimmerSize = 1.0 + (shimmer - 0.88) * 0.3; // Subtle size variation with shimmer
        // v10.90: Scan wave surface ripple — dots swell as sweep passes, creating pressure wave
        float scanWaveSize = 1.0 + vScanBoost * 0.35 + vScanTrail * 0.15;
        // v11.83: Latitude size variation — equatorial dots larger, polar dots compact
        float latitudeFactor = 1.0 - abs(posNorm.y);
        float latSize = 0.92 + latitudeFactor * 0.16; // 0.92 at poles, 1.08 at equator

        float mouseSize = 1.0 + vMouseGlow * 0.5; // Cursor-near dots swell
        gl_PointSize = max(aSize * uBaseSize * depthSize * (1.0 + vScanBoost * 0.6) * citySize * shimmerSize * scanWaveSize * latSize * mouseSize, 0.5);

        // ── Scroll Spiral Dispersal ──
        float rawScroll = smoothstep(100.0 / 700.0, 1.0, uScroll);
        // v11.77: Per-particle coalesce stagger — particles settle at different rates
        float particleDelay = aRandom.x * 0.15; // Up to 15% later
        float staggeredScroll = max(rawScroll - particleDelay, 0.0) / max(1.0 - particleDelay, 0.001);
        float scatter = staggeredScroll * staggeredScroll;

        if (scatter > 0.001) {
          float baseAngle = atan(pos.x, pos.z);
          float baseRadius = length(pos.xz);
          float equatorDist = abs(pos.y);

          // v11.37: Discrete spiral arms — particles attracted to 5 arm positions
          float armCount = 5.0;
          float armAngle = floor(baseAngle / (6.28318 / armCount) + 0.5) * (6.28318 / armCount);
          float armAttract = mix(baseAngle, armAngle, scatter * 0.6); // Gradually pulled into arms
          float twistRate = 3.0 + aRandom.x * 4.0;
          float spiralAngle = armAttract + scatter * twistRate * 3.14159;

          float expandRate = 0.4 + aRandom.y * 0.6;
          float expandRadius = baseRadius + scatter * scatter * 4.0 * expandRate * (1.0 - equatorDist * 0.4);

          float vertDrift = scatter * (sign(pos.y) * equatorDist * 2.5 + (aRandom.z - 0.5) * 1.5);

          vec3 spiralPos = vec3(
            sin(spiralAngle) * expandRadius,
            pos.y + vertDrift,
            cos(spiralAngle) * expandRadius
          );

          pos = mix(pos, spiralPos, scatter);
          mv = modelViewMatrix * vec4(pos, 1.0);

          vOpacity *= (1.0 - scatter * scatter);
          // v11.41: Dispersal size curve — initial growth (energy release) then shrink
          float disperseSize = 1.0 + scatter * 0.3 - scatter * scatter * 0.7; // Peak at scatter ~0.21
          gl_PointSize *= disperseSize;
          // Color temperature shift: accent → icy white-blue as energy dissipates
          vec3 warmAccent = uAccentColor * 1.3;
          vec3 icyBlue = vec3(0.7, 0.85, 1.0);
          vec3 disperseColor = mix(warmAccent, icyBlue, scatter * 0.6);
          vColor = mix(vColor, disperseColor, scatter * 0.45);
        }

        gl_Position = projectionMatrix * mv;
      }
    `;

    // ── Dot Fragment Shader ──
    const dotFragSrc = `
      uniform vec3 uAccentColor;
      uniform float uTime;
      uniform sampler2D uNoiseAtlas;
      uniform vec3 uSunColor;
      varying float vOpacity;
      varying vec3 vColor;
      varying float vScanBoost;
      varying float vFresnel;
      varying float vSunLight;
      varying float vSunDotRaw;
      varying float vCityGlow;
      varying float vDepthHaze;
      varying float vCoastalHalo;
      varying float vTerminator;
      varying float vOceanGlint;
      varying float vDataPulse;
      varying float vPulseDistance;
      varying float vScanTrail;
      varying float vBacklit;
      varying float vIsOcean;
      varying float vNightLight;
      varying float vTerrainSlope;
      varying float vMouseGlow;
      varying vec2 vGeoUV;
      void main() {
        float dist = length(gl_PointCoord - vec2(0.5));
        if (dist > 0.55) discard;
        // v4.98: Cinematic DOF — deeper bokeh with dramatic silhouette softness
        float sigma = 0.13 + vDepthHaze * 0.12; // 0.13 razor center → 0.25 dreamy edges
        float core = exp(-(dist * dist) / (2.0 * sigma * sigma));
        float aaRim = smoothstep(0.52, 0.44, dist);
        float halo = 0.04 / (dist * dist + 0.003) - 0.05;
        halo *= smoothstep(0.0, 0.18, dist);
        // Bokeh ring — subtle bright edge characteristic of photographic bokeh
        // v4.98: Depth-responsive bokeh ring — more visible on edge dots (DOF circles)
        float bokehRingBase = smoothstep(0.3, 0.42, dist) * smoothstep(0.5, 0.44, dist);
        float bokehRing = bokehRingBase * (0.15 + vDepthHaze * 0.20);
        float strength = core * 0.8 + max(halo, 0.0) * 0.3 * aaRim + bokehRing;
        if (strength < 0.005) discard;
        // Fresnel atmospheric scattering — sun-responsive rim color
        vec3 sunWarmFresnel = mix(uAccentColor, uSunColor * vec3(0.85, 0.55, 0.25), 0.3); // Sun-tinted rim
        vec3 shadowCoolFresnel = mix(uAccentColor, vec3(0.3, 0.2, 0.6), 0.4); // Violet rim on shadow side
        vec3 fresnelColor = mix(shadowCoolFresnel, sunWarmFresnel, vSunLight);
        // v11.23: Richer fresnel — stronger accent at rim edges for vivid silhouette
        vec3 baseCol = mix(vColor, fresnelColor, vFresnel * 0.65);
        // Sun hemisphere warm/cool shift
        vec3 warmTint = uSunColor * uAccentColor * 0.25;
        vec3 coolTint = vec3(0.01, 0.02, 0.07);
        baseCol += mix(coolTint, warmTint, vSunLight);
        // v11.30: Land warmth gradient — bright interior land dots subtly warmer
        float landBrightness = dot(vColor, vec3(0.299, 0.587, 0.114));
        float warmBlend = smoothstep(0.15, 0.5, landBrightness) * vSunLight * 0.08;
