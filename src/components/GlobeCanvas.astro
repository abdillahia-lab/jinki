---
/*
  GlobeCanvas v6.0 — "The Eye"
  Photorealistic Earth with LWIR thermal intelligence on the dark hemisphere.

  Architecture:
  - Textured sphere with NASA Blue Marble (day) + thermal false-color (night)
  - Physically-based Rayleigh atmosphere (BackSide sphere, r=1.025)
  - SRTM-derived normal map for terrain relief at silhouette
  - Semi-transparent cloud layer on separate sphere (r=1.005)
  - Thermal scan line on dark hemisphere (ONE animated element)
  - No post-processing. renderer.render(scene, camera) directly.
  - Dynamic import('three') — zero initial bundle cost
  - Mobile (<768px): No WebGL, CSS gradient fallback

  Textures (all in public/textures/):
  - earth-day.webp (4096x2048) — NASA Blue Marble, color-graded in shader
  - earth-thermal.webp (4096x2048) — NASA Black Marble → LWIR cyan palette
  - earth-normal.webp (4096x2048) — SRTM topography → Sobel normal map
  - earth-specular.webp (2048x1024) — Ocean reflectivity mask
  - earth-clouds.webp (2048x1024) — Cloud transparency layer
*/
---

<div class="globe-wrap" aria-hidden="true">
  <canvas id="globe-canvas"></canvas>
</div>

<style>
  .globe-wrap {
    position: fixed;
    top: 0;
    right: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    will-change: opacity;
    transition: opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    mask-image: linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%);
    -webkit-mask-image: linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%);
  }
  .globe-wrap.ready { opacity: 1; }
  :global([data-theme="light"]) .globe-wrap.ready { opacity: 0.45; }
  #globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 767px) {
    .globe-wrap { display: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .globe-wrap {
      mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
      -webkit-mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
    }
  }
</style>

<script>
  (function () {
    if (window.innerWidth < 768) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const start = () => initGlobe(reduced).catch(e => console.error('[Globe] Init failed:', e));
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 2000 });
    } else {
      setTimeout(start, 300);
    }
  })();

  async function initGlobe(reducedMotion: boolean) {
    const wrap = document.querySelector('.globe-wrap') as HTMLDivElement;
    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
    if (!wrap || !canvas) return;

    const THREE = await import('three');

    // ── Scene ──
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, wrap.clientWidth / wrap.clientHeight, 0.1, 50);
    camera.position.set(0, 0, 2.8);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(wrap.clientWidth, wrap.clientHeight);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    const globeGroup = new THREE.Group();
    scene.add(globeGroup);

    // ── Load Textures ──
    const loader = new THREE.TextureLoader();
    const loadTex = (url: string, wrap = true) => {
      const tex = loader.load(url);
      tex.minFilter = THREE.LinearFilter;
      tex.magFilter = THREE.LinearFilter;
      if (wrap) {
        tex.wrapS = THREE.RepeatWrapping;
        tex.wrapT = THREE.ClampToEdgeWrapping;
      }
      return tex;
    };

    const dayTex = loadTex('/textures/earth-day.webp');
    const thermalTex = loadTex('/textures/earth-thermal.webp');
    const normalTex = loadTex('/textures/earth-normal.webp');
    const specularTex = loadTex('/textures/earth-specular.webp');
    const cloudTex = loadTex('/textures/earth-clouds.webp');

    // ── Sun Direction (fixed, gentle) ──
    const sunDir = new THREE.Vector3(0.6, 0.3, 0.7).normalize();

    // ── Earth Material ──
    const earthGeo = new THREE.SphereGeometry(1, 64, 64);
    const earthMat = new THREE.ShaderMaterial({
      uniforms: {
        uDay: { value: dayTex },
        uThermal: { value: thermalTex },
        uNormal: { value: normalTex },
        uSpecular: { value: specularTex },
        uSunDir: { value: sunDir },
        uTime: { value: 0 },
      },
      vertexShader: `
        varying vec2 vUv;
        varying vec3 vNormal;
        varying vec3 vPosition;
        varying vec3 vWorldNormal;
        void main() {
          vUv = uv;
          vNormal = normalize(normalMatrix * normal);
          vWorldNormal = normalize(normal);
          vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform sampler2D uDay;
        uniform sampler2D uThermal;
        uniform sampler2D uNormal;
        uniform sampler2D uSpecular;
        uniform vec3 uSunDir;
        uniform float uTime;
        varying vec2 vUv;
        varying vec3 vNormal;
        varying vec3 vPosition;
        varying vec3 vWorldNormal;

        void main() {
          // Sample textures
          vec3 dayColor = texture2D(uDay, vUv).rgb;
          vec3 thermalColor = texture2D(uThermal, vUv).rgb;
          vec3 normalMap = texture2D(uNormal, vUv).rgb * 2.0 - 1.0;
          float specMask = texture2D(uSpecular, vUv).r;

          // Color-grade day side: warm sandstone land, deep navy ocean
          // Slight desaturation for photographic look
          float dayLum = dot(dayColor, vec3(0.299, 0.587, 0.114));
          dayColor = mix(vec3(dayLum), dayColor, 0.85); // 15% desaturation
          dayColor.r *= 1.05; // Warm shift
          dayColor.b *= 0.92; // Cool reduction

          // Perturb normal with normal map (TBN approximation)
          vec3 n = normalize(vNormal);
          // Simple tangent-space perturbation
          vec3 T = normalize(cross(n, vec3(0.0, 1.0, 0.0)));
          vec3 B = cross(n, T);
          float bumpStrength = 0.35;
          n = normalize(n + (T * normalMap.x + B * normalMap.y) * bumpStrength);

          // Day/night factor
          float sunDot = dot(vWorldNormal, uSunDir);
          // Sigmoid transition for realistic terminator
          float dayFactor = smoothstep(-0.15, 0.1, sunDot);

          // Diffuse lighting on day side
          float diffuse = max(dot(n, uSunDir), 0.0);
          float ambient = 0.06;
          vec3 dayLit = dayColor * (ambient + diffuse * 0.94);

          // Specular on oceans (Blinn-Phong)
          vec3 viewDir = normalize(-vPosition);
          vec3 halfDir = normalize(uSunDir + viewDir);
          float spec = pow(max(dot(n, halfDir), 0.0), 80.0) * specMask;
          dayLit += vec3(0.8, 0.85, 0.9) * spec * 0.6;

          // Thermal scan line on dark hemisphere
          float scanY = fract(uTime * 0.05); // Sweeps north to south over 20s
          float scanDist = abs(vUv.y - scanY);
          float scanLine = smoothstep(0.008, 0.0, scanDist) * (1.0 - dayFactor);
          // Hotspots pulse as scan passes
          float thermalLum = dot(thermalColor, vec3(0.299, 0.587, 0.114));
          float hotspotPulse = exp(-scanDist * scanDist * 8000.0) * thermalLum * 0.3;
          vec3 nightColor = thermalColor + thermalColor * hotspotPulse;
          // Scan line itself: thin white-cyan band
          nightColor += vec3(0.0, 0.9, 1.0) * scanLine * 0.15;

          // Terminator edge: warm amber band
          float terminator = exp(-(sunDot * sunDot) * 80.0);
          vec3 terminatorColor = vec3(1.0, 0.4, 0.15) * terminator * 0.25;

          // Blend day and night
          vec3 color = mix(nightColor, dayLit, dayFactor) + terminatorColor;

          // Fresnel rim darkening (atmosphere absorbs at edges)
          float facing = max(dot(viewDir, vNormal), 0.0);
          float rim = 1.0 - facing;
          color *= (0.7 + 0.3 * facing); // Edges slightly darker

          gl_FragColor = vec4(color, 1.0);
        }
      `,
    });
    const earth = new THREE.Mesh(earthGeo, earthMat);
    globeGroup.add(earth);

    // ── Atmosphere (Rayleigh scattering) ──
    const atmosGeo = new THREE.SphereGeometry(1.025, 64, 64);
    const atmosMat = new THREE.ShaderMaterial({
      uniforms: {
        uSunDir: { value: sunDir },
      },
      vertexShader: `
        varying vec3 vNormal;
        varying vec3 vPosition;
        varying vec3 vWorldNormal;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vWorldNormal = normalize(normal);
          vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uSunDir;
        varying vec3 vNormal;
        varying vec3 vPosition;
        varying vec3 vWorldNormal;
        void main() {
          vec3 viewDir = normalize(-vPosition);
          float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
          float sunFacing = dot(vWorldNormal, uSunDir);

          // Rayleigh-inspired scattering: blue on sunlit limb, dim on dark side
          float scatter = pow(rim, 3.0) * 0.6;

          // Color varies with sun angle
          vec3 sunLimb = vec3(0.27, 0.53, 1.0); // Blue
          vec3 darkLimb = vec3(0.1, 0.07, 0.25); // Deep violet, barely visible
          vec3 termLimb = vec3(1.0, 0.4, 0.2); // Sunset orange

          float sunSide = smoothstep(-0.2, 0.5, sunFacing);
          float termBand = exp(-(sunFacing * sunFacing) * 40.0);

          vec3 atmosColor = mix(darkLimb, sunLimb, sunSide);
          atmosColor = mix(atmosColor, termLimb, termBand * 0.6);

          float alpha = scatter * (0.3 + sunSide * 0.7);
          gl_FragColor = vec4(atmosColor, alpha);
        }
      `,
      transparent: true,
      side: THREE.BackSide,
      depthWrite: false,
    });
    globeGroup.add(new THREE.Mesh(atmosGeo, atmosMat));

    // ── Clouds ──
    const cloudGeo = new THREE.SphereGeometry(1.005, 64, 64);
    const cloudMat = new THREE.ShaderMaterial({
      uniforms: {
        uClouds: { value: cloudTex },
        uSunDir: { value: sunDir },
      },
      vertexShader: `
        varying vec2 vUv;
        varying vec3 vWorldNormal;
        void main() {
          vUv = uv;
          vWorldNormal = normalize(normal);
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform sampler2D uClouds;
        uniform vec3 uSunDir;
        varying vec2 vUv;
        varying vec3 vWorldNormal;
        void main() {
          vec4 cloud = texture2D(uClouds, vUv);
          float sunDot = dot(vWorldNormal, uSunDir);
          // Clouds visible on day side, dim on night
          float dayFactor = smoothstep(-0.1, 0.2, sunDot);
          // Slight blue tint on shadow side
          vec3 cloudColor = mix(vec3(0.15, 0.2, 0.35), vec3(1.0), dayFactor);
          float alpha = cloud.a * 0.25 * (0.15 + dayFactor * 0.85);
          gl_FragColor = vec4(cloudColor, alpha);
        }
      `,
      transparent: true,
      depthWrite: false,
    });
    const cloudMesh = new THREE.Mesh(cloudGeo, cloudMat);
    globeGroup.add(cloudMesh);

    // ── Minimal Star Field ──
    const STAR_COUNT = 400;
    const starPositions = new Float32Array(STAR_COUNT * 3);
    const starSizes = new Float32Array(STAR_COUNT);
    for (let i = 0; i < STAR_COUNT; i++) {
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const r = 8 + Math.random() * 10;
      starPositions[i * 3] = Math.sin(phi) * Math.cos(theta) * r;
      starPositions[i * 3 + 1] = Math.sin(phi) * Math.sin(theta) * r;
      starPositions[i * 3 + 2] = Math.cos(phi) * r;
      starSizes[i] = 0.3 + Math.random() * 0.8;
    }
    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
    starGeo.setAttribute('aSize', new THREE.BufferAttribute(starSizes, 1));
    const starMat = new THREE.ShaderMaterial({
      uniforms: {},
      vertexShader: `
        attribute float aSize;
        void main() {
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = aSize * (200.0 / -mv.z);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        void main() {
          float d = length(gl_PointCoord - vec2(0.5));
          if (d > 0.5) discard;
          float alpha = exp(-d * d * 20.0) * 0.12;
          gl_FragColor = vec4(1.0, 1.0, 1.0, alpha);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    scene.add(new THREE.Points(starGeo, starMat));

    // ── Cached DOM Values ──
    let cachedScrollY = window.scrollY;
    let cachedInnerHeight = window.innerHeight;
    let cachedWrapWidth = wrap.clientWidth;
    let cachedWrapHeight = wrap.clientHeight;
    window.addEventListener('scroll', () => { cachedScrollY = window.scrollY; }, { passive: true });
    window.addEventListener('resize', () => { cachedInnerHeight = window.innerHeight; }, { passive: true });
    function updateCachedSize() {
      cachedWrapWidth = wrap.clientWidth;
      cachedWrapHeight = wrap.clientHeight;
    }

    // ── Interaction: Drag to Rotate ──
    let isDragging = false;
    let dragVelocityX = 0, dragVelocityY = 0;
    let prevPointerX = 0, prevPointerY = 0;
    const DRAG_FRICTION = 0.94;

    canvas.style.pointerEvents = 'auto';
    wrap.style.pointerEvents = 'none';

    canvas.addEventListener('pointerdown', (e) => {
      isDragging = true;
      prevPointerX = e.clientX;
      prevPointerY = e.clientY;
      canvas.setPointerCapture(e.pointerId);
    });
    canvas.addEventListener('pointermove', (e) => {
      if (!isDragging) return;
      const dx = e.clientX - prevPointerX;
      const dy = e.clientY - prevPointerY;
      dragVelocityX = dx * 0.003;
      dragVelocityY = dy * 0.001;
      prevPointerX = e.clientX;
      prevPointerY = e.clientY;
    });
    canvas.addEventListener('pointerup', () => { isDragging = false; });
    canvas.addEventListener('pointercancel', () => { isDragging = false; });

    // ── Visibility Skip ──
    let globeVisible = true;
    const visObserver = new IntersectionObserver(([e]) => {
      globeVisible = e.isIntersecting;
    }, { threshold: 0.01 });
    visObserver.observe(wrap);

    // ── Animation ──
    let animId = 0;
    let time = 0;
    let prevTimestamp = 0;

    function animate(timestamp: number) {
      animId = requestAnimationFrame(animate);

      if (!globeVisible && time > 3) {
        prevTimestamp = timestamp;
        return;
      }

      const dt = prevTimestamp ? Math.min((timestamp - prevTimestamp) / 1000, 0.1) : 0.016;
      prevTimestamp = timestamp;
      time += dt;

      // Auto-rotation
      if (!reducedMotion) {
        const autoSpeed = isDragging ? 0 : 0.0008;
        globeGroup.rotation.y += autoSpeed;

        // Drag momentum
        if (!isDragging) {
          globeGroup.rotation.y += dragVelocityX;
          globeGroup.rotation.x += dragVelocityY;
          globeGroup.rotation.x = Math.max(-0.5, Math.min(0.5, globeGroup.rotation.x));
          dragVelocityX *= DRAG_FRICTION;
          dragVelocityY *= DRAG_FRICTION;
        }

        // Cloud layer rotates independently (very slow)
        cloudMesh.rotation.y += 0.00003;
      }

      // Update uniforms
      earthMat.uniforms.uTime.value = time;

      // Scroll fade
      const scrollFade = 1.0 - smoothstep(0, cachedInnerHeight * 0.7, cachedScrollY);
      wrap.style.opacity = String(Math.max(0, scrollFade));

      // Position globe
      const isDesktop = cachedWrapWidth >= 1024;
      const baseScale = isDesktop ? 1.1 : 0.85;
      globeGroup.scale.setScalar(baseScale);
      if (isDesktop) {
        globeGroup.position.set(0.9, 0.05, 0);
      }

      // Entrance: simple dolly
      if (time < 2.0) {
        const t = Math.min(time / 2.0, 1.0);
        const ease = 1.0 - Math.pow(1.0 - t, 4);
        camera.position.z = 4.0 + (2.8 - 4.0) * ease;
        wrap.style.opacity = String(Math.min(scrollFade, ease));
      } else {
        camera.position.z = 2.8;
      }

      camera.lookAt(0, 0, 0);

      // Render directly — no post-processing
      renderer.render(scene, camera);
    }

    function smoothstep(edge0: number, edge1: number, x: number): number {
      const t = Math.max(0, Math.min(1, (x - edge0) / (edge1 - edge0)));
      return t * t * (3 - 2 * t);
    }

    // ── Resize ──
    const ro = new ResizeObserver(() => {
      updateCachedSize();
      const w = cachedWrapWidth;
      const h = cachedWrapHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
    });
    ro.observe(wrap);

    // ── Launch ──
    animate(0);
    setTimeout(() => {
      wrap.classList.add('ready');
      wrap.dispatchEvent(new CustomEvent('globe-ready', { bubbles: true }));
    }, 80);

    // ── Cleanup ──
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
      visObserver.disconnect();
      renderer.dispose();
      earthGeo.dispose();
      earthMat.dispose();
      atmosGeo.dispose();
      atmosMat.dispose();
      cloudGeo.dispose();
      cloudMat.dispose();
      starGeo.dispose();
      starMat.dispose();
      dayTex.dispose();
      thermalTex.dispose();
      normalTex.dispose();
      specularTex.dispose();
      cloudTex.dispose();
    }, { once: true });
  }
</script>
