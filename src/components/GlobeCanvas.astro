          float disp = vnoise(n * 2.5 + uTime * 0.08) * 0.038
                     + vnoise(n * 5.0 - uTime * 0.06) * 0.020
                     + vnoise(n * 10.0 + uTime * 0.12) * 0.009
                     + vnoise(n * 18.0 + uTime * 0.15) * 0.004;
          // Sweep-reactive bulge — atmosphere swells where scan beam passes
          float scanAngle = atan(n.x, n.z);
