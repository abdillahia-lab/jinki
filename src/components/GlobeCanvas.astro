    globeGroup.add(new THREE.Mesh(outerAtmosGeo, outerAtmosMat));

    // Shell 2: Inner rim (FrontSide, 1.005r)
    const innerRimGeo = new THREE.IcosahedronGeometry(1.005, 48);
    const innerRimMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
