          float irScanAngle = atan(vWorldNormal.x, vWorldNormal.z);
          float irScanDist = mod(irScanAngle - sweepAngleIR + 6.28318, 6.28318);
          float sweepBreathBoost = smoothstep(1.0, 0.0, irScanDist) * 0.08; // Breathing amplitude spike
          float breathe = 1.0 + (sin(uTime * 0.25) * 0.08 + sin(uTime * 0.13) * 0.04) * (1.0 + sweepBreathBoost);
          glow *= breathe;
          // Rayleigh scattering — full spectrum: violet shadow → cyan accent → warm amber terminator
          vec3 sunDir = uSunDir; // Already normalized on CPU
          float sunFacing = dot(normalize(vWorldNormal), sunDir);
          vec3 deepViolet = vec3(0.2, 0.1, 0.55);
          vec3 twilightCyan = vec3(0.15, 0.5, 0.65);
          vec3 shadowTint = mix(deepViolet, twilightCyan, smoothstep(-0.5, -0.1, sunFacing));
          vec3 terminatorWarm = vec3(0.9, 0.5, 0.2);
          vec3 rimColor = mix(shadowTint, uColor, smoothstep(-0.1, 0.5, sunFacing));
          // v12.04: Wider terminator — dual-band amber core + rose twilight fringe
          float termBand = exp(-(sunFacing - 0.05) * (sunFacing - 0.05) / 0.025); // Wider amber core
          vec3 twilightRose = vec3(0.85, 0.35, 0.3);
          float roseFringe = exp(-(sunFacing + 0.1) * (sunFacing + 0.1) / 0.04); // Rose on shadow side
