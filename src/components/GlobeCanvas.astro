          float tendrilGlow = excitedTendril * rim * 0.11; // v4.91: +37% visibility
          glow += tendrilGlow;
          vec3 tendrilHot = mix(uColor * 1.4, vec3(1.0, 0.95, 0.85), min(sweepExcite * 0.6, 0.7));
          coronaCol = mix(coronaCol, tendrilHot, tendrilGlow * 2.5);
          // v12.71: Corona micro-oscillation — rapid brightness flutter (coronal loop dynamics)
          float loopFlutter = sin(uTime * 7.0 + worldN.x * 20.0) * sin(uTime * 5.3 + worldN.z * 15.0);
          glow *= 1.0 + loopFlutter * rim * 0.06;
          gl_FragColor = vec4(coronaCol, glow);
        }
      `,
      side: THREE.BackSide,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const coronaMesh = new THREE.Mesh(coronaGeo, coronaMat);
    globeGroup.add(coronaMesh);

    // ── Scan Sweep Ring — visible rotating radar line ──
    // v11.39: Wider sweep arc for visible trailing wash
    const sweepRingGeo = new THREE.RingGeometry(0.96, 1.2, 128, 1, 0, 0.18);
    const sweepRingMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
        uPulse: { value: 0 },
        uSunWarmth: { value: 0.5 },
      },
      vertexShader: `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform float uTime;
        uniform float uPulse;
        uniform float uSunWarmth;
        varying vec2 vUv;
        void main() {
          // Leading edge — white-hot razor line (at the front of the wider arc)
          // v12.00: Leading edge energy discharge — stochastic sparking at razor front
          float sparkHash = fract(sin(uTime * 37.1 + vUv.y * 127.3) * 43758.5);
          float sparkle = step(0.85, sparkHash) * smoothstep(0.88, 0.98, vUv.x) * 2.0;
          float leadBright = smoothstep(0.7, 0.95, vUv.x) + sparkle;
          // Primary glow — accent-colored body
          float bodyGlow = smoothstep(0.0, 0.1, vUv.x) * smoothstep(1.0, 0.4, vUv.x);
          // v12.45: Ionization wake — decaying electromagnetic ripples behind leading edge
          float trailWash = smoothstep(0.5, 0.0, vUv.x) * 0.25;
          float wakeRipple = sin(vUv.x * 40.0 + uTime * 3.0) * 0.5 + 0.5;
          float wakeDecay = smoothstep(0.6, 0.1, vUv.x); // Fades toward tail
          float ionWake = wakeRipple * wakeDecay * (1.0 - vUv.x) * 0.12;
          trailWash += ionWake;
          // Radial profile — tight core at globe surface + wide soft halo
          // v12.80: Radial breathing — core focus oscillates between tight and diffuse
          float radialBreathe = 25.0 + sin(uTime * 0.6) * 4.0; // 21-29 tightness
          float radialCore = exp(-pow(vUv.y - 0.3, 2.0) * radialBreathe);
          float radialHalo = exp(-pow(vUv.y - 0.35, 2.0) * 6.0) * 0.4;
          // v12.34: Inner edge contact glow — bright accent line where beam touches globe
          float contactEdge = exp(-pow(vUv.y - 0.08, 2.0) * 200.0) * 0.6; // Tight line near inner edge
          // v12.84: Contact sparks — stochastic bright flashes at globe-beam interface
          float sparkSeed = fract(sin(uTime * 23.7 + vUv.x * 87.3 + vUv.y * 53.1) * 43758.5);
          float contactSpark = step(0.94, sparkSeed) * contactEdge * 3.0;
          float radialShape = radialCore + radialHalo + contactEdge + contactSpark;
          // Intensity breathing — synced with sweep cycle
          float breathe = 0.9 + sin(uTime * 0.4) * 0.1;
          // v11.01: Camera-facing pulse — brighter when sweep passes camera-facing side
          float facingPulse = 1.0 + uPulse * 0.6;
          float alpha = (bodyGlow + leadBright * 0.8 + trailWash) * radialShape * 0.45 * breathe * facingPulse;
          // v11.63: Color: sun-responsive — warm gold in sunlight, cool blue in shadow
          vec3 warmWhite = vec3(1.0, 0.92, 0.75);
          vec3 coolWhite = vec3(0.85, 0.92, 1.0);
          vec3 hotWhite = mix(coolWhite, warmWhite, uSunWarmth);
          vec3 warmAccent = mix(uColor, uColor * vec3(1.15, 0.95, 0.8), uSunWarmth * 0.3);
          vec3 col = mix(warmAccent * 1.3, hotWhite, leadBright * 0.65);
          // v12.24: Trail color temperature decay — hot lead → accent → warm amber tail
          float trailAge = 1.0 - vUv.x; // 0 at lead, 1 at tail
          vec3 agedAmber = mix(uColor, vec3(0.75, 0.5, 0.2), 0.5); // Phosphor amber
          col = mix(col, agedAmber, trailAge * trailAge * 0.4);
          // Radial edge tint — outer edge shifts slightly warmer
          col = mix(col, col * vec3(1.1, 0.95, 0.85), smoothstep(0.5, 0.9, vUv.y) * 0.2);
          // v12.68: Echo harmonic — faint secondary pulse trailing behind main sweep
          float echoPos = vUv.x * 2.0 - 0.3; // Shifted and scaled to appear mid-trail
          float echoLine = exp(-echoPos * echoPos * 80.0) * 0.15; // Narrow, faint
          alpha += echoLine * radialShape * breathe * facingPulse;
          gl_FragColor = vec4(col * 1.8, alpha);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      side: THREE.DoubleSide,
    });
    const sweepRing = new THREE.Mesh(sweepRingGeo, sweepRingMat);
    sweepRing.rotation.x = Math.PI / 2; // Lay flat (XZ plane)
    globeGroup.add(sweepRing);

    // ── Arc Routes — great-circle data flows between cities ──
    const arcPairs: [number, number, number, number][] = [
      // Tier 1: Major intercontinental corridors
      [40.7, -74.0, 51.5, -0.1],    // NYC → London
      [51.5, -0.1, 25.3, 55.3],     // London → Dubai
      [25.3, 55.3, 1.35, 103.8],    // Dubai → Singapore
      [1.35, 103.8, 35.7, 139.7],   // Singapore → Tokyo
      [35.7, 139.7, 22.3, 114.2],   // Tokyo → Hong Kong
      [48.9, 2.35, 40.7, -74.0],    // Paris → NYC
      // Tier 2: Global mesh — dense network topology
      [37.8, -122.4, 35.7, 139.7],  // San Francisco → Tokyo
      [40.7, -74.0, -23.5, -46.6],  // NYC → São Paulo
      [51.5, -0.1, 19.1, 72.9],     // London → Mumbai
      [22.3, 114.2, -33.9, 151.2],  // Hong Kong → Sydney
      [-33.9, 151.2, 1.35, 103.8],  // Sydney → Singapore
      [25.3, 55.3, 6.5, 3.4],       // Dubai → Lagos
      [48.9, 2.35, 35.7, 139.7],    // Paris → Tokyo
      [37.8, -122.4, 51.5, -0.1],   // San Francisco → London
      [19.1, 72.9, 35.7, 139.7],    // Mumbai → Tokyo
      [-23.5, -46.6, 6.5, 3.4],     // São Paulo → Lagos
    ];

    function latLngToVec3(lat: number, lng: number, r: number): THREE.Vector3 {
      const phi = (90 - lat) * Math.PI / 180;
      const theta = (lng + 180) * Math.PI / 180;
      return new THREE.Vector3(
        -r * Math.sin(phi) * Math.cos(theta),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.sin(theta)
      );
    }

    // v4.82: Higher arc resolution — smoother curves for long trans-oceanic routes
    const ARC_SEGMENTS = 128;
    const arcGeometries: THREE.BufferGeometry[] = [];
    const arcMeshes: THREE.Mesh[] = [];

    const arcMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accent) },
        uSunDir: { value: new THREE.Vector3(0.6, 0.4, 0.8).normalize() },
        uSweepAngle: sharedSweepAngle,
      },
      vertexShader: `
        attribute float aT;
        attribute float aPhase;
        attribute float aRadial;
        uniform float uTime;
        uniform vec3 uSunDir;
        uniform float uSweepAngle;
        varying float vT;
        varying float vFacing;
        varying float vPhase;
        varying float vRadial;
        varying float vArcSunLight;
        varying float vSweepHit;
        void main() {
          vT = aT;
          vPhase = aPhase;
          vRadial = aRadial;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          vec3 posNorm = normalize(position);
          vFacing = dot(posNorm, vec3(0.0, 0.0, 1.0));
          // v11.57: Arc sun interaction
          vArcSunLight = smoothstep(-0.1, 0.5, dot(posNorm, uSunDir));
          // v12.88: Sweep-arc intersection — flash when scan beam crosses arc
          float arcAngle = atan(posNorm.x, posNorm.z);
          float sweepAngle = uSweepAngle;
          float sweepDist = mod(arcAngle - sweepAngle + 6.28318, 6.28318);
          vSweepHit = exp(-sweepDist * sweepDist * 25.0); // Tight Gaussian at sweep position
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform float uTime;
        uniform vec3 uColor;
        varying float vT;
        varying float vFacing;
        varying float vPhase;
        varying float vRadial;
        varying float vArcSunLight;
        varying float vSweepHit;
        void main() {
          // Backface culling — hide arcs on far side
          if (vFacing < -0.05) discard;
          float faceFade = smoothstep(-0.05, 0.2, vFacing);
          // Radial glow — width varies along arc (thicker at apex, thinner at ends)
          float arcWidthMod = 1.0 + sin(vT * 3.14159) * 0.35; // +35% at midpoint
          float radDist = abs(vRadial) / arcWidthMod;
          // v11.94: Arc pressure pulsation — core width breathes with data flow rhythm
          float pressurePulse = sin(uTime * 1.5 + vPhase * 4.0) * 0.03 + sin(uTime * 0.6 + vPhase * 2.0) * 0.02;
          float coreWidth = 0.25 + pressurePulse;
          float coreLine = smoothstep(coreWidth, 0.0, radDist);
          float haloFalloff = exp(-radDist * radDist * 3.0);
          // v12.28: Apex scatter bloom — wider diffuse glow at arc peak
          float apexFactor = sin(vT * 3.14159);
          float apexScatter = apexFactor * apexFactor * exp(-radDist * radDist * 1.2) * 0.15;
          float radialShape = coreLine * 0.7 + haloFalloff * 0.3 + apexScatter;
          // Per-arc speed variation (0.18-0.35)
          float speed = 0.18 + vPhase * 0.17;
          // Traveling pulse — data packets with per-arc phase offset
          float pulse = fract(uTime * speed + vPhase);
          float pulse2 = fract(uTime * speed * 0.7 + vPhase + 0.4);
          float d1 = abs(vT - pulse);
          float d2 = abs(vT - pulse2);
          // Wider, brighter pulses with glow trail
          float glow1 = exp(-d1 * d1 * 40.0) * 1.4;
          float trail1 = exp(-d1 * d1 * 12.0) * 0.35;
          float glow2 = exp(-d2 * d2 * 40.0) * 0.8;
          float trail2 = exp(-d2 * d2 * 12.0) * 0.25;
          // v11.03: Ghost trails — faint afterimage behind each pulse (directional)
          float ghost1Dir = vT - pulse; // Negative when behind pulse
          float ghost1 = exp(-ghost1Dir * ghost1Dir * 6.0) * step(0.0, -ghost1Dir) * 0.15;
          float ghost2Dir = vT - pulse2;
          float ghost2 = exp(-ghost2Dir * ghost2Dir * 6.0) * step(0.0, -ghost2Dir) * 0.1;
          // v11.82: 3rd data pulse — faster, dimmer packet for denser traffic feel
          float pulse3 = fract(uTime * speed * 1.4 + vPhase + 0.7);
          float d3 = abs(vT - pulse3);
          float glow3 = exp(-d3 * d3 * 50.0) * 0.5;
          float trail3 = exp(-d3 * d3 * 15.0) * 0.15;
          // v11.45: Arc heartbeat — baseline breathes in sync with pulse rhythm
          float heartbeatFreq = speed * 6.28318; // Matches pulse travel speed
          float baseLine = 0.08 + sin(uTime * heartbeatFreq + vPhase * 6.28) * 0.03
                         + sin(uTime * heartbeatFreq * 2.0 + vPhase * 3.14) * 0.012;
          // v11.71: Apex brightness — arc segments at highest point glow brighter
          float apexBright = 1.0 + apexFactor * apexFactor * 0.25; // +25% at apex (reuses apexFactor)
          // Endpoints fade
          float endFade = smoothstep(0.0, 0.08, vT) * smoothstep(1.0, 0.92, vT);
          // v12.42: Endpoint concentration — arcs brighten near nodes (data convergence)
          float nearStart = exp(-vT * vT * 25.0) * 0.25; // Bright near origin
          float nearEnd = exp(-(1.0 - vT) * (1.0 - vT) * 25.0) * 0.25; // Bright near destination
          float endpointConcentrate = nearStart + nearEnd;
          // v11.86: Arrival flash — pulses flare at destination endpoint
          float arrivalZone = smoothstep(0.92, 1.0, vT); // Only near endpoint
          float arrival1 = exp(-d1 * d1 * 80.0) * arrivalZone * 0.6;
          float arrival2 = exp(-d2 * d2 * 80.0) * arrivalZone * 0.4;
          float arrival3 = exp(-d3 * d3 * 80.0) * arrivalZone * 0.3;
          float arrivalFlash = arrival1 + arrival2 + arrival3;
          // v12.18: Departure flash — pulses flare at origin as they launch
          float departZone = smoothstep(0.08, 0.0, vT); // Only near origin
          float depart1 = exp(-d1 * d1 * 60.0) * departZone * 0.45;
          float depart2 = exp(-d2 * d2 * 60.0) * departZone * 0.3;
          float depart3 = exp(-d3 * d3 * 60.0) * departZone * 0.2;
          float departFlash = depart1 + depart2 + depart3;
          float pulseTotal = glow1 + trail1 + glow2 + trail2 + glow3 + trail3 + ghost1 + ghost2 + arrivalFlash + departFlash;
          // Pulses widen the visible halo — energy expands the glow
          float pulseWidening = 1.0 + pulseTotal * 0.3;
          float alpha = (baseLine + pulseTotal + endpointConcentrate) * radialShape * pulseWidening * faceFade * endFade;
          // Color: pulse head is white-hot, halo shifts to accent
          float pulseHeat = (glow1 + glow2 + glow3) / max(baseLine + pulseTotal, 0.01);
          float edgeTint = radDist * 0.4;
          // v11.16: Per-arc color temperature — varies by phase (route identity)
          // v12.07: Temporal color drift — route color shifts slowly over time
          float tempDrift = sin(uTime * 0.05 + vPhase * 3.14) * 0.15; // Slow drift per-route
          vec3 warmArc = vec3(1.0, 0.8 + tempDrift * 0.1, 0.5 - tempDrift * 0.1);
          vec3 coolArc = uColor * (1.3 + tempDrift * 0.1);
          vec3 arcBase = mix(warmArc, coolArc, smoothstep(0.0, 0.8, vPhase) * 0.4 + 0.6);
          vec3 col = mix(arcBase, vec3(1.0, 0.97, 0.92), pulseHeat * 0.5 * (1.0 - edgeTint));
          // v11.57: Arc sun interaction — brighter/warmer on sunlit side, dimmer on shadow
          float arcSunBright = 0.85 + vArcSunLight * 0.3;
          col = mix(col, col * vec3(1.05, 0.98, 0.9), vArcSunLight * 0.2); // Warm sunlit
          // v12.73: Shadow-side arc cooling — blue-violet tint on dark hemisphere arcs
          float arcShadow = (1.0 - vArcSunLight) * (1.0 - vArcSunLight);
          col = mix(col, col * vec3(0.85, 0.9, 1.15), arcShadow * 0.25);
          // v12.96: Arc altitude atmospheric gradient — warm near surface, white-blue at apex
          float altitudeFactor = sin(vT * 3.14159); // 0 at endpoints, 1 at apex
          float altSquared = altitudeFactor * altitudeFactor;
          vec3 apexWhiteBlue = vec3(0.85, 0.92, 1.0); // Thin-atmosphere white-blue
          col = mix(col, apexWhiteBlue * 1.3, altSquared * 0.2); // Subtle shift toward cooler at apex
          // Apex desaturation — energy at altitude scatters more uniformly
          float apexLum = dot(col, vec3(0.299, 0.587, 0.114));
          col = mix(col, vec3(apexLum) * 1.15, altSquared * 0.1);
          // v12.88: Sweep intersection flash — white-hot ping as scan crosses arc
          float sweepFlash = vSweepHit * 1.5;
          col = mix(col, vec3(1.0, 0.97, 0.9), sweepFlash * 0.6);
          alpha += sweepFlash * radialShape * faceFade * 0.4;
          // Bloom push — arcs glow brighter for bloom pickup
          float arcBloom = 1.0 + pulseTotal * 0.8 + coreLine * 0.3 + sweepFlash * 0.5;
          gl_FragColor = vec4(col * 1.8 * arcBloom * arcSunBright * apexBright, alpha);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      side: THREE.DoubleSide,
    });

    for (let arcIdx = 0; arcIdx < arcPairs.length; arcIdx++) {
      const [lat1, lng1, lat2, lng2] = arcPairs[arcIdx];
      const arcPhase = arcIdx / arcPairs.length; // 0-1 unique per arc
      const start = latLngToVec3(lat1, lng1, 1.02);
      const end = latLngToVec3(lat2, lng2, 1.02);
      // Great circle via slerp with altitude bulge
      const positions = new Float32Array(ARC_SEGMENTS * 3);
      const tValues = new Float32Array(ARC_SEGMENTS);
      const midDist = start.distanceTo(end);
      // v4.87: More dramatic arc heights — minimum lift + steeper long-route arcs
      const arcHeight = 1.02 + Math.max(midDist * 0.25, 0.08);

      // v4.98: True spherical interpolation — great-circle accuracy for long routes
      const startN = start.clone().normalize();
      const endN = end.clone().normalize();
      const omega = Math.acos(Math.min(startN.dot(endN), 1.0));
      const sinOmega = Math.sin(omega);
      for (let i = 0; i < ARC_SEGMENTS; i++) {
        const t = i / (ARC_SEGMENTS - 1);
        // True slerp — follows great-circle path on sphere surface
        const p = sinOmega > 0.001
          ? startN.clone().multiplyScalar(Math.sin((1 - t) * omega) / sinOmega)
              .add(endN.clone().multiplyScalar(Math.sin(t * omega) / sinOmega))
          : startN.clone().lerp(endN, t); // Fallback for nearly identical points
        // Altitude: parabolic bulge peaking at midpoint
        const alt = 1.02 + Math.sin(t * Math.PI) * (arcHeight - 1.02);
        p.multiplyScalar(alt);
        positions[i * 3] = p.x;
        positions[i * 3 + 1] = p.y;
        positions[i * 3 + 2] = p.z;
        tValues[i] = t;
      }

      // Create tube with glow halo — 4 vertices per segment (outer glow + inner core + inner core + outer glow)
      // v5.02: Wider arc ribbons — more visible network with richer bloom
      const coreWidth = 0.008;
      const glowWidth = 0.032;
      const VERTS_PER_SEG = 4;
      const tubePositions = new Float32Array(ARC_SEGMENTS * VERTS_PER_SEG * 3);
      const tubeTs = new Float32Array(ARC_SEGMENTS * VERTS_PER_SEG);
      const tubeRadials = new Float32Array(ARC_SEGMENTS * VERTS_PER_SEG);
      const tubeIndices: number[] = [];

      for (let i = 0; i < ARC_SEGMENTS; i++) {
        const px = positions[i * 3], py = positions[i * 3 + 1], pz = positions[i * 3 + 2];
        const p = new THREE.Vector3(px, py, pz);
        let tangent: THREE.Vector3;
        if (i < ARC_SEGMENTS - 1) {
          tangent = new THREE.Vector3(
            positions[(i + 1) * 3] - px,
            positions[(i + 1) * 3 + 1] - py,
            positions[(i + 1) * 3 + 2] - pz
          ).normalize();
        } else {
          tangent = new THREE.Vector3(
            px - positions[(i - 1) * 3],
            py - positions[(i - 1) * 3 + 1],
            pz - positions[(i - 1) * 3 + 2]
          ).normalize();
        }
        const normal = p.clone().normalize();
        const bitangent = new THREE.Vector3().crossVectors(tangent, normal).normalize();
        const bCore = bitangent.clone().multiplyScalar(coreWidth);
        const bGlow = bitangent.clone().multiplyScalar(glowWidth);
        const base = i * VERTS_PER_SEG;
        // v0: outer glow left (-1.0)
        tubePositions[(base) * 3] = px - bGlow.x;
        tubePositions[(base) * 3 + 1] = py - bGlow.y;
        tubePositions[(base) * 3 + 2] = pz - bGlow.z;
        tubeRadials[base] = -1.0;
        // v1: inner core left (-0.24)
        tubePositions[(base + 1) * 3] = px - bCore.x;
        tubePositions[(base + 1) * 3 + 1] = py - bCore.y;
        tubePositions[(base + 1) * 3 + 2] = pz - bCore.z;
        tubeRadials[base + 1] = -coreWidth / glowWidth;
        // v2: inner core right (+0.24)
        tubePositions[(base + 2) * 3] = px + bCore.x;
        tubePositions[(base + 2) * 3 + 1] = py + bCore.y;
        tubePositions[(base + 2) * 3 + 2] = pz + bCore.z;
        tubeRadials[base + 2] = coreWidth / glowWidth;
        // v3: outer glow right (+1.0)
        tubePositions[(base + 3) * 3] = px + bGlow.x;
        tubePositions[(base + 3) * 3 + 1] = py + bGlow.y;
        tubePositions[(base + 3) * 3 + 2] = pz + bGlow.z;
        tubeRadials[base + 3] = 1.0;
        for (let v = 0; v < VERTS_PER_SEG; v++) {
          tubeTs[base + v] = tValues[i];
        }
        if (i < ARC_SEGMENTS - 1) {
          const next = (i + 1) * VERTS_PER_SEG;
          // 3 quads per segment (left glow, core, right glow)
          for (let q = 0; q < 3; q++) {
            tubeIndices.push(base + q, base + q + 1, next + q, base + q + 1, next + q + 1, next + q);
          }
        }
      }

      // Per-arc phase attribute
      const tubePhases = new Float32Array(ARC_SEGMENTS * VERTS_PER_SEG);
      tubePhases.fill(arcPhase);

      const tubeGeo = new THREE.BufferGeometry();
      tubeGeo.setAttribute('position', new THREE.BufferAttribute(tubePositions, 3));
      tubeGeo.setAttribute('aT', new THREE.BufferAttribute(tubeTs, 1));
      tubeGeo.setAttribute('aPhase', new THREE.BufferAttribute(tubePhases, 1));
      tubeGeo.setAttribute('aRadial', new THREE.BufferAttribute(tubeRadials, 1));
      tubeGeo.setIndex(tubeIndices);

      const mesh = new THREE.Mesh(tubeGeo, arcMat);
      globeGroup.add(mesh);
      arcGeometries.push(tubeGeo);
      arcMeshes.push(mesh);
    }

    // ── Arc Node Markers — pulsing dots at city endpoints ──
    // v4.79: All unique arc endpoint cities — matches expanded 16-route network
    const uniqueCities: [number, number][] = [
      [40.7, -74.0], [51.5, -0.1], [25.3, 55.3],    // NYC, London, Dubai
      [1.35, 103.8], [35.7, 139.7], [22.3, 114.2],   // Singapore, Tokyo, Hong Kong
      [48.9, 2.35], [37.8, -122.4], [-23.5, -46.6],   // Paris, San Francisco, São Paulo
      [19.1, 72.9], [-33.9, 151.2], [6.5, 3.4],       // Mumbai, Sydney, Lagos
    ];
    const nodePositions = new Float32Array(uniqueCities.length * 3);
    const nodePhases = new Float32Array(uniqueCities.length);
    for (let i = 0; i < uniqueCities.length; i++) {
      const p = latLngToVec3(uniqueCities[i][0], uniqueCities[i][1], 1.018);
      nodePositions[i * 3] = p.x;
      nodePositions[i * 3 + 1] = p.y;
      nodePositions[i * 3 + 2] = p.z;
      nodePhases[i] = i * 0.9;
    }
    const nodeGeo = new THREE.BufferGeometry();
    nodeGeo.setAttribute('position', new THREE.BufferAttribute(nodePositions, 3));
    nodeGeo.setAttribute('aPhase', new THREE.BufferAttribute(nodePhases, 1));
    const nodeMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accent) },
        uSunDir: { value: new THREE.Vector3(0.6, 0.4, 0.8).normalize() },
        uSweepAngle: sharedSweepAngle,
      },
      vertexShader: `
        attribute float aPhase;
        uniform float uTime;
        uniform vec3 uSunDir;
        uniform float uSweepAngle;
        varying float vPulse;
        varying float vFacing;
        varying float vTime;
        varying float vPhase;
        varying float vNodeSunLight;
        varying float vSweepHit;
        void main() {
          vPulse = 0.6 + 0.4 * sin(uTime * 2.0 + aPhase);
          vTime = uTime;
          vPhase = aPhase;
          vec3 posNorm = normalize(position);
          vFacing = dot(posNorm, vec3(0.0, 0.0, 1.0));
          // v11.58: Node sun interaction
          vNodeSunLight = smoothstep(-0.1, 0.5, dot(posNorm, uSunDir));
          // v11.08: Scan sweep interaction — nodes flash when sweep passes
          float nodeAngle = atan(posNorm.x, posNorm.z);
          float sweepAngle = uSweepAngle;
          float scanDist = mod(nodeAngle - sweepAngle + 6.28318, 6.28318);
          float sweepHit = smoothstep(0.5, 0.0, scanDist) * 1.5;
          vSweepHit = sweepHit;
          // v11.90: Data reception pulse — periodic brightness surge simulating incoming data
