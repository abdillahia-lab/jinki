          // Sun-side inner rim brightening — wider, softer
          glow += pow(max(sunFacing, 0.0), 1.8) * rim * 0.2;
          // v11.02: Sun crescent — tight bright backlit edge on sun-facing limb
          float sunCrescent = pow(max(sunFacing, 0.0), 5.0) * pow(rim, 3.0) * 0.35;
          glow += sunCrescent;
          rimColor = mix(rimColor, vec3(1.0, 0.92, 0.75), sunCrescent * 0.8);
          // v11.26: Enhanced scan sweep flash on inner rim — razor + warm glow trail
          // v12.39: Reuse irScanAngle from breathing section (was duplicate atan)
          float scanDist = mod(irScanAngle - sweepAngleIR + 6.28318, 6.28318);
          float sweepRazor = smoothstep(0.15, 0.0, scanDist) * 0.4;
          float sweepBody = smoothstep(0.6, 0.0, scanDist) * 0.2;
