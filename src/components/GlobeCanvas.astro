---
/*
  GlobeCanvas v4 — World-class Fibonacci point-cloud globe.

  Architecture (GitHub Globe + Stripe + COBE patterns):
  - Fibonacci sphere sampling (28k desktop, 10k tablet)
  - Texture-based land detection via canvas getImageData (256×128 land mask)
  - 8-direction coastal edge detection for crisp continental outlines
  - Anti-aliased bokeh dot shader (adaptive Gaussian + inverse-square halo)
  - 3-shell atmosphere: outer halo (BackSide) + mid volume (FrontSide) + inner subsurface
  - Blending stratification: NormalBlending for atmosphere, AdditiveBlending for dots/arcs
  - Scanning sweep, depth fog, unified breathing at 0.3Hz
  - Trailing-particle arc animations (comet effect)
  - Dark core sphere with depth-aware shader
  - CSS mask integration for hero text readability
  - position: fixed — persists across full page scroll
  - Dynamic import('three') — zero initial bundle cost
  - MutationObserver for theme sync (no getComputedStyle polling)

  Mobile (<768px): No WebGL. CSS mesh gradient fallback.
*/
---

<div class="globe-wrap" aria-hidden="true">
  <canvas id="globe-canvas"></canvas>
</div>

<style>
  .globe-wrap {
    position: fixed;
    top: 0;
    right: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    will-change: opacity;
    transition: opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    mask-image: linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%);
    -webkit-mask-image: linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%);
  }
  .globe-wrap.ready { opacity: 1; }
  :global([data-theme="light"]) .globe-wrap.ready { opacity: 0.55; }
  #globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 767px) {
    .globe-wrap { display: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .globe-wrap {
      mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
      -webkit-mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
    }
  }
</style>

<script>
  (function () {
    if (window.innerWidth < 768) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const start = () => initGlobe(reduced).catch(e => console.error('[Globe] Init failed:', e));
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 2000 });
    } else {
      setTimeout(start, 300);
    }
  })();

  async function initGlobe(reducedMotion: boolean) {
    const wrap = document.querySelector('.globe-wrap') as HTMLDivElement;
    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
    if (!wrap || !canvas) return;

    const THREE = await import('three');

    // ── Theme colors via MutationObserver (no getComputedStyle polling) ──
    let themeColors = readThemeColors();
    function readThemeColors() {
      const s = getComputedStyle(document.documentElement);
      return {
        accent: s.getPropertyValue('--accent').trim() || '#00e5ff',
        accentSecondary: s.getPropertyValue('--accent-secondary').trim() || '#7B61FF',
        isLight: document.documentElement.getAttribute('data-theme') === 'light',
      };
    }
    const themeObserver = new MutationObserver(() => {
      themeColors = readThemeColors();
      outerAtmosMat.uniforms.uColor.value.set(themeColors.accent);
      midAtmosMat.uniforms.uColor.value.set(themeColors.accent);
      markerMat.uniforms.uColor.value.set(themeColors.accent);
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ── Scene ──
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, wrap.clientWidth / wrap.clientHeight, 0.1, 50);
    camera.position.set(0, 0, 2.8);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: false, // Stripe finding: MSAA hurts perf, shader AA is better
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(wrap.clientWidth, wrap.clientHeight);

    const globeGroup = new THREE.Group();
    scene.add(globeGroup);

    // ── Land Mask Texture — pixel-perfect land detection (GitHub/Stripe pattern) ──
    const LAND_MASK_B64 = 'data:image/png;base64,';

    const MASK_W = 256, MASK_H = 128;
    let landData: Uint8ClampedArray;

    // Load land mask via Image + Canvas getImageData (GitHub pattern)
    const landImg = new Image();
    await new Promise<void>((resolve, reject) => {
      landImg.onload = () => resolve();
      landImg.onerror = () => reject(new Error('Land mask failed to load'));
      landImg.src = LAND_MASK_B64;
    });
    const landCanvas = document.createElement('canvas');
    landCanvas.width = MASK_W;
    landCanvas.height = MASK_H;
    const landCtx = landCanvas.getContext('2d')!;
    landCtx.drawImage(landImg, 0, 0, MASK_W, MASK_H);
    landData = landCtx.getImageData(0, 0, MASK_W, MASK_H).data;

    // Pixel-perfect land detection via texture lookup
    function isLand(lat: number, lng: number): number {
      const u = Math.floor(((lng + 180) / 360) * MASK_W) % MASK_W;
      const v = Math.floor(((90 - lat) / 180) * MASK_H);
      const clampV = Math.max(0, Math.min(MASK_H - 1, v));
      return landData[(clampV * MASK_W + u) * 4] / 255;
    }

    // 8-direction coastal edge detection at texture resolution
    function isCoastal(lat: number, lng: number): boolean {
      const stepLat = 180 / MASK_H; // ~1.4° per pixel
      const stepLng = 360 / MASK_W;
      const dirs = [[1,0],[-1,0],[0,1],[0,-1],[0.7,0.7],[-0.7,0.7],[0.7,-0.7],[-0.7,-0.7]];
      for (const [dy, dx] of dirs) {
        if (isLand(lat + dy * stepLat, lng + dx * stepLng) < 0.3) return true;
      }
      return false;
    }

    // ── Fibonacci Sphere Point Cloud ──
    const isTablet = wrap.clientWidth < 1024;
    const DOT_COUNT = isTablet ? 10000 : 28000;
    const GOLDEN_RATIO = (1 + Math.sqrt(5)) / 2;
    const ANGLE_INC = Math.PI * 2 * GOLDEN_RATIO;

    const dotPositions = new Float32Array(DOT_COUNT * 3);
    const dotSizes = new Float32Array(DOT_COUNT);
    const dotOpacities = new Float32Array(DOT_COUNT);
    const dotPhases = new Float32Array(DOT_COUNT);
    const dotColors = new Float32Array(DOT_COUNT * 3);

    const cAccent = new THREE.Color(themeColors.accent);
    const cSecondary = new THREE.Color(themeColors.accentSecondary);
    const cTertiary = new THREE.Color('#34D399');

    for (let i = 0; i < DOT_COUNT; i++) {
      const t = i / DOT_COUNT;
      const inclination = Math.acos(1 - 2 * t);
      const azimuth = ANGLE_INC * i;

      const x = Math.sin(inclination) * Math.cos(azimuth);
      const y = Math.cos(inclination);
      const z = Math.sin(inclination) * Math.sin(azimuth);

      dotPositions[i * 3] = x;
      dotPositions[i * 3 + 1] = y;
      dotPositions[i * 3 + 2] = z;

      const lat = 90 - (inclination * 180 / Math.PI);
      const lng = (azimuth * 180 / Math.PI) % 360 - 180;
      const landFactor = isLand(lat, lng);

      const noise = Math.sin(i * 0.1) * Math.cos(i * 0.07) * 0.5 + 0.5;
      const coastal = landFactor > 0.5 && isCoastal(lat, lng);

      // Dot hierarchy: coastal (bright edges) > land (medium) > ocean (dim)
      if (coastal) {
        dotSizes[i] = 1.1 + noise * 0.5;
        dotOpacities[i] = 0.85;
      } else if (landFactor > 0.5) {
        dotSizes[i] = 0.7 + noise * 0.6;
        dotOpacities[i] = 0.35 + noise * 0.15;
      } else {
        dotSizes[i] = 0.1 + noise * 0.12;
        dotOpacities[i] = 0.02 + noise * 0.02;
      }
      dotPhases[i] = i * 2.399;

      const latFactor = Math.abs(y);
      let c: THREE.Color;
      if (coastal) {
        c = new THREE.Color().lerpColors(cAccent, new THREE.Color('#ffffff'), 0.3);
      } else if (landFactor > 0.5) {
        c = new THREE.Color().lerpColors(cAccent, cTertiary, latFactor * 0.35 + noise * 0.25);
        if (latFactor > 0.55) c.lerp(cSecondary, (latFactor - 0.55) * 0.6);
      } else {
        c = new THREE.Color().lerpColors(
          new THREE.Color('#0a1828'),
          new THREE.Color('#0e2440'),
          noise
        );
      }
      dotColors[i * 3] = c.r;
      dotColors[i * 3 + 1] = c.g;
      dotColors[i * 3 + 2] = c.b;
    }

    const dotGeo = new THREE.BufferGeometry();
    dotGeo.setAttribute('position', new THREE.BufferAttribute(dotPositions, 3));
    dotGeo.setAttribute('aSize', new THREE.BufferAttribute(dotSizes, 1));
    dotGeo.setAttribute('aOpacity', new THREE.BufferAttribute(dotOpacities, 1));
    dotGeo.setAttribute('aPhase', new THREE.BufferAttribute(dotPhases, 1));
    dotGeo.setAttribute('aColor', new THREE.BufferAttribute(dotColors, 3));

    // ── Dot Vertex Shader — breathing, depth fog, rim fade, scanning sweep ──
    const dotVertSrc = `
      attribute float aSize;
      attribute float aOpacity;
      attribute float aPhase;
      attribute vec3 aColor;
      uniform float uTime;
      uniform float uBaseSize;
      varying float vOpacity;
      varying vec3 vColor;
      varying float vScanBoost;
      void main() {
        vColor = aColor;
        float breath = sin(uTime * 0.3 + aPhase) * 0.025;
        vec3 pos = position * (1.0 + breath);
        vec4 mv = modelViewMatrix * vec4(pos, 1.0);
        float depth = -mv.z;
        // Backface fade
        float backFade = smoothstep(3.8, 1.9, depth);
        // Rim attenuation — reduce additive accumulation at silhouette
        vec3 posNorm = normalize(pos);
        vec3 camDir = vec3(0.0, 0.0, 1.0);
        float facing = dot(posNorm, camDir);
        float rimFade = smoothstep(-0.05, 0.35, facing);
        // Depth fog — far dots fade for spatial depth cue
        float depthFog = smoothstep(4.2, 2.0, depth);
        // Scanning sweep — bright meridian band rotating around globe
        float scanAngle = atan(posNorm.x, posNorm.z);
        float sweepAngle = mod(uTime * 0.35, 6.28318);
        float scanDist = abs(mod(scanAngle - sweepAngle + 3.14159, 6.28318) - 3.14159);
        vScanBoost = smoothstep(0.3, 0.0, scanDist) * facing * 0.5;
        vOpacity = aOpacity * backFade * rimFade * depthFog;
        gl_PointSize = max(aSize * uBaseSize * (20.0 / depth) * (1.0 + vScanBoost * 0.3), 0.5);
        gl_Position = projectionMatrix * mv;
      }
    `;

    // ── Dot Fragment Shader — anti-aliased bokeh (adaptive Gaussian + inverse-square halo) ──
    const dotFragSrc = `
      varying float vOpacity;
      varying vec3 vColor;
      varying float vScanBoost;
      void main() {
        float dist = length(gl_PointCoord - vec2(0.5));
        if (dist > 0.55) discard;
        // Adaptive Gaussian core with AA rim
        float sigma = 0.13;
        float core = exp(-(dist * dist) / (2.0 * sigma * sigma));
        float aaRim = smoothstep(0.52, 0.44, dist);
        // Inverse-square halo (physically-based light falloff)
        float halo = 0.04 / (dist * dist + 0.003) - 0.05;
        halo *= smoothstep(0.0, 0.18, dist);
        float strength = core * 0.8 + max(halo, 0.0) * 0.3 * aaRim;
        if (strength < 0.005) discard;
        // Scan sweep adds brightness + white shift
        vec3 col = mix(vColor, vec3(1.0), vScanBoost * 0.4);
        float alpha = strength * (vOpacity + vScanBoost);
        gl_FragColor = vec4(col, alpha);
      }
    `;

    const dotMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uBaseSize: { value: isTablet ? 1.0 : 1.4 },
      },
      vertexShader: dotVertSrc,
      fragmentShader: dotFragSrc,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const globeDots = new THREE.Points(dotGeo, dotMat);
    globeGroup.add(globeDots);

    // ── Shared atmosphere vertex shaders ──
    const atmosVert = `
      varying vec3 vNormal;
      varying vec3 vPos;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;
    const atmosVertAnimated = `
      uniform float uTime;
      varying vec3 vNormal;
      varying vec3 vPos;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;

    // ── Dark Core Sphere — solid body behind dots ──
    const coreGeo = new THREE.IcosahedronGeometry(0.99, 32);
    const coreMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.isLight ? '#e8eaed' : '#040410') },
      },
      vertexShader: atmosVert,
      fragmentShader: `
        uniform vec3 uColor;
        varying vec3 vNormal;
        varying vec3 vPos;
        void main() {
          vec3 viewDir = normalize(-vPos);
          float facing = max(dot(viewDir, vNormal), 0.0);
          float edgeLift = pow(1.0 - facing, 2.5) * 0.08;
          gl_FragColor = vec4(uColor + edgeLift, 1.0);
        }
      `,
      transparent: false,
      depthWrite: true,
    });
    globeGroup.add(new THREE.Mesh(coreGeo, coreMat));

    // ── 3-Shell Atmosphere System ──

    // Shell 1: Outer halo (BackSide, 1.15r) — AdditiveBlending for dramatic rim glow
    const outerAtmosGeo = new THREE.IcosahedronGeometry(1.15, 48);
    const outerAtmosMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
      },
      vertexShader: atmosVertAnimated,
      fragmentShader: `
        uniform vec3 uColor;
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        void main() {
          vec3 viewDir = normalize(-vPos);
          float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
          float breathe = 1.0 + sin(uTime * 0.3) * 0.1;
          // Concentrated bright inner rim + soft extended falloff
          float innerRim = pow(rim, 4.0) * 0.28;
          float outerFalloff = pow(rim, 1.8) * 0.04;
          float glow = (innerRim + outerFalloff) * breathe;
          gl_FragColor = vec4(uColor * 1.2, glow);
        }
      `,
      transparent: true,
      side: THREE.BackSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    globeGroup.add(new THREE.Mesh(outerAtmosGeo, outerAtmosMat));

    // Shell 2: Extended halo (BackSide, 1.25r) — wider, softer secondary glow
    const midAtmosGeo = new THREE.IcosahedronGeometry(1.25, 32);
    const midAtmosMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
      },
      vertexShader: atmosVertAnimated,
      fragmentShader: `
        uniform vec3 uColor;
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        void main() {
          vec3 viewDir = normalize(-vPos);
          float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
          float breathe = 1.0 + sin(uTime * 0.3 + 1.0) * 0.1;
          float glow = pow(rim, 5.0) * 0.12 * breathe;
          gl_FragColor = vec4(uColor, glow);
        }
      `,
      transparent: true,
      side: THREE.BackSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    })
    globeGroup.add(new THREE.Mesh(midAtmosGeo, midAtmosMat));

    // ── Data Arcs — Trailing particle comet effect ──
    function latLngToVec3(lat: number, lng: number, r: number) {
      const phi = (90 - lat) * (Math.PI / 180);
      const theta = (lng + 180) * (Math.PI / 180);
      return new THREE.Vector3(
        -r * Math.sin(phi) * Math.cos(theta),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.sin(theta)
      );
    }

    const arcDefs = [
      { from: [39.0, -77.0], to: [51.5, -0.1],   alt: 0.4, speed: 0.25 },
      { from: [39.0, -77.0], to: [1.35, 103.8],   alt: 0.55, speed: 0.18 },
      { from: [39.0, -77.0], to: [35.7, 139.7],   alt: 0.5, speed: 0.2 },
      { from: [39.0, -77.0], to: [25.3, 55.3],    alt: 0.42, speed: 0.22 },
      { from: [39.0, -77.0], to: [-23.5, -46.6],  alt: 0.38, speed: 0.24 },
      { from: [39.0, -77.0], to: [50.1, 8.7],     alt: 0.35, speed: 0.26 },
    ];

    const ARC_RESOLUTION = 80;
    const arcSystems: { mat: THREE.ShaderMaterial; points: THREE.Points; speed: number; phase: number }[] = [];

    arcDefs.forEach((def, idx) => {
      const start = latLngToVec3(def.from[0], def.from[1], 1.005);
      const end = latLngToVec3(def.to[0], def.to[1], 1.005);
      const mid = start.clone().add(end).multiplyScalar(0.5);
      mid.normalize().multiplyScalar(1.0 + def.alt);

      const curve = new THREE.QuadraticBezierCurve3(start, mid, end);
      const pts = curve.getPoints(ARC_RESOLUTION);

      const pos = new Float32Array(ARC_RESOLUTION * 3);
      const prog = new Float32Array(ARC_RESOLUTION);
      for (let i = 0; i < ARC_RESOLUTION; i++) {
        pos[i * 3] = pts[i].x;
        pos[i * 3 + 1] = pts[i].y;
        pos[i * 3 + 2] = pts[i].z;
        prog[i] = i / (ARC_RESOLUTION - 1);
      }

      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      geo.setAttribute('aProgress', new THREE.BufferAttribute(prog, 1));

      const mat = new THREE.ShaderMaterial({
        uniforms: {
          uHead: { value: 0 },
          uColorA: { value: new THREE.Color(themeColors.accent) },
          uColorB: { value: new THREE.Color(themeColors.accentSecondary) },
        },
        vertexShader: `
          attribute float aProgress;
          uniform float uHead;
          varying float vProgress;
          varying float vTrail;
          void main() {
            vProgress = aProgress;
            float headDist = aProgress - uHead;
            vTrail = headDist > -0.02 ? (headDist > 0.02 ? 0.0 : 1.0) : smoothstep(-0.35, -0.02, headDist);
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            float headProximity = 1.0 - smoothstep(0.0, 0.08, abs(headDist));
            gl_PointSize = max((3.0 + headProximity * 5.0) * (45.0 / -mv.z), 1.0);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          uniform vec3 uColorA;
          uniform vec3 uColorB;
          varying float vProgress;
          varying float vTrail;
          void main() {
            if (vTrail <= 0.0) discard;
            float dist = length(gl_PointCoord - vec2(0.5));
            float strength = 0.05 / dist - 0.1;
            if (strength <= 0.0) discard;
            vec3 col = mix(uColorA, uColorB, vProgress);
            gl_FragColor = vec4(col, strength * vTrail);
          }
        `,
        transparent: true,
        blending: THREE.AdditiveBlending,
        depthWrite: false,
      });

      const arcPoints = new THREE.Points(geo, mat);
      globeGroup.add(arcPoints);
      arcSystems.push({ mat, points: arcPoints, speed: def.speed, phase: idx * 0.6 });
    });

    // ── Pulse Markers at arc endpoints ──
    const markerPositions: THREE.Vector3[] = [];
    const uniqueCoords = new Set<string>();
    arcDefs.forEach(def => {
      [def.from, def.to].forEach(c => {
        const key = c.join(',');
        if (!uniqueCoords.has(key)) {
          uniqueCoords.add(key);
          markerPositions.push(latLngToVec3(c[0], c[1], 1.008));
        }
      });
    });

    const markerCount = markerPositions.length;
    const mPos = new Float32Array(markerCount * 3);
    markerPositions.forEach((p, i) => {
      mPos[i * 3] = p.x;
      mPos[i * 3 + 1] = p.y;
      mPos[i * 3 + 2] = p.z;
    });
    const markerGeo = new THREE.BufferGeometry();
    markerGeo.setAttribute('position', new THREE.BufferAttribute(mPos, 3));
    const markerMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accent) },
      },
      vertexShader: `
        uniform float uTime;
        varying float vPulse;
        void main() {
          vPulse = 0.6 + sin(uTime * 1.2) * 0.4;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = max((4.0 + sin(uTime * 1.2) * 2.0) * (50.0 / -mv.z), 2.0);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        varying float vPulse;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          float strength = 0.06 / dist - 0.12;
          if (strength <= 0.0) discard;
          gl_FragColor = vec4(uColor, strength * vPulse);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    globeGroup.add(new THREE.Points(markerGeo, markerMat));

    // ── Latitude Grid Rings — NormalBlending (drawn lines, not light) ──
    const RING_LATS = [0, 23.5, -23.5, 39];
    const RING_RES = 128;
    const ringRefs: { geo: THREE.BufferGeometry; mat: THREE.ShaderMaterial; pts: THREE.Points }[] = [];
    RING_LATS.forEach((lat) => {
      const phi = (90 - lat) * (Math.PI / 180);
      const rPos = new Float32Array(RING_RES * 3);
      const rPhase = new Float32Array(RING_RES);
      for (let j = 0; j < RING_RES; j++) {
        const theta = (j / RING_RES) * Math.PI * 2;
        const r = 1.003;
        rPos[j * 3] = r * Math.sin(phi) * Math.cos(theta);
        rPos[j * 3 + 1] = r * Math.cos(phi);
        rPos[j * 3 + 2] = r * Math.sin(phi) * Math.sin(theta);
        rPhase[j] = j / RING_RES;
      }
      const rGeo = new THREE.BufferGeometry();
      rGeo.setAttribute('position', new THREE.BufferAttribute(rPos, 3));
      rGeo.setAttribute('aPhase', new THREE.BufferAttribute(rPhase, 1));
      const isEquator = lat === 0;
      const isDC = lat === 39;
      const rMat = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uColor: { value: isDC
            ? new THREE.Color(themeColors.accent)
            : new THREE.Color(isEquator ? '#1a3a5c' : '#0f2840') },
        },
        vertexShader: `
          attribute float aPhase;
          uniform float uTime;
          varying float vAlpha;
          void main() {
            float dash = sin(aPhase * 50.0 + uTime * 0.5) * 0.5 + 0.5;
            vAlpha = dash * ${isDC ? '0.35' : isEquator ? '0.12' : '0.06'};
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            gl_PointSize = max(${isDC ? '1.8' : '1.2'} * (30.0 / -mv.z), 0.5);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          uniform vec3 uColor;
          varying float vAlpha;
          void main() {
            float dist = length(gl_PointCoord - vec2(0.5));
            if (dist > 0.5) discard;
            float strength = smoothstep(0.5, 0.1, dist);
            gl_FragColor = vec4(uColor, strength * vAlpha);
          }
        `,
        transparent: true,
        blending: THREE.NormalBlending,
        depthWrite: false,
      });
      const ringPts = new THREE.Points(rGeo, rMat);
      globeGroup.add(ringPts);
      ringRefs.push({ geo: rGeo, mat: rMat, pts: ringPts });
    });

    // ── Stardust Field ──
    const STAR_COUNT = 300;
    const starPos = new Float32Array(STAR_COUNT * 3);
    const starSizes = new Float32Array(STAR_COUNT);
    for (let i = 0; i < STAR_COUNT; i++) {
      const r = 3.5 + Math.random() * 5;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      starPos[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      starPos[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
      starPos[i * 3 + 2] = r * Math.cos(phi);
      starSizes[i] = 0.5 + Math.random() * 1.5;
    }
    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
    starGeo.setAttribute('aSize', new THREE.BufferAttribute(starSizes, 1));
    const starMat = new THREE.ShaderMaterial({
      uniforms: { uTime: { value: 0 } },
      vertexShader: `
        attribute float aSize;
        uniform float uTime;
        varying float vTwinkle;
        void main() {
          float idx = position.x * 73.0 + position.y * 157.0;
          vTwinkle = 0.3 + 0.7 * (sin(uTime * 0.8 + idx) * 0.5 + 0.5);
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = max(aSize * (20.0 / -mv.z), 0.5);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        varying float vTwinkle;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          float strength = 0.03 / dist - 0.06;
          if (strength <= 0.0) discard;
          gl_FragColor = vec4(1.0, 1.0, 1.0, strength * vTwinkle * 0.5);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const stars = new THREE.Points(starGeo, starMat);
    scene.add(stars);

    // ── Positioning ──
    function positionGlobe() {
      if (wrap.clientWidth >= 1024) {
        globeGroup.position.set(0.95, 0.05, 0);
        globeGroup.scale.setScalar(1.15);
      } else {
        globeGroup.position.set(0, 0, 0);
        globeGroup.scale.setScalar(0.85);
      }
    }
    positionGlobe();
    globeGroup.rotation.y = -0.4; // Atlantic facing

    // ── Interaction ──
    let mouseX = 0, mouseY = 0;
    if (!reducedMotion) {
      document.addEventListener('mousemove', (e) => {
        mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
        mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
      });
    }

    let scrollFade = 1;
    window.addEventListener('scroll', () => {
      scrollFade = Math.max(0.35, 1 - window.scrollY / (window.innerHeight * 1.5));
    }, { passive: true });

    // ── Animation Loop ──
    let animId = 0;
    let time = 0;
    const clock = new THREE.Clock();

    function animate() {
      animId = requestAnimationFrame(animate);
      const dt = clock.getDelta();
      time += dt;

      const opacityMult = themeColors.isLight ? 0.55 : 1;

      if (!reducedMotion) globeGroup.rotation.y += 0.0008;

      // Mouse parallax (desktop)
      if (!reducedMotion && wrap.clientWidth >= 1024) {
        const tiltX = mouseY * 0.06;
        globeGroup.rotation.x += (tiltX - globeGroup.rotation.x) * 0.025;
      }

      // Update all time uniforms
      dotMat.uniforms.uTime.value = time;
      markerMat.uniforms.uTime.value = time;
      starMat.uniforms.uTime.value = time;
      outerAtmosMat.uniforms.uTime.value = time;
      midAtmosMat.uniforms.uTime.value = time;
      ringRefs.forEach(r => { r.mat.uniforms.uTime.value = time; });

      // Arc comet animation
      if (!reducedMotion) {
        arcSystems.forEach(({ mat, speed, phase }) => {
          const cycle = (time * speed + phase) % 2.0;
          mat.uniforms.uHead.value = Math.min(cycle, 1.0);
        });
      }

      // Scroll-driven opacity
      if (scrollControlsOpacity) {
        wrap.style.opacity = String(Math.max(0, scrollFade * opacityMult));
      }

      renderer.render(scene, camera);
    }

    // ── Resize ──
    const ro = new ResizeObserver(() => {
      const w = wrap.clientWidth;
      const h = wrap.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      positionGlobe();
    });
    ro.observe(wrap);

    // ── Launch ──
    let scrollControlsOpacity = false;
    animate();
    // Use setTimeout instead of double-rAF — more reliable across browsers
    setTimeout(() => {
      wrap.classList.add('ready');
      wrap.dispatchEvent(new CustomEvent('globe-ready', { bubbles: true }));
    }, 80);
    setTimeout(() => {
      scrollControlsOpacity = true;
      wrap.style.transition = 'none';
    }, 1600);

    // ── Cleanup — dispose ALL geometries/materials (including rings) ──
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
      themeObserver.disconnect();
      renderer.dispose();
      dotGeo.dispose();
      dotMat.dispose();
      coreGeo.dispose();
      coreMat.dispose();
      outerAtmosGeo.dispose();
      outerAtmosMat.dispose();
      midAtmosGeo.dispose();
      midAtmosMat.dispose();
      starGeo.dispose();
      starMat.dispose();
      markerGeo.dispose();
      markerMat.dispose();
      ringRefs.forEach(r => { r.geo.dispose(); r.mat.dispose(); });
      arcSystems.forEach(({ points }) => {
        points.geometry.dispose();
        (points.material as THREE.Material).dispose();
      });
    }, { once: true });
  }
</script>
