        // v11.34: Scan-boosted sparkle — glitter activates along sweep path
        float sparkleIntensity = vScanBoost * 0.7 + vScanTrail * 0.3 + vOceanGlint * 0.6 + vCityGlow * 0.7 + vCoastalHalo * 0.25 + vDataPulse * 0.5;
        if (sparkleIntensity > 0.1) {
          float angle = atan(gl_PointCoord.y - 0.5, gl_PointCoord.x - 0.5);
          // 4-pointed primary spikes
          float spikes4 = pow(abs(cos(angle * 2.0)), 20.0);
          // 6-pointed secondary spikes (rotated 30°) — on brightest dots only
          float spikes6 = pow(abs(cos(angle * 3.0 + 0.523)), 24.0) * smoothstep(0.25, 0.5, sparkleIntensity);
          float spikeCombined = spikes4 + spikes6 * 0.4;
          float sparkle = spikeCombined * exp(-dist * 4.5) * sparkleIntensity * 0.45;
          // v11.76: Prismatic sparkle — rainbow diffraction colors
          float prismaticAngle = angle * 0.5 + uTime * 0.5; // Slow color rotation
          vec3 prismatic = vec3(
            0.5 + 0.5 * sin(prismaticAngle),
            0.5 + 0.5 * sin(prismaticAngle + 2.094),
            0.5 + 0.5 * sin(prismaticAngle + 4.189)
          );
          vec3 sparkleCol = mix(mix(vec3(1.0, 0.95, 0.9), uAccentColor * 1.2, 0.15), prismatic, 0.2);
          col += sparkleCol * sparkle;
          strength += sparkle * 0.6;
        }
        float alpha = strength * (vOpacity + vScanBoost);
        // Bloom push — v11.13: stronger phosphor trail bloom
        // v12.56: Depth-modulated bloom — front dots bloom more, edge dots less (DOF glow)
        float depthBloomMod = 1.0 + (1.0 - vDepthHaze) * 0.15; // +15% bloom on near dots
        // v12.64: Sun-hemisphere bloom bias — sunlit dots glow brighter into bloom
        float sunBloomBias = 1.0 + vSunLight * vSunLight * 0.25; // +25% bloom on fully sunlit dots
        float dotBloomPush = (1.0 + vCityGlow * 1.5 + vScanBoost * 0.3 + vScanTrail * 0.4 + vCoastalHalo * 0.5 + vOceanGlint * 1.0 + vDataPulse * 0.6 + vBacklit * 1.2 + vMouseGlow * 1.0) * depthBloomMod * sunBloomBias;
        // v4.84: Cursor proximity accent tint — dots under cursor shift toward accent
        col = mix(col, uAccentColor * 1.6, vMouseGlow * 0.4);
        // v4.97: Atmospheric rim luminance — silhouette edge dots glow with scattered light
        float rimGlow = vFresnel * vFresnel * 0.30;
        vec3 rimAtmo = mix(uAccentColor * 0.5, vec3(0.7, 0.85, 1.0), vSunLight);
        col += rimAtmo * rimGlow * (1.0 - vDepthHaze);
        gl_FragColor = vec4(col * dotBloomPush, alpha);
      }
    `;

    const dotMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        // v4.81: Denser surface fill — premium solid feel with richer bloom
        uBaseSize: { value: isTablet ? 0.78 : 0.95 },
        uAccentColor: { value: new THREE.Color(themeColors.accent) },
        uScroll: { value: 0 },
        uSunDir: { value: new THREE.Vector3(0.6, 0.4, 0.8).normalize() },
