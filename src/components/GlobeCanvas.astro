        baseCol += specColor * sunSpecular * (1.0 - vFresnel * 0.7);
        // v5.00: Prismatic specular dispersion — rainbow fringe around hotspot like lens refraction
        float prismZone = pow(max(vSunDotRaw, 0.0), 8.0) * (1.0 - pow(max(vSunDotRaw, 0.0), 16.0)); // Ring around hotspot
        float prismAngle = atan(vColor.g - vColor.r, vColor.b - vColor.r) + vFresnel * 3.14; // Pseudorandom rotation
        vec3 prismColor = vec3(
          0.5 + 0.5 * sin(prismAngle),
          0.5 + 0.5 * sin(prismAngle + 2.094),
          0.5 + 0.5 * sin(prismAngle + 4.189)
        );
        baseCol += prismColor * prismZone * 0.08 * (1.0 - vFresnel);
        // v10.92: Night-side ambient emission — faint self-illumination on dark hemisphere
        float nightEmission = (1.0 - vSunLight) * (1.0 - vSunLight);
        vec3 nightAmbient = mix(vec3(0.02, 0.04, 0.08), uAccentColor * 0.15, 0.2);
        baseCol += nightAmbient * nightEmission * 0.4;
        // v12.67: Night-side micro-flare — rare sharp glints on dark hemisphere (satellite/light reflections)
        float nightFlareHash = texture2D(uNoiseAtlas, vGeoUV * 11.3 + vec2(floor(uTime * 3.0) * 0.1, 0.0)).g;
        float nightFlare = step(0.992, nightFlareHash) * nightEmission * (1.0 - vFresnel) * 0.8;
        baseCol += vec3(0.9, 0.95, 1.0) * nightFlare;
        // v11.49: Backlit translucency — warm golden rim when sun behind globe
        // v12.49: Sweep-backlit synergy — sweep beam amplifies translucency at silhouette edge
        float sweepBacklitBoost = vScanBoost * vBacklit * 1.5; // Sweep × backlit interaction
        float totalBacklit = vBacklit + sweepBacklitBoost;
        vec3 backlitGold = vec3(1.0, 0.78, 0.35); // Golden atmospheric scatter
        baseCol = mix(baseCol, backlitGold, totalBacklit * 0.55);
        // v12.10: Chromatic bokeh — ring tints warm inner, cool outer for lens realism
        float bokehInner = smoothstep(0.3, 0.38, dist) * smoothstep(0.44, 0.4, dist);
        float bokehOuter = smoothstep(0.38, 0.44, dist) * smoothstep(0.5, 0.46, dist);
        baseCol += vec3(0.08, 0.03, -0.02) * bokehInner; // Warm inner fringe
        baseCol += vec3(-0.02, 0.01, 0.06) * bokehOuter; // Cool outer fringe
        // v12.40: Atmosphere-dot color bleed — rim dots pick up atmospheric tint for seamless transition
        float rimBlend = pow(vFresnel, 1.8) * 0.2; // Strongest at silhouette edges
        vec3 atmosTint = mix(uAccentColor * 0.6, vec3(0.8, 0.5, 0.2), vSunLight * 0.3); // Cool shadow → warm sun
        baseCol = mix(baseCol, atmosTint, rimBlend);
        // Sun-responsive saturation: vivid sunlit, desaturated shadow
        float sunSat = 1.0 + vSunLight * 0.15; // Sunlit side +15% saturation
        float shadowDesat = (1.0 - vSunLight) * 0.35; // Shadow side -35%
