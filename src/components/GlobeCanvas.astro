    const globeDots = new THREE.Points(dotGeo, dotMat);
    globeGroup.add(globeDots);

    // ── Dark Core Sphere — gives the globe volume and occludes backface dots ──
    const coreGeo = new THREE.IcosahedronGeometry(0.99, 32);
    const coreMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.isLight ? '#e8eaed' : '#020208') },
        uAccent: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
        uSunDir: { value: new THREE.Vector3(0.6, 0.4, 0.8).normalize() },
        uFade: { value: 1.0 },
