      transparent: true,
      side: THREE.FrontSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const innerRimMesh = new THREE.Mesh(innerRimGeo, innerRimMat);
    globeGroup.add(innerRimMesh);

    // ── Data Arcs — Trailing particle comet effect ──
    function latLngToVec3(lat: number, lng: number, r: number) {
      const phi = (90 - lat) * (Math.PI / 180);
      const theta = (lng + 180) * (Math.PI / 180);
      return new THREE.Vector3(
        -r * Math.sin(phi) * Math.cos(theta),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.sin(theta)
      );
    }

    const arcDefs = [
      // Atlantic hemisphere routes
      { from: [40.7, -74.0], to: [51.5, -0.1],    alt: 0.35, speed: 0.22 }, // NYC → London
      { from: [51.5, -0.1],  to: [6.5, 3.4],      alt: 0.42, speed: 0.19 }, // London → Lagos
      { from: [40.7, -74.0], to: [-23.5, -46.6],  alt: 0.40, speed: 0.18 }, // NYC → São Paulo
      { from: [51.5, -0.1],  to: [25.3, 55.3],    alt: 0.32, speed: 0.23 }, // London → Dubai
      { from: [48.9, 2.35],  to: [-33.9, 18.4],   alt: 0.55, speed: 0.16 }, // Paris → Cape Town
      { from: [40.7, -74.0], to: [48.9, 2.35],    alt: 0.30, speed: 0.25 }, // NYC → Paris
      { from: [-23.5, -46.6],to: [6.5, 3.4],      alt: 0.35, speed: 0.21 }, // São Paulo → Lagos
      { from: [51.5, -0.1],  to: [55.8, 37.6],    alt: 0.25, speed: 0.26 }, // London → Moscow
      { from: [19.4, -99.1], to: [40.7, -74.0],   alt: 0.22, speed: 0.28 }, // Mexico City → NYC
      // Asia-Pacific hemisphere routes
      { from: [35.7, 139.7], to: [1.35, 103.8],   alt: 0.30, speed: 0.24 }, // Tokyo → Singapore
      { from: [1.35, 103.8], to: [-33.9, 151.2],  alt: 0.42, speed: 0.17 }, // Singapore → Sydney
      { from: [22.3, 114.2], to: [35.7, 139.7],   alt: 0.25, speed: 0.27 }, // Hong Kong → Tokyo
      { from: [25.3, 55.3],  to: [22.3, 114.2],   alt: 0.38, speed: 0.19 }, // Dubai → Hong Kong
      { from: [37.6, 127.0], to: [-33.9, 151.2],  alt: 0.50, speed: 0.15 }, // Seoul → Sydney
      { from: [13.8, 100.5], to: [28.6, 77.2],    alt: 0.28, speed: 0.26 }, // Bangkok → Delhi
      { from: [35.7, 139.7], to: [37.8, -122.4],  alt: 0.65, speed: 0.13 }, // Tokyo → San Francisco
      { from: [51.5, -0.1],  to: [35.7, 139.7],   alt: 0.60, speed: 0.12 }, // London → Tokyo
      { from: [40.7, -74.0], to: [1.35, 103.8],   alt: 0.58, speed: 0.11 }, // NYC → Singapore
    ];

    const ARC_RESOLUTION = 240;
    const arcSystems: { mat: THREE.ShaderMaterial; points: THREE.Points; speed: number; phase: number }[] = [];

    arcDefs.forEach((def, idx) => {
      const start = latLngToVec3(def.from[0], def.from[1], 1.03);
      const end = latLngToVec3(def.to[0], def.to[1], 1.03);
      const mid = start.clone().add(end).multiplyScalar(0.5);
      mid.normalize().multiplyScalar(1.0 + def.alt);

      const curve = new THREE.QuadraticBezierCurve3(start, mid, end);
      const pts = curve.getPoints(ARC_RESOLUTION);

      const pos = new Float32Array(ARC_RESOLUTION * 3);
      const prog = new Float32Array(ARC_RESOLUTION);
      for (let i = 0; i < ARC_RESOLUTION; i++) {
        pos[i * 3] = pts[i].x;
        pos[i * 3 + 1] = pts[i].y;
        pos[i * 3 + 2] = pts[i].z;
        prog[i] = i / (ARC_RESOLUTION - 1);
      }

      const geo = new THREE.BufferGeometry();
      geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
      geo.setAttribute('aProgress', new THREE.BufferAttribute(prog, 1));

      const mat = new THREE.ShaderMaterial({
        uniforms: {
          uHead: { value: 0 },
          uColorA: { value: new THREE.Color(themeColors.accent) },
          uColorB: { value: new THREE.Color(themeColors.accentSecondary) },
        },
        vertexShader: `
          attribute float aProgress;
          uniform float uHead;
          varying float vProgress;
          varying float vTrail;
          varying float vHead;
          void main() {
            vProgress = aProgress;
            float headDist = aProgress - uHead;
            // Longer trail (0.55 length) with smooth falloff
            float activeTrail = headDist > 0.01 ? 0.0 : smoothstep(-0.55, -0.01, headDist);
            // Faint ghost trail behind the comet — persistent route visibility
            float ghostTrail = headDist < -0.01 ? 0.06 : 0.0;
            vTrail = max(activeTrail, ghostTrail);
            // Bright head indicator — wider detection range
            vHead = smoothstep(0.08, 0.0, abs(headDist));
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            // Dramatic tapered trail: huge blazing head → thin tail
            float trailTaper = pow(activeTrail, 0.6); // wider near head, thin at tail
            float size = 2.5 + vHead * 24.0 + trailTaper * 7.0 + ghostTrail * 1.5;
            gl_PointSize = max(size * (55.0 / -mv.z), 1.0);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          uniform vec3 uColorA;
          uniform vec3 uColorB;
          varying float vProgress;
          varying float vTrail;
          varying float vHead;
          void main() {
            if (vTrail <= 0.0) discard;
            float dist = length(gl_PointCoord - vec2(0.5));
            // Tighter core + soft outer glow
            float core = exp(-dist * dist * 12.0);
            float outerGlow = exp(-dist * dist * 3.0) * 0.3;
            float glow = core + outerGlow * vHead;
            if (glow < 0.01) discard;
            vec3 col = mix(uColorA, uColorB, vProgress);
            // Head burns white-hot with intense center
            col = mix(col, vec3(1.0), vHead * 0.9);
