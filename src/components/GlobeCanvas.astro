        float termCore = vTerminator;
        float termOuter = exp(-(vSunLight - 0.25) * (vSunLight - 0.25) / 0.05) * 0.35;
        float termFringe = exp(-(vSunLight - 0.05) * (vSunLight - 0.05) / 0.08) * 0.2;
        baseCol = mix(baseCol, terminatorAmber, termCore * 0.5);
        baseCol = mix(baseCol, terminatorRose, termOuter);
        baseCol = mix(baseCol, terminatorViolet, termFringe);
        // Ocean sun glint — bright white-cyan specular
        vec3 glintColor = mix(vec3(1.0, 0.98, 0.95), uAccentColor * 1.3, 0.25);
        baseCol = mix(baseCol, glintColor, clamp(vOceanGlint, 0.0, 1.0));
        // v4.84: Ocean surface enhancement — subtle accent tint on sunlit ocean
        if (vIsOcean > 0.5) {
          // Sunlit ocean gets a faint cyan accent lift — visible "alive" surface
          vec3 oceanAccentTint = uAccentColor * 0.08;
          baseCol += oceanAccentTint * vSunLight * (1.0 - vDepthHaze);
          // Sweep reveals ocean structure — scan beam makes ocean dots momentarily brighter
          float oceanSweepReveal = vScanBoost * 0.12;
          baseCol += uAccentColor * oceanSweepReveal;
          // v4.96: Ocean subsurface scattering — deep translucent blue-teal glow
          // Light passes through water surface, creating a warm-to-cool depth gradient
          float oceanSSS = pow(max(vSunLight, 0.0), 1.5) * (1.0 - vDepthHaze) * 0.10;
          vec3 deepOcean = vec3(0.02, 0.12, 0.22); // Deep oceanic blue
          vec3 shallowOcean = mix(uAccentColor * 0.3, vec3(0.1, 0.35, 0.4), 0.5); // Teal shallows
          float depthGrad = smoothstep(0.0, 0.5, vTerrainSlope); // Coastal = shallow
          baseCol += mix(deepOcean, shallowOcean, depthGrad) * oceanSSS;
          // Night ocean bioluminescence — faint blue-green glow on dark ocean
          float bioLum = (1.0 - vSunLight) * (1.0 - vSunLight) * 0.015;
          baseCol += vec3(0.0, 0.08, 0.12) * bioLum;
        }
        // City glow — warm golden-white night lights with light pollution halo
        // v12.35: Per-city color temperature — hash-based sodium vs LED mix
        float cityHash = texture2D(uNoiseAtlas, vGeoUV * 9.7).b;
        vec3 citySodium = vec3(1.0, 0.78, 0.4);    // Older sodium-vapor (warm orange)
        vec3 cityAmber = vec3(1.0, 0.85, 0.55);     // Standard warm
        vec3 cityLED = vec3(0.95, 0.95, 1.0);       // Modern LED (cool white)
        vec3 cityBase = mix(citySodium, cityAmber, smoothstep(0.0, 0.5, cityHash));
        vec3 cityWhite = mix(cityAmber, cityLED, smoothstep(0.5, 1.0, cityHash));
        float cityIntensity = vCityGlow * vCityGlow; // Squared for sharper hotspots
        vec3 cityCol = mix(cityBase, cityWhite, cityIntensity);
        baseCol = mix(baseCol, cityCol, min(vCityGlow * 0.85, 1.0));
        // Light pollution halo — soft warm bloom around city centers
        if (vCityGlow > 0.15) {
          float pollutionHalo = smoothstep(0.15, 0.5, vCityGlow);
          float haloBreathe = 0.9 + sin(uTime * 0.4 + vCityGlow * 8.0) * 0.1;
          baseCol += vec3(0.8, 0.55, 0.2) * pollutionHalo * 0.25 * haloBreathe;
        }
        // v4.85: DGX terrain relief — slopes catch light differently, adding 3D depth
        if (vTerrainSlope > 0.1) {
          float slopeLight = vTerrainSlope * vSunLight * 0.12;
          baseCol += vec3(0.8, 0.9, 1.0) * slopeLight;
        }
        // v4.85: NASA night lights — worldwide city illumination on dark hemisphere
        if (vNightLight > 0.1 && vSunLight < 0.5) {
          float nightVis = vNightLight * vNightLight * (1.0 - vSunLight) * (1.0 - vSunLight);
          vec3 nightWarm = vec3(1.0, 0.82, 0.5);
          baseCol += nightWarm * nightVis * 0.5;
          // v4.94: Light pollution soft glow — wider warm halo around bright night lights
          float pollutionSpread = exp(-dist * dist / 0.12) * nightVis * 0.2;
          baseCol += vec3(0.9, 0.6, 0.25) * pollutionSpread;
          strength += pollutionSpread * 0.4;
        }
        // Scan sweep — white-hot leading edge → accent body → cool phosphor decay
        float leadingEdge = max(vScanBoost - vScanTrail, 0.0);
        vec3 sweepWhite = vec3(1.0, 0.98, 0.93);
        // Phosphor decay: hot accent → cooler, desaturated teal → faint blue-grey
        float trailAge = 1.0 - vScanTrail / max(vScanBoost, 0.001); // 0=fresh, 1=old
        vec3 freshTrail = uAccentColor * 1.4;
        vec3 agedTrail = mix(uAccentColor * 0.6, vec3(0.3, 0.5, 0.6), 0.4);
        vec3 trailColor = mix(freshTrail, agedTrail, trailAge * 0.7);
        vec3 col = baseCol;
        // v11.75: Phosphor trail desaturation — old trail fades to grey-blue
        float trailSat = 1.0 - trailAge * 0.4; // Aged trail loses 40% saturation
        vec3 desatTrail = mix(vec3(dot(trailColor, vec3(0.3, 0.59, 0.11))), trailColor, trailSat);
        col = mix(col, desatTrail, vScanTrail * 0.5);
        // v11.56: Sweep leading edge tints warm on sunlit side, cool on shadow
        vec3 sweepTintedWhite = mix(vec3(0.85, 0.9, 1.0), vec3(1.0, 0.95, 0.85), vSunLight);
        col = mix(col, sweepTintedWhite, leadingEdge * 0.65);
        // Data pulse wave — white-hot leading edge → warm epicenter → cool wavefront
        float pulseDist = smoothstep(0.0, 1.5, vPulseDistance);
        vec3 pulseHot = vec3(1.0, 0.97, 0.9);   // White-hot leading edge
        vec3 pulseWarm = vec3(1.0, 0.75, 0.3);   // Warm gold at epicenter
        vec3 pulseCool = uAccentColor * 1.4;      // Cool accent at wavefront
        // v11.68: Brighter leading edge — pulse peak glows white
        float pulseSharpness = pow(max(vDataPulse, 0.0), 0.5); // Sqrt for wider white zone
        vec3 pulseColor = mix(pulseWarm, pulseCool, pulseDist);
        pulseColor = mix(pulseColor, pulseHot, pulseSharpness * 0.4);
        col = mix(col, pulseColor, vDataPulse * 0.55);
        // Atmospheric perspective — multi-layer scattering: warm near → cool mid → deep blue far
        // v12.27: Gradient atmospheric haze — 3-layer color temperature shift
        vec3 nearHaze = vec3(0.12, 0.10, 0.10);  // Warm neutral near
        vec3 midHaze = vec3(0.08, 0.12, 0.18);    // Cool blue-grey mid
        vec3 farHaze = vec3(0.04, 0.08, 0.22);    // Deep blue far (Rayleigh)
        float hazeMid = smoothstep(0.0, 0.5, vDepthHaze);
        float hazeFar = smoothstep(0.4, 1.0, vDepthHaze);
        vec3 hazeColor = mix(nearHaze, midHaze, hazeMid);
        hazeColor = mix(hazeColor, farHaze, hazeFar);
        col = mix(col, hazeColor, vDepthHaze * 0.45);
        // v10.93: Depth color temperature — edge dots shift cooler (Rayleigh-like scattering)
        float depthCool = vDepthHaze * 0.3;
        col.r *= 1.0 - depthCool * 0.15;
        col.b *= 1.0 + depthCool * 0.12;
        // v4.81: Continental luminance lift — compensate for 200k density ocean floor
        float dotLum = dot(vColor, vec3(0.299, 0.587, 0.114));
        float isLandDot = smoothstep(0.04, 0.12, dotLum); // Ocean is very dark (lum < 0.04)
        col *= 1.0 + isLandDot * 0.15; // +15% brightness on continental dots
        // v4.82: Precision coastal emission — tighter core for high-res 2048×1024 mask
        if (vCoastalHalo > 0.5) {
          // Tighter bloom ring — sharper coastline trace with 200k dots
          float haloRing = smoothstep(0.28, 0.40, dist) * smoothstep(0.50, 0.42, dist);
          float coastHash = texture2D(uNoiseAtlas, vGeoUV * 13.1).a;
          float sweepCoastSync = vScanBoost * 0.5;
          float haloPulse = 0.88 + sin(uTime * (0.25 + coastHash * 0.15) + coastHash * 6.28) * 0.12 + sweepCoastSync;
          strength += haloRing * 0.40 * haloPulse;
          // Sun-responsive coastal color — whiter/brighter on sunlit side
          vec3 coastSunlit = mix(uAccentColor * 1.3, vec3(1.0, 0.98, 0.93), 0.5); // Bright white-accent
          vec3 coastShadow = uAccentColor * 0.9; // Dimmer pure accent on dark side
          vec3 coastEmit = mix(coastShadow, coastSunlit, vSunLight);
          col = mix(col, coastEmit, haloRing * 0.38 * haloPulse);
          // Tighter core — sharper point of light per coastal dot
          float coreBright = exp(-dist * dist / 0.015) * 0.35 * haloPulse;
          strength += coreBright;
          col = mix(col, uAccentColor * 1.6, coreBright * 0.22);
          // Terminator coastal blaze — dawn/dusk fire along continent edges
          float coastTermBlaze = vTerminator * 2.8;
          vec3 blazeAmber = vec3(1.0, 0.65, 0.2);
