          atmosColor = mix(atmosColor, uColorSecondary * 0.7, max(-plasmaIntensity, 0.0) * 0.25);
          // v11.35: Layered glow with per-layer breathing — staggered pulsation
          // v11.89: Consolidated breathing — global breathe folded into per-layer values
          float globalBreathe = 1.0 + sin(uTime * 0.3) * 0.08 + sin(uTime * 0.17) * 0.03;
          float innerBreathe = (1.0 + sin(uTime * 0.35) * 0.06) * globalBreathe;
          float midBreathe = (1.0 + sin(uTime * 0.22 + 1.0) * 0.08) * globalBreathe;
          float outerBreathe = (1.0 + sin(uTime * 0.15 + 2.3) * 0.10) * globalBreathe;
          // v11.44: Tighter inner rim with sharper edge definition
