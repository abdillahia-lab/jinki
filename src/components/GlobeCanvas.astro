          float auroraWave = vnoise(n * 3.0 + vec3(0.0, uTime * 0.03, 0.0)) * 0.6 + 0.4;
          // v12.59: Reuse scanAngle (same as atan(n.x, n.z) since n = normalize(vWorldNormal))
          float curtainBands = pow(sin(scanAngle * 8.0 + uTime * 0.05) * 0.5 + 0.5, 3.0); // Sharp peaks
          float curtainFine = sin(scanAngle * 24.0 + uTime * 0.08) * 0.3 + 0.7; // Fine detail
          float auroraGlow = polarBand * auroraWave * curtainBands * curtainFine * rim * 0.06;
          // Dual color — green body with violet upper fringe
          vec3 auroraGreen = vec3(0.2, 0.9, 0.5);
          vec3 auroraViolet = vec3(0.5, 0.2, 0.8);
