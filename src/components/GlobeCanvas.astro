        }
        void main() {
          vec3 viewDir = normalize(-vPos);
          float facing = max(dot(viewDir, vNormal), 0.0);
          // Digital hex grid substrate — visible at rim, fades toward center
          vec3 n = normalize(vWorldPos);
          float lat = asin(n.y);
          float lng = atan(n.z, n.x);
          float hex = hexGrid(vec2(lng * 3.0, lat * 3.0), 8.0);
          float gridPulse = 0.4 + 0.6 * (sin(uTime * 0.5 + lat * 4.0) * 0.5 + 0.5);
          // v11.20: Scan sweep hex grid reaction — grid brightens as sweep passes
          float sweepAngle = uSweepAngle;
          // v12.29: Consolidated — hexAngle same as scanAngle below (atan of normalized = same)
          float coreAngle = atan(n.x, n.z);
          float hexScanDist = mod(coreAngle - sweepAngle + 6.28318, 6.28318);
          float hexSweepBoost = smoothstep(0.8, 0.0, hexScanDist) * 2.5;
          // v12.21: Hex data cascade — staggered cell activation behind sweep
          float cellId = fract(sin(lat * 127.1 + lng * 311.7) * 43758.5);
          // v12.52: Latitude-weighted cascade — equatorial cells activate first (major cable routes)
          float latWeight = abs(n.y) * 0.4; // Polar cells delayed +0.4s
          float cascadeDelay = cellId * 0.8 + latWeight; // Base stagger + latitude delay
          float cascadeWindow = mod(hexScanDist - cascadeDelay, 6.28318);
          float hexCascade = smoothstep(1.5, 0.3, cascadeWindow) * smoothstep(3.0, 1.5, cascadeWindow) * 1.8;
          float gridVis = hex * pow(1.0 - facing, 2.0) * 0.025 * (gridPulse + hexSweepBoost + hexCascade);
          // v12.78: Hex cascade color temperature — white-hot activation → accent decay
          float cascadeHeat = hexCascade / max(gridPulse + hexSweepBoost + hexCascade, 0.001);
          vec3 cascadeHotCol = vec3(1.0, 0.97, 0.9); // White-hot
          // Accent rim glow — stronger edge luminance
          float edgeLift = pow(1.0 - facing, 2.5) * 0.06 + gridVis;
          // Subsurface emission — boosted data processing heartbeat
          float pulse1 = sin(uTime * 0.8) * 0.5 + 0.5;
          float pulse2 = sin(uTime * 1.3 + 2.0) * 0.5 + 0.5;
          float pulse3 = sin(uTime * 0.4 + 1.0) * 0.5 + 0.5;
          float subsurface = (pulse1 * 0.4 + pulse2 * 0.35 + pulse3 * 0.25) * pow(1.0 - facing, 1.5) * 0.045;
          // v5.22: Deep core heartbeat — very slow throbbing that's visible over 10s observation
          float heartPhase = uTime * 0.15; // ~42s full cycle
          float heartRaw = sin(heartPhase) * 0.5 + 0.5;
          float heartbeat = heartRaw * heartRaw * heartRaw; // Cubic for sharp peaks, long valleys
          float deepPulse = heartbeat * pow(1.0 - facing, 2.0) * 0.035;
          subsurface += deepPulse;
          // v12.93: Sweep-synchronized subsurface flare — core lights up from within as scan passes
          float ssFlare = smoothstep(0.8, 0.0, hexScanDist) * pow(1.0 - facing, 1.0) * 0.06;
          subsurface += ssFlare;
          // v11.92: Latitude-dependent subsurface emission — warm equator, cool poles
          float coreLat = abs(n.y);
          vec3 equatorEmit = uAccent * vec3(1.15, 0.95, 0.8); // Warm equatorial glow
          vec3 polarEmit = uAccent * vec3(0.8, 0.9, 1.2);     // Cool polar glow
          vec3 latEmission = mix(equatorEmit, polarEmit, smoothstep(0.2, 0.7, coreLat));
          vec3 emissionColor = latEmission * (subsurface + gridVis * 0.5);
          emissionColor = mix(emissionColor, cascadeHotCol * gridVis * 0.5, cascadeHeat * 0.4);
          // Scanning sweep illumination on core surface — dramatic
          float scanDist = mod(coreAngle - sweepAngle + 6.28318, 6.28318);
          float sweepLead = smoothstep(0.25, 0.0, scanDist) * 0.18;
          float sweepTrail = smoothstep(1.5, 0.08, scanDist) * 0.06;
          float sweepDeep = smoothstep(3.0, 0.8, scanDist) * 0.02; // Deep afterglow
          float sweepGlow = (sweepLead + sweepTrail + sweepDeep) * facing;
          // Interior illumination — sweep lights up the core from within
          float interiorGlow = smoothstep(0.5, 0.0, scanDist) * pow(1.0 - facing, 1.2) * 0.08;
          emissionColor += uAccent * interiorGlow;
          // v11.69: Radial energy pulse — expanding ring emanating from sweep origin
          float pulseFront = mod(coreAngle - sweepAngle + 0.3 + 6.28318, 6.28318); // Slightly ahead of sweep
          float pulseRing = exp(-pulseFront * pulseFront * 8.0) * pow(1.0 - facing, 1.8) * 0.06;
          emissionColor += vec3(1.0, 0.95, 0.85) * pulseRing;
          // Subsurface scattering — light bleeds through sunlit hemisphere
          vec3 lightDir = uSunDir; // Already normalized on CPU
          float sssWrap = max(dot(n, lightDir), 0.0);
          float sssRim = pow(1.0 - facing, 2.0);
          // v11.22: Enhanced SSS — stronger warm bleed with multi-layer scattering
          vec3 sssDeep = vec3(0.18, 0.08, 0.02); // Deep warm amber
          vec3 sssSurface = mix(uAccent * 0.4, vec3(0.12, 0.06, 0.01), 0.3); // Surface layer
          float sssDepth = pow(sssWrap, 1.5); // Softer wrap for wider bleed
          vec3 sss = (sssDeep * sssDepth * sssRim * 0.12) + (sssSurface * sssWrap * sssRim * 0.06);
          // v12.38: Backlit rim translucency — light bleeds through edges when sun is behind
          float backlit = max(-dot(n, lightDir), 0.0); // Strongest when sun behind globe
          float backlitRim = pow(1.0 - facing, 3.5) * backlit;
          vec3 backlitAmber = vec3(1.0, 0.7, 0.3); // Warm amber transmission
          sss += backlitAmber * backlitRim * 0.1;
          // v11.36: Multi-layer specular — needle + primary + rim for polished surface
          vec3 halfVec = normalize(lightDir + viewDir);
          float specNeedle = pow(max(dot(vNormal, halfVec), 0.0), 256.0) * 0.04;
          float spec = pow(max(dot(vNormal, halfVec), 0.0), 64.0) * 0.06 + specNeedle;
          // v12.60: Hex cascade specular boost — data processing flash on active cells
          spec *= (1.0 + hexCascade * 0.4); // Active cells get +40% specular
          // Rim specular — catches light at globe edges
          float rimSpec = pow(1.0 - facing, 4.0) * max(dot(n, lightDir), 0.0) * 0.04;
          // v12.65: Hemisphere sheen — broad soft luster on sunlit core (polished obsidian)
          float sheenDot = max(dot(n, lightDir), 0.0);
          float sheen = pow(sheenDot, 1.8) * facing * 0.025;
          spec += sheen;
          // v12.15: Sweep color with phosphor aging — white-hot lead → accent → warm amber trail
          float edgeWhiteness = sweepLead / max(sweepGlow / max(facing, 0.01), 0.001);
          float trailAge = sweepTrail / max(sweepGlow, 0.001); // 0=fresh, 1=aged
          vec3 agedAmber = mix(uAccent, vec3(0.8, 0.55, 0.25), 0.4); // Warm amber phosphor decay
          vec3 sweepAccent = mix(uAccent, agedAmber, trailAge * 0.5);
          vec3 sweepColor = mix(sweepAccent, vec3(1.0), edgeWhiteness * 0.3) * sweepGlow;
          gl_FragColor = vec4(uColor + edgeLift + spec + rimSpec + sweepColor + emissionColor + sss, uFade);
        }
      `,
      transparent: true,
      depthWrite: true,
    });
    globeGroup.add(new THREE.Mesh(coreGeo, coreMat));

    // ── 2-Shell Atmosphere ──
    const atmosVert = `
      varying vec3 vNormal;
      varying vec3 vPos;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;

    // Shell 1: Outer halo (BackSide, 1.15r)
    const outerAtmosGeo = new THREE.IcosahedronGeometry(1.15, 48);
    const outerAtmosMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uColorSecondary: { value: new THREE.Color(themeColors.accentSecondary) },
        uTime: { value: 0 },
        uSunDir: { value: new THREE.Vector3(0.6, 0.4, 0.8).normalize() },
        uAtmosphereLUT: { value: atmosLutTex },
        uNoiseAtlas: { value: noiseAtlasTex },
        uSweepAngle: sharedSweepAngle,
