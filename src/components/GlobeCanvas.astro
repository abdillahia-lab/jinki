      const arcPoints = new THREE.Points(geo, mat);
      globeGroup.add(arcPoints);
      // Stagger phases with golden ratio for maximum visual spread
      const goldenPhase = (idx * 1.618033988749895) % 2.0;
      arcSystems.push({ mat, points: arcPoints, speed: def.speed, phase: goldenPhase });
    });

    // ── Pulse Markers at arc endpoints ──
    const markerPositions: THREE.Vector3[] = [];
    const uniqueCoords = new Set<string>();
    arcDefs.forEach(def => {
      [def.from, def.to].forEach(c => {
        const key = c.join(',');
        if (!uniqueCoords.has(key)) {
          uniqueCoords.add(key);
          markerPositions.push(latLngToVec3(c[0], c[1], 1.015));
        }
      });
    });

    const markerCount = markerPositions.length;
    const mPos = new Float32Array(markerCount * 3);
    const mPhase = new Float32Array(markerCount);
    markerPositions.forEach((p, i) => {
      mPos[i * 3] = p.x;
      mPos[i * 3 + 1] = p.y;
      mPos[i * 3 + 2] = p.z;
      mPhase[i] = Math.random() * 6.28; // Per-marker random phase offset
    });
    const markerGeo = new THREE.BufferGeometry();
    markerGeo.setAttribute('position', new THREE.BufferAttribute(mPos, 3));
    markerGeo.setAttribute('aPhase', new THREE.BufferAttribute(mPhase, 1));
    const markerMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accent) },
      },
      vertexShader: `
        attribute float aPhase;
        uniform float uTime;
        varying float vPulse1;
        varying float vRingRadius1;
        varying float vPulse2;
        varying float vRingRadius2;
        void main() {
          // Primary ring — staggered per marker
          float cycle1 = fract(uTime * 0.35 + aPhase);
          vPulse1 = 1.0 - cycle1;
          vRingRadius1 = 0.06 + cycle1 * 0.40;
          // Secondary ring — delayed echo
          float cycle2 = fract(uTime * 0.35 + aPhase + 0.35);
          vPulse2 = (1.0 - cycle2) * 0.5;
          vRingRadius2 = 0.06 + cycle2 * 0.40;
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = max(26.0 * (55.0 / -mv.z), 6.0);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        varying float vPulse1;
        varying float vRingRadius1;
        varying float vPulse2;
        varying float vRingRadius2;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          // Bright center dot — strong focal point
          float centerDot = exp(-dist * dist * 180.0) * 1.8;
          // Primary expanding ring — more visible
          float ringDist1 = abs(dist - vRingRadius1);
          float ring1 = exp(-ringDist1 * ringDist1 * 700.0) * vPulse1 * 1.1;
          // Secondary echo ring
          float ringDist2 = abs(dist - vRingRadius2);
          float ring2 = exp(-ringDist2 * ringDist2 * 1000.0) * vPulse2 * 0.7;
          // Wider ambient glow
          float glow = 0.03 / (dist + 0.02);
          float strength = centerDot + ring1 + ring2 + glow;
          if (strength < 0.02) discard;
          vec3 col = mix(uColor, vec3(1.0), centerDot * 0.6);
          gl_FragColor = vec4(col, strength);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    globeGroup.add(new THREE.Points(markerGeo, markerMat));

    // ── Latitude Grid Rings — NormalBlending (drawn lines, not light) ──
    const RING_LATS = [0, 23.5, -23.5, 39];
    const RING_RES = 128;
    const ringRefs: { geo: THREE.BufferGeometry; mat: THREE.ShaderMaterial; pts: THREE.Points }[] = [];
    RING_LATS.forEach((lat) => {
      const phi = (90 - lat) * (Math.PI / 180);
      const rPos = new Float32Array(RING_RES * 3);
      const rPhase = new Float32Array(RING_RES);
      for (let j = 0; j < RING_RES; j++) {
        const theta = (j / RING_RES) * Math.PI * 2;
        const r = 1.003;
        rPos[j * 3] = r * Math.sin(phi) * Math.cos(theta);
        rPos[j * 3 + 1] = r * Math.cos(phi);
        rPos[j * 3 + 2] = r * Math.sin(phi) * Math.sin(theta);
        rPhase[j] = j / RING_RES;
      }
      const rGeo = new THREE.BufferGeometry();
      rGeo.setAttribute('position', new THREE.BufferAttribute(rPos, 3));
      rGeo.setAttribute('aPhase', new THREE.BufferAttribute(rPhase, 1));
      const isEquator = lat === 0;
      const isDC = lat === 39;
      const rMat = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uColor: { value: isDC
            ? new THREE.Color(themeColors.accent)
            : new THREE.Color(isEquator ? '#1a3a5c' : '#0f2840') },
        },
        vertexShader: `
          attribute float aPhase;
          uniform float uTime;
          varying float vAlpha;
          void main() {
            float dash = sin(aPhase * 50.0 + uTime * 0.5) * 0.5 + 0.5;
            vAlpha = dash * ${isDC ? '0.35' : isEquator ? '0.12' : '0.06'};
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            gl_PointSize = max(${isDC ? '1.8' : '1.2'} * (30.0 / -mv.z), 0.5);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          uniform vec3 uColor;
          varying float vAlpha;
          void main() {
            float dist = length(gl_PointCoord - vec2(0.5));
            if (dist > 0.5) discard;
            float strength = smoothstep(0.5, 0.1, dist);
            gl_FragColor = vec4(uColor, strength * vAlpha);
          }
        `,
        transparent: true,
        blending: THREE.NormalBlending,
        depthWrite: false,
      });
      const ringPts = new THREE.Points(rGeo, rMat);
      globeGroup.add(ringPts);
      ringRefs.push({ geo: rGeo, mat: rMat, pts: ringPts });
    });

    // ── Meridian Grid Lines — vertical structure lines for geographic legibility ──
    const MERIDIAN_LNGS = [0, 90, -90]; // Prime, 90E, 90W
    const MERID_RES = 128;
    MERIDIAN_LNGS.forEach((lng) => {
      const theta = (lng + 180) * (Math.PI / 180);
      const mPos = new Float32Array(MERID_RES * 3);
      const mPhase = new Float32Array(MERID_RES);
      for (let j = 0; j < MERID_RES; j++) {
        const phi = (j / (MERID_RES - 1)) * Math.PI; // pole to pole
        const r = 1.003;
        mPos[j * 3] = -r * Math.sin(phi) * Math.cos(theta);
        mPos[j * 3 + 1] = r * Math.cos(phi);
        mPos[j * 3 + 2] = r * Math.sin(phi) * Math.sin(theta);
        mPhase[j] = j / MERID_RES;
      }
      const mGeo = new THREE.BufferGeometry();
      mGeo.setAttribute('position', new THREE.BufferAttribute(mPos, 3));
      mGeo.setAttribute('aPhase', new THREE.BufferAttribute(mPhase, 1));
      const isPrime = lng === 0;
      const mMat = new THREE.ShaderMaterial({
        uniforms: {
          uTime: { value: 0 },
          uColor: { value: new THREE.Color(isPrime ? '#1a3a5c' : '#0f2840') },
        },
        vertexShader: `
          attribute float aPhase;
          uniform float uTime;
          varying float vAlpha;
          void main() {
            float dash = sin(aPhase * 50.0 + uTime * 0.5) * 0.5 + 0.5;
            vAlpha = dash * ${isPrime ? '0.10' : '0.05'};
            vec4 mv = modelViewMatrix * vec4(position, 1.0);
            gl_PointSize = max(1.0 * (30.0 / -mv.z), 0.5);
            gl_Position = projectionMatrix * mv;
          }
        `,
        fragmentShader: `
          uniform vec3 uColor;
          varying float vAlpha;
          void main() {
            float dist = length(gl_PointCoord - vec2(0.5));
            if (dist > 0.5) discard;
            float strength = smoothstep(0.5, 0.1, dist);
            gl_FragColor = vec4(uColor, strength * vAlpha);
          }
        `,
        transparent: true,
        blending: THREE.NormalBlending,
        depthWrite: false,
      });
      const meridPts = new THREE.Points(mGeo, mMat);
      globeGroup.add(meridPts);
      ringRefs.push({ geo: mGeo, mat: mMat, pts: meridPts });
    });

    // ── Radar Beam Line — visible scan sweep meridian ──
    const BEAM_RES = 96;
    const beamPos = new Float32Array(BEAM_RES * 3);
    const beamPhase = new Float32Array(BEAM_RES);
    for (let j = 0; j < BEAM_RES; j++) {
      const phi = (j / (BEAM_RES - 1)) * Math.PI;
      const r = 1.006;
      beamPos[j * 3] = 0; // will be rotated in shader
      beamPos[j * 3 + 1] = r * Math.cos(phi);
      beamPos[j * 3 + 2] = r * Math.sin(phi);
      beamPhase[j] = j / BEAM_RES;
    }
    const beamGeo = new THREE.BufferGeometry();
    beamGeo.setAttribute('position', new THREE.BufferAttribute(beamPos, 3));
    beamGeo.setAttribute('aPhase', new THREE.BufferAttribute(beamPhase, 1));
    const beamMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accent) },
      },
      vertexShader: `
        attribute float aPhase;
        uniform float uTime;
        varying float vAlpha;
        varying float vPhase;
        void main() {
          vPhase = aPhase;
          // Rotate beam position to match primary sweep angle
          float angle = mod(uTime * 0.4, 6.28318);
          float cosA = cos(angle);
          float sinA = sin(angle);
          vec3 pos = vec3(
            position.z * sinA,
            position.y,
            position.z * cosA
          );
          vec4 mv = modelViewMatrix * vec4(pos, 1.0);
          // Backface fade — hide beam on far side of globe
          vec3 viewDir = vec3(0.0, 0.0, 1.0);
          float facing = dot(normalize(pos), viewDir);
          vAlpha = smoothstep(-0.1, 0.3, facing) * 0.45;
          // Fade near poles for elegance
          float poleFade = smoothstep(0.0, 0.12, aPhase) * smoothstep(1.0, 0.88, aPhase);
          vAlpha *= poleFade;
          gl_PointSize = max(2.0 * (30.0 / -mv.z), 0.8);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        varying float vAlpha;
        varying float vPhase;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          if (dist > 0.5) discard;
          float core = exp(-dist * dist * 20.0);
          float glow = exp(-dist * dist * 6.0) * 0.3;
          float strength = core + glow;
          gl_FragColor = vec4(uColor * 1.3, strength * vAlpha);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const beamPts = new THREE.Points(beamGeo, beamMat);
    globeGroup.add(beamPts);

    // ── Secondary Radar Beam — counter-rotating, dimmer ──
    const beam2Geo = new THREE.BufferGeometry();
    beam2Geo.setAttribute('position', new THREE.BufferAttribute(beamPos.slice(), 3));
    beam2Geo.setAttribute('aPhase', new THREE.BufferAttribute(beamPhase.slice(), 1));
    const beam2Mat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accentSecondary) },
      },
      vertexShader: `
        attribute float aPhase;
        uniform float uTime;
        varying float vAlpha;
        void main() {
          float angle = mod(-uTime * 0.25, 6.28318);
          float cosA = cos(angle);
          float sinA = sin(angle);
          vec3 pos = vec3(
            position.z * sinA,
            position.y,
            position.z * cosA
          );
          vec4 mv = modelViewMatrix * vec4(pos, 1.0);
          vec3 viewDir = vec3(0.0, 0.0, 1.0);
          float facing = dot(normalize(pos), viewDir);
          vAlpha = smoothstep(-0.1, 0.3, facing) * 0.25;
          float poleFade = smoothstep(0.0, 0.15, aPhase) * smoothstep(1.0, 0.85, aPhase);
          vAlpha *= poleFade;
          gl_PointSize = max(1.5 * (30.0 / -mv.z), 0.5);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        varying float vAlpha;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          if (dist > 0.5) discard;
          float core = exp(-dist * dist * 25.0);
          gl_FragColor = vec4(uColor * 1.2, core * vAlpha);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const beam2Pts = new THREE.Points(beam2Geo, beam2Mat);
    globeGroup.add(beam2Pts);

    // ── Stardust Field — depth backdrop with varied brightness classes ──
    const STAR_COUNT = 2000;
    const starPos = new Float32Array(STAR_COUNT * 3);
    const starSizes = new Float32Array(STAR_COUNT);
    const starBrightness = new Float32Array(STAR_COUNT);
    for (let i = 0; i < STAR_COUNT; i++) {
      const r = 2.8 + Math.random() * 6;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      starPos[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      starPos[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
      starPos[i * 3 + 2] = r * Math.cos(phi);
      // 10% bright stars, 30% medium, 60% dim — realistic distribution
      const roll = Math.random();
      starSizes[i] = roll < 0.1 ? 1.5 + Math.random() * 2.0
                    : roll < 0.4 ? 0.8 + Math.random() * 1.0
                    : 0.3 + Math.random() * 0.6;
      starBrightness[i] = roll < 0.1 ? 0.8 + Math.random() * 0.2
                         : roll < 0.4 ? 0.4 + Math.random() * 0.3
                         : 0.15 + Math.random() * 0.2;
    }
    const starGeo = new THREE.BufferGeometry();
    starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
    starGeo.setAttribute('aSize', new THREE.BufferAttribute(starSizes, 1));
    starGeo.setAttribute('aBrightness', new THREE.BufferAttribute(starBrightness, 1));
    const starMat = new THREE.ShaderMaterial({
      uniforms: { uTime: { value: 0 } },
      vertexShader: `
        attribute float aSize;
        attribute float aBrightness;
        uniform float uTime;
        varying float vTwinkle;
        varying float vBright;
        void main() {
          vBright = aBrightness;
          // Each star twinkles at unique frequency and phase
          float idx = position.x * 73.0 + position.y * 157.0;
          float twinkleSpeed = 0.5 + fract(idx * 0.31) * 1.5;
          vTwinkle = 0.4 + 0.6 * (sin(uTime * twinkleSpeed + idx) * 0.5 + 0.5);
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          gl_PointSize = max(aSize * (25.0 / -mv.z), 0.5);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        varying float vTwinkle;
        varying float vBright;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          // Sharp core + soft glow for brighter stars
          float core = exp(-dist * dist * 40.0);
          float glow = 0.02 / (dist + 0.04);
          float strength = core * 0.7 + glow * vBright;
          if (strength < 0.02) discard;
          // Spectral class color variation — warm (orange/red) to cool (blue/white)
          float colorSeed = fract(vBright * 7.31 + 0.5);
          vec3 warmStar = vec3(1.0, 0.85, 0.7);   // K-type orange
          vec3 coolStar = vec3(0.8, 0.9, 1.0);     // A-type blue-white
          vec3 whiteStar = vec3(0.98, 0.97, 1.0);   // F-type white
          vec3 col = colorSeed < 0.15 ? warmStar
                   : colorSeed < 0.35 ? coolStar
                   : whiteStar;
          gl_FragColor = vec4(col, strength * vTwinkle * vBright);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const stars = new THREE.Points(starGeo, starMat);
    scene.add(stars);

    // ── Ambient Nebula Backdrop — radial glow behind globe for depth separation ──
    const nebulaGeo = new THREE.PlaneGeometry(6, 6);
    const nebulaMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uColorSecondary: { value: new THREE.Color(themeColors.accentSecondary) },
        uTime: { value: 0 },
      },
      vertexShader: `
        varying vec2 vUv;
        void main() {
          vUv = uv;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform vec3 uColorSecondary;
        uniform float uTime;
        varying vec2 vUv;
        void main() {
          vec2 center = vUv - vec2(0.5);
          float dist = length(center);
          // Primary soft radial glow — tight core
          float glow1 = exp(-dist * dist * 8.0) * 0.06;
          // Extended haze — wider, dimmer
          float glow2 = exp(-dist * dist * 2.5) * 0.025;
          // Asymmetric warm spot — offset for sun-side bias
          vec2 warmCenter = center - vec2(0.12, 0.08);
          float warmDist = length(warmCenter);
          float warmGlow = exp(-warmDist * warmDist * 6.0) * 0.03;
          // Breathing — subtle pulse synced with atmosphere
          float breathe = 1.0 + sin(uTime * 0.3 + 2.5) * 0.15;
          float totalGlow = (glow1 + glow2 + warmGlow) * breathe;
          // Two-tone color: primary accent core, secondary at edges
          float colorMix = smoothstep(0.0, 0.4, dist);
          vec3 col = mix(uColor, uColorSecondary, colorMix * 0.4);
          // Very subtle — this is a background element, not a feature
          gl_FragColor = vec4(col, totalGlow);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      side: THREE.DoubleSide,
    });
    const nebulaMesh = new THREE.Mesh(nebulaGeo, nebulaMat);
    nebulaMesh.position.z = -0.5; // Behind the globe
    globeGroup.add(nebulaMesh);
    // Nebula always faces camera (billboard)
    nebulaMesh.lookAt(camera.position);

    // ── Ambient Dust Particles — depth + scale cues near globe ──
    const DUST_COUNT = 200;
    const dustPos = new Float32Array(DUST_COUNT * 3);
    const dustSizes = new Float32Array(DUST_COUNT);
    const dustDrift = new Float32Array(DUST_COUNT * 3); // velocity vectors
    for (let i = 0; i < DUST_COUNT; i++) {
      // Distribute in a shell around the globe (1.2r to 2.2r)
      const r = 1.2 + Math.random() * 1.0;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      dustPos[i * 3] = r * Math.sin(phi) * Math.cos(theta);
      dustPos[i * 3 + 1] = r * Math.sin(phi) * Math.sin(theta);
      dustPos[i * 3 + 2] = r * Math.cos(phi);
      dustSizes[i] = 0.5 + Math.random() * 1.5;
      // Slow random drift direction
      dustDrift[i * 3] = (Math.random() - 0.5) * 0.003;
      dustDrift[i * 3 + 1] = (Math.random() - 0.5) * 0.002;
      dustDrift[i * 3 + 2] = (Math.random() - 0.5) * 0.003;
    }
    const dustGeo = new THREE.BufferGeometry();
    dustGeo.setAttribute('position', new THREE.BufferAttribute(dustPos, 3));
    dustGeo.setAttribute('aSize', new THREE.BufferAttribute(dustSizes, 1));
    dustGeo.setAttribute('aDrift', new THREE.BufferAttribute(dustDrift, 3));
    const dustMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uColor: { value: new THREE.Color(themeColors.accent) },
      },
      vertexShader: `
        attribute float aSize;
        attribute vec3 aDrift;
        uniform float uTime;
        varying float vAlpha;
        void main() {
          // True orbital motion — rotate around Y axis at unique speed + wobble
          float orbitSpeed = aDrift.x * 80.0; // use drift.x as orbit speed seed
          float wobbleSpeed = aDrift.z * 60.0;
          float angle = uTime * orbitSpeed;
          float wobble = sin(uTime * wobbleSpeed + position.y * 5.0) * 0.03;
          // Rotate position around Y axis
          float cosA = cos(angle);
          float sinA = sin(angle);
          vec3 pos = vec3(
            position.x * cosA - position.z * sinA,
            position.y + wobble,
            position.x * sinA + position.z * cosA
          );
          vec4 mv = modelViewMatrix * vec4(pos, 1.0);
          float depth = -mv.z;
          // Fade by distance from camera
          vAlpha = smoothstep(3.5, 1.5, depth) * 0.25;
          gl_PointSize = max(aSize * (15.0 / depth), 0.5);
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        varying float vAlpha;
        void main() {
          float dist = length(gl_PointCoord - vec2(0.5));
          float glow = exp(-dist * dist * 18.0);
          if (glow < 0.02) discard;
          gl_FragColor = vec4(uColor * 0.75 + vec3(0.25), glow * vAlpha);
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    const dustParticles = new THREE.Points(dustGeo, dustMat);
    globeGroup.add(dustParticles);

    // ── Positioning ──
    function positionGlobe() {
      if (wrap.clientWidth >= 1024) {
        globeGroup.position.set(0.95, 0.05, 0);
        globeGroup.scale.setScalar(1.15);
      } else {
        globeGroup.position.set(0, 0, 0);
        globeGroup.scale.setScalar(0.85);
      }
    }
    positionGlobe();
    globeGroup.rotation.y = -0.4; // Atlantic facing
    globeGroup.rotation.z = -0.12; // Subtle axial tilt (~7°) for natural Earth feel

    // ── Interaction ──
    let mouseX = 0, mouseY = 0;
    if (!reducedMotion) {
      document.addEventListener('mousemove', (e) => {
        mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
        mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
      });
    }

    let scrollFade = 1;
    let scrollZoom = 1;
    let scrollRotMult = 1;
    window.addEventListener('scroll', () => {
      const scrollPct = window.scrollY / window.innerHeight;
      scrollFade = Math.max(0.35, 1 - scrollPct / 1.5);
      // Subtle zoom-out + upward shift on scroll — parallax depth
      scrollZoom = Math.max(0.88, 1 - scrollPct * 0.08);
      // Rotation deceleration on scroll — globe "pauses" as user reads content
      scrollRotMult = Math.max(0.1, 1 - scrollPct * 0.7);
    }, { passive: true });

    // ── Animation Loop ──
    let animId = 0;
    let time = 0;
    let prevTimestamp = 0;

    function animate(timestamp: number) {
      animId = requestAnimationFrame(animate);
      const dt = prevTimestamp ? Math.min((timestamp - prevTimestamp) / 1000, 0.1) : 0.016;
      prevTimestamp = timestamp;
      time += dt;

      const opacityMult = themeColors.isLight ? 0.55 : 1;

      // Auto-rotation with entrance wind-up + mouse parallax
      if (!reducedMotion) {
        // Wind-up: rotation starts slow, reaches full speed over 3 seconds
        const windUp = Math.min(time / 3.0, 1.0);
        const windUpEase = windUp * windUp * (3 - 2 * windUp); // smoothstep
        const baseSpeed = 0.0008 * windUpEase * scrollRotMult;
        const mouseSpeedMod = wrap.clientWidth >= 1024 ? mouseX * 0.0006 * windUpEase * scrollRotMult : 0;
        globeGroup.rotation.y += baseSpeed + mouseSpeedMod;
      }

      // Mouse parallax — vertical tilt (desktop)
      if (!reducedMotion && wrap.clientWidth >= 1024) {
        const targetTiltX = mouseY * 0.15;
        globeGroup.rotation.x += (targetTiltX - globeGroup.rotation.x) * 0.04;
      }

      // Nebula billboard — always faces camera regardless of globe rotation
      nebulaMesh.quaternion.copy(camera.quaternion);

      // Star field parallax — subtle counter-rotation for depth
      if (!reducedMotion) {
        stars.rotation.y -= 0.00004;
        stars.rotation.x = globeGroup.rotation.x * 0.05;
      }

      // Update all time uniforms
      dotMat.uniforms.uTime.value = time;
      coreMat.uniforms.uTime.value = time;
      markerMat.uniforms.uTime.value = time;
      starMat.uniforms.uTime.value = time;
      outerAtmosMat.uniforms.uTime.value = time;
      midAtmosMat.uniforms.uTime.value = time;
      innerRimMat.uniforms.uTime.value = time;
      ringRefs.forEach(r => { r.mat.uniforms.uTime.value = time; });
      dustMat.uniforms.uTime.value = time;
      beamMat.uniforms.uTime.value = time;
      beam2Mat.uniforms.uTime.value = time;
      nebulaMat.uniforms.uTime.value = time;

      // Arc comet animation — ease-in-out for organic motion
      if (!reducedMotion) {
        arcSystems.forEach(({ mat, speed, phase }) => {
          const cycle = (time * speed + phase) % 2.0;
          const linear = Math.min(cycle, 1.0);
          // Smooth ease-in-out: slow start, fast middle, slow end
          const eased = linear < 0.5
            ? 2 * linear * linear
            : 1 - Math.pow(-2 * linear + 2, 2) / 2;
          mat.uniforms.uHead.value = eased;
        });
      }

      // Entrance animation — smooth scale-up over first 3 seconds with wind-up
      const entranceDur = 3.0;
      const entranceT = Math.min(time / entranceDur, 1.0);
      // Quartic ease-out: dramatic deceleration
      const entranceEase = 1.0 - Math.pow(1.0 - entranceT, 4);
      const entranceScale = 0.82 + 0.18 * entranceEase;

      // Scroll-driven opacity + zoom parallax
      if (scrollControlsOpacity) {
        wrap.style.opacity = String(Math.max(0, scrollFade * opacityMult));
        const baseScale = wrap.clientWidth >= 1024 ? 1.15 : 0.85;
        globeGroup.scale.setScalar(baseScale * scrollZoom * entranceScale);
        globeGroup.position.y = (wrap.clientWidth >= 1024 ? 0.05 : 0) + (1 - scrollZoom) * 0.3;
      } else {
        // Pre-scroll-control: still apply entrance scale
        const baseScale = wrap.clientWidth >= 1024 ? 1.15 : 0.85;
        globeGroup.scale.setScalar(baseScale * entranceScale);
      }

      renderer.render(scene, camera);
    }

    // ── Resize ──
    const ro = new ResizeObserver(() => {
      const w = wrap.clientWidth;
      const h = wrap.clientHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      positionGlobe();
    });
    ro.observe(wrap);

    // ── Launch ──
    let scrollControlsOpacity = false;
    animate();
    // Use setTimeout instead of double-rAF — more reliable across browsers
    setTimeout(() => {
      wrap.classList.add('ready');
      wrap.dispatchEvent(new CustomEvent('globe-ready', { bubbles: true }));
    }, 80);
    setTimeout(() => {
      scrollControlsOpacity = true;
      wrap.style.transition = 'none';
    }, 1600);

    // ── Cleanup — dispose ALL geometries/materials (including rings) ──
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
      themeObserver.disconnect();
      renderer.dispose();
      dotGeo.dispose();
      dotMat.dispose();
      coreGeo.dispose();
      coreMat.dispose();
      outerAtmosGeo.dispose();
      outerAtmosMat.dispose();
      midAtmosGeo.dispose();
      midAtmosMat.dispose();
      innerRimGeo.dispose();
      innerRimMat.dispose();
      starGeo.dispose();
      starMat.dispose();
      markerGeo.dispose();
      markerMat.dispose();
      dustGeo.dispose();
      dustMat.dispose();
      beamGeo.dispose();
      beamMat.dispose();
      beam2Geo.dispose();
      beam2Mat.dispose();
      nebulaGeo.dispose();
      nebulaMat.dispose();
      ringRefs.forEach(r => { r.geo.dispose(); r.mat.dispose(); });
      arcSystems.forEach(({ points }) => {
        points.geometry.dispose();
        (points.material as THREE.Material).dispose();
      });
    }, { once: true });
  }
</script>
