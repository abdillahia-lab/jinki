      `,
      transparent: true,
      side: THREE.BackSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    })
    globeGroup.add(new THREE.Mesh(midAtmosGeo, midAtmosMat));

    // Shell 3: Inner rim boundary (FrontSide, 1.002r) — crisp atmosphere edge + sweep flash
    const innerRimGeo = new THREE.IcosahedronGeometry(1.002, 48);
    const innerRimMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
      },
      vertexShader: `
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldPos;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vWorldPos = normal;
          vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldPos;
        void main() {
          vec3 viewDir = normalize(-vPos);
          float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
          // Shell 3 breathe: tighter, faster variation for crisp rim
          float breathe = 1.0 + sin(uTime * 0.35 + 0.5) * 0.1 + sin(uTime * 0.13) * 0.03;
          // Scan sweep flash on inner rim — beam hits atmospheric boundary
          float scanAngle = atan(vWorldPos.x, vWorldPos.z);
          float sweepAngle = mod(uTime * 0.4, 6.28318);
          float scanDist = mod(scanAngle - sweepAngle + 6.28318, 6.28318);
          float sweepFlash = smoothstep(0.4, 0.0, scanDist) * 0.6;
          // Razor-sharp horizon line — ultra-concentrated at the silhouette edge
          float razorEdge = pow(rim, 16.0) * 1.2;
          // Softer secondary bloom behind the razor edge
          float bloomEdge = pow(rim, 8.0) * (0.55 + sweepFlash);
          float glow = (razorEdge + bloomEdge) * breathe;
          // Color-shifted corona — white-hot at the razor edge, accent in the bloom
          vec3 razorColor = mix(uColor * 1.6, vec3(1.0), razorEdge / max(glow, 0.01) * 0.5);
          // Sun-side horizon is brighter — directional atmospheric scattering
          vec3 sunDir = normalize(vec3(0.6, 0.4, 0.8));
          float sunHorizon = max(dot(normalize(vWorldPos), sunDir), 0.0);
          float sunBright = 1.0 + sunHorizon * 0.4;
