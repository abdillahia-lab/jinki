---
/*
  GlobeCanvas v6.0
  Photorealistic Earth: Blue Marble day + LWIR thermal night
  Rayleigh atmosphere, normal-mapped terrain, cloud layer, thermal scan
  No post-processing, no fake HUD
*/
---

<canvas id="globe-canvas"></canvas>

<style>
  #globe-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.4s ease-out;
    will-change: opacity;
    mask-image: radial-gradient(ellipse 110% 130% at 75% 45%, rgba(0,0,0,0.9) 15%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.15) 60%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 110% 130% at 75% 45%, rgba(0,0,0,0.9) 15%, rgba(0,0,0,0.5) 40%, rgba(0,0,0,0.15) 60%, transparent 75%);
  }
  #globe-canvas {
    background: radial-gradient(ellipse 55% 50% at 65% 45%,
      rgba(0, 40, 80, 0.35) 0%, rgba(0, 15, 35, 0.15) 40%, transparent 70%);
  }
  #globe-canvas:hover { cursor: crosshair; }
  @media (max-width: 767px) {
    #globe-canvas { display: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    #globe-canvas {
      mask-image: radial-gradient(ellipse 70% 80% at 50% 55%, rgba(0,0,0,0.6) 0%, transparent 100%);
      -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 55%, rgba(0,0,0,0.6) 0%, transparent 100%);
    }
  }
</style>

<script>
  async function initGlobe(): Promise<void> {
    if (window.innerWidth < 768) return;
    const canvas = document.getElementById("globe-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;

    const {
      WebGLRenderer, Scene, PerspectiveCamera, Group, Clock,
      TextureLoader, SRGBColorSpace, ACESFilmicToneMapping,
      ShaderMaterial, SphereGeometry, Mesh, BackSide,
      BufferGeometry, BufferAttribute, Points, AdditiveBlending,
      LineSegments, LineBasicMaterial, Vector3
    } = await import("three");

    const renderer = new WebGLRenderer({
      canvas, antialias: true, alpha: true, powerPreference: "high-performance",
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.toneMapping = ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    const scene = new Scene();
    const camera = new PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.set(0, 0, 2.8);

    const globeGroup = new Group();
    scene.add(globeGroup);
    const isTablet = window.innerWidth < 1024;
    globeGroup.position.x = isTablet ? 0 : 0.8;
    globeGroup.scale.setScalar(isTablet ? 0.85 : 1.1);

    const loader = new TextureLoader();
    const maxAniso = renderer.capabilities.getMaxAnisotropy();
    const loadTexAsync = (path: string, srgb = true): Promise<any> =>
      new Promise((resolve) => {
        const tex = loader.load(path, () => resolve(tex));
        if (srgb) tex.colorSpace = SRGBColorSpace;
        tex.anisotropy = maxAniso;
      });

    // Wait for ALL textures before showing the globe
    const [dayMap, nightMap, normalMap, specularMap, cloudMap] = await Promise.all([
      loadTexAsync("/textures/earth-day.webp"),
      loadTexAsync("/textures/earth-thermal.webp"),
      loadTexAsync("/textures/earth-normal.webp", false),
      loadTexAsync("/textures/earth-specular.webp", false),
      loadTexAsync("/textures/earth-clouds.webp", false),
    ]);

    // Time-aware sun — matches visitor's local time
    const hour = new Date().getHours() + new Date().getMinutes() / 60;
    const sunAngle = ((hour - 6) / 24) * Math.PI * 2;
    const sunDir = new Vector3(
      Math.cos(sunAngle) * 0.8, 0.3, Math.sin(sunAngle) * 0.6
    ).normalize();

    const earthUniforms = {
      uDayMap: { value: dayMap }, uNightMap: { value: nightMap },
      uNormalMap: { value: normalMap }, uSpecular: { value: specularMap },
      uSunDir: { value: sunDir }, uTime: { value: 0 },
    };

    const earthVS = `
      varying vec2 vUv; varying vec3 vNormal; varying vec3 vPosition;
      varying vec3 vTangent; varying vec3 vBitangent;
      void main() {
        vUv = uv;
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
        vec3 t = normalize(normalMatrix * vec3(-sin(uv.x * 6.2832), 0.0, cos(uv.x * 6.2832)));
        vTangent = t;
        vBitangent = cross(vNormal, t);
        gl_Position = projectionMatrix * vec4(vPosition, 1.0);
      }
    `;

    const earthFS = `
      uniform sampler2D uDayMap; uniform sampler2D uNightMap;
      uniform sampler2D uNormalMap; uniform sampler2D uSpecular;
      uniform vec3 uSunDir; uniform float uTime;
      varying vec2 vUv; varying vec3 vNormal; varying vec3 vPosition;
      varying vec3 vTangent; varying vec3 vBitangent;
      void main() {
        vec3 mapN = texture2D(uNormalMap, vUv).xyz * 2.0 - 1.0;
        mapN.xy *= 0.6;
        vec3 normal = normalize(vTangent * mapN.x + vBitangent * mapN.y + vNormal * mapN.z);
        float sunDot = dot(normal, uSunDir);
        float dayMix = smoothstep(-0.15, 0.1, sunDot);
        vec3 dayColor = texture2D(uDayMap, vUv).rgb;
        vec3 nightColor = texture2D(uNightMap, vUv).rgb;
        float lum = dot(dayColor, vec3(0.299, 0.587, 0.114));
        dayColor = mix(vec3(lum), dayColor, 0.85);
        float terminator = exp(-sunDot * sunDot / 0.008) * 0.4;
        vec3 termColor = vec3(1.0, 0.4, 0.13);
        float spec = texture2D(uSpecular, vUv).r;
        vec3 halfVec = normalize(uSunDir + normalize(-vPosition));
        float specular = pow(max(dot(normal, halfVec), 0.0), 80.0) * spec * 0.6;
        float scanY = fract(uTime * 0.05);
        float scanDist = abs(vUv.y - scanY);
        float scanLine = (1.0 - dayMix) * exp(-scanDist * scanDist * 8000.0) * 0.3;
        nightColor += scanLine * vec3(0.0, 0.9, 1.0);
        vec3 color = mix(nightColor, dayColor, dayMix);
        color += termColor * terminator;
        color += vec3(1.0, 0.95, 0.85) * specular * dayMix;
        // Coordinate reticle — visible only at silhouette edges
        vec3 vDir = normalize(-vPosition);
        float rim = 1.0 - abs(dot(vDir, normal));
        float gLon = 1.0 - smoothstep(0.0, fwidth(vUv.x) * 30.0, abs(fract(vUv.x * 12.0) - 0.5) * 2.0);
        float gLat = 1.0 - smoothstep(0.0, fwidth(vUv.y) * 30.0, abs(fract(vUv.y * 6.0) - 0.5) * 2.0);
        color += vec3(0.0, 0.9, 1.0) * max(gLon, gLat) * pow(rim, 4.0) * 0.12;
        gl_FragColor = vec4(color, 1.0);
      }
    `;

    const earthMat = new ShaderMaterial({
      uniforms: earthUniforms, vertexShader: earthVS, fragmentShader: earthFS,
    });
    const earthGeo = new SphereGeometry(1, 64, 64);
    const earthMesh = new Mesh(earthGeo, earthMat);
    globeGroup.add(earthMesh);

    const cloudUniforms = { uCloudMap: { value: cloudMap }, uSunDir: { value: sunDir } };
    const cloudVS = `
      varying vec2 vUv; varying vec3 vNormal;
      void main() {
        vUv = uv; vNormal = normalize(normalMatrix * normal);
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;
    const cloudFS = `
      uniform sampler2D uCloudMap; uniform vec3 uSunDir;
      varying vec2 vUv; varying vec3 vNormal;
      void main() {
        float cloud = texture2D(uCloudMap, vUv).r;
        float sunFace = max(dot(vNormal, uSunDir), 0.0);
        vec3 cloudColor = mix(vec3(0.15, 0.18, 0.25), vec3(1.0), smoothstep(-0.1, 0.2, sunFace));
        gl_FragColor = vec4(cloudColor, cloud * 0.3);
      }
    `;
    const cloudMat = new ShaderMaterial({
      uniforms: cloudUniforms, vertexShader: cloudVS, fragmentShader: cloudFS,
      transparent: true, depthWrite: false,
    });
    const cloudMesh = new Mesh(new SphereGeometry(1.003, 48, 48), cloudMat);
    globeGroup.add(cloudMesh);

    const atmoUniforms = { uSunDir: { value: sunDir } };
    const atmoVS = `
      varying vec3 vNormal; varying vec3 vPosition;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * vec4(vPosition, 1.0);
      }
    `;
    const atmoFS = `
      uniform vec3 uSunDir; varying vec3 vNormal; varying vec3 vPosition;
      void main() {
        vec3 viewDir = normalize(-vPosition);
        float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
        float atmosphere = pow(rim, 4.0) * 0.8;
        float sunFacing = max(dot(vNormal, uSunDir), 0.0);
        vec3 sunColor = mix(vec3(0.1, 0.07, 0.25), vec3(0.27, 0.53, 1.0), sunFacing);
        float termGlow = exp(-pow(dot(vNormal, uSunDir), 2.0) * 8.0);
        sunColor = mix(sunColor, vec3(1.0, 0.4, 0.2), termGlow * 0.5);
        gl_FragColor = vec4(sunColor, atmosphere * 0.45);
      }
    `;
    const atmoMat = new ShaderMaterial({
      uniforms: atmoUniforms, vertexShader: atmoVS, fragmentShader: atmoFS,
      transparent: true, depthWrite: false, side: BackSide,
    });
    const atmoMesh = new Mesh(new SphereGeometry(1.025, 48, 48), atmoMat);
    globeGroup.add(atmoMesh);

    // ── Orbital Shell — satellite constellation at LEO altitude ──
    const SAT_COUNT = 150;
    const satPositions = new Float32Array(SAT_COUNT * 3);
    const satPlanes = new Float32Array(SAT_COUNT);
    const tilts = [53 * Math.PI / 180, 97 * Math.PI / 180, 45 * Math.PI / 180];
    for (let i = 0; i < SAT_COUNT; i++) {
      const plane = Math.floor(i / 50);
      const angle = ((i % 50) / 50) * Math.PI * 2 + Math.random() * 0.1;
      const r = 1.12;
      const tilt = tilts[plane];
      const x = Math.cos(angle) * r;
      const y = Math.sin(angle) * Math.cos(tilt) * r;
      const z = Math.sin(angle) * Math.sin(tilt) * r;
      satPositions[i * 3] = x;
      satPositions[i * 3 + 1] = y;
      satPositions[i * 3 + 2] = z;
      satPlanes[i] = plane;
    }
    const satGeo = new BufferGeometry();
    satGeo.setAttribute("position", new BufferAttribute(satPositions, 3));
    satGeo.setAttribute("aPlane", new BufferAttribute(satPlanes, 1));
    const satUniforms = { uTime: { value: 0 }, uSunDir: { value: sunDir } };
    const satMat = new ShaderMaterial({
      uniforms: satUniforms,
      vertexShader: `
        attribute float aPlane;
        uniform float uTime; uniform vec3 uSunDir;
        varying float vBright;
        void main() {
          float speed = 0.08 + aPlane * 0.03;
          float a = uTime * speed;
          float ca = cos(a), sa = sin(a);
          vec3 p = vec3(position.x*ca + position.z*sa, position.y, -position.x*sa + position.z*ca);
          vBright = 0.15 + 0.85 * max(dot(normalize(p), uSunDir), 0.0);
          vec4 mv = modelViewMatrix * vec4(p, 1.0);
          gl_PointSize = 2.0;
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        varying float vBright;
        void main() {
          float d = length(gl_PointCoord - 0.5);
          if (d > 0.5) discard;
          gl_FragColor = vec4(0.6, 0.85, 1.0, (1.0 - d*2.0) * 0.5 * vBright);
        }
      `,
      transparent: true, blending: AdditiveBlending,
      depthWrite: false, depthTest: true,
    });
    globeGroup.add(new Points(satGeo, satMat));

    // ── Data Center Hub Markers ──
    // First entry is HQ (McLean, VA) — rendered larger + cyan
    const dcHubs = [
      [38.93,-77.18], // McLean, VA — Jinki HQ
      [39.0,-77.5],[37.4,-122.1],[41.9,-87.6],[33.7,-84.4],[25.8,-80.2],[33.4,-112.0],
      [51.5,-0.1],[50.1,8.7],[48.9,2.3],[52.4,4.9],[59.3,18.1],[55.7,12.6],
      [1.3,103.9],[35.7,139.7],[22.3,114.2],[37.6,126.9],[25.0,121.5],
      [-33.9,151.2],[19.1,72.9],[25.3,55.3],[-23.5,-46.6],[55.7,37.6],
    ];
    const dcPositions = new Float32Array(dcHubs.length * 3);
    const dcPhases = new Float32Array(dcHubs.length);
    const dcIsHQ = new Float32Array(dcHubs.length);
    dcHubs.forEach(([lat, lng], i) => {
      const phi = (90 - lat) * Math.PI / 180;
      const theta = (lng + 180) * Math.PI / 180;
      dcPositions[i*3]   = -1.008 * Math.sin(phi) * Math.cos(theta);
      dcPositions[i*3+1] =  1.008 * Math.cos(phi);
      dcPositions[i*3+2] =  1.008 * Math.sin(phi) * Math.sin(theta);
      dcPhases[i] = i * 0.29;
      dcIsHQ[i] = i === 0 ? 1.0 : 0.0;
    });
    const dcGeo = new BufferGeometry();
    dcGeo.setAttribute("position", new BufferAttribute(dcPositions, 3));
    dcGeo.setAttribute("aPhase", new BufferAttribute(dcPhases, 1));
    dcGeo.setAttribute("aIsHQ", new BufferAttribute(dcIsHQ, 1));
    const dcUniforms = { uTime: { value: 0 }, uSunDir: { value: sunDir } };
    const dcMat = new ShaderMaterial({
      uniforms: dcUniforms,
      vertexShader: `
        attribute float aPhase; attribute float aIsHQ;
        uniform float uTime; uniform vec3 uSunDir;
        varying float vPulse; varying float vBright; varying float vHQ;
        void main() {
          vHQ = aIsHQ;
          vec3 n = normalize(position);
          vBright = 0.4 + 0.6 * max(dot(n, uSunDir), 0.0);
          vPulse = 0.6 + 0.4 * sin(uTime * 1.5 + aPhase * 6.28);
          vec4 mv = modelViewMatrix * vec4(position, 1.0);
          float baseSize = mix(12.0, 18.0, aIsHQ); // HQ is larger
          gl_PointSize = baseSize * vPulse;
          gl_Position = projectionMatrix * mv;
        }
      `,
      fragmentShader: `
        varying float vPulse; varying float vBright; varying float vHQ;
        void main() {
          float d = length(gl_PointCoord - 0.5);
          if (d > 0.5) discard;
          float core = exp(-d * d * 20.0);
          float glow = exp(-d * d * 6.0) * 0.4;
          float alpha = (core + glow) * vPulse * vBright;
          // HQ = brand cyan, others = warm amber
          vec3 col = mix(vec3(0.2, 1.0, 0.4), vec3(0.0, 0.9, 1.0), vHQ);
          gl_FragColor = vec4(col, alpha * 0.8);
        }
      `,
      transparent: true, blending: AdditiveBlending,
      depthWrite: false, depthTest: true,
    });
    globeGroup.add(new Points(dcGeo, dcMat));

    // ── Submarine Cables + Shipping Lanes ──
    function latLngToVec3(lat: number, lng: number, r: number): [number, number, number] {
      const phi = (90 - lat) * Math.PI / 180;
      const theta = (lng + 180) * Math.PI / 180;
      return [
        -r * Math.sin(phi) * Math.cos(theta),
        r * Math.cos(phi),
        r * Math.sin(phi) * Math.sin(theta),
      ];
    }

    function buildGreatCircleLines(routes: number[][][], radius: number, segments: number): Float32Array {
      const allPositions: number[] = [];
      for (const route of routes) {
        // Route can be 2+ points; interpolate between consecutive pairs
        for (let p = 0; p < route.length - 1; p++) {
          const [lat1, lng1] = route[p];
          const [lat2, lng2] = route[p + 1];
          const start = new Vector3(...latLngToVec3(lat1, lng1, radius));
          const end = new Vector3(...latLngToVec3(lat2, lng2, radius));
          for (let i = 0; i < segments; i++) {
            const t1 = i / segments;
            const t2 = (i + 1) / segments;
            const p1 = start.clone().lerp(end, t1).normalize().multiplyScalar(radius);
            const p2 = start.clone().lerp(end, t2).normalize().multiplyScalar(radius);
            allPositions.push(p1.x, p1.y, p1.z, p2.x, p2.y, p2.z);
          }
        }
      }
      return new Float32Array(allPositions);
    }

    // Load and render cables + lanes in parallel
    Promise.all([
      fetch('/data/submarine-cables.json').then(r => r.json()),
      fetch('/data/shipping-lanes.json').then(r => r.json()),
    ]).then(([cables, lanes]) => {
      // Submarine cables — cyan
      const cablePositions = buildGreatCircleLines(cables, 1.002, 16);
      const cableGeo = new BufferGeometry();
      cableGeo.setAttribute('position', new BufferAttribute(cablePositions, 3));
      const cableMat = new LineBasicMaterial({ color: 0x00D4FF, transparent: true, opacity: 0.55 });
      globeGroup.add(new LineSegments(cableGeo, cableMat));

      // Shipping lanes — amber
      const lanePositions = buildGreatCircleLines(lanes, 1.001, 20);
      const laneGeo = new BufferGeometry();
      laneGeo.setAttribute('position', new BufferAttribute(lanePositions, 3));
      const laneMat = new LineBasicMaterial({ color: 0xFF8C00, transparent: true, opacity: 0.35 });
      globeGroup.add(new LineSegments(laneGeo, laneMat));
    }).catch(e => console.warn('[Globe] Overlays failed:', e));

    let isDragging = false;
    let prevMouse = { x: 0, y: 0 };
    let rotVelX = 0, rotVelY = 0;
    let mouseParallaxX = 0, mouseParallaxY = 0;
    let isVisible = true, scrollOpacity = 1, currentOpacity = 1;
    const AUTO_ROT = 0.00175;
    const FRICTION = 0.95;

    const onPointerDown = (e: PointerEvent) => {
      isDragging = true;
      prevMouse.x = e.clientX; prevMouse.y = e.clientY;
      canvas.style.pointerEvents = "auto";
    };
    const onPointerMove = (e: PointerEvent) => {
      mouseParallaxX = (e.clientX / window.innerWidth - 0.5) * 0.15;
      mouseParallaxY = (e.clientY / window.innerHeight - 0.5) * 0.1;
      if (!isDragging) return;
      rotVelY = (e.clientX - prevMouse.x) * 0.003;
      rotVelX = (e.clientY - prevMouse.y) * 0.003;
      prevMouse.x = e.clientX; prevMouse.y = e.clientY;
    };
    const onPointerUp = () => {
      isDragging = false;
      canvas.style.pointerEvents = "none";
    };

    document.addEventListener("pointerdown", (e) => {
      if (e.clientX > window.innerWidth * 0.3) onPointerDown(e);
    });
    document.addEventListener("pointermove", onPointerMove);
    document.addEventListener("pointerup", onPointerUp);

    const onScroll = () => {
      const raw = Math.max(0, Math.min(1, 1 - window.scrollY / (window.innerHeight * 0.9)));
      scrollOpacity = raw * raw * (3 - 2 * raw);
    };
    window.addEventListener("scroll", onScroll, { passive: true });

    const observer = new IntersectionObserver(
      (entries) => { isVisible = entries[0].isIntersecting; },
      { threshold: 0 }
    );
    observer.observe(canvas);

    const resizeObs = new ResizeObserver(() => {
      const w = window.innerWidth, h = window.innerHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      const t = w < 1024;
      globeGroup.position.x = t ? 0 : 0.8;
      globeGroup.scale.setScalar(t ? 0.85 : 1.1);
    });
    resizeObs.observe(document.documentElement);

    requestAnimationFrame(() => { canvas.style.opacity = "1"; });

    const clock = new Clock();
    let animId = 0;

    const animate = () => {
      animId = requestAnimationFrame(animate);
      if (!isVisible) return;
      const elapsed = clock.getElapsedTime();
      earthUniforms.uTime.value = elapsed;
      satUniforms.uTime.value = elapsed;
      dcUniforms.uTime.value = elapsed;
      if (!isDragging) {
        globeGroup.rotation.y += AUTO_ROT;
        rotVelX *= FRICTION;
        rotVelY *= FRICTION;
      }
      globeGroup.rotation.y += rotVelY;
      globeGroup.rotation.x += rotVelX;
      globeGroup.rotation.x = Math.max(-0.8, Math.min(0.8, globeGroup.rotation.x));
      cloudMesh.rotation.y = -elapsed * 0.002;
      
      currentOpacity += (scrollOpacity - currentOpacity) * 0.08;
      const scrollFactor = 1 - currentOpacity;
      camera.position.x = mouseParallaxX;
      camera.position.y = -mouseParallaxY - scrollFactor * 0.06;
      camera.position.z = 2.8 + scrollFactor * 0.12;
      camera.lookAt(globeGroup.position);
      canvas.style.opacity = String(currentOpacity);
      renderer.render(scene, camera);
    };
    animate();

    const cleanup = () => {
      cancelAnimationFrame(animId);
      observer.disconnect();
      resizeObs.disconnect();
      window.removeEventListener("scroll", onScroll);
      document.removeEventListener("pointermove", onPointerMove);
      document.removeEventListener("pointerup", onPointerUp);
      earthGeo.dispose(); earthMat.dispose();
      cloudMat.dispose(); atmoMat.dispose();
      satGeo.dispose(); satMat.dispose();
      dcGeo.dispose(); dcMat.dispose();
      dayMap.dispose(); nightMap.dispose();
      normalMap.dispose(); specularMap.dispose();
      cloudMap.dispose(); renderer.dispose();
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }

  initGlobe();
  document.addEventListener("astro:after-swap", initGlobe);
</script>
