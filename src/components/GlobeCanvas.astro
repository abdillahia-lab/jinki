          vec3 lutScatter = texture2D(uAtmosphereLUT, lutUV).rgb;
          // v4.97: Dominant physically-based scattering (65% LUT) — realistic Rayleigh/Mie color
          atmosColor = mix(atmosColor, lutScatter * uColor * 3.0, 0.65 * rim);
          // v11.17: 4-octave plasma noise — non-uniform turbulent speeds per octave
          vec3 n = normalize(vWorldNormal);
          // v12.16: Latitude-dependent plasma speed — equatorial flows faster (Coriolis-like)
          float latSpeed = 1.0 + (1.0 - abs(n.y)) * 0.4; // 1.0 at poles, 1.4 at equator
          float drift1 = uTime * 0.08 * latSpeed + sin(uTime * 0.05) * 0.3; // Slow surge
          float drift2 = uTime * 0.12 + sin(uTime * 0.09) * 0.2; // Mid acceleration
          float drift3 = uTime * 0.18;
          float drift4 = uTime * 0.25 + cos(uTime * 0.07) * 0.15; // Fine turbulence bursts
          float plasma = vnoise(n * 2.5 + drift1) * 0.4
                       + vnoise(n * 5.0 - drift2) * 0.3
                       + vnoise(n * 10.0 + drift3) * 0.2
                       + vnoise(n * 20.0 - drift4) * 0.1;
          // v12.46: Displacement-correlated plasma — physical bulges glow brighter
          float dispBrightness = smoothstep(0.02, 0.06, vDisplacement) * 0.15; // Bulging regions brighter
          plasma += dispBrightness;
