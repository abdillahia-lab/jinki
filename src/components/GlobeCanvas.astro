          vec3 auroraColor = mix(auroraGreen, auroraViolet, upperFringe * 0.4);
          atmosColor = mix(atmosColor, auroraColor, auroraGlow);
          glow += auroraGlow * 0.3;
          // v12.57: Latitude-banded heat shimmer — tropics shimmer more, poles calmer
