---
/*
  GlobeCanvas v6.0
  Photorealistic Earth: Blue Marble day + LWIR thermal night
  Rayleigh atmosphere, normal-mapped terrain, cloud layer, thermal scan
  No post-processing, no fake HUD
*/
---

<canvas id="globe-canvas"></canvas>

<style>
  #globe-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.4s ease-out;
    mask-image: linear-gradient(to left, rgba(0,0,0,1) 40%, rgba(0,0,0,0.3) 70%, transparent 90%);
    -webkit-mask-image: linear-gradient(to left, rgba(0,0,0,1) 40%, rgba(0,0,0,0.3) 70%, transparent 90%);
  }
  @media (max-width: 767px) {
    #globe-canvas { display: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    #globe-canvas {
      mask-image: radial-gradient(ellipse 70% 80% at 50% 55%, rgba(0,0,0,0.6) 0%, transparent 100%);
      -webkit-mask-image: radial-gradient(ellipse 70% 80% at 50% 55%, rgba(0,0,0,0.6) 0%, transparent 100%);
    }
  }
</style>

<script>
  async function initGlobe(): Promise<void> {
    if (window.innerWidth < 768) return;
    const canvas = document.getElementById("globe-canvas") as HTMLCanvasElement | null;
    if (!canvas) return;

    const THREE = await import("three");

    const renderer = new THREE.WebGLRenderer({
      canvas, antialias: true, alpha: true, powerPreference: "high-performance",
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
    camera.position.set(0, 0, 2.8);

    const globeGroup = new THREE.Group();
    scene.add(globeGroup);
    const isTablet = window.innerWidth < 1024;
    globeGroup.position.x = isTablet ? 0 : 0.8;
    globeGroup.scale.setScalar(isTablet ? 0.85 : 1.1);

    const loader = new THREE.TextureLoader();
    const loadTex = (path: string, srgb = true): THREE.Texture => {
      const tex = loader.load(path);
      if (srgb) tex.colorSpace = THREE.SRGBColorSpace;
      tex.anisotropy = renderer.capabilities.getMaxAnisotropy();
      return tex;
    };
    const dayMap = loadTex("/textures/earth-day.webp");
    const nightMap = loadTex("/textures/earth-thermal.webp");
    const normalMap = loadTex("/textures/earth-normal.webp", false);
    const specularMap = loadTex("/textures/earth-specular.webp", false);
    const cloudMap = loadTex("/textures/earth-clouds.webp", false);

    const sunDir = new THREE.Vector3(0.8, 0.3, 0.6).normalize();

    const earthUniforms = {
      uDayMap: { value: dayMap }, uNightMap: { value: nightMap },
      uNormalMap: { value: normalMap }, uSpecular: { value: specularMap },
      uSunDir: { value: sunDir }, uTime: { value: 0 },
    };

    const earthVS = `
      varying vec2 vUv; varying vec3 vNormal; varying vec3 vPosition;
      varying vec3 vTangent; varying vec3 vBitangent;
      void main() {
        vUv = uv;
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
        vec3 t = normalize(normalMatrix * vec3(-sin(uv.x * 6.2832), 0.0, cos(uv.x * 6.2832)));
        vTangent = t;
        vBitangent = cross(vNormal, t);
        gl_Position = projectionMatrix * vec4(vPosition, 1.0);
      }
    `;

    const earthFS = `
      uniform sampler2D uDayMap; uniform sampler2D uNightMap;
      uniform sampler2D uNormalMap; uniform sampler2D uSpecular;
      uniform vec3 uSunDir; uniform float uTime;
      varying vec2 vUv; varying vec3 vNormal; varying vec3 vPosition;
      varying vec3 vTangent; varying vec3 vBitangent;
      void main() {
        vec3 mapN = texture2D(uNormalMap, vUv).xyz * 2.0 - 1.0;
        mapN.xy *= 0.6;
        vec3 normal = normalize(vTangent * mapN.x + vBitangent * mapN.y + vNormal * mapN.z);
        float sunDot = dot(normal, uSunDir);
        float dayMix = smoothstep(-0.15, 0.1, sunDot);
        vec3 dayColor = texture2D(uDayMap, vUv).rgb;
        vec3 nightColor = texture2D(uNightMap, vUv).rgb;
        float lum = dot(dayColor, vec3(0.299, 0.587, 0.114));
        dayColor = mix(vec3(lum), dayColor, 0.85);
        float terminator = exp(-sunDot * sunDot / 0.008) * 0.4;
        vec3 termColor = vec3(1.0, 0.4, 0.13);
        float spec = texture2D(uSpecular, vUv).r;
        vec3 halfVec = normalize(uSunDir + normalize(-vPosition));
        float specular = pow(max(dot(normal, halfVec), 0.0), 80.0) * spec * 0.6;
        float scanY = fract(uTime * 0.05);
        float scanDist = abs(vUv.y - scanY);
        float scanLine = (1.0 - dayMix) * exp(-scanDist * scanDist * 8000.0) * 0.3;
        nightColor += scanLine * vec3(0.0, 0.9, 1.0);
        vec3 color = mix(nightColor, dayColor, dayMix);
        color += termColor * terminator;
        color += vec3(1.0, 0.95, 0.85) * specular * dayMix;
        gl_FragColor = vec4(color, 1.0);
      }
    `;

    const earthMat = new THREE.ShaderMaterial({
      uniforms: earthUniforms, vertexShader: earthVS, fragmentShader: earthFS,
    });
    const earthGeo = new THREE.SphereGeometry(1, 64, 64);
    const earthMesh = new THREE.Mesh(earthGeo, earthMat);
    globeGroup.add(earthMesh);

    const cloudUniforms = { uCloudMap: { value: cloudMap }, uSunDir: { value: sunDir } };
    const cloudVS = `
      varying vec2 vUv; varying vec3 vNormal;
      void main() {
        vUv = uv; vNormal = normalize(normalMatrix * normal);
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;
    const cloudFS = `
      uniform sampler2D uCloudMap; uniform vec3 uSunDir;
      varying vec2 vUv; varying vec3 vNormal;
      void main() {
        float cloud = texture2D(uCloudMap, vUv).r;
        float sunFace = max(dot(vNormal, uSunDir), 0.0);
        vec3 cloudColor = mix(vec3(0.15, 0.18, 0.25), vec3(1.0), smoothstep(-0.1, 0.2, sunFace));
        gl_FragColor = vec4(cloudColor, cloud * 0.3);
      }
    `;
    const cloudMat = new THREE.ShaderMaterial({
      uniforms: cloudUniforms, vertexShader: cloudVS, fragmentShader: cloudFS,
      transparent: true, depthWrite: false,
    });
    const cloudMesh = new THREE.Mesh(new THREE.SphereGeometry(1.003, 48, 48), cloudMat);
    globeGroup.add(cloudMesh);

    const atmoUniforms = { uSunDir: { value: sunDir } };
    const atmoVS = `
      varying vec3 vNormal; varying vec3 vPosition;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPosition = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * vec4(vPosition, 1.0);
      }
    `;
    const atmoFS = `
      uniform vec3 uSunDir; varying vec3 vNormal; varying vec3 vPosition;
      void main() {
        vec3 viewDir = normalize(-vPosition);
        float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
        float atmosphere = pow(rim, 3.0) * 1.5;
        float sunFacing = max(dot(vNormal, uSunDir), 0.0);
        vec3 sunColor = mix(vec3(0.1, 0.07, 0.25), vec3(0.27, 0.53, 1.0), sunFacing);
        float termGlow = exp(-pow(dot(vNormal, uSunDir), 2.0) * 8.0);
        sunColor = mix(sunColor, vec3(1.0, 0.4, 0.2), termGlow * 0.5);
        gl_FragColor = vec4(sunColor, atmosphere * 0.7);
      }
    `;
    const atmoMat = new THREE.ShaderMaterial({
      uniforms: atmoUniforms, vertexShader: atmoVS, fragmentShader: atmoFS,
      transparent: true, depthWrite: false, side: THREE.BackSide,
    });
    const atmoMesh = new THREE.Mesh(new THREE.SphereGeometry(1.025, 48, 48), atmoMat);
    globeGroup.add(atmoMesh);

    let isDragging = false;
    let prevMouse = { x: 0, y: 0 };
    let rotVelX = 0, rotVelY = 0;
    let mouseParallaxX = 0, mouseParallaxY = 0;
    let isVisible = true, scrollOpacity = 1;
    const AUTO_ROT = 0.00175;
    const FRICTION = 0.95;

    const onPointerDown = (e: PointerEvent) => {
      isDragging = true;
      prevMouse.x = e.clientX; prevMouse.y = e.clientY;
      canvas.style.pointerEvents = "auto";
    };
    const onPointerMove = (e: PointerEvent) => {
      mouseParallaxX = (e.clientX / window.innerWidth - 0.5) * 0.15;
      mouseParallaxY = (e.clientY / window.innerHeight - 0.5) * 0.1;
      if (!isDragging) return;
      rotVelY = (e.clientX - prevMouse.x) * 0.003;
      rotVelX = (e.clientY - prevMouse.y) * 0.003;
      prevMouse.x = e.clientX; prevMouse.y = e.clientY;
    };
    const onPointerUp = () => {
      isDragging = false;
      canvas.style.pointerEvents = "none";
    };

    document.addEventListener("pointerdown", (e) => {
      if (e.clientX > window.innerWidth * 0.3) onPointerDown(e);
    });
    document.addEventListener("pointermove", onPointerMove);
    document.addEventListener("pointerup", onPointerUp);

    const onScroll = () => {
      scrollOpacity = Math.max(0, 1 - window.scrollY / (window.innerHeight * 0.6));
    };
    window.addEventListener("scroll", onScroll, { passive: true });

    const observer = new IntersectionObserver(
      (entries) => { isVisible = entries[0].isIntersecting; },
      { threshold: 0 }
    );
    observer.observe(canvas);

    const resizeObs = new ResizeObserver(() => {
      const w = window.innerWidth, h = window.innerHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      const t = w < 1024;
      globeGroup.position.x = t ? 0 : 0.8;
      globeGroup.scale.setScalar(t ? 0.85 : 1.1);
    });
    resizeObs.observe(document.documentElement);

    requestAnimationFrame(() => { canvas.style.opacity = "1"; });

    const clock = new THREE.Clock();
    let animId = 0;

    const animate = () => {
      animId = requestAnimationFrame(animate);
      if (!isVisible) return;
      const elapsed = clock.getElapsedTime();
      earthUniforms.uTime.value = elapsed;
      if (!isDragging) {
        earthMesh.rotation.y += AUTO_ROT;
        rotVelX *= FRICTION;
        rotVelY *= FRICTION;
      }
      earthMesh.rotation.y += rotVelY;
      earthMesh.rotation.x += rotVelX;
      earthMesh.rotation.x = Math.max(-0.8, Math.min(0.8, earthMesh.rotation.x));
      cloudMesh.rotation.y = earthMesh.rotation.y * 0.9 - elapsed * 0.002;
      cloudMesh.rotation.x = earthMesh.rotation.x;
      camera.position.x = mouseParallaxX;
      camera.position.y = -mouseParallaxY;
      camera.lookAt(globeGroup.position);
      canvas.style.opacity = String(scrollOpacity);
      renderer.render(scene, camera);
    };
    animate();

    const cleanup = () => {
      cancelAnimationFrame(animId);
      observer.disconnect();
      resizeObs.disconnect();
      window.removeEventListener("scroll", onScroll);
      document.removeEventListener("pointermove", onPointerMove);
      document.removeEventListener("pointerup", onPointerUp);
      earthGeo.dispose(); earthMat.dispose();
      cloudMat.dispose(); atmoMat.dispose();
      dayMap.dispose(); nightMap.dispose();
      normalMap.dispose(); specularMap.dispose();
      cloudMap.dispose(); renderer.dispose();
    };
    document.addEventListener("astro:before-swap", cleanup, { once: true });
  }

  initGlobe();
  document.addEventListener("astro:after-swap", initGlobe);
</script>
