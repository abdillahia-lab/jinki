      const entranceShake = entranceShakeDecay * entranceShakeDecay * 0.012;
      const totalShake = shakeIntensity + entranceShake;
      const shakeX = totalShake * Math.sin(time * 47.3) * Math.cos(time * 31.7);
      const shakeY = totalShake * Math.sin(time * 53.1) * Math.cos(time * 41.3);
      camera.position.set(entranceCamX + driftX + shakeX, entranceCamY + driftY + shakeY, dollyZ + dispersalDolly);
      camera.lookAt(0, 0, 0);
      // v11.59: Entrance barrel roll — subtle camera roll that decays during approach
      const rollDecay = Math.max(0, 1.0 - time / ENTRANCE_COALESCE_DUR);
      const entranceRoll = rollDecay * rollDecay * rollDecay * 0.08; // Cubic decay, ~4.6° max
      camera.rotation.z = entranceRoll;

      // Entrance "power-on" — deep dark start, multi-stage exposure + bloom cascade
      if (time < ENTRANCE_COALESCE_DUR + 2.0) {
        const coalesceProgress = Math.min(time / ENTRANCE_COALESCE_DUR, 1.0);
        // Power-on: start nearly black, ramp with cubic Hermite
        const powerOn = coalesceProgress * coalesceProgress * (3.0 - 2.0 * coalesceProgress);
        // v11.97: Exposure overshoot — auto-exposure simulation: slightly overexpose then settle
        const overshootT = Math.max(0, (coalesceProgress - 0.6) / 0.4); // Starts at 60% coalesce
        const exposureOvershoot = overshootT * Math.exp(-(overshootT - 0.5) * (overshootT - 0.5) * 8.0) * 0.15;
        const bootExposure = 0.15 + powerOn * 1.25 + exposureOvershoot; // Peak overshoot ~+0.15
        // Initial scattered glow — ethereal bloom while particles are dispersed
        const scatterGlow = Math.max(0, 1.0 - coalesceProgress) * 0.2;
        // Chroma ramp — aberration decreases as globe stabilizes
        const chromaEntrance = (1.0 - powerOn) * 0.004;
        chromaPass.uniforms['uIntensity'].value = chromaEntrance + 0.002;
        // Primary lock-in flash — bloom spike at formation completion
        const lockInT = Math.max(0, (coalesceProgress - 0.8) / 0.2);
        const lockInFlash = Math.pow(lockInT, 2) * Math.exp(-(lockInT - 1.0) * (lockInT - 1.0) * 5.0) * 0.7;
        // Secondary bloom cascade — slower, gentler wave after primary flash
        const postFlashT = Math.max(0, (time - ENTRANCE_COALESCE_DUR) / 2.0);
        const secondaryBloom = postFlashT > 0 ? Math.exp(-postFlashT * 2.5) * 0.3 : 0;
        // Tertiary subtle pulse — very gentle "settling" bloom
        const tertiaryT = Math.max(0, (time - ENTRANCE_COALESCE_DUR - 0.8) / 1.2);
        const tertiaryPulse = tertiaryT > 0 ? Math.exp(-tertiaryT * 4.0) * 0.1 : 0;
        bloomPass.strength = 0.22 + scatterGlow + lockInFlash + secondaryBloom + tertiaryPulse;
        // v12.33: Entrance focus pull — starts defocused (wider bloom), sharpens as globe forms
        const defocus = (1.0 - powerOn) * 0.4; // Wide bloom early, tight at lock-in
        bloomPass.radius = 0.75 + defocus;
        renderer.toneMappingExposure = bootExposure;
        // v11.09: Entrance warmth — color temperature shifts warm during ignition, cools as it settles
        const ignitionWarmth = (1.0 - powerOn) * 0.06; // Warm during early boot
        const lockInWarmth = lockInFlash * 0.03; // Warm flash at lock-in
        colorGradePass.uniforms['uHighlightTint'].value.set(0.08 + ignitionWarmth + lockInWarmth, 0.035, 0.0);
        // v11.62: Cold boot → warm stabilize — shadows start deep blue, warm to teal
        const coldBoot = (1.0 - powerOn) * 0.12;
        colorGradePass.uniforms['uShadowTint'].value.set(0.0, 0.05 + coldBoot * 0.3, 0.18 + coldBoot * 0.4);
        // v12.11: Entrance saturation with overshoot — briefly oversaturates then settles
        const satOvershoot = lockInT * Math.exp(-(lockInT - 0.7) * (lockInT - 0.7) * 6.0) * 0.12;
        colorGradePass.uniforms['uSaturation'].value = 0.7 + powerOn * 0.48 + satOvershoot;
        // v12.62: Entrance cold-to-warm color temperature arc — globe starts blue-cold, warms as it powers on
        const coldTemp = (1.0 - powerOn) * (1.0 - powerOn); // Quadratic decay for lingering cold start
        colorGradePass.uniforms['uEntranceTemp'].value = coldTemp;
        // v12.70: Entrance contrast ramp — flat/washed out → punchy (display warming up)
        const bootContrast = 0.85 + powerOn * 0.27; // 0.85 → 1.12 (matches base)
        colorGradePass.uniforms['uContrast'].value = bootContrast;
      }

      // Common values for both entrance and main-path exposure
      const sunCamDot = sunZ / sunLen;
      const backlitAmount = Math.max(-sunCamDot, 0);
      const dragAge = time - dragStartTime;

      // v5.08: Dynamic corona expansion — wider halo during backlit (eclipse drama)
      const coronaBreath = 1.0 + Math.sin(time * 0.2) * 0.01;
      const coronaBacklitExpand = 1.0 + backlitAmount * backlitAmount * 0.08;
      const coronaSweepPulse = 1.0 + sweepFacing * 0.02;
      coronaMesh.scale.setScalar(coronaBreath * coronaBacklitExpand * coronaSweepPulse);

      // v5.02 opt: Guard bloom/exposure/chroma during entrance — was being overwritten
      if (time >= ENTRANCE_COALESCE_DUR + 2.0) {
        // Dynamic exposure + bloom (main path — after entrance completes)
        const baseExposure = themeColors.isLight ? 1.15 : 1.5;
        const hemisphereExposure = -sunCamDot * 0.08 + backlitAmount * backlitAmount * 0.12;
        const sweepFlash = sweepFacing * sweepFacing * 0.12;
        const breatheExposure = Math.sin(time * 0.3) * 0.05 + Math.sin(time * 0.17) * 0.025;
        const grabDip = dragAge < 0.5 ? Math.exp(-dragAge * 8) * -0.1 : 0;
        renderer.toneMappingExposure = baseExposure + breatheExposure + sweepFlash + peakEnergy * 0.25 + hemisphereExposure + grabDip;
        const sunFacingStrength = Math.max(sunCamDot, 0) * 0.03;
        bloomPass.strength = 0.18 + sweepFacing * 0.06 + Math.sin(time * 0.25) * 0.015 + peakEnergy * 0.14 + backlitAmount * 0.06 + sunFacingStrength;
        bloomPass.radius = 0.75 + peakEnergy * 0.2 + sweepFacing * 0.05 + Math.sin(time * 0.2) * 0.02;
        const thresholdBreathe = Math.sin(time * 0.18) * 0.02 + Math.sin(time * 0.07) * 0.01;
        const sunFacingBloom = Math.max(sunCamDot, 0) * 0.03;
        bloomPass.threshold = 0.62 - peakEnergy * 0.15 - sweepFacing * 0.04 + thresholdBreathe - sunFacingBloom;
        const chromaSpike = Math.pow(peakEnergy, 0.5) * 0.012;
        const sweepChromaFlare = sweepFacing * sweepFacing * 0.006;
        chromaPass.uniforms['uIntensity'].value = 0.002 + sweepFacing * 0.003 + sweepChromaFlare + Math.sin(time * 0.3) * 0.0005 + chromaSpike;
      }
      chromaPass.uniforms['uTime'].value = time;
      // v11.55: Shift vignette center toward sun — opens up sunlit side, darkens shadow side
      // v12.82: Backlit vignette opening — wider vignette when sun behind globe (show golden rim)
      const backlitVigOpen = backlitAmount * 0.02; // Open up to 2% more
      chromaPass.uniforms['uVignetteShift'].value.set(sunX / sunLen * (0.04 + backlitVigOpen), sunY / sunLen * (0.025 + backlitVigOpen * 0.5));
      // v4.90: God rays — project sun direction to screen UV for radial light shafts
      {
        _sunScreenVec.set(sunX / sunLen, sunY / sunLen, sunZ / sunLen).multiplyScalar(5);
        _sunScreenVec.applyMatrix4(globeGroup.matrixWorld);
        _sunScreenVec.project(camera);
        const su = _sunScreenVec.x * 0.5 + 0.5;
        const sv = -_sunScreenVec.y * 0.5 + 0.5;
        chromaPass.uniforms['uSunScreenPos'].value.set(su, sv);
        const onScreen = (su > -0.3 && su < 1.3 && sv > -0.3 && sv < 1.3) ? 1.0 : 0.0;
        chromaPass.uniforms['uGodRayIntensity'].value = (backlitAmount * 0.6 + Math.max(sunCamDot, 0) * 0.4) * onScreen;
      }
      colorGradePass.uniforms['uTime'].value = time;
      colorGradePass.uniforms['uSweepPulse'].value = sweepFacing;
      // v12.29: Only apply main-path color grading AFTER entrance completes
      // (entrance block sets its own shadow/highlight/saturation that was being overwritten)
      if (time >= ENTRANCE_COALESCE_DUR + 2.0) {
        // v11.19: Dynamic contrast — deeper when dark hemisphere faces camera, sharper during interaction
        // v12.14: Grab contrast punch — brief sharp contrast spike on drag start
        const grabContrast = dragAge < 0.3 ? Math.exp(-dragAge * 12) * 0.06 : 0;
        colorGradePass.uniforms['uContrast'].value = 1.12 + backlitAmount * 0.04 + peakEnergy * 0.03 + grabContrast;
        // v11.43: Dynamic shadow tint — warmer when sun faces camera, cooler when away
        // v12.31: Shadow color breathing — slow teal/violet oscillation in darkest areas
        const sunWarmth = Math.max(sunCamDot, 0) * 0.04;
        const shadowBreathe = Math.sin(time * 0.09) * 0.015 + Math.sin(time * 0.04) * 0.008;
        colorGradePass.uniforms['uShadowTint'].value.set(
          sunWarmth + shadowBreathe * 0.3,
          0.1 - sunWarmth * 0.3 + shadowBreathe,
          0.18 - sunWarmth * 0.5 - shadowBreathe * 0.5
        );
        // v10.89: Dynamic saturation — richer during sweep facing + slow rhythmic breathing
        // v11.61: Interaction desaturates slightly (motion blur simulation), re-saturates on stop
        const motionDesat = peakEnergy * -0.08; // Fast spin desaturates
        colorGradePass.uniforms['uSaturation'].value = 1.18 + sweepFacing * 0.06 + Math.sin(time * 0.22) * 0.025 + motionDesat;
        // v11.54: Dynamic highlight tint — warm golden during backlit, neutral when front-lit
        const backlitWarmR = 0.08 + backlitAmount * 0.06;
        const backlitWarmG = 0.035 + backlitAmount * 0.025;
        colorGradePass.uniforms['uHighlightTint'].value.set(backlitWarmR, backlitWarmG, 0.0);
      }

      // FOV breathing + dispersal pull-back
      const dispersalFov = scrollDispersalCurrent * scrollDispersalCurrent * 8; // Up to +8° at full scatter
      const interactionFov = peakEnergy * 1.5; // Subtle FOV widen during fast interaction
      // v11.27: Sweep-responsive FOV breathing — deeper breath when sweep faces camera
      // v11.85: Amplitude-modulated breathing — depth of breath varies over long cycle
      // v5.01: Deeper cinematic FOV breathing — 3 harmonics with amplitude modulation
      const breathDepth = 0.7 + 0.3 * Math.sin(time * 0.037); // Slow 27s cycle modulates amplitude
      const fovBreathe = breathDepth * ((0.35 + sweepFacing * 0.2) * Math.sin(time * 0.18) + 0.15 * Math.sin(time * 0.11) + 0.08 * Math.sin(time * 0.29));
      // v11.72: Grab FOV punch — brief narrowing on drag start, then widens
      const grabFov = dragAge < 0.4 ? Math.exp(-dragAge * 10) * -1.5 : 0; // Brief -1.5° punch
      // v5.01: Entrance telephoto zoom — camera starts wider, tightens during coalesce
      const entranceFovPull = Math.max(0, 1.0 - time / ENTRANCE_COALESCE_DUR) * -3.0; // Tighter during entrance
      camera.fov = 45 + fovBreathe + dispersalFov + interactionFov + grabFov + entranceFovPull;
      camera.updateProjectionMatrix();

      // Scroll-driven opacity + mouse parallax position
      const isDesktop = cachedWrapWidth >= 1024;
      if (scrollControlsOpacity) {
        wrap.style.opacity = String(Math.max(0, scrollFade * opacityMult));
        const baseScale = isDesktop ? 1.15 : 0.85;
        globeGroup.scale.setScalar(baseScale * entranceScale);
        const baseX = isDesktop ? 0.95 : 0;
        const baseY = isDesktop ? 0.05 : 0;
        globeGroup.position.x = baseX + parallaxX;
        globeGroup.position.y = baseY + parallaxY;
      } else {
        const baseScale = isDesktop ? 1.15 : 0.85;
        globeGroup.scale.setScalar(baseScale * entranceScale);
      }

      // Scroll dispersal environment — everything reacts to the scatter
      if (scrollDispersalCurrent > 0.01) {
        const s = scrollDispersalCurrent;
        const s2 = s * s;
        // Core sphere fades — energy releasing
        coreMat.uniforms.uFade.value = 1.0 - s2 * 0.95;
        // v5.10: Visibility toggles only (removed dead .opacity writes)
        for (const m of arcMeshes) m.visible = s < 0.85;
        nodePoints.visible = s < 0.8;
        sweepRing.visible = s < 0.7;
        motePoints.visible = s < 0.6;
        ringPoints.visible = s < 0.5;
        // Bloom increases during scatter — energy release glow
        bloomPass.strength += s * 0.08;
        // v5.23: Scatter bloom threshold drop — more particles glow as they disperse
        bloomPass.threshold -= s * 0.12; // Lower threshold = more bloom sources
        bloomPass.radius += s * 0.15; // Wider bloom = softer, more ethereal
        // v11.67: Dispersal warm highlight shift — energy release warms highlights
        const dispersalWarm = s * (1.0 - s); // Peaks at s=0.5, fades at full scatter
        colorGradePass.uniforms['uHighlightTint'].value.x += dispersalWarm * 0.08;
        colorGradePass.uniforms['uHighlightTint'].value.y += dispersalWarm * 0.03;
        // v5.23: Scatter desaturation — energy dissipating loses color intensity
        colorGradePass.uniforms['uSaturation'].value -= s * 0.15;
        // v5.23: Scatter chroma spike — particles releasing energy creates prismatic flare
        chromaPass.uniforms['uIntensity'].value += s * s * 0.003;
        // Exposure dims slightly — cinematic fade
        renderer.toneMappingExposure -= s2 * 0.3;
      }

      updateHUD(time);
      composer.render();
    }

    // ── Resize ──
    const ro = new ResizeObserver(() => {
      updateCachedSize(); // v4.87: Keep cached dimensions fresh
      const w = cachedWrapWidth;
      const h = cachedWrapHeight;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      composer.setSize(w, h);
      // v4.88: Bloom at half resolution on resize
      bloomPass.resolution.set(Math.floor(w / 2), Math.floor(h / 2));
      const pr = renderer.getPixelRatio();
      fxaaPass.uniforms['resolution'].value.set(1 / (w * pr), 1 / (h * pr));
      positionGlobe();
    });
    ro.observe(wrap);

    // ── HUD Counter Animation ──
    const hudContainer = document.querySelector('.globe-hud') as HTMLElement;
    const hudNodes = document.getElementById('hud-nodes');
    const hudThroughput = document.getElementById('hud-throughput');
    const hudLatency = document.getElementById('hud-latency');
    const hudTpUnit = document.createElement('span');
    hudTpUnit.className = 'hud-unit';
    hudTpUnit.textContent = ' TB/s';
    const hudLatUnit = document.createElement('span');
    hudLatUnit.className = 'hud-unit';
    hudLatUnit.textContent = ' ms';
    const hudRoutes = document.getElementById('hud-routes');
    let hudFrame = 0;
    let smoothNodes = 0, smoothTp = 0, smoothLat = 0, smoothRoutes = 0;
    function updateHUD(t: number) {
      hudFrame++;
      if (hudFrame % 4 !== 0) return; // Faster update rate (was 6)
      const rampT = Math.min(t / 4.0, 1.0);
      const spring = rampT < 1.0
        ? 1.0 - Math.exp(-6.0 * rampT) * Math.cos(rampT * 8.0) * (1.0 - rampT)
        : 1.0;
      const baseNodes = 2847;
      const nodesJitter = Math.sin(t * 0.7) * 12 + Math.cos(t * 1.1) * 8;
      const targetNodes = (baseNodes + nodesJitter) * spring;
      smoothNodes += (targetNodes - smoothNodes) * 0.15; // Smooth interpolation
      if (hudNodes) hudNodes.textContent = String(Math.floor(smoothNodes));
      const baseThroughput = 14.2;
      const tpJitter = Math.sin(t * 0.5) * 1.8 + Math.cos(t * 0.9) * 0.6;
      const targetTp = (baseThroughput + tpJitter) * spring;
      smoothTp += (targetTp - smoothTp) * 0.12;
      if (hudThroughput) {
        hudThroughput.textContent = smoothTp.toFixed(1);
        hudThroughput.appendChild(hudTpUnit);
      }
      const baseLatency = 23;
      const latJitter = Math.sin(t * 1.3) * 4 + Math.cos(t * 0.7) * 2;
      const targetLat = (baseLatency + latJitter) * spring;
      smoothLat += (targetLat - smoothLat) * 0.1;
      if (hudLatency) {
        hudLatency.textContent = String(Math.floor(smoothLat));
        hudLatency.appendChild(hudLatUnit);
      }
      // v5.17: Active routes counter — 16 arcs with jitter
      const baseRoutes = 16;
      const routeJitter = Math.sin(t * 0.4) * 1.5 + Math.cos(t * 0.9) * 0.8;
      const targetRoutes = Math.max(14, (baseRoutes + routeJitter) * spring);
      smoothRoutes += (targetRoutes - smoothRoutes) * 0.08;
      if (hudRoutes) hudRoutes.textContent = String(Math.floor(smoothRoutes));
      // HUD fades out on scroll
      if (hudContainer) {
        const hudFade = Math.max(0, 1 - cachedScrollY / (cachedInnerHeight * 0.5));
        hudContainer.style.opacity = String(hudFade * 0.6);
      }
    }

    // ── Launch ──
    let scrollControlsOpacity = false;
    animate(0);
    setTimeout(() => {
      wrap.classList.add('ready');
      wrap.dispatchEvent(new CustomEvent('globe-ready', { bubbles: true }));
    }, 80);
    setTimeout(() => {
      scrollControlsOpacity = true;
      wrap.style.transition = 'none';
    }, 1600);

    // ── Cleanup ──
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
      visObserver.disconnect();
      themeObserver.disconnect();
      composer.dispose();
      renderer.dispose();
      dotGeo.dispose();
      dotMat.dispose();
      coreGeo.dispose();
      coreMat.dispose();
      outerAtmosGeo.dispose();
      outerAtmosMat.dispose();
      innerRimGeo.dispose();
      innerRimMat.dispose();
      starGeo.dispose();
      starMat.dispose();
      arcMat.dispose();
      arcGeometries.forEach(g => g.dispose());
      sweepRingGeo.dispose();
      sweepRingMat.dispose();
      nodeGeo.dispose();
      nodeMat.dispose();
      moteGeo.dispose();
      moteMat.dispose();
      coronaGeo.dispose();
      coronaMat.dispose();
      sunDiskGeo.dispose();
      sunDiskMat.dispose();
      ringGeo.dispose();
      ringMat.dispose();
      // v5.02 opt: Dispose textures to free GPU memory on navigation
      nightLightsTex.dispose();
      terrainNormalsTex.dispose();
      noiseAtlasTex.dispose();
      atmosLutTex.dispose();
      colorLutTex.dispose();
    }, { once: true });
  }
</script>
