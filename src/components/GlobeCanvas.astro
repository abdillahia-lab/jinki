          float tendril = vnoise(worldN * 4.0 + vec3(uTime * 0.06, uTime * -0.04, uTime * 0.05)) * 0.45
                        + vnoise(worldN * 8.0 - vec3(uTime * 0.09, uTime * 0.07, 0.0)) * 0.28
                        + vnoise(worldN * 16.0 + uTime * 0.12) * 0.17
                        + vnoise(worldN * 32.0 - uTime * 0.18) * 0.10; // Fine filament detail
          float tendrilShape = pow(max(tendril - 0.25, 0.0) * 1.33, 1.4); // Lower threshold — more visible
