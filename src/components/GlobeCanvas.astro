          glow += forwardScatter;
          // v4.77: Atmospheric scintillation — blue noise atlas replaces hash banding
          vec2 scintUV = n.xz * 3.0 + vec2(uTime * 0.3, uTime * 0.2);
          float scintHash = texture2D(uNoiseAtlas, scintUV).r;
          float scintillation = (scintHash - 0.5) * pow(rim, 3.0) * 0.10;
