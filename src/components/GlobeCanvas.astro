          // v11.96: Sun crescent flare — concentrated bright point where sun hits limb most directly
          vec3 sunHalfOA = normalize(sunDir + viewDir);
          float sunFlare = pow(max(dot(normalize(vWorldNormal), sunHalfOA), 0.0), 48.0) * pow(rim, 2.0) * 0.15;
