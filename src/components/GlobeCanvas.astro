---
/*
  GlobeCanvas v4 — World-class Fibonacci point-cloud globe.

  Architecture (GitHub Globe + Stripe + COBE patterns):
  - Fibonacci sphere sampling (28k desktop, 10k tablet)
  - Texture-based land detection via canvas getImageData (256×128 land mask)
  - 8-direction coastal edge detection for crisp continental outlines
  - Anti-aliased bokeh dot shader (adaptive Gaussian + inverse-square halo)
  - 3-shell atmosphere: outer halo (BackSide) + mid volume (FrontSide) + inner subsurface
  - Blending stratification: NormalBlending for atmosphere, AdditiveBlending for dots/arcs
  - Scanning sweep, depth fog, unified breathing at 0.3Hz
  - Trailing-particle arc animations (comet effect)
  - Dark core sphere with depth-aware shader
  - CSS mask integration for hero text readability
  - position: fixed — persists across full page scroll
  - Dynamic import('three') — zero initial bundle cost
  - MutationObserver for theme sync (no getComputedStyle polling)

  Mobile (<768px): No WebGL. CSS mesh gradient fallback.
*/
---

<div class="globe-wrap" aria-hidden="true">
  <canvas id="globe-canvas"></canvas>
</div>

<style>
  .globe-wrap {
    position: fixed;
    top: 0;
    right: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    will-change: opacity;
    transition: opacity 1.4s cubic-bezier(0.16, 1, 0.3, 1);
    mask-image: linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%);
    -webkit-mask-image: linear-gradient(to right, transparent 2%, rgba(0,0,0,0.12) 18%, rgba(0,0,0,0.6) 45%, black 65%);
  }
  .globe-wrap.ready { opacity: 1; }
  :global([data-theme="light"]) .globe-wrap.ready { opacity: 0.55; }
  #globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
  @media (max-width: 767px) {
    .globe-wrap { display: none; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .globe-wrap {
      mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
      -webkit-mask-image: radial-gradient(ellipse 90% 90% at 60% 50%, rgba(0,0,0,0.25) 0%, transparent 65%);
    }
  }
</style>

<script>
  (function () {
    if (window.innerWidth < 768) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const start = () => initGlobe(reduced).catch(e => console.error('[Globe] Init failed:', e));
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(start, { timeout: 2000 });
    } else {
      setTimeout(start, 300);
    }
  })();

  async function initGlobe(reducedMotion: boolean) {
    const wrap = document.querySelector('.globe-wrap') as HTMLDivElement;
    const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
    if (!wrap || !canvas) return;

    const THREE = await import('three');

    // ── Theme colors via MutationObserver (no getComputedStyle polling) ──
    let themeColors = readThemeColors();
    function readThemeColors() {
      const s = getComputedStyle(document.documentElement);
      return {
        accent: s.getPropertyValue('--accent').trim() || '#00e5ff',
        accentSecondary: s.getPropertyValue('--accent-secondary').trim() || '#7B61FF',
        isLight: document.documentElement.getAttribute('data-theme') === 'light',
      };
    }
    const themeObserver = new MutationObserver(() => {
      themeColors = readThemeColors();
      outerAtmosMat.uniforms.uColor.value.set(themeColors.accent);
      outerAtmosMat.uniforms.uColorSecondary.value.set(themeColors.accentSecondary);
      midAtmosMat.uniforms.uColor.value.set(themeColors.accent);
      innerRimMat.uniforms.uColor.value.set(themeColors.accent);
      markerMat.uniforms.uColor.value.set(themeColors.accent);
      dotMat.uniforms.uAccentColor.value.set(themeColors.accent);
      beamMat.uniforms.uColor.value.set(themeColors.accent);
      beam2Mat.uniforms.uColor.value.set(themeColors.accentSecondary);
      coreMat.uniforms.uAccent.value.set(themeColors.accent);
      coreMat.uniforms.uColor.value.set(themeColors.isLight ? '#e8eaed' : '#020208');
      dustMat.uniforms.uColor.value.set(themeColors.accent);
      nebulaMat.uniforms.uColor.value.set(themeColors.accent);
      nebulaMat.uniforms.uColorSecondary.value.set(themeColors.accentSecondary);
      arcSystems.forEach(({ mat }) => {
        mat.uniforms.uColorA.value.set(themeColors.accent);
        mat.uniforms.uColorB.value.set(themeColors.accentSecondary);
      });
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ── Scene ──
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, wrap.clientWidth / wrap.clientHeight, 0.1, 50);
    camera.position.set(0, 0, 2.8);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: false, // Stripe finding: MSAA hurts perf, shader AA is better
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(wrap.clientWidth, wrap.clientHeight);

    const globeGroup = new THREE.Group();
    scene.add(globeGroup);

    // ── Land Mask Texture — pixel-perfect land detection (GitHub/Stripe pattern) ──
    const LAND_MASK_B64 = 'data:image/png;base64,';

    const MASK_W = 256, MASK_H = 128;
    let landData: Uint8ClampedArray;

    // Load land mask via Image + Canvas getImageData (GitHub pattern)
    const landImg = new Image();
    await new Promise<void>((resolve, reject) => {
      landImg.onload = () => resolve();
      landImg.onerror = () => reject(new Error('Land mask failed to load'));
      landImg.src = LAND_MASK_B64;
    });
    const landCanvas = document.createElement('canvas');
    landCanvas.width = MASK_W;
    landCanvas.height = MASK_H;
    const landCtx = landCanvas.getContext('2d')!;
    landCtx.drawImage(landImg, 0, 0, MASK_W, MASK_H);
    landData = landCtx.getImageData(0, 0, MASK_W, MASK_H).data;

    // Pixel-perfect land detection via texture lookup
    function isLand(lat: number, lng: number): number {
      const u = Math.floor(((lng + 180) / 360) * MASK_W) % MASK_W;
      const v = Math.floor(((90 - lat) / 180) * MASK_H);
      const clampV = Math.max(0, Math.min(MASK_H - 1, v));
      return landData[(clampV * MASK_W + u) * 4] / 255;
    }

    // 8-direction coastal edge detection at texture resolution
    function isCoastal(lat: number, lng: number): boolean {
      const stepLat = 180 / MASK_H; // ~1.4° per pixel
      const stepLng = 360 / MASK_W;
      const dirs = [[1,0],[-1,0],[0,1],[0,-1],[0.7,0.7],[-0.7,0.7],[0.7,-0.7],[-0.7,-0.7]];
      for (const [dy, dx] of dirs) {
        if (isLand(lat + dy * stepLat, lng + dx * stepLng) < 0.3) return true;
      }
      return false;
    }

    // ── Fibonacci Sphere Point Cloud ──
    const isTablet = wrap.clientWidth < 1024;
    const DOT_COUNT = isTablet ? 18000 : 55000;
    const GOLDEN_RATIO = (1 + Math.sqrt(5)) / 2;
    const ANGLE_INC = Math.PI * 2 * GOLDEN_RATIO;

    const dotPositions = new Float32Array(DOT_COUNT * 3);
    const dotSizes = new Float32Array(DOT_COUNT);
    const dotOpacities = new Float32Array(DOT_COUNT);
    const dotPhases = new Float32Array(DOT_COUNT);
    const dotColors = new Float32Array(DOT_COUNT * 3);

    const cAccent = new THREE.Color(themeColors.accent);
    const cSecondary = new THREE.Color(themeColors.accentSecondary);
    const cTertiary = new THREE.Color('#34D399');

    // Major city coordinates for night-side city glow hotspots
    const cityCoords = [
      [40.7, -74.0], [51.5, -0.1], [35.7, 139.7], [22.3, 114.2],   // NYC, London, Tokyo, HK
      [48.9, 2.35], [55.8, 37.6], [1.35, 103.8], [-33.9, 151.2],   // Paris, Moscow, Singapore, Sydney
      [25.3, 55.3], [28.6, 77.2], [37.8, -122.4], [34.1, -118.2],  // Dubai, Delhi, SF, LA
      [19.4, -99.1], [-23.5, -46.6], [6.5, 3.4], [37.6, 127.0],   // Mexico City, São Paulo, Lagos, Seoul
      [39.9, 116.4], [31.2, 121.5], [13.8, 100.5], [-33.9, 18.4],  // Beijing, Shanghai, Bangkok, Cape Town
      [41.0, 29.0], [30.0, 31.2], [52.5, 13.4], [59.3, 18.1],      // Istanbul, Cairo, Berlin, Stockholm
    ];
    const dotCityGlow = new Float32Array(DOT_COUNT);

    for (let i = 0; i < DOT_COUNT; i++) {
      const t = i / DOT_COUNT;
      const inclination = Math.acos(1 - 2 * t);
      const azimuth = ANGLE_INC * i;

      const x = Math.sin(inclination) * Math.cos(azimuth);
      const y = Math.cos(inclination);
      const z = Math.sin(inclination) * Math.sin(azimuth);

      const lat = 90 - (inclination * 180 / Math.PI);
      const lng = (azimuth * 180 / Math.PI) % 360 - 180;
      const landFactor = isLand(lat, lng);

      // Topographic elevation — land sits above ocean for 3D terrain relief
      const jitterSeed = Math.sin(i * 127.1) * Math.cos(i * 311.7);
      const jitterNoise = jitterSeed * 0.004; // ±0.4% micro-variation
      let elevation: number;
      const isCoast = landFactor > 0.5 && isCoastal(lat, lng);
      if (isCoast) {
        elevation = 1.012 + jitterNoise; // Coastal shelf — highest points
      } else if (landFactor > 0.5) {
        // Land — slight variation for mountain/valley feel
        const terrainHeight = (Math.sin(i * 0.23) * Math.cos(i * 0.41) * 0.5 + 0.5);
        elevation = 1.005 + terrainHeight * 0.006 + jitterNoise;
      } else {
        elevation = 1.0 + jitterNoise * 0.5; // Ocean — at base radius
      }
      dotPositions[i * 3] = x * elevation;
      dotPositions[i * 3 + 1] = y * elevation;
      dotPositions[i * 3 + 2] = z * elevation;

      const noise = Math.sin(i * 0.1) * Math.cos(i * 0.07) * 0.5 + 0.5;
      // Equatorial brightness boost — data activity peaks near equator
      const latBrightness = 1.0 - Math.abs(lat) / 90 * 0.2; // 1.0 at equator, 0.8 at poles

      // Dot hierarchy: coastal (bright edges) > land (medium) > ocean (dim)
      if (isCoast) {
        dotSizes[i] = 1.4 + noise * 0.5;
        dotOpacities[i] = 1.0 * latBrightness;
      } else if (landFactor > 0.5) {
        dotSizes[i] = 0.85 + noise * 0.6;
        dotOpacities[i] = (0.50 + noise * 0.2) * latBrightness;
      } else {
        // Deep ocean dots — barely visible, coastal proximity adds subtle brightness
        const coastProximity = isCoastal(lat, lng) ? 0.015 : 0;
        dotSizes[i] = 0.06 + noise * 0.06;
        dotOpacities[i] = 0.004 + noise * 0.008 + coastProximity;
      }
      dotPhases[i] = i * 2.399;

      const latFactor = Math.abs(y);
      let c: THREE.Color;
      if (isCoast) {
        c = new THREE.Color().lerpColors(cAccent, new THREE.Color('#ffffff'), 0.35);
      } else if (landFactor > 0.5) {
        // Terrain variation: noise-driven blend between accent, green, and warm gold
        const terrainNoise = Math.sin(i * 0.37) * Math.cos(i * 0.19) * 0.5 + 0.5;
        const warmGold = new THREE.Color('#D4A843');
        c = new THREE.Color().lerpColors(cAccent, cTertiary, latFactor * 0.35 + noise * 0.25);
        // Desert/arid regions get warm gold tint at lower latitudes
        if (latFactor < 0.4 && terrainNoise > 0.6) c.lerp(warmGold, (terrainNoise - 0.6) * 0.3);
        if (latFactor > 0.55) c.lerp(cSecondary, (latFactor - 0.55) * 0.6);
      } else {
        c = new THREE.Color().lerpColors(
          new THREE.Color('#0a1828'),
          new THREE.Color('#0e2440'),
          noise
        );
      }
      dotColors[i * 3] = c.r;
      dotColors[i * 3 + 1] = c.g;
      dotColors[i * 3 + 2] = c.b;

      // City glow — proximity to major cities creates warm light pools
      let maxCityGlow = 0;
      if (landFactor > 0.3) { // Only compute for land/near-land dots
        for (const [cLat, cLng] of cityCoords) {
          const dLat = lat - cLat;
          const dLng = lng - cLng;
          const dist2 = dLat * dLat + dLng * dLng;
          // Gaussian falloff — ~5° radius of influence
          const glow = Math.exp(-dist2 / 50);
          if (glow > maxCityGlow) maxCityGlow = glow;
        }
      }
      dotCityGlow[i] = maxCityGlow;
    }

    const dotGeo = new THREE.BufferGeometry();
    dotGeo.setAttribute('position', new THREE.BufferAttribute(dotPositions, 3));
    dotGeo.setAttribute('aSize', new THREE.BufferAttribute(dotSizes, 1));
    dotGeo.setAttribute('aOpacity', new THREE.BufferAttribute(dotOpacities, 1));
    dotGeo.setAttribute('aPhase', new THREE.BufferAttribute(dotPhases, 1));
    dotGeo.setAttribute('aColor', new THREE.BufferAttribute(dotColors, 3));
    dotGeo.setAttribute('aCityGlow', new THREE.BufferAttribute(dotCityGlow, 1));

    // ── Dot Vertex Shader — breathing, depth fog, rim fade, scanning sweep ──
    const dotVertSrc = `
      attribute float aSize;
      attribute float aOpacity;
      attribute float aPhase;
      attribute vec3 aColor;
      attribute float aCityGlow;
      uniform float uTime;
      uniform float uBaseSize;
      uniform vec3 uAccentColor;
      varying float vOpacity;
      varying vec3 vColor;
      varying float vScanBoost;
      varying float vFresnel;
      varying float vSunLight;
      varying float vCityGlow;
      varying float vTerminator;
      void main() {
        vColor = aColor;
        float breath = sin(uTime * 0.3 + aPhase) * 0.025;
        vec3 pos = position * (1.0 + breath);
        vec4 mv = modelViewMatrix * vec4(pos, 1.0);
        float depth = -mv.z;
        // Backface fade
        float backFade = smoothstep(3.8, 1.9, depth);
        // Face-dimming — center dots dimmer, edge dots brighter (premium globe look)
        vec3 posNorm = normalize(pos);
        vec3 camDir = vec3(0.0, 0.0, 1.0);
        float facing = dot(posNorm, camDir);
        float rimFade = smoothstep(-0.05, 0.25, facing);
        // Darken center-facing dots aggressively, keep edges bright (premium globe)
        float faceDim = 0.04 + 0.96 * pow(1.0 - facing, 0.65);
        // Fresnel — edge dots tint toward accent (atmospheric scattering)
        vFresnel = pow(1.0 - max(facing, 0.0), 2.2);
        // Hemisphere sun illumination — dramatic day/night terminator
        vec3 sunDir = normalize(vec3(0.6, 0.4, 0.8));
        float sunDot = dot(posNorm, sunDir);
        // Sharper terminator transition — tighter smoothstep for visible day/night line
        vSunLight = smoothstep(-0.15, 0.5, sunDot);
        // Terminator glow — atmospheric scattering at the day/night boundary
        // Peak brightness where sunDot ≈ 0.1 (just past the terminator edge)
        vTerminator = exp(-(sunDot - 0.1) * (sunDot - 0.1) / 0.025) * 0.8;
        // Depth fog — far dots fade for spatial depth cue
        float depthFog = smoothstep(4.2, 2.0, depth);
        // Primary scanning sweep — dramatic rotating light band
        float scanAngle = atan(posNorm.x, posNorm.z);
        float sweepAngle1 = mod(uTime * 0.4, 6.28318);
        float scanDist1 = mod(scanAngle - sweepAngle1 + 6.28318, 6.28318);
        float leadEdge1 = smoothstep(0.45, 0.0, scanDist1) * 0.9;
        float trail1 = smoothstep(1.8, 0.3, scanDist1) * 0.4;
        float scan1 = max(leadEdge1, trail1);
        // Secondary sweep — opposite direction, subtler
        float sweepAngle2 = mod(-uTime * 0.25, 6.28318);
        float scanDist2 = mod(scanAngle - sweepAngle2 + 6.28318, 6.28318);
        float leadEdge2 = smoothstep(0.35, 0.0, scanDist2) * 0.5;
        float trail2 = smoothstep(1.2, 0.3, scanDist2) * 0.2;
        float scan2 = max(leadEdge2, trail2);
        float scanRaw = max(scan1, scan2 * 0.6);
        // Sweep overrides face-dimming — illuminates the dark center
        vScanBoost = scanRaw * max(facing, 0.15);
        // Dramatic hemisphere split — 50% brightness differential for cinematic day/night
        float sunBoost = 0.5 + vSunLight * 0.5;
        // Terminator line boost — dots at the boundary glow brighter
        sunBoost += vTerminator;
        // City glow — warm light pools visible especially on shadow side (night lights)
        vCityGlow = aCityGlow * (1.0 - vSunLight * 0.6); // Stronger on night side
        float cityBoost = 1.0 + vCityGlow * 2.5; // Cities glow 2.5x brighter
        vOpacity = aOpacity * backFade * rimFade * depthFog * max(faceDim, vScanBoost * 1.5) * sunBoost * cityBoost;
        float citySize = 1.0 + vCityGlow * 0.8; // Cities slightly larger
        gl_PointSize = max(aSize * uBaseSize * (20.0 / depth) * (1.0 + vScanBoost * 0.6) * citySize, 0.5);
        gl_Position = projectionMatrix * mv;
      }
    `;

    // ── Dot Fragment Shader — anti-aliased bokeh (adaptive Gaussian + inverse-square halo) ──
    const dotFragSrc = `
      uniform vec3 uAccentColor;
      varying float vOpacity;
      varying vec3 vColor;
      varying float vScanBoost;
      varying float vFresnel;
      varying float vSunLight;
      varying float vCityGlow;
      varying float vTerminator;
      void main() {
        float dist = length(gl_PointCoord - vec2(0.5));
        if (dist > 0.55) discard;
        // Adaptive Gaussian core with AA rim
        float sigma = 0.13;
        float core = exp(-(dist * dist) / (2.0 * sigma * sigma));
        float aaRim = smoothstep(0.52, 0.44, dist);
        // Inverse-square halo (physically-based light falloff)
        float halo = 0.04 / (dist * dist + 0.003) - 0.05;
        halo *= smoothstep(0.0, 0.18, dist);
        float strength = core * 0.8 + max(halo, 0.0) * 0.3 * aaRim;
        if (strength < 0.005) discard;
        // Fresnel atmospheric scattering — edge dots tint toward accent
        vec3 baseCol = mix(vColor, uAccentColor, vFresnel * 0.45);
        // Sun hemisphere warm/cool shift — dramatic day/night color separation
        vec3 warmTint = uAccentColor * 0.2;
        vec3 coolTint = vec3(0.01, 0.02, 0.06); // Deeper blue shadow
        baseCol += mix(coolTint, warmTint, vSunLight);
        // Shadow side desaturation — night side loses color richness
        float desat = 1.0 - (1.0 - vSunLight) * 0.25;
        float lum = dot(baseCol, vec3(0.299, 0.587, 0.114));
        baseCol = mix(vec3(lum), baseCol, desat);
        // Terminator glow — warm amber tint at the day/night boundary
        vec3 terminatorColor = vec3(1.0, 0.7, 0.3); // Sunrise/sunset amber
        baseCol = mix(baseCol, terminatorColor, vTerminator * 0.5);
        // City glow — warm golden-white tint for night-side city lights
        vec3 cityWarm = vec3(1.0, 0.92, 0.75); // Warm incandescent
        baseCol = mix(baseCol, cityWarm, vCityGlow * 0.6);
        // Scan sweep adds brightness + accent tint (branded sweep)
        vec3 sweepColor = mix(vec3(1.0), uAccentColor * 1.5, 0.35);
        vec3 col = mix(baseCol, sweepColor, vScanBoost * 0.5);
        float alpha = strength * (vOpacity + vScanBoost);
        gl_FragColor = vec4(col, alpha);
      }
    `;

    const dotMat = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
        uBaseSize: { value: isTablet ? 0.9 : 1.2 },
        uAccentColor: { value: new THREE.Color(themeColors.accent) },
      },
      vertexShader: dotVertSrc,
      fragmentShader: dotFragSrc,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });

    const globeDots = new THREE.Points(dotGeo, dotMat);
    globeGroup.add(globeDots);

    // ── Shared atmosphere vertex shaders ──
    const atmosVert = `
      varying vec3 vNormal;
      varying vec3 vPos;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;
    const atmosVertAnimated = `
      uniform float uTime;
      varying vec3 vNormal;
      varying vec3 vPos;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
        gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
      }
    `;

    // ── Dark Core Sphere — solid body with subtle surface noise ──
    const coreGeo = new THREE.IcosahedronGeometry(0.99, 32);
    const coreMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.isLight ? '#e8eaed' : '#020208') },
        uAccent: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
      },
      vertexShader: `
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldPos;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vWorldPos = position;
          vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform vec3 uAccent;
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldPos;
        // Cheap hash noise — no texture lookups
        float hash(vec3 p) {
          p = fract(p * vec3(443.897, 441.423, 437.195));
          p += dot(p, p.yzx + 19.19);
          return fract((p.x + p.y) * p.z);
        }
        float noise3D(vec3 p) {
          vec3 i = floor(p);
          vec3 f = fract(p);
          f = f * f * (3.0 - 2.0 * f);
          return mix(
            mix(mix(hash(i), hash(i + vec3(1,0,0)), f.x),
                mix(hash(i + vec3(0,1,0)), hash(i + vec3(1,1,0)), f.x), f.y),
            mix(mix(hash(i + vec3(0,0,1)), hash(i + vec3(1,0,1)), f.x),
                mix(hash(i + vec3(0,1,1)), hash(i + vec3(1,1,1)), f.x), f.y), f.z);
        }
        void main() {
          vec3 viewDir = normalize(-vPos);
          float facing = max(dot(viewDir, vNormal), 0.0);
          float edgeLift = pow(1.0 - facing, 3.0) * 0.04;
          // Subtle surface noise — slow-drifting continental texture
          float n = noise3D(vWorldPos * 4.0 + uTime * 0.02) * 0.5
                  + noise3D(vWorldPos * 8.0 - uTime * 0.01) * 0.25;
          // Very subtle accent tint at edges through the noise
          vec3 noiseTint = mix(uColor, uAccent * 0.15, n * pow(1.0 - facing, 2.0) * 0.3);
          // Subsurface emission pulse — heartbeat of data processing
          float pulse1 = sin(uTime * 0.8) * 0.5 + 0.5; // ~0.8 Hz primary
          float pulse2 = sin(uTime * 1.3 + 2.0) * 0.5 + 0.5; // offset harmonic
          float subsurface = (pulse1 * 0.6 + pulse2 * 0.4) * pow(1.0 - facing, 1.8) * 0.035;
          // Noise-modulated emission — data activity hotspots
          float emissionNoise = noise3D(vWorldPos * 3.0 + uTime * 0.08);
          subsurface *= (0.6 + emissionNoise * 0.8);
          vec3 emissionColor = uAccent * subsurface;
          // Scanning sweep illumination on core surface
          float scanAngle = atan(vWorldPos.x, vWorldPos.z);
          float sweepAngle = mod(uTime * 0.4, 6.28318);
          float scanDist = mod(scanAngle - sweepAngle + 6.28318, 6.28318);
          float sweepGlow = smoothstep(0.5, 0.0, scanDist) * 0.06
                          + smoothstep(1.6, 0.2, scanDist) * 0.02;
          // Sweep only visible on face-facing parts (not backside)
          sweepGlow *= facing;
          vec3 sweepColor = uAccent * sweepGlow;
          // Specular highlight — glossy sphere reflection from upper-right light
          vec3 lightDir = normalize(vec3(0.5, 0.8, 0.6));
          vec3 halfVec = normalize(lightDir + viewDir);
          float spec = pow(max(dot(vNormal, halfVec), 0.0), 64.0) * 0.08;
          gl_FragColor = vec4(noiseTint + edgeLift + spec + sweepColor + emissionColor, 1.0);
        }
      `,
      transparent: false,
      depthWrite: true,
    });
    globeGroup.add(new THREE.Mesh(coreGeo, coreMat));

    // ── 3-Shell Atmosphere System ──

    // Shell 1: Outer halo (BackSide, 1.15r) — two-tone gradient atmosphere
    const outerAtmosGeo = new THREE.IcosahedronGeometry(1.15, 48);
    const outerAtmosMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uColorSecondary: { value: new THREE.Color(themeColors.accentSecondary) },
        uTime: { value: 0 },
      },
      vertexShader: `
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldNormal;
        varying vec3 vWorldPos;
        // Simplex-like noise for vertex displacement
        float hash3(vec3 p) {
          p = fract(p * vec3(443.897, 441.423, 437.195));
          p += dot(p, p.yzx + 19.19);
          return fract((p.x + p.y) * p.z);
        }
        float vnoise(vec3 p) {
          vec3 i = floor(p);
          vec3 f = fract(p);
          f = f * f * (3.0 - 2.0 * f);
          return mix(
            mix(mix(hash3(i), hash3(i + vec3(1,0,0)), f.x),
                mix(hash3(i + vec3(0,1,0)), hash3(i + vec3(1,1,0)), f.x), f.y),
            mix(mix(hash3(i + vec3(0,0,1)), hash3(i + vec3(1,0,1)), f.x),
                mix(hash3(i + vec3(0,1,1)), hash3(i + vec3(1,1,1)), f.x), f.y), f.z);
        }
        void main() {
          vec3 n = normalize(normal);
          // Animated noise displacement — plasma-like undulation
          float disp = vnoise(n * 3.0 + uTime * 0.08) * 0.015
                     + vnoise(n * 6.0 - uTime * 0.05) * 0.008;
          vec3 displaced = position + n * disp;
          vNormal = normalize(normalMatrix * n);
          vWorldNormal = n;
          vWorldPos = n;
          vPos = (modelViewMatrix * vec4(displaced, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(displaced, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform vec3 uColorSecondary;
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldNormal;
        varying vec3 vWorldPos;
        // Fragment noise for glow variation
        float fhash(vec3 p) {
          p = fract(p * vec3(443.897, 441.423, 437.195));
          p += dot(p, p.yzx + 19.19);
          return fract((p.x + p.y) * p.z);
        }
        float fnoise(vec3 p) {
          vec3 i = floor(p);
          vec3 f = fract(p);
          f = f * f * (3.0 - 2.0 * f);
          return mix(
            mix(mix(fhash(i), fhash(i + vec3(1,0,0)), f.x),
                mix(fhash(i + vec3(0,1,0)), fhash(i + vec3(1,1,0)), f.x), f.y),
            mix(mix(fhash(i + vec3(0,0,1)), fhash(i + vec3(1,0,1)), f.x),
                mix(fhash(i + vec3(0,1,1)), fhash(i + vec3(1,1,1)), f.x), f.y), f.z);
        }
        void main() {
          vec3 viewDir = normalize(-vPos);
          float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
          // Shell 1 breathe: primary freq + slower harmonic for organic motion
          float breathe = 1.0 + sin(uTime * 0.3) * 0.12 + sin(uTime * 0.17) * 0.04;
          // Two-tone gradient: primary accent at top, secondary at bottom
          float gradient = smoothstep(-0.6, 0.6, vWorldNormal.y);
          vec3 atmosColor = mix(uColorSecondary, uColor, gradient);
          // Animated noise modulation — glow varies across the atmosphere surface
          float noiseVar = fnoise(vWorldPos * 4.0 + uTime * 0.06) * 0.3 + 0.85;
          // Concentrated bright inner rim + soft extended falloff + mid bloom
          float innerRim = pow(rim, 4.0) * 0.35;
          float midBloom = pow(rim, 2.5) * 0.08;
          float outerFalloff = pow(rim, 1.8) * 0.05;
          float glow = (innerRim + midBloom + outerFalloff) * breathe * noiseVar;
          // Volumetric scan sweep — atmosphere brightens where radar passes
          float scanAngle = atan(vWorldPos.x, vWorldPos.z);
          float sweepAngle = mod(uTime * 0.4, 6.28318);
          float scanDist = mod(scanAngle - sweepAngle + 6.28318, 6.28318);
          float sweepBoost = smoothstep(0.6, 0.0, scanDist) * 0.4
                           + smoothstep(1.8, 0.3, scanDist) * 0.15;
          glow *= (1.0 + sweepBoost * rim);
          // Specular hot spot — sun reflection on atmosphere (upper-right light)
          vec3 sunDir = normalize(vec3(0.6, 0.4, 0.8));
          vec3 halfVec = normalize(sunDir + viewDir);
          float spec = pow(max(dot(vNormal, halfVec), 0.0), 32.0) * 0.25;
          float specRim = spec * pow(rim, 1.5); // Only visible near edges
          glow += specRim;
          // Chromatic aberration — color channels separate at extreme edges
          float caOffset = pow(rim, 6.0) * 0.12;
          vec3 caColor = vec3(
            atmosColor.r * (1.0 + caOffset * 1.5),
            atmosColor.g,
            atmosColor.b * (1.0 + caOffset * 0.8)
          );
          // Hot spot adds white to the specular area
          vec3 finalColor = caColor * 1.2 + vec3(1.0) * specRim * 0.5;
          gl_FragColor = vec4(finalColor, glow);
        }
      `,
      transparent: true,
      side: THREE.BackSide,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
    });
    globeGroup.add(new THREE.Mesh(outerAtmosGeo, outerAtmosMat));

    // Shell 2: Extended halo (BackSide, 1.25r) — wider, softer secondary glow
    const midAtmosGeo = new THREE.IcosahedronGeometry(1.25, 32);
    const midAtmosMat = new THREE.ShaderMaterial({
      uniforms: {
        uColor: { value: new THREE.Color(themeColors.accent) },
        uTime: { value: 0 },
      },
      vertexShader: `
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldPos;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vWorldPos = normal;
          vPos = (modelViewMatrix * vec4(position, 1.0)).xyz;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: `
        uniform vec3 uColor;
        uniform float uTime;
        varying vec3 vNormal;
        varying vec3 vPos;
        varying vec3 vWorldPos;
        void main() {
          vec3 viewDir = normalize(-vPos);
          float rim = 1.0 - max(dot(viewDir, vNormal), 0.0);
          // Shell 2 breathe: offset phase + different harmonic
          float breathe = 1.0 + sin(uTime * 0.3 + 1.0) * 0.08 + sin(uTime * 0.22 + 2.0) * 0.05;
          // Scan sweep sync on extended halo
          float scanAngle = atan(vWorldPos.x, vWorldPos.z);
          float sweepAngle = mod(uTime * 0.4, 6.28318);
          float scanDist = mod(scanAngle - sweepAngle + 6.28318, 6.28318);
          float sweepBoost = smoothstep(0.7, 0.0, scanDist) * 0.3;
          float glow = pow(rim, 4.0) * (0.16 + sweepBoost * rim) * breathe;
          gl_FragColor = vec4(uColor, glow);
