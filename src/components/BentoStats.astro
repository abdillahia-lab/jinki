---
/* BentoStats — Bento grid stats section (counter animation handled by Layout.astro) */
---

<section id="stats" class="bento-section" style="background: var(--surface-dim); padding: 5rem 0;" aria-label="Platform Statistics">
  <div style="max-width: 80rem; margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem;">
    <div class="bento-grid">
      <!-- Main Panel -->
      <div class="bento-main reveal">
        <div>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
            <span style="display: block; height: 1px; width: 2rem; background: var(--accent);"></span>
            <span class="bento-eyebrow">Platform</span>
          </div>
          <h2 class="bento-headline" style="color: var(--text-primary); margin-bottom: 1.5rem;">
            Always Watching. Always <span class="bento-headline-accent">Learning.</span>
          </h2>
          <p class="bento-body" style="color: var(--text-secondary); margin-bottom: 3rem; max-width: 42rem;">
            Our AI-powered aerial platform monitors your infrastructure around the clock. It doesn't just capture data — it detects anomalies, predicts failures, and delivers prioritized recommendations so you can act before problems escalate.
          </p>
        </div>
        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-value" data-count="98.4" data-suffix="%">0%</span>
            <span class="stat-label">Anomaly Detection</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">24/7</span>
            <span class="stat-label">Continuous Coverage</span>
          </div>
          <div class="stat-item">
            <span class="stat-value">&lt;2m</span>
            <span class="stat-label">Spatial Precision</span>
          </div>
        </div>
      </div>
      <!-- Sidebar Panel -->
      <div class="bento-sidebar reveal" style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;">
        <div class="bento-icon-ring" style="width: 6rem; height: 6rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: var(--accent-glow); margin-bottom: 2rem;">
          <span class="material-symbols-outlined" style="font-size: 3rem; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">verified_user</span>
        </div>
        <h3 style="font-family: var(--font-headline); font-size: 1.75rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;">Your Data Stays Yours</h3>
        <p style="color: var(--text-secondary); font-weight: 300; font-size: 1.125rem; margin-bottom: 2.5rem;">
          All inspection data is processed on your premises or in your choice of secure cloud region. Nothing leaves your control.
        </p>
        <a href="#lead-gen" class="bento-sidebar-cta" style="display: block; width: 100%; padding: 1.25rem; font-family: var(--font-label); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.25em; text-align: center; text-decoration: none; border-radius: 0.75rem;">
          Learn About Our Security
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) { .bento-section { padding: 8rem 0 !important; } }
  .bento-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 1024px) { .bento-grid { grid-template-columns: 2fr 1fr; } }
  .bento-main {
    background: var(--surface-container); padding: 2rem; min-height: 400px;
    border-radius: 1rem; border: 1px solid var(--glass-border);
    display: flex; flex-direction: column; justify-content: space-between;
  }
  @media (min-width: 768px) { .bento-main { padding: 4rem; min-height: 550px; } }
  .bento-eyebrow { font-family: var(--font-label); font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.3em; color: var(--accent); }
  .bento-headline { font-family: var(--font-headline); font-weight: 700; font-size: 2rem; letter-spacing: -0.02em; }
  @media (min-width: 768px) { .bento-headline { font-size: 3rem; } }
  .bento-headline-accent {
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; font-style: italic;
  }
  :global([data-theme="light"]) .bento-headline-accent {
    background: linear-gradient(135deg, #00838f, #5B4ACF);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .bento-body { font-family: var(--font-body); font-size: 1.125rem; line-height: 1.65; font-weight: 300; }
  @media (min-width: 768px) { .bento-body { font-size: 1.5rem; } }
  .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  @media (min-width: 768px) { .stats-row { gap: 3rem; } }
  .stat-value { display: block; font-family: var(--font-headline); font-weight: 700; font-size: 1.5rem; color: var(--accent); }
  @media (min-width: 768px) { .stat-value { font-size: 2.25rem; } }
  .stat-label { display: block; font-family: var(--font-label); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); margin-top: 0.5rem; }
  .stat-item + .stat-item { border-left: 1px solid var(--glass-border); padding-left: 1.5rem; }
  @media (min-width: 768px) { .stat-item + .stat-item { padding-left: 3rem; } }
  .bento-sidebar { background: var(--surface-container); padding: 2rem; border-radius: 1rem; border: 1px solid var(--glass-border); }
  @media (min-width: 768px) { .bento-sidebar { padding: 4rem; } }
  .bento-sidebar-cta {
    border: 1.5px solid rgba(0, 229, 255, 0.25); color: var(--accent);
    background: transparent; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .bento-sidebar-cta:hover {
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    color: #fff; border-color: transparent;
    box-shadow: 0 4px 16px rgba(0, 229, 255, 0.3); transform: translateY(-1px);
  }
  .bento-sidebar-cta:active { transform: translateY(0); }
  .bento-icon-ring { animation: glow-pulse 4s ease-in-out infinite; }
  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(0, 229, 255, 0.15); }
    50% { box-shadow: 0 0 40px rgba(0, 229, 255, 0.3); }
  }
  @media (prefers-reduced-motion: reduce) { .bento-icon-ring { animation: none; } }
</style>
