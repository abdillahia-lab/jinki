---
/* BentoStats — Bento grid stats section */
---

<section id="stats" class="relative overflow-hidden bento-section-padding" style="background: var(--surface-dim);" aria-label="Platform Statistics">
  <div style="max-width: 80rem; margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem;">
    <div class="bento-grid">

      <!-- Main Panel -->
      <div class="bento-main bento-main-span rounded-2xl flex flex-col justify-between shadow-xl reveal">

        <div>
          <div class="flex items-center gap-3" style="margin-bottom: 1rem;">
            <span class="block h-[1px] w-8" style="background: var(--accent);"></span>
            <span class="bento-eyebrow">Platform</span>
          </div>
          <h2 class="bento-headline font-headline font-bold mb-6" style="color: var(--text-primary); margin-bottom: 1.5rem;">
            Always Watching. Always <span class="bento-headline-accent">Learning.</span>
          </h2>
          <p class="bento-body-text leading-relaxed font-light mb-12 max-w-2xl bento-body" style="margin-bottom: 3rem;">
            Our AI-powered aerial platform monitors your infrastructure around the clock. It doesn't just capture data — it detects anomalies, predicts failures, and delivers prioritized recommendations so you can act before problems escalate.
          </p>
        </div>

        <div class="stats-row">
          <div class="stat-item">
            <span class="stat-value text-4xl font-headline font-bold" data-count="98.4" data-suffix="%">0%</span>
            <span class="stat-label text-[0.75rem] font-label uppercase tracking-widest font-bold block mt-2" style="margin-top: 0.5rem;">Anomaly Detection</span>
          </div>
          <div class="stat-item">
            <span class="stat-value text-4xl font-headline font-bold">24/7</span>
            <span class="stat-label text-[0.75rem] font-label uppercase tracking-widest font-bold block mt-2" style="margin-top: 0.5rem;">Continuous Coverage</span>
          </div>
          <div class="stat-item">
            <span class="stat-value text-4xl font-headline font-bold">&lt;2m</span>
            <span class="stat-label text-[0.75rem] font-label uppercase tracking-widest font-bold block mt-2" style="margin-top: 0.5rem;">Spatial Precision</span>
          </div>
        </div>
      </div>

      <!-- Sidebar Panel -->
      <div class="bento-sidebar rounded-2xl flex flex-col justify-center items-center text-center shadow-2xl reveal">

        <div class="bento-icon-ring w-24 h-24 rounded-full flex items-center justify-center mb-8" style="background: var(--accent-glow); margin-bottom: 2rem;">
          <span class="material-symbols-outlined text-5xl" style="color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">verified_user</span>
        </div>

        <h3 class="font-headline text-3xl font-bold mb-4 bento-sidebar-title" style="margin-bottom: 1rem;">Your Data Stays Yours</h3>

        <p class="bento-sidebar-body font-light mb-10 text-lg" style="margin-bottom: 2.5rem;">
          All inspection data is processed on your premises or in your choice of secure cloud region. Nothing leaves your control.
        </p>

        <a
          href="#lead-gen"
          class="bento-sidebar-cta btn-premium transition-all font-label font-bold rounded-xl text-center block"
          style="width: 100%; padding-top: 1.25rem; padding-bottom: 1.25rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.25em;"
        >
          Learn About Our Security
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  .bento-section-padding {
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .bento-section-padding {
      padding-top: 8rem;
      padding-bottom: 8rem;
    }
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .bento-main {
    background: var(--surface-container);
    padding: 2rem;
    min-height: 400px;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
  }

  .bento-main::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .bento-main {
      padding: 4rem;
      min-height: 550px;
    }
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .stats-row {
      gap: 3rem;
    }
  }

  .bento-eyebrow {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--accent);
    position: relative;
    z-index: 2;
  }

  .bento-headline-accent {
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  :global([data-theme="light"]) .bento-headline-accent {
    background: linear-gradient(135deg, #00838f, #5B4ACF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .bento-headline {
    font-size: 2rem;
  }

  @media (min-width: 768px) {
    .bento-headline {
      font-size: 3rem;
    }
  }

  .bento-body-text {
    font-size: 1.125rem;
  }

  @media (min-width: 768px) {
    .bento-body-text {
      font-size: 1.5rem;
    }
  }

  .bento-body {
    color: var(--text-secondary);
  }

  .stat-value {
    color: var(--accent);
    font-size: 1.5rem;
    position: relative;
    z-index: 2;
    transition: text-shadow 0.3s ease;
  }

  .stat-value:hover {
    text-shadow: 0 0 20px var(--accent-glow-strong);
  }

  @media (min-width: 768px) {
    .stat-value {
      font-size: 2.25rem;
    }
  }

  .stat-label {
    color: var(--text-tertiary);
  }

  .stat-item {
    position: relative;
    z-index: 2;
  }

  .stat-item + .stat-item {
    border-left: 1px solid var(--border);
    padding-left: 1.5rem;
  }

  @media (min-width: 768px) {
    .stat-item + .stat-item {
      padding-left: 3rem;
    }
  }

  .bento-sidebar {
    background-color: var(--surface-container);
    padding: 2rem;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
  }

  .bento-sidebar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
    border-radius: inherit;
    z-index: 1;
  }

  @media (min-width: 768px) {
    .bento-sidebar {
      padding: 4rem;
    }
  }

  .bento-sidebar-title {
    color: var(--text-primary);
  }

  .bento-sidebar-body {
    color: var(--text-secondary);
  }

  .bento-sidebar-cta {
    border: 1.5px solid rgba(0, 229, 255, 0.25);
    color: var(--accent);
    position: relative;
    z-index: 2;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
  }

  .bento-sidebar-cta:hover {
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    color: #ffffff;
    border-color: transparent;
    box-shadow: 0 4px 16px rgba(0, 229, 255, 0.3), inset 0 1px 0 rgba(255,255,255,0.2);
    transform: translateY(-1px);
  }

  .bento-sidebar-cta:active {
    transform: translateY(0);
  }

  .bento-icon-ring {
    animation: glow-pulse 4s ease-in-out infinite;
    transition: transform 0.3s ease;
  }

  .bento-icon-ring:hover {
    transform: scale(1.08);
  }

  @keyframes glow-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(0, 229, 255, 0.15); }
    50% { box-shadow: 0 0 40px rgba(0, 229, 255, 0.3), 0 0 80px rgba(0, 229, 255, 0.08); }
  }
</style>

<script>
  // Counter animation for stat values with data-count attribute
  function animateCounters() {
    const counters = document.querySelectorAll('.stat-value[data-count]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const el = entry.target as HTMLElement;
        const target = parseFloat(el.dataset.count || '0');
        const suffix = el.dataset.suffix || '';
        const duration = 2000;
        const startTime = performance.now();

        function update(currentTime: number) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          // Ease-out cubic
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = target * eased;

          if (target % 1 !== 0) {
            el.textContent = current.toFixed(1) + suffix;
          } else {
            el.textContent = Math.floor(current) + suffix;
          }

          if (progress < 1) {
            requestAnimationFrame(update);
          }
        }

        requestAnimationFrame(update);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach((counter) => observer.observe(counter));
  }

  document.addEventListener('astro:page-load', animateCounters);
  animateCounters();
</script>
