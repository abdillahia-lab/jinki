---
/*
  TrustStrip.astro — Narrow always-visible band of proof signals
  rendered right under the main Nav on every page.

  Copy is locked (2026-04-20 user decision). Do not edit items without
  updating the plan file §5 CHUNK-02.
*/

const signals = [
  'FAA Part 107',
  '$5M Liability',
  'NVIDIA Inception',
  'SOC 2 Target Spring 2027',
  'NDA by Default',
];
---

<div class="trust-strip">
  <div class="trust-strip-scroll">
    <ul class="trust-strip-list">
      {signals.map((s, i) => (
        <li class="trust-strip-item">
          <span class="trust-strip-label">{s}</span>
          {i < signals.length - 1 && <span class="trust-strip-sep" aria-hidden="true">·</span>}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .trust-strip {
    position: relative;
    width: 100%;
    background: var(--surface-container-low, rgba(0, 0, 0, 0.18));
    border-bottom: 1px solid var(--glass-border);
    /* Subtle accent tint so it reads as "ours" not as generic chrome */
    box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--accent) 8%, transparent);
  }

  :global([data-theme="light"]) .trust-strip {
    background: color-mix(in srgb, var(--accent) 3%, var(--surface-container-low, #f4f5f7));
    border-bottom-color: color-mix(in srgb, var(--accent) 12%, transparent);
    box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .trust-strip-scroll {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 24px;
    /* Mobile: horizontal scroll with scroll-snap; desktop: full row visible */
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
  }
  .trust-strip-scroll::-webkit-scrollbar { display: none; }

  .trust-strip-list {
    list-style: none;
    margin: 0;
    padding: 10px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    white-space: nowrap;
    min-height: 36px;
  }

  .trust-strip-item {
    display: inline-flex;
    align-items: center;
    scroll-snap-align: start;
  }

  .trust-strip-label {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    transition: color 0.2s;
  }

  .trust-strip-sep {
    display: inline-block;
    margin: 0 14px;
    color: color-mix(in srgb, var(--accent) 45%, transparent);
    font-weight: 700;
    /* visual weight for the mid-dot */
    font-size: 0.75rem;
  }

  /* Hover: subtle accent for the item (no link semantics — proof not promo) */
  .trust-strip-item:hover .trust-strip-label {
    color: var(--text-primary);
  }

  /* Mobile: smaller padding, left-align so the first item is visible, fade edge */
  @media (max-width: 767px) {
    .trust-strip-scroll {
      padding: 0 16px;
      /* Fade both edges to hint at horizontal scroll */
      mask-image: linear-gradient(
        to right,
        transparent 0,
        black 20px,
        black calc(100% - 20px),
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        black 20px,
        black calc(100% - 20px),
        transparent 100%
      );
    }
    .trust-strip-list {
      justify-content: flex-start;
      padding: 8px 0;
      min-height: 32px;
    }
    .trust-strip-label {
      font-size: 0.625rem;
      letter-spacing: 0.06em;
    }
    .trust-strip-sep {
      margin: 0 10px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-strip-label {
      transition: none;
    }
    .trust-strip-scroll {
      scroll-behavior: auto;
    }
  }
</style>
