---
/*
  ThermalHUD Section — Jinki Aerial Intelligence
  Split layout: text + stats left, thermal image right.
  Zero JavaScript. All spacing inline.
*/
---

<section id="thermal-hud" style="background: color-mix(in srgb, var(--surface-container-low) 30%, transparent); padding-top: 7rem; padding-bottom: 7rem;" aria-label="Precision Structural Analysis">
  <div style="max-width: 80rem; margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem;">
    <div class="thermal-grid">

      <!-- Left: Text -->
      <div class="reveal">
        <div class="flex items-center gap-3" style="margin-bottom: 1.5rem;">
          <span class="block h-[1px] w-8" style="background: var(--accent);"></span>
          <span class="section-eyebrow">Thermal Imaging</span>
        </div>

        <h2 style="font-family: var(--font-headline); font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; line-height: 1.1;">
          Find Hidden Problems With <span class="thermal-headline-accent">Heat Vision</span>
        </h2>

        <p style="font-family: var(--font-body); font-size: 1.125rem; font-weight: 300; line-height: 1.7; color: var(--text-secondary); margin-bottom: 2.5rem;">
          Our aerial thermal imaging detects temperature differences as small as 0.5&deg;C. We identify overheating equipment, insulation gaps, water leaks, and structural weak points — delivering prioritized repair recommendations without disrupting your operations.
        </p>

        <!-- Stats -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
          <div style="border-left: 2px solid var(--accent); padding-left: 1rem;">
            <span style="font-family: var(--font-headline); font-size: clamp(1.25rem, 4vw, 1.875rem); font-weight: 700; color: var(--accent); display: block;">0.1m</span>
            <span class="section-eyebrow" style="color: var(--text-tertiary); display: block; margin-top: 0.25rem;">Spatial Resolution</span>
          </div>
          <div style="border-left: 2px solid var(--accent); padding-left: 1rem;">
            <span style="font-family: var(--font-headline); font-size: clamp(1.25rem, 4vw, 1.875rem); font-weight: 700; color: var(--accent); display: block;">Edge AI</span>
            <span class="section-eyebrow" style="color: var(--text-tertiary); display: block; margin-top: 0.25rem;">On-Platform Processing</span>
          </div>
        </div>
      </div>

      <!-- Right: Image -->
      <div class="reveal">
        <div class="thermal-panel relative overflow-hidden" style="border: 1px solid rgba(255,140,0,0.15); border-radius: 0.75rem; box-shadow: 0 8px 32px rgba(0,0,0,0.2), 0 0 40px rgba(255,100,0,0.04);">
          <img
            src="/images/thermal-infrastructure.jpg"
            alt="Thermal infrared scan of industrial infrastructure showing heat distribution analysis"
            class="thermal-img aspect-video w-full object-cover"
            loading="lazy"
            decoding="async"
          />
          <!-- Scan line sweep -->
          <div class="thermal-scanline" aria-hidden="true"></div>
          <!-- Corner HUD readouts -->
          <span class="hud-readout hud-top-left" aria-hidden="true">38.897&deg;N 77.036&deg;W</span>
          <span class="hud-readout hud-top-right" aria-hidden="true">ALT 120m AGL</span>
          <span class="hud-readout hud-bottom-right" aria-hidden="true">UTC 14:32:07.4</span>
          <!-- Status badge -->
          <div class="thermal-badge absolute z-10 flex items-center rounded-sm" style="bottom: 1rem; left: 1rem; padding: 0.375rem 0.75rem; gap: 0.5rem;">
            <span style="display: block; width: 0.5rem; height: 0.5rem; border-radius: 50%; background: #4ade80;"></span>
            <span style="font-family: var(--font-mono); font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-secondary);">LIVE // THERMAL SCAN</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    #thermal-hud { padding-top: 8rem !important; padding-bottom: 8rem !important; }
  }

  .thermal-headline-accent {
    background: linear-gradient(135deg, #FF6B35, #FF4500);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }
  :global([data-theme="light"]) .thermal-headline-accent {
    background: linear-gradient(135deg, #D44500, #B83000);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .thermal-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .thermal-grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .thermal-img {
    filter: brightness(0.9) contrast(1.25);
    display: block;
  }
  :root[data-theme="dark"] .thermal-img,
  :root:not([data-theme]) .thermal-img {
    filter: brightness(0.75) contrast(1.25);
  }
  :global([data-theme="light"]) .thermal-img {
    filter: brightness(0.9) contrast(1.25);
  }

  .thermal-panel {
    background: var(--surface-dim);
  }

  .thermal-badge {
    background: rgba(12, 14, 16, 0.8);
    backdrop-filter: blur(8px);
  }
  :global([data-theme="light"]) .thermal-badge {
    background: rgba(255, 255, 255, 0.85);
  }

  /* === HUD corner readouts === */
  .hud-readout {
    position: absolute;
    z-index: 10;
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.04em;
    color: rgba(255, 140, 0, 0.7);
    text-shadow: 0 1px 4px rgba(0,0,0,0.6);
    pointer-events: none;
  }
  .hud-top-left    { top: 0.75rem; left: 0.75rem; }
  .hud-top-right   { top: 0.75rem; right: 0.75rem; }
  .hud-bottom-right { bottom: 0.75rem; right: 0.75rem; }
  :global([data-theme="light"]) .hud-readout {
    color: rgba(180, 80, 0, 0.6);
    text-shadow: 0 1px 3px rgba(255,255,255,0.5);
  }

  /* === Scan line sweep === */
  .thermal-scanline {
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    overflow: hidden;
  }
  .thermal-scanline::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 5%, rgba(255,140,0,0.35) 30%, rgba(255,140,0,0.6) 50%, rgba(255,140,0,0.35) 70%, transparent 95%);
    box-shadow: 0 0 12px rgba(255,140,0,0.2), 0 2px 8px rgba(255,140,0,0.1);
    animation: scanSweep 4s ease-in-out infinite;
  }

  @keyframes scanSweep {
    0%   { top: -2px; opacity: 0; }
    5%   { opacity: 1; }
    95%  { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .thermal-img { transition: none; }
    .thermal-scanline::after { animation: none; display: none; }
  }
</style>
