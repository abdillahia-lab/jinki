---
/*
  Use Cases Section — Jinki Aerial Intelligence

  Agent 4: Research-backed industry content from tier-1 consulting firms.
  Each vertical leads with a compelling stat, frames risks as managed advantages,
  and positions Jinki as an aerial intelligence company (not a hardware vendor).

  Sources cited in content:
  - McKinsey Global Institute: infrastructure inspection automation
  - Gartner: data center operations and predictive maintenance
  - McKinsey/PwC: precision agriculture ROI
  - Deloitte/Accenture: physical security automation
*/

const useCases = [
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
    title: 'Infrastructure Inspection',
    stat: 'Industry trend: 45% cost reduction potential',
    statSource: 'McKinsey Global Institute (general industry)',
    description: 'Autonomous aerial intelligence replaces manual inspection of power lines, bridges, pipelines, and solar farms — delivering millimeter-precision defect data in a fraction of the time.',
    benefits: [
      'Reduce inspection cycles from weeks to hours with autonomous flight planning',
      'Detect sub-centimeter structural defects invisible to ground-level assessment',
      'Generate automated compliance reports with geotagged anomaly data',
      'Eliminate confined-space and at-height safety risks for inspection teams'
    ],
    riskReframe: 'Regulatory complexity around BVLOS (Beyond Visual Line of Sight) operations is real — and it\'s exactly where our FAA-certified operations team and security-first data handling give clients a turnkey advantage. We manage the airspace, you receive the intelligence.',
    color: '#00D4FF'
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/><line x1="10" y1="6" x2="18" y2="6" opacity="0.5"/><line x1="10" y1="18" x2="18" y2="18" opacity="0.5"/></svg>`,
    title: 'Data Center Monitoring',
    stat: 'Industry trend: predictive monitoring reduces outages',
    statSource: 'Gartner (general industry)',
    description: 'Thermal aerial intelligence detects HVAC failures, hot spots, and facility anomalies before they cascade into downtime — integrating directly with your DCIM and BMS systems.',
    benefits: [
      'Identify thermal anomalies across rooftop infrastructure in minutes, not days',
      'Predict cooling system failures with AI-driven trend analysis',
      'Monitor physical security perimeters and detect unauthorized access',
      'Generate facility health reports that integrate with existing DCIM platforms'
    ],
    riskReframe: 'Data privacy and airspace restrictions near facilities are critical considerations. Our end-to-end encrypted data pipeline, NIST-aligned security controls, and controlled airspace coordination protocols ensure zero data exposure and full regulatory compliance.',
    color: '#7B61FF'
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c-4.97 0-9-2.24-9-5v-4"/><path d="M12 14c-4.97 0-9-2.24-9-5s4.03-5 9-5 9 2.24 9 5"/><path d="M3 13c0 2.76 4.03 5 9 5s9-2.24 9-5V9"/><path d="M21 9c0 2.76-4.03 5-9 5"/><line x1="12" y1="2" x2="12" y2="6" opacity="0.3"/><line x1="7" y1="4" x2="7" y2="8" opacity="0.3"/><line x1="17" y1="4" x2="17" y2="8" opacity="0.3"/></svg>`,
    title: 'Precision Agriculture',
    stat: 'Industry trend: precision ag improves resource efficiency',
    statSource: 'PwC / McKinsey (general industry)',
    description: 'Thermal aerial intelligence transforms crop management — from early stress detection to irrigation optimization — enabling data-driven decisions across every acre.',
    benefits: [
      'Generate thermal crop health maps and stress indicators across entire properties',
      'Detect crop stress, disease, and pest damage weeks before visible onset',
      'Optimize irrigation with precision water-stress mapping',
      'Build season-over-season predictive yield models with historical aerial data'
    ],
    riskReframe: 'Initial technology adoption cost is a common concern. Aerial intelligence can reduce input waste, enable earlier intervention, and improve decision-making — contact us for a tailored analysis of your operation.',
    color: '#4ADE80'
  },
  {
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><circle cx="12" cy="10" r="3"/></svg>`,
    title: 'Security & Surveillance',
    stat: 'Industry trend: autonomous systems accelerate response',
    statSource: 'Deloitte (general industry)',
    description: 'Autonomous aerial patrols deliver persistent surveillance for corporate campuses, critical infrastructure, and high-value facilities — augmenting security teams with intelligent overwatch.',
    benefits: [
      'Deploy autonomous patrol routes covering areas impossible for ground teams',
      'Detect and classify intrusions with AI-powered real-time analytics',
      'Integrate alerts directly with existing SIEM and SOC workflows',
      'Expand surveillance coverage area without proportional staffing increases'
    ],
    riskReframe: 'Privacy compliance and regulatory considerations are foundational to our approach. Every deployment follows strict data minimization principles, ensuring responsible, compliant surveillance that protects both clients and the communities they operate in.',
    color: '#FF6B6B'
  }
];
---

<section id="use-cases" class="section" aria-label="Use Cases" data-scrollytelling>
  <div class="section-inner">
    <div class="use-cases-header reveal">
      <span class="label">Industries We Serve</span>
      <h2>Aerial Intelligence<br/>Across Every Vertical</h2>
      <p class="use-cases-subtitle">
        From critical infrastructure to precision agriculture — our platform adapts
        to deliver the intelligence each industry demands.
      </p>
    </div>

    <div class="use-cases-grid">
      {useCases.map((uc, i) => (
        <div class={`use-case-card card reveal reveal-delay-${i + 1}`}>
          <div class="use-case-icon" style={`color: ${uc.color}; background: ${uc.color}15;`}>
            <Fragment set:html={uc.icon} />
          </div>
          <h3 class="use-case-title">{uc.title}</h3>

          <!-- Lead stat from tier-1 research -->
          <div class="use-case-stat" style={`border-color: ${uc.color}30;`}>
            <span class="use-case-stat-value" style={`color: ${uc.color};`}>{uc.stat}</span>
            <span class="use-case-stat-source">{uc.statSource}</span>
          </div>

          <p class="use-case-desc">{uc.description}</p>

          <ul class="use-case-benefits">
            {uc.benefits.map(benefit => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke={uc.color} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
                {benefit}
              </li>
            ))}
          </ul>

          <!-- Risk reframed as managed advantage -->
          <div class="use-case-risk-reframe">
            <span class="risk-reframe-label">Managed Advantage</span>
            <p>{uc.riskReframe}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .use-cases-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .use-cases-subtitle {
    max-width: 560px;
    margin: 16px auto 0;
  }

  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }

  .use-case-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px 28px;
  }

  .use-case-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    transition: transform 0.35s var(--ease-out-premium);
  }

  .use-case-card:hover .use-case-icon {
    transform: scale(1.1);
  }

  .use-case-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .use-case-stat {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 12px 16px;
    background: var(--bg-elevated);
    border-radius: 8px;
    border-left: 3px solid;
  }

  .use-case-stat-value {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 16px;
  }

  .use-case-stat-source {
    font-size: 12px;
    color: var(--text-tertiary);
    font-style: italic;
  }

  .use-case-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .use-case-benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  .use-case-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .use-case-benefits svg {
    flex-shrink: 0;
    margin-top: 3px;
  }

  .use-case-risk-reframe {
    margin-top: auto;
    padding: 16px;
    background: var(--accent-glow);
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .risk-reframe-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .use-case-risk-reframe p {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: none;
  }

  @media (max-width: 1024px) {
    .use-cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
