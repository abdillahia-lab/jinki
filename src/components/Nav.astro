---
/*
  Nav.astro — Lightweight marketing nav
  Logo, links, verticals dropdown, theme toggle, CTA
*/

const verticals = [
  { href: '/verticals/data-centers', label: 'Data Centers', color: '#00E5FF' },
  { href: '/verticals/energy-grid', label: 'Energy Grid', color: '#FF8C00' },
  { href: '/verticals/security', label: 'Security', color: '#7B61FF' },
  { href: '/verticals/agriculture', label: 'Agriculture', color: '#34D399' },
];

const services = [
  { href: '/services/audit', label: 'Facility Intelligence Scan' },
  { href: '/services/deployment', label: 'Autonomous Deployment' },
];
---

<header id="site-nav" class="site-nav" style="position:fixed;top:0;left:0;right:0;z-index:1000;padding:12px 24px;">
  <nav class="nav-inner" style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:16px;padding:10px 20px;backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);transition:box-shadow .3s,background .3s;" aria-label="Main navigation">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Jinki — Home" style="display:flex;align-items:center;gap:8px;text-decoration:none;color:var(--text-primary);flex-shrink:0;">
      <svg class="jinki-mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true" style="display:block;flex-shrink:0;">
        <!-- Center ping dot -->
        <circle class="mark-ping" cx="16" cy="16" r="2.5" fill="#00E5FF"/>
        <!-- Scanning arcs -->
        <path class="mark-arc mark-arc-1" d="M 16 8 A 8 8 0 1 1 8.5 20" stroke="#00E5FF" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path class="mark-arc mark-arc-2" d="M 22 4.5 A 14 14 0 0 1 22 27.5" stroke="#00E5FF" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path class="mark-arc mark-arc-3" d="M 9 2 A 18 18 0 0 1 29 20" stroke="#00E5FF" stroke-width="1" fill="none" stroke-linecap="round"/>
        <!-- Sweep line (radar) -->
        <line class="mark-sweep" x1="16" y1="16" x2="16" y2="2" stroke="#00E5FF" stroke-width="0.8" stroke-linecap="round" opacity="0.4"/>
      </svg>
      <span style="font-family:var(--font-headline);font-weight:700;font-size:18px;letter-spacing:-0.02em;">Jinki</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" style="display:flex;align-items:center;gap:4px;list-style:none;margin:0;padding:0;">
      <!-- Verticals dropdown -->
      <li class="dropdown" style="position:relative;">
        <button class="nav-link dropdown-trigger" aria-expanded="false" aria-haspopup="true" style="display:flex;align-items:center;gap:4px;">
          Verticals
          <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;transition:transform .25s;">expand_more</span>
        </button>
        <div class="dropdown-panel" style="position:absolute;top:calc(100% + 8px);left:50%;transform:translateX(-50%);min-width:200px;background:var(--surface-container);border:1px solid var(--glass-border);border-radius:12px;padding:6px;transition:opacity .2s,visibility .2s;box-shadow:0 8px 32px rgba(0,0,0,.3);">
          {verticals.map(v => (
            <a href={v.href} class="dropdown-item" style={`display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:8px;text-decoration:none;color:var(--text-primary);font-family:var(--font-label);font-size:14px;transition:background .15s;`}>
              <span class="dot" style={`width:8px;height:8px;border-radius:50%;background:${v.color};flex-shrink:0;`}></span>
              {v.label}
            </a>
          ))}
        </div>
      </li>

      <!-- Services dropdown -->
      <li class="dropdown" style="position:relative;">
        <button class="nav-link dropdown-trigger" aria-expanded="false" aria-haspopup="true" style="display:flex;align-items:center;gap:4px;">
          Services
          <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;transition:transform .25s;">expand_more</span>
        </button>
        <div class="dropdown-panel" style="position:absolute;top:calc(100% + 8px);left:50%;transform:translateX(-50%);min-width:200px;background:var(--surface-container);border:1px solid var(--glass-border);border-radius:12px;padding:6px;transition:opacity .2s,visibility .2s;box-shadow:0 8px 32px rgba(0,0,0,.3);">
          {services.map(s => (
            <a href={s.href} class="dropdown-item" style={`display:flex;align-items:center;gap:10px;padding:10px 14px;border-radius:8px;text-decoration:none;color:var(--text-primary);font-family:var(--font-label);font-size:14px;transition:background .15s;`}>
              {s.label}
            </a>
          ))}
        </div>
      </li>

      <li><a href="/about" class="nav-link">About</a></li>
      <li><a href="/blog" class="nav-link">Blog</a></li>
    </ul>

    <!-- Right side: theme toggle + CTA -->
    <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" style="background:none;border:1px solid var(--glass-border);border-radius:12px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-secondary);transition:color .2s,border-color .2s;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:20px;">dark_mode</span>
      </button>
      <a href="#lead-gen" class="nav-cta" style="display:inline-flex;align-items:center;font-family:var(--font-label);font-size:14px;font-weight:600;padding:8px 18px;border-radius:12px;background:var(--accent);color:#050508;text-decoration:none;white-space:nowrap;transition:opacity .2s;">Get in Touch</a>

      <!-- Mobile hamburger -->
      <button id="mobile-toggle" class="mobile-toggle" aria-label="Open menu" aria-expanded="false" style="display:none;background:none;border:none;cursor:pointer;color:var(--text-primary);padding:8px;min-width:44px;min-height:44px;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:26px;">menu</span>
      </button>
    </div>
  </nav>

  <!-- Mobile slide-out panel -->
  <div id="mobile-panel" class="mobile-panel" aria-hidden="true">
    <div class="mobile-panel-inner" style="display:flex;flex-direction:column;gap:4px;padding:20px;">
      <div class="mobile-section-label" style="font-family:var(--font-label);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);padding:16px 14px 6px;">Verticals</div>
      {verticals.map(v => (
        <a href={v.href} class="mobile-link" style="display:flex;align-items:center;gap:10px;">
          <span style={`width:8px;height:8px;border-radius:50%;background:${v.color};flex-shrink:0;`}></span>
          {v.label}
        </a>
      ))}

      <div class="mobile-section-label" style="font-family:var(--font-label);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);padding:16px 14px 6px;">Services</div>
      {services.map(s => (
        <a href={s.href} class="mobile-link">{s.label}</a>
      ))}

      <div style="border-top:1px solid var(--glass-border);margin:12px 0;"></div>
      <a href="/about" class="mobile-link">About</a>
      <a href="/blog" class="mobile-link">Blog</a>

      <a href="#lead-gen" class="mobile-cta" style="display:block;text-align:center;margin-top:16px;font-family:var(--font-label);font-size:15px;font-weight:600;padding:14px;border-radius:12px;background:var(--accent);color:#050508;text-decoration:none;">Get in Touch</a>
    </div>
  </div>

  <!-- Mobile backdrop -->
  <div id="mobile-backdrop" class="mobile-backdrop"></div>
</header>

<!-- Spacer to prevent content from hiding behind fixed nav -->
<div style="height:72px;" aria-hidden="true"></div>

<style>
  /* Nav link base */
  .nav-link {
    font-family: var(--font-label);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.06);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s ease, left 0.3s ease;
    border-radius: 1px;
  }
  .nav-link:hover::after {
    width: 60%;
    left: 20%;
  }
  .nav-link {
    position: relative;
  }
  :global([data-theme="light"]) .nav-link:hover {
    background: rgba(0,0,0,0.05);
  }

  /* Dropdown default hidden */
  .dropdown-panel {
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(8px);
    transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease;
  }

  /* Dropdown open state */
  .dropdown:hover .dropdown-panel,
  .dropdown.open .dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .dropdown:hover .dropdown-trigger span.material-symbols-outlined,
  .dropdown.open .dropdown-trigger span.material-symbols-outlined {
    transform: rotate(180deg);
  }

  .dropdown-item:hover {
    background: rgba(255,255,255,0.06);
  }
  :global([data-theme="light"]) .dropdown-item:hover {
    background: rgba(0,0,0,0.05);
  }

  /* Theme button hover */
  .theme-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent);
  }

  /* CTA hover */
  .nav-cta {
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0, 229, 255, 0.3);
    opacity: 0.95;
  }
  .nav-cta:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(0, 229, 255, 0.2);
  }

  /* === Active scanning logo === */
  .jinki-mark { overflow: visible; }

  /* Center dot ping */
  .mark-ping {
    animation: markPing 3s ease-in-out infinite;
  }
  @keyframes markPing {
    0%, 100% { r: 2.5; opacity: 1; filter: drop-shadow(0 0 2px #00E5FF); }
    50% { r: 3; opacity: 0.8; filter: drop-shadow(0 0 6px #00E5FF); }
  }

  /* Arcs pulse outward sequentially with staggered boot */
  .mark-arc-1 {
    opacity: 0;
    animation: arcBoot 0.6s ease-out 0.2s forwards, arcPulse1 4s ease-in-out 0.8s infinite;
  }
  .mark-arc-2 {
    opacity: 0;
    animation: arcBoot 0.6s ease-out 0.5s forwards, arcPulse2 4s ease-in-out 1.1s infinite;
  }
  .mark-arc-3 {
    opacity: 0;
    animation: arcBoot 0.6s ease-out 0.8s forwards, arcPulse3 4s ease-in-out 1.4s infinite;
  }
  @keyframes arcBoot {
    from { opacity: 0; stroke-dasharray: 0 200; }
    to { opacity: 1; stroke-dasharray: 200 0; }
  }
  @keyframes arcPulse1 {
    0%, 100% { opacity: 0.5; }
    25% { opacity: 1; }
    75% { opacity: 0.5; }
  }
  @keyframes arcPulse2 {
    0%, 100% { opacity: 0.2; }
    40% { opacity: 0.7; }
    80% { opacity: 0.2; }
  }
  @keyframes arcPulse3 {
    0%, 100% { opacity: 0.08; }
    55% { opacity: 0.45; }
    85% { opacity: 0.08; }
  }

  /* Radar sweep line rotation */
  .mark-sweep {
    transform-origin: 16px 16px;
    animation: radarSweep 3s linear infinite;
  }
  @keyframes radarSweep {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mark-ping, .mark-arc-1, .mark-arc-2, .mark-arc-3, .mark-sweep {
      animation: none;
    }
    .mark-arc-1 { opacity: 0.9; }
    .mark-arc-2 { opacity: 0.5; }
    .mark-arc-3 { opacity: 0.25; }
    .mark-sweep { opacity: 0; }
  }

  /* Light mode: darken logo arcs for visibility on white */
  :global([data-theme="light"]) .jinki-mark circle,
  :global([data-theme="light"]) .jinki-mark path,
  :global([data-theme="light"]) .jinki-mark line {
    stroke: #0891b2;
    fill: #0891b2;
  }
  :global([data-theme="light"]) .mark-arc-2 { stroke: #0891b2; }
  :global([data-theme="light"]) .mark-arc-3 { stroke: #0891b2; }
  :global([data-theme="light"]) .mark-sweep { stroke: #0891b2; }

  /* Logo icon hover */
  .nav-logo:hover .material-symbols-outlined {
    transform: rotate(20deg);
  }

  /* Scrolled state — applied by JS */
  .nav-inner.scrolled {
    box-shadow: 0 4px 24px rgba(0,0,0,0.25), 0 1px 0 rgba(200,220,230,0.05) inset;
    backdrop-filter: blur(28px) saturate(1.9);
    -webkit-backdrop-filter: blur(28px) saturate(1.9);
    background: rgba(18, 20, 22, 0.92);
  }
  :global([data-theme="light"]) .nav-inner.scrolled {
    background: rgba(250, 251, 252, 0.92);
    box-shadow: 0 4px 24px rgba(0,0,0,0.08), 0 1px 0 rgba(0,0,0,0.03) inset;
  }

  /* ---- Mobile ---- */
  .mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 300px;
    max-width: 85vw;
    background: var(--surface-container);
    border-left: 1px solid var(--glass-border);
    z-index: 1001;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }
  .mobile-panel.open {
    transform: translateX(0);
  }

  .mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }
  .mobile-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-link {
    font-family: var(--font-label);
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    padding: 14px 16px;
    border-radius: 12px;
    transition: background 0.15s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .mobile-link:hover,
  .mobile-link:active {
    background: rgba(255,255,255,0.06);
  }
  :global([data-theme="light"]) .mobile-link:hover,
  :global([data-theme="light"]) .mobile-link:active {
    background: rgba(0,0,0,0.05);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .nav-links {
      display: none !important;
    }
    .nav-cta {
      display: none !important;
    }
    .mobile-toggle {
      display: flex !important;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .nav-inner,
    .mobile-panel,
    .mobile-backdrop,
    .nav-link,
    .dropdown-panel,
    .dropdown-item,
    .theme-btn,
    .nav-cta,
    .nav-logo .material-symbols-outlined {
      transition: none !important;
    }
  }
</style>

<script>
  (function () {
    var html = document.documentElement;
    var nav = document.querySelector('.nav-inner');
    var themeToggle = document.getElementById('theme-toggle');
    var themeIcon = themeToggle?.querySelector('.material-symbols-outlined');
    var mobileToggle = document.getElementById('mobile-toggle');
    var mobilePanel = document.getElementById('mobile-panel');
    var backdrop = document.getElementById('mobile-backdrop');

    /* ---- Scroll shadow ---- */
    var lastScroll = 0;
    function onScroll() {
      var y = window.scrollY;
      if (y > 20) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
      }
      lastScroll = y;
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* ---- Theme toggle ---- */
    function syncIcon() {
      if (!themeIcon) return;
      var theme = html.getAttribute('data-theme') || 'dark';
      themeIcon.textContent = theme === 'dark' ? 'dark_mode' : 'light_mode';
    }
    syncIcon();

    themeToggle?.addEventListener('click', function () {
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('jinki-theme', next);
      syncIcon();
    });

    /* ---- Mobile menu ---- */
    function openMobile() {
      mobilePanel?.classList.add('open');
      mobilePanel?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.add('open');
      mobileToggle?.setAttribute('aria-expanded', 'true');
      var icon = mobileToggle?.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = 'close';
      document.body.style.overflow = 'hidden';
      // Focus first link for keyboard users
      var firstLink = mobilePanel?.querySelector('a');
      if (firstLink) setTimeout(function() { firstLink.focus(); }, 100);
    }

    function closeMobile() {
      mobilePanel?.classList.remove('open');
      mobilePanel?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.remove('open');
      mobileToggle?.setAttribute('aria-expanded', 'false');
      var icon = mobileToggle?.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = 'menu';
      document.body.style.overflow = '';
      // Return focus to toggle button
      mobileToggle?.focus();
    }

    mobileToggle?.addEventListener('click', function () {
      var isOpen = mobilePanel?.classList.contains('open');
      isOpen ? closeMobile() : openMobile();
    });

    backdrop?.addEventListener('click', closeMobile);

    /* Close mobile menu on link click */
    mobilePanel?.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMobile);
    });

    /* Close mobile menu on Escape */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && mobilePanel?.classList.contains('open')) {
        closeMobile();
      }
    });

    /* ---- Dropdown keyboard support ---- */
    document.querySelectorAll('.dropdown-trigger').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        var parent = btn.closest('.dropdown');
        if (!parent) return;
        var isOpen = parent.classList.contains('open');
        /* close all */
        document.querySelectorAll('.dropdown').forEach(function (d) { d.classList.remove('open'); });
        if (!isOpen) parent.classList.add('open');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    /* Close dropdowns on outside click */
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.dropdown')) {
        document.querySelectorAll('.dropdown').forEach(function (d) {
          d.classList.remove('open');
          var btn = d.querySelector('.dropdown-trigger');
          btn?.setAttribute('aria-expanded', 'false');
        });
      }
    });
  })();
</script>
