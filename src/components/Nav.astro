---
/*
  Navigation — Jinki
  Fixed nav with backdrop-blur glassmorphism, dropdown menus,
  theme toggle, mobile overlay. Uses CSS custom properties from global.css.
*/

const navItems = [
  {
    label: 'About Us',
    children: [
      { href: '/about/mission', label: 'Our Mission' },
      { href: '/about/team', label: 'Team' },
    ],
  },
  {
    label: 'Verticals',
    active: true,
    children: [
      { href: '/verticals/data-centers', label: 'Data Centers' },
      { href: '/verticals/energy-grid', label: 'Energy Grid' },
      { href: '/verticals/security', label: 'Security' },
      { href: '/verticals/agriculture', label: 'Agriculture' },
    ],
  },
  {
    label: 'Services',
    children: [
      { href: '/services/audit', label: 'Audit' },
      { href: '/services/deployment', label: 'Deployment' },
    ],
  },
  {
    label: 'Careers',
    children: [
      { href: '/careers', label: 'Open Roles' },
    ],
  },
  {
    label: 'Blog',
    children: [
      { href: '/blog', label: 'Insights' },
    ],
  },
];

/* Flatten for mobile menu */
const mobileLinks = navItems.flatMap(item =>
  item.children.map(child => child)
);
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-[1000] transition-all duration-300 border-b border-transparent">
  <div class="max-w-[1280px] flex items-center justify-between" style="margin-left: auto; margin-right: auto; padding: 1.25rem clamp(20px,5vw,80px);">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline z-10" aria-label="Jinki — Home">
      <span class="material-symbols-outlined nav-logo-icon" aria-hidden="true">radar</span>
      <span class="nav-logo-text">Jinki</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navItems.map(item => (
        <div class="group relative">
          <button
            type="button"
            class:list={[
              "nav-btn",
              item.active ? 'nav-btn-active' : '',
            ]}
            aria-haspopup="true"
          >
            {item.label}
          </button>
          <div class="dropdown-panel invisible opacity-0 group-hover:visible group-hover:opacity-100 absolute top-full left-1/2 -translate-x-1/2 pt-2 transition-all duration-200 z-50">
            <div class="dropdown-inner min-w-[180px] rounded-lg shadow-xl p-1.5">
              {item.children.map(child => (
                <a href={child.href} class="dropdown-link block px-4 py-2.5 text-[0.8125rem] font-medium rounded-md no-underline transition-colors duration-150">
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-3">

      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="theme-toggle-btn flex items-center justify-center w-9 h-9 rounded-[10px] bg-transparent border cursor-pointer transition-all duration-200"
        aria-label="Toggle dark/light mode"
        type="button"
      >
        <span class="material-symbols-outlined icon-dark-mode text-lg" aria-hidden="true">dark_mode</span>
        <span class="material-symbols-outlined icon-light-mode text-lg" aria-hidden="true">light_mode</span>
      </button>

      <!-- CTA -->
      <a href="#lead-gen" class="nav-cta btn-premium hidden lg:inline-flex items-center rounded-xl no-underline">
        Get in Touch
      </a>

      <!-- Mobile hamburger -->
      <button
        id="mobile-toggle"
        class="mobile-toggle flex md:hidden flex-col justify-center gap-[5px] w-10 h-10 bg-transparent border-none cursor-pointer p-2 z-10"
        aria-label="Open menu"
        aria-expanded="false"
        type="button"
      >
        <span class="hamburger-line block w-6 h-0.5 rounded-sm transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 rounded-sm transition-all duration-300"></span>
        <span class="hamburger-line block w-6 h-0.5 rounded-sm transition-all duration-300"></span>
      </button>
    </div>
  </div>

  <!-- Mobile overlay -->
  <div id="mobile-menu" class="mobile-menu fixed inset-0 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-[5]" aria-hidden="true">
    <nav class="flex flex-col items-center gap-5" aria-label="Mobile navigation">
      {mobileLinks.map(link => (
        <a href={link.href} class="mobile-link text-xl font-medium no-underline transition-colors duration-200">
          {link.label}
        </a>
      ))}
      <a href="#lead-gen" class="nav-cta-mobile btn-premium inline-flex items-center rounded-xl no-underline">
        Get in Touch
      </a>
    </nav>
  </div>
</header>

<style>
  /* ---- Nav shell ---- */
  #site-nav.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom-color: var(--border);
  }

  /* ---- Padding fixes (Tailwind v4 p/px/py classes broken) ---- */
  .nav-btn {
    padding: 0.5rem 0.75rem;
  }

  .nav-cta {
    padding: 0.625rem 1.25rem;
  }

  .nav-cta-mobile {
    padding: 0.75rem 2rem;
  }

  .dropdown-inner {
    padding: 0.375rem;
  }

  .dropdown-link {
    padding: 0.625rem 1rem;
  }

  .mobile-toggle {
    padding: 0.5rem;
  }

  /* ---- Logo ---- */
  .nav-logo-icon {
    font-size: 28px;
    font-variation-settings: 'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 28;
    color: var(--accent);
    transition: color 0.3s ease;
  }

  .nav-logo-text {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text-primary);
    transition: color 0.3s ease;
  }

  :global([data-theme="light"]) .nav-logo-icon {
    color: var(--accent);
  }

  :global([data-theme="light"]) .nav-logo-text {
    color: var(--text-primary);
  }

  /* ---- Desktop nav buttons ---- */
  .nav-btn {
    font-family: var(--font-headline);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    cursor: pointer;
    position: relative;
    transition: color 0.2s ease;
  }

  .nav-btn:hover {
    color: var(--text-primary);
  }

  .nav-btn-active {
    color: var(--accent) !important;
    border-bottom: 2px solid var(--accent);
  }

  /* ---- Dropdown panels ---- */
  .dropdown-panel {
    transform: translate(-50%, 4px);
  }

  .group:hover .dropdown-panel {
    transform: translate(-50%, 0);
  }

  .dropdown-inner {
    background: var(--glass-bg);
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
  }

  :global([data-theme="light"]) .dropdown-inner {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow), inset 0 1px 0 var(--glass-highlight);
  }

  .dropdown-link {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: all 0.15s ease;
  }

  .dropdown-link:hover {
    color: var(--text-primary);
    background: var(--surface-container-high);
    transform: translateX(2px);
  }

  /* ---- Theme toggle ---- */
  .theme-toggle-btn {
    border-color: var(--border);
    color: var(--text-secondary);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .theme-toggle-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent-glow);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: inherit;
  }

  .theme-toggle-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  .theme-toggle-btn:hover::before {
    opacity: 1;
  }

  .theme-toggle-btn:active {
    transform: scale(0.9);
  }

  /* Show dark_mode icon in dark, light_mode icon in light */
  .icon-light-mode {
    display: none;
  }

  :global([data-theme="light"]) .icon-dark-mode {
    display: none;
  }

  :global([data-theme="light"]) .icon-light-mode {
    display: inline-block;
  }

  /* ---- CTA button ---- */
  .nav-cta {
    font-family: var(--font-headline);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.625rem 1.25rem;
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    color: #ffffff;
    box-shadow: 0 2px 12px rgba(0, 229, 255, 0.3), 0 0 40px rgba(0, 229, 255, 0.08), inset 0 1px 0 rgba(255,255,255,0.2);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-cta-mobile {
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    color: #ffffff;
    box-shadow: 0 2px 12px rgba(0, 229, 255, 0.3), inset 0 1px 0 rgba(255,255,255,0.2);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-cta:hover,
  .nav-cta-mobile:hover {
    background: linear-gradient(135deg, #33ecff 0%, #00c4d4 50%, #007a8a 100%);
    box-shadow: 0 4px 20px rgba(0, 229, 255, 0.4), 0 0 60px rgba(0, 229, 255, 0.12), inset 0 1px 0 rgba(255,255,255,0.25);
    transform: translateY(-1px);
  }

  :global([data-theme="light"]) .nav-cta,
  :global([data-theme="light"]) .nav-cta-mobile {
    background: #00838f;
    color: #ffffff;
    box-shadow: 0 0 20px rgba(0, 131, 143, 0.2);
  }

  :global([data-theme="light"]) .nav-cta:hover,
  :global([data-theme="light"]) .nav-cta-mobile:hover {
    background: #00969e;
    box-shadow: 0 0 30px rgba(0, 131, 143, 0.3);
  }

  /* ---- Hamburger ---- */
  .hamburger-line {
    background: var(--text-primary);
  }

  .mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-toggle[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ---- Mobile overlay ---- */
  .mobile-menu {
    background: var(--bg-primary);
    backdrop-filter: blur(32px) saturate(1.8);
    -webkit-backdrop-filter: blur(32px) saturate(1.8);
    min-height: 100vh;
    min-height: 100dvh;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-link {
    color: var(--text-primary);
    opacity: 0;
    transform: translateY(12px);
    transition: color 0.2s ease, opacity 0.4s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu.open .mobile-link {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger mobile link entrances */
  .mobile-menu.open .mobile-link:nth-child(1) { transition-delay: 0.05s; }
  .mobile-menu.open .mobile-link:nth-child(2) { transition-delay: 0.1s; }
  .mobile-menu.open .mobile-link:nth-child(3) { transition-delay: 0.15s; }
  .mobile-menu.open .mobile-link:nth-child(4) { transition-delay: 0.2s; }
  .mobile-menu.open .mobile-link:nth-child(5) { transition-delay: 0.25s; }
  .mobile-menu.open .mobile-link:nth-child(6) { transition-delay: 0.3s; }
  .mobile-menu.open .mobile-link:nth-child(7) { transition-delay: 0.35s; }
  .mobile-menu.open .mobile-link:nth-child(8) { transition-delay: 0.4s; }
  .mobile-menu.open .mobile-link:nth-child(9) { transition-delay: 0.45s; }
  .mobile-menu.open .mobile-link:nth-child(10) { transition-delay: 0.5s; }
  .mobile-menu.open .mobile-link:nth-child(11) { transition-delay: 0.55s; }

  .nav-cta-mobile {
    opacity: 0;
    transform: translateY(12px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-menu.open .nav-cta-mobile {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.5s;
  }

  .mobile-link:hover {
    color: var(--accent);
  }
</style>

<script is:inline>
  (function () {
    var nav = document.getElementById('site-nav');
    var scrollThreshold = 50;

    /* --- Scroll: solid nav on scroll --- */
    function updateScroll() {
      if (window.scrollY > scrollThreshold) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }

    window.addEventListener('scroll', updateScroll, { passive: true });
    updateScroll();

    /* --- Theme toggle --- */
    var toggle = document.getElementById('theme-toggle');
    toggle.addEventListener('click', function () {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('jinki-theme', next);
      toggle.style.transform = 'rotate(180deg) scale(0.85)';
      setTimeout(function () {
        toggle.style.transform = '';
      }, 300);
    });

    /* --- Keyboard navigation for dropdown menus --- */
    var dropdownBtns = nav.querySelectorAll('.nav-btn');
    dropdownBtns.forEach(function (btn) {
      btn.addEventListener('keydown', function (e) {
        var panel = btn.parentElement.querySelector('.dropdown-panel');
        var links = panel ? panel.querySelectorAll('a') : [];
        if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown') {
          e.preventDefault();
          if (links.length) {
            panel.style.visibility = 'visible';
            panel.style.opacity = '1';
            links[0].focus();
          }
        }
        if (e.key === 'Escape') {
          panel.style.visibility = '';
          panel.style.opacity = '';
          btn.focus();
        }
      });

      var panel = btn.parentElement.querySelector('.dropdown-panel');
      if (panel) {
        var links = panel.querySelectorAll('a');
        links.forEach(function (link, idx) {
          link.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              if (idx < links.length - 1) links[idx + 1].focus();
            } else if (e.key === 'ArrowUp') {
              e.preventDefault();
              if (idx > 0) links[idx - 1].focus();
              else btn.focus();
            } else if (e.key === 'Escape') {
              panel.style.visibility = '';
              panel.style.opacity = '';
              btn.focus();
            }
          });
        });

        // Close dropdown when focus leaves
        btn.parentElement.addEventListener('focusout', function (e) {
          if (!btn.parentElement.contains(e.relatedTarget)) {
            panel.style.visibility = '';
            panel.style.opacity = '';
          }
        });
      }
    });

    /* --- Mobile menu --- */
    var mobileToggle = document.getElementById('mobile-toggle');
    var mobileMenu = document.getElementById('mobile-menu');

    mobileToggle.addEventListener('click', function () {
      var expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', !expanded);
      mobileMenu.classList.toggle('open');
      mobileMenu.setAttribute('aria-hidden', expanded);
      document.body.style.overflow = expanded ? '' : 'hidden';
    });

    // Close mobile menu on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && mobileToggle.getAttribute('aria-expanded') === 'true') {
        mobileToggle.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.remove('open');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        mobileToggle.focus();
      }
    });

    var mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(function (link) {
      link.addEventListener('click', function () {
        mobileToggle.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.remove('open');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  })();
</script>
