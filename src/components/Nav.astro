---
/*
  Nav.astro — Lightweight marketing nav
  Logo, links, verticals dropdown, theme toggle, CTA
*/

const verticals = [
  { href: '/verticals/data-centers', label: 'Data Centers', color: '#00E5FF' },
  { href: '/verticals/energy-grid', label: 'Energy Grid', color: '#FF8C00' },
  { href: '/verticals/security', label: 'Security', color: '#7B61FF' },
  { href: '/verticals/agriculture', label: 'Agriculture', color: '#34D399' },
];

const services = [
  { href: '/services/intelligence-scan', label: 'Facility Intelligence Scan' },
  { href: '/services/deployment', label: 'Autonomous Deployment' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
function isActive(href: string) {
  const clean = href.replace(/\/$/, '') || '/';
  return currentPath === clean || currentPath.startsWith(clean + '/');
}
function isDropdownActive(items: { href: string }[]) {
  return items.some(item => isActive(item.href));
}
---

<header id="site-nav" class="site-nav" style="position:fixed;top:0;left:0;right:0;z-index:1000;padding:12px 24px;view-transition-name:site-nav;">
  <nav class="nav-inner" style="max-width: var(--container-max);margin:0 auto;display:flex;align-items:center;justify-content:space-between;background:var(--glass-bg);border:1px solid var(--glass-border);border-radius:16px;padding:12px 20px;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);transition:box-shadow .3s,background .3s;" aria-label="Main navigation">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Jinki — Home" style="display:flex;align-items:center;gap:8px;text-decoration:none;color:var(--text-primary);flex-shrink:0;">
      <svg class="jinki-mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true" style="display:block;flex-shrink:0;">
        <!-- Center ping dot -->
        <circle class="mark-ping" cx="16" cy="16" r="2.5" fill="#00E5FF"/>
        <!-- Scanning arcs -->
        <path class="mark-arc mark-arc-1" d="M 16 8 A 8 8 0 1 1 8.5 20" stroke="#00E5FF" stroke-width="2" fill="none" stroke-linecap="round"/>
        <path class="mark-arc mark-arc-2" d="M 22 4.5 A 14 14 0 0 1 22 27.5" stroke="#00E5FF" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path class="mark-arc mark-arc-3" d="M 9 2 A 18 18 0 0 1 29 20" stroke="#00E5FF" stroke-width="1" fill="none" stroke-linecap="round"/>
        <!-- Sweep line (radar) -->
        <line class="mark-sweep" x1="16" y1="16" x2="16" y2="2" stroke="#00E5FF" stroke-width="0.8" stroke-linecap="round" opacity="0.4"/>
      </svg>
      <span style="font-family:var(--font-headline);font-weight:700;font-size:18px;letter-spacing:-0.02em;">Jinki</span>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links" style="display:flex;align-items:center;gap:4px;list-style:none;margin:0;padding:0;">
      <!-- Verticals dropdown -->
      <li class="dropdown" style="position:relative;">
        <button class={`nav-link dropdown-trigger${isDropdownActive(verticals) ? ' nav-link-active' : ''}`} aria-expanded="false" aria-haspopup="menu" style="display:flex;align-items:center;gap:4px;">
          Verticals
          <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;transition:transform .25s;">expand_more</span>
        </button>
        <div class="dropdown-panel" role="menu" aria-label="Industry verticals" style="position:absolute;top:calc(100% + 8px);left:50%;transform:translateX(-50%);min-width:200px;background:var(--surface-container);border:1px solid var(--glass-border);border-radius:12px;padding:8px;transition:opacity .2s,visibility .2s;box-shadow:0 8px 32px rgba(0,0,0,.3);">
          {verticals.map(v => (
            <a href={v.href} class={`dropdown-item${isActive(v.href) ? ' dropdown-item-active' : ''}`} role="menuitem" aria-current={isActive(v.href) ? 'page' : undefined} style={`display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:8px;text-decoration:none;color:var(--text-primary);font-family:var(--font-label);font-size:14px;transition:background .15s;`}>
              <span class="dot" style={`width:8px;height:8px;border-radius:50%;background:${v.color};flex-shrink:0;`} aria-hidden="true"></span>
              {v.label}
            </a>
          ))}
        </div>
      </li>

      <!-- Services dropdown -->
      <li class="dropdown" style="position:relative;">
        <button class={`nav-link dropdown-trigger${isDropdownActive(services) ? ' nav-link-active' : ''}`} aria-expanded="false" aria-haspopup="menu" style="display:flex;align-items:center;gap:4px;">
          Services
          <span class="material-symbols-outlined" aria-hidden="true" style="font-size:16px;transition:transform .25s;">expand_more</span>
        </button>
        <div class="dropdown-panel" role="menu" aria-label="Services" style="position:absolute;top:calc(100% + 8px);left:50%;transform:translateX(-50%);min-width:200px;background:var(--surface-container);border:1px solid var(--glass-border);border-radius:12px;padding:8px;transition:opacity .2s,visibility .2s;box-shadow:0 8px 32px rgba(0,0,0,.3);">
          {services.map(s => (
            <a href={s.href} class={`dropdown-item${isActive(s.href) ? ' dropdown-item-active' : ''}`} role="menuitem" aria-current={isActive(s.href) ? 'page' : undefined} style={`display:flex;align-items:center;gap:12px;padding:12px 16px;border-radius:8px;text-decoration:none;color:var(--text-primary);font-family:var(--font-label);font-size:14px;transition:background .15s;`}>
              {s.label}
            </a>
          ))}
        </div>
      </li>

      <li><a href="/about" class={`nav-link${isActive('/about') ? ' nav-link-active' : ''}`} aria-current={isActive('/about') ? 'page' : undefined}>About</a></li>
      <li><a href="/security" class={`nav-link${isActive('/security') ? ' nav-link-active' : ''}`} aria-current={isActive('/security') ? 'page' : undefined}>Security</a></li>
      <li><a href="/data-security" class={`nav-link${isActive('/data-security') ? ' nav-link-active' : ''}`} aria-current={isActive('/data-security') ? 'page' : undefined}>Data Security</a></li>
      <li><a href="/blog" class={`nav-link${isActive('/blog') ? ' nav-link-active' : ''}`} aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a></li>
    </ul>

    <!-- Right side: theme toggle + CTA -->
    <div style="display:flex;align-items:center;gap:12px;flex-shrink:0;">
      <button id="theme-toggle" class="theme-btn" aria-label="Toggle theme" style="background:none;border:1px solid var(--glass-border);border-radius:12px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--text-secondary);transition:color .2s,border-color .2s;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:20px;">dark_mode</span>
      </button>
      <a href="#lead-gen" class="nav-cta" style="display:inline-flex;align-items:center;font-family:var(--font-label);font-size:14px;font-weight:600;padding:8px 18px;border-radius:12px;background:var(--accent);color:var(--text-on-accent);text-decoration:none;white-space:nowrap;transition:opacity .2s;">Request Assessment</a>

      <!-- Mobile hamburger -->
      <button id="mobile-toggle" class="mobile-toggle" aria-label="Open menu" aria-expanded="false" style="display:none;background:none;border:none;cursor:pointer;color:var(--text-primary);padding:8px;min-width:44px;min-height:44px;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:26px;">menu</span>
      </button>
    </div>
  </nav>

  <!-- Mobile slide-out panel -->
  <div id="mobile-panel" class="mobile-panel" aria-hidden="true">
    <div class="mobile-panel-inner" style="display:flex;flex-direction:column;gap:4px;padding:20px;">
      <div class="mobile-section-label" style="font-family:var(--font-label);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);padding:16px 16px 8px;">Verticals</div>
      {verticals.map(v => (
        <a href={v.href} class={`mobile-link${isActive(v.href) ? ' mobile-link-active' : ''}`} aria-current={isActive(v.href) ? 'page' : undefined} style="display:flex;align-items:center;gap:12px;">
          <span style={`width:8px;height:8px;border-radius:50%;background:${v.color};flex-shrink:0;`}></span>
          {v.label}
        </a>
      ))}

      <div class="mobile-section-label" style="font-family:var(--font-label);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-secondary);padding:16px 16px 8px;">Services</div>
      {services.map(s => (
        <a href={s.href} class={`mobile-link${isActive(s.href) ? ' mobile-link-active' : ''}`} aria-current={isActive(s.href) ? 'page' : undefined}>{s.label}</a>
      ))}

      <div style="border-top:1px solid var(--glass-border);margin:12px 0;"></div>
      <a href="/about" class={`mobile-link${isActive('/about') ? ' mobile-link-active' : ''}`} aria-current={isActive('/about') ? 'page' : undefined}>About</a>
      <a href="/careers" class={`mobile-link${isActive('/careers') ? ' mobile-link-active' : ''}`} aria-current={isActive('/careers') ? 'page' : undefined}>Careers</a>
      <a href="/security" class={`mobile-link${isActive('/security') ? ' mobile-link-active' : ''}`} aria-current={isActive('/security') ? 'page' : undefined}>Security</a>
      <a href="/data-security" class={`mobile-link${isActive('/data-security') ? ' mobile-link-active' : ''}`} aria-current={isActive('/data-security') ? 'page' : undefined}>Data Security</a>
      <a href="/blog" class={`mobile-link${isActive('/blog') ? ' mobile-link-active' : ''}`} aria-current={isActive('/blog') ? 'page' : undefined}>Blog</a>

      <a href="#lead-gen" class="mobile-cta" style="display:block;text-align:center;margin-top:16px;font-family:var(--font-label);font-size:15px;font-weight:600;padding:16px;border-radius:12px;background:var(--accent);color:var(--text-on-accent);text-decoration:none;">Request Assessment</a>

      <div style="border-top:1px solid var(--glass-border);margin:16px 0 8px;"></div>
      <button id="mobile-theme-toggle" class="mobile-link" style="display:flex;align-items:center;gap:12px;width:100%;background:none;border:none;cursor:pointer;color:var(--text-primary);font-family:var(--font-body);font-size:15px;" aria-label="Toggle theme">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size:20px;">dark_mode</span>
        <span class="mobile-theme-label">Dark mode</span>
      </button>
    </div>
  </div>

  <!-- Mobile backdrop -->
  <div id="mobile-backdrop" class="mobile-backdrop"></div>
</header>

<!-- Spacer to prevent content from hiding behind fixed nav -->
<div style="height:72px;" aria-hidden="true"></div>

<style>
  /* Nav link base */
  .nav-link {
    font-family: var(--font-label);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 8px 16px;
    border-radius: 8px;
    transition: color 0.2s, background 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.06);
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 20%;
    width: 60%;
    height: 1.5px;
    background: var(--accent);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    border-radius: 1px;
  }
  .nav-link:hover::after,
  .nav-link-active::after {
    transform: scaleX(1);
  }
  .nav-link-active {
    color: var(--text-primary);
  }
  .nav-link {
    position: relative;
  }
  :global([data-theme="light"]) .nav-link:hover {
    background: rgba(0,0,0,0.05);
  }

  /* Active dropdown item */
  .dropdown-item-active {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  /* Active mobile link */
  .mobile-link-active {
    color: var(--accent) !important;
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* Dropdown default hidden */
  .dropdown-panel {
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(8px) scale(0.97);
    transition: opacity 0.3s var(--ease-out-premium),
                visibility 0.3s var(--ease-out-premium),
                transform 0.3s var(--ease-out-premium);
  }

  /* Dropdown item stagger */
  .dropdown-item {
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;
  }
  .dropdown-item:nth-child(1) { transition-delay: 0s; }
  .dropdown-item:nth-child(2) { transition-delay: 0.03s; }
  .dropdown-item:nth-child(3) { transition-delay: 0.06s; }
  .dropdown-item:nth-child(4) { transition-delay: 0.09s; }
  .dropdown-item:nth-child(5) { transition-delay: 0.12s; }

  /* Dropdown open state */
  .dropdown:hover .dropdown-panel,
  .dropdown.open .dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .dropdown:hover .dropdown-item,
  .dropdown.open .dropdown-item {
    opacity: 1;
    transform: translateY(0);
  }
  .dropdown:hover .dropdown-trigger span.material-symbols-outlined,
  .dropdown.open .dropdown-trigger span.material-symbols-outlined {
    transform: rotate(180deg);
  }

  .dropdown-item {
    position: relative;
    transition: background 0.2s ease, padding-left 0.2s ease;
  }
  .dropdown-item:hover {
    background: rgba(255,255,255,0.06);
    padding-left: 18px;
  }
  .dropdown-item:hover::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 16px;
    background: var(--accent);
    border-radius: 1px;
  }
  :global([data-theme="light"]) .dropdown-item:hover {
    background: rgba(0,0,0,0.06);
    color: var(--text-primary);
  }

  /* Theme button hover */
  .theme-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent);
  }

  /* CTA hover */
  .nav-cta {
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 30%, transparent);
    opacity: 0.95;
  }
  .nav-cta:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  /* === Active scanning logo === */
  .jinki-mark { overflow: visible; }

  /* Center dot ping */
  .mark-ping {
    animation: markPing 3s ease-in-out infinite;
  }
  @keyframes markPing {
    0%, 100% { r: 2.5; opacity: 1; filter: drop-shadow(0 0 2px #00E5FF); }
    50% { r: 3; opacity: 0.8; filter: drop-shadow(0 0 6px #00E5FF); }
  }

  /* Arcs pulse outward sequentially with staggered boot */
  .mark-arc-1 {
    opacity: 0;
    animation: arcBoot 0.6s ease-out 0.2s forwards, arcPulse1 4s ease-in-out 0.8s infinite;
  }
  .mark-arc-2 {
    opacity: 0;
    animation: arcBoot 0.6s ease-out 0.5s forwards, arcPulse2 4s ease-in-out 1.1s infinite;
  }
  .mark-arc-3 {
    opacity: 0;
    animation: arcBoot 0.6s ease-out 0.8s forwards, arcPulse3 4s ease-in-out 1.4s infinite;
  }
  @keyframes arcBoot {
    from { opacity: 0; stroke-dasharray: 0 200; }
    to { opacity: 1; stroke-dasharray: 200 0; }
  }
  @keyframes arcPulse1 {
    0%, 100% { opacity: 0.5; }
    25% { opacity: 1; }
    75% { opacity: 0.5; }
  }
  @keyframes arcPulse2 {
    0%, 100% { opacity: 0.2; }
    40% { opacity: 0.7; }
    80% { opacity: 0.2; }
  }
  @keyframes arcPulse3 {
    0%, 100% { opacity: 0.08; }
    55% { opacity: 0.45; }
    85% { opacity: 0.08; }
  }

  /* Radar sweep line rotation */
  .mark-sweep {
    transform-origin: 16px 16px;
    animation: radarSweep 3s linear infinite;
  }
  @keyframes radarSweep {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .mark-ping, .mark-arc-1, .mark-arc-2, .mark-arc-3, .mark-sweep {
      animation: none;
    }
    .mark-arc-1 { opacity: 0.9; }
    .mark-arc-2 { opacity: 0.5; }
    .mark-arc-3 { opacity: 0.25; }
    .mark-sweep { opacity: 0; }
  }

  /* Light mode: darken logo arcs for visibility on white */
  :global([data-theme="light"]) .jinki-mark circle,
  :global([data-theme="light"]) .jinki-mark path,
  :global([data-theme="light"]) .jinki-mark line {
    stroke: #0891b2;
    fill: #0891b2;
  }
  :global([data-theme="light"]) .mark-arc-2 { stroke: #0891b2; }
  :global([data-theme="light"]) .mark-arc-3 { stroke: #0891b2; }
  :global([data-theme="light"]) .mark-sweep { stroke: #0891b2; }

  /* Logo icon hover */
  .nav-logo:hover .material-symbols-outlined {
    transform: rotate(20deg);
  }

  /* Scrolled state — applied by JS */
  .nav-inner.scrolled {
    box-shadow: 0 4px 24px rgba(0,0,0,0.25), 0 1px 0 rgba(200,220,230,0.05) inset;
    backdrop-filter: blur(12px) saturate(1.3);
    -webkit-backdrop-filter: blur(12px) saturate(1.3);
    background: rgba(18, 20, 22, 0.92);
    border-image: linear-gradient(
      to right,
      transparent,
      color-mix(in srgb, var(--accent) 25%, transparent) 30%,
      color-mix(in srgb, var(--accent) 40%, transparent) 50%,
      color-mix(in srgb, var(--accent) 25%, transparent) 70%,
      transparent
    ) 1 / 0 0 1px 0;
  }
  :global([data-theme="light"]) .nav-inner.scrolled {
    background: rgba(250, 251, 252, 0.95);
    border-color: rgba(0,0,0,0.08);
    box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 1px 0 rgba(0,0,0,0.04);
    border-image: linear-gradient(
      to right,
      transparent,
      rgba(8, 145, 178, 0.2) 30%,
      rgba(8, 145, 178, 0.35) 50%,
      rgba(8, 145, 178, 0.2) 70%,
      transparent
    ) 1 / 0 0 1px 0;
  }

  /* CTA shimmer sweep */
  .nav-cta {
    position: relative;
    overflow: hidden;
  }
  .nav-cta::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 80%
    );
    animation: ctaShimmer 4s ease-in-out infinite;
  }
  @keyframes ctaShimmer {
    0%, 85%, 100% { left: -100%; opacity: 0; }
    88% { opacity: 1; }
    95% { left: 150%; opacity: 1; }
    96% { opacity: 0; }
  }

  /* ---- Mobile ---- */
  .mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 300px;
    max-width: 85vw;
    background: var(--surface-container);
    border-left: 1px solid var(--glass-border);
    z-index: 1001;
    transform: translateX(100%);
    transition: transform 0.3s ease;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    contain: layout;
    visibility: hidden;
    pointer-events: none;
  }
  .mobile-panel.open {
    transform: translateX(0);
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
  }
  .mobile-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-link {
    font-family: var(--font-label);
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    padding: 16px 16px;
    border-radius: 12px;
    transition: background 0.15s;
    min-height: 44px;
    display: flex;
    align-items: center;
  }
  .mobile-link:hover,
  .mobile-link:active {
    background: rgba(255,255,255,0.06);
  }
  :global([data-theme="light"]) .mobile-link:hover,
  :global([data-theme="light"]) .mobile-link:active {
    background: rgba(0,0,0,0.05);
  }

  /* ---- Responsive ---- */
  @media (max-width: 767px) {
    .nav-links {
      display: none !important;
    }
    .nav-cta {
      display: none !important;
    }
    .mobile-toggle {
      display: flex !important;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .nav-inner,
    .mobile-panel,
    .mobile-backdrop,
    .nav-link,
    .dropdown-panel,
    .dropdown-item,
    .theme-btn,
    .nav-cta,
    .nav-logo .material-symbols-outlined {
      transition: none !important;
    }
    .nav-cta::before {
      animation: none;
      display: none;
    }
  }
</style>

<script>
  (function () {
    var html = document.documentElement;
    var nav = document.querySelector('.nav-inner');
    var themeToggle = document.getElementById('theme-toggle');
    var themeIcon = themeToggle?.querySelector('.material-symbols-outlined');
    var mobileThemeToggle = document.getElementById('mobile-theme-toggle');
    var mobileThemeIcon = mobileThemeToggle?.querySelector('.material-symbols-outlined');
    var mobileThemeLabel = mobileThemeToggle?.querySelector('.mobile-theme-label');
    var mobileToggle = document.getElementById('mobile-toggle');
    var mobilePanel = document.getElementById('mobile-panel');
    var backdrop = document.getElementById('mobile-backdrop');

    /* ---- Scroll shadow ---- */
    var lastScroll = 0;
    function onScroll() {
      var y = window.scrollY;
      if (y > 20) {
        nav?.classList.add('scrolled');
      } else {
        nav?.classList.remove('scrolled');
      }
      lastScroll = y;
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* ---- Theme toggle ---- */
    function syncIcon() {
      var theme = html.getAttribute('data-theme') || 'dark';
      if (themeIcon) themeIcon.textContent = theme === 'dark' ? 'dark_mode' : 'light_mode';
      themeToggle?.setAttribute('aria-label', theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
      themeToggle?.setAttribute('aria-pressed', theme === 'light' ? 'true' : 'false');
      if (mobileThemeIcon) mobileThemeIcon.textContent = theme === 'dark' ? 'dark_mode' : 'light_mode';
      if (mobileThemeLabel) mobileThemeLabel.textContent = theme === 'dark' ? 'Dark mode' : 'Light mode';
    }
    syncIcon();

    function toggleTheme() {
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      try { localStorage.setItem('jinki-theme', next); } catch(e) {}
      syncIcon();
    }

    themeToggle?.addEventListener('click', toggleTheme);
    mobileThemeToggle?.addEventListener('click', toggleTheme);

    /* ---- Mobile menu ---- */
    function openMobile() {
      mobilePanel?.classList.add('open');
      mobilePanel?.setAttribute('aria-hidden', 'false');
      backdrop?.classList.add('open');
      mobileToggle?.setAttribute('aria-expanded', 'true');
      var icon = mobileToggle?.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = 'close';
      document.body.style.overflow = 'hidden';
      // Focus first link for keyboard users
      var firstLink = mobilePanel?.querySelector('a');
      if (firstLink) setTimeout(function() { firstLink.focus(); }, 100);
    }

    function closeMobile() {
      mobilePanel?.classList.remove('open');
      mobilePanel?.setAttribute('aria-hidden', 'true');
      backdrop?.classList.remove('open');
      mobileToggle?.setAttribute('aria-expanded', 'false');
      var icon = mobileToggle?.querySelector('.material-symbols-outlined');
      if (icon) icon.textContent = 'menu';
      document.body.style.overflow = '';
      // Return focus to toggle button
      mobileToggle?.focus();
    }

    mobileToggle?.addEventListener('click', function () {
      var isOpen = mobilePanel?.classList.contains('open');
      isOpen ? closeMobile() : openMobile();
    });

    backdrop?.addEventListener('click', closeMobile);

    /* Close mobile menu on link click */
    mobilePanel?.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', closeMobile);
    });

    /* Close mobile menu on Escape + focus trap */
    document.addEventListener('keydown', function (e) {
      if (!mobilePanel?.classList.contains('open')) return;
      if (e.key === 'Escape') { closeMobile(); return; }
      if (e.key === 'Tab') {
        var focusable = mobilePanel.querySelectorAll('a, button');
        if (!focusable.length) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault(); last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault(); first.focus();
        }
      }
    });

    /* ---- Dropdown keyboard support ---- */
    document.querySelectorAll('.dropdown-trigger').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        var parent = btn.closest('.dropdown');
        if (!parent) return;
        var isOpen = parent.classList.contains('open');
        /* close all */
        document.querySelectorAll('.dropdown').forEach(function (d) { d.classList.remove('open'); });
        if (!isOpen) parent.classList.add('open');
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    /* Arrow key navigation within dropdown menus */
    document.querySelectorAll('.dropdown-trigger').forEach(function (btn) {
      btn.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowDown' || e.key === 'Enter' || e.key === ' ') {
          var parent = btn.closest('.dropdown');
          if (!parent) return;
          if (!parent.classList.contains('open')) {
            document.querySelectorAll('.dropdown').forEach(function (d) { d.classList.remove('open'); });
            parent.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
          }
          if (e.key === 'ArrowDown') {
            e.preventDefault();
            var items = parent.querySelectorAll('[role="menuitem"]');
            if (items.length) items[0].focus();
          }
        }
        if (e.key === 'Escape') {
          var p = btn.closest('.dropdown');
          if (p) { p.classList.remove('open'); btn.setAttribute('aria-expanded', 'false'); }
        }
      });
    });

    document.querySelectorAll('.dropdown-panel').forEach(function (panel) {
      panel.addEventListener('keydown', function (e) {
        var items = Array.from(panel.querySelectorAll('[role="menuitem"]'));
        var idx = items.indexOf(document.activeElement);
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          var next = idx < items.length - 1 ? idx + 1 : 0;
          items[next].focus();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          var prev = idx > 0 ? idx - 1 : items.length - 1;
          items[prev].focus();
        } else if (e.key === 'Home') {
          e.preventDefault();
          items[0]?.focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          items[items.length - 1]?.focus();
        } else if (e.key === 'Escape') {
          var dropdown = panel.closest('.dropdown');
          var trigger = dropdown?.querySelector('.dropdown-trigger');
          if (dropdown) dropdown.classList.remove('open');
          if (trigger) { trigger.setAttribute('aria-expanded', 'false'); trigger.focus(); }
        } else if (e.key === 'Tab') {
          var dropdown = panel.closest('.dropdown');
          var trigger = dropdown?.querySelector('.dropdown-trigger');
          if (dropdown) dropdown.classList.remove('open');
          if (trigger) trigger.setAttribute('aria-expanded', 'false');
        }
      });
    });

    /* Close dropdowns on outside click */
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.dropdown')) {
        document.querySelectorAll('.dropdown').forEach(function (d) {
          d.classList.remove('open');
          var btn = d.querySelector('.dropdown-trigger');
          btn?.setAttribute('aria-expanded', 'false');
        });
      }
    });
  })();
</script>
