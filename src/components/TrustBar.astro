---
/*
  TrustBar — Thin social proof strip between Hero and Verticals.
  Shows key differentiators with icons.
*/
const signals = [
  { icon: 'precision_manufacturing', text: 'FAA Part 107 Certified' },
  { icon: 'shield', text: 'SOC 2 Compliant' },
  { icon: 'speed', text: '< 24hr Deployment' },
  { icon: 'trending_down', text: '60% Lower Inspection Costs' },
];
---

<div class="trust-bar reveal" aria-label="Trust signals">
  <div class="trust-inner">
    {signals.map(s => (
      <div class="trust-item">
        <span class="material-symbols-outlined trust-icon" aria-hidden="true">{s.icon}</span>
        <span class="trust-text">{s.text}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .trust-bar {
    background: var(--surface-container);
    padding: 1.25rem 1.5rem;
    overflow: hidden;
    border-top: 1px solid var(--glass-border);
    border-bottom: 1px solid var(--glass-border);
    position: relative;
  }

  .trust-bar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--glossy-shine);
    pointer-events: none;
  }

  .trust-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem 3rem;
    flex-wrap: wrap;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    transition: background 0.3s ease, transform 0.3s ease;
    cursor: default;
  }

  .trust-item:hover {
    background: var(--accent-glow);
    transform: translateY(-1px);
  }

  .trust-item:hover .trust-icon {
    text-shadow: 0 0 12px var(--accent-glow-strong);
  }

  .trust-icon {
    font-size: 1.125rem;
    color: var(--accent);
    font-variation-settings: 'FILL' 1;
    transition: text-shadow 0.3s ease;
  }

  .trust-text {
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  /* Mobile: 2-column */
  @media (max-width: 767px) {
    .trust-inner {
      gap: 1rem 2rem;
      justify-content: center;
    }
  }

</style>
