---
const outcomes = [
  {
    icon: "speed",
    headline: "From Data to Decisions in 48 Hours",
    description: "Traditional inspections take weeks and deliver raw data. Jinki delivers a prioritized action plan — severity-ranked with clear next steps, ready for your next maintenance window.",
    stat: "48hr",
    statLabel: "data to decisions",
  },
  {
    icon: "visibility",
    headline: "Total Coverage Without Total Headcount",
    description: "One aerial platform covers what would require multiple crew members and extended site access. No scaffolding, no roof access, no operational disruption. Your team stays focused on operations.",
    stat: "Zero",
    statLabel: "roof access needed",
  },
  {
    icon: "trending_up",
    headline: "Catch Degradation Before It Becomes Downtime",
    description: "Autonomous recurring missions build thermal baselines over time. Our AI flags degradation velocity — so you fix what's failing, not just what's failed.",
    stat: "200+",
    statLabel: "autonomous missions per month",
  },
];

const trustBadges = [
  { icon: 'flight_takeoff', label: 'FAA Part 107', full: 'FAA Remote Pilot Certificate — Part 107' },
  { icon: 'radar', label: 'DC SFRA Trained', full: 'Washington DC Special Flight Rules Area Certified' },
  { icon: 'verified_user', label: '$5M Liability Coverage', full: '$5M Commercial Liability Insurance Per Operation' },
  { icon: 'lock', label: 'End-to-End Encrypted', full: 'AES-256 End-to-End Data Encryption' },
  { icon: 'health_and_safety', label: 'OSHA Compliant', full: 'OSHA Workplace Safety Standards Compliant' },
  { icon: 'shield', label: 'NDA by Default', full: 'Non-Disclosure Agreement Included With Every Engagement' },
];
---

<section class="trust-bar" aria-label="Why teams choose Jinki">

  <!-- Stats Bar -->
  <div class="trust-counters reveal-curtain">
    <div class="trust-counters-grid reveal-stagger">
      <div class="trust-counter">
        <span class="trust-counter-val">0.5°C</span>
        <span class="trust-counter-lbl">Thermal Accuracy</span>
      </div>
      <div class="trust-counter">
        <span class="trust-counter-val">50+ mi</span>
        <span class="trust-counter-lbl">Daily Corridor Range</span>
      </div>
      <div class="trust-counter">
        <span class="trust-counter-val">48hr</span>
        <span class="trust-counter-lbl">Report Turnaround</span>
      </div>
      <div class="trust-counter">
        <span class="trust-counter-val">200/mo</span>
        <span class="trust-counter-lbl">Autonomous Missions</span>
      </div>
    </div>
  </div>

  <!-- Industry insight — domain expertise proof -->
  <div class="trust-insight reveal">
    <p class="trust-quote">
      <span class="quote-mark quote-open" aria-hidden="true">&ldquo;</span>
      73% of cooling system failures show detectable thermal signatures weeks before catastrophic failure.
      <span class="quote-mark quote-close" aria-hidden="true">&rdquo;</span>
      <span class="trust-quote-source">— ASHRAE / Uptime Institute Research</span>
    </p>
  </div>

  <!-- Certifications — distinct elevated band -->
  <div class="trust-certs reveal">
    <div class="trust-certs-inner">
      <div class="trust-certs-heading">
        <span class="material-symbols-outlined trust-certs-icon" aria-hidden="true">verified</span>
        <span class="trust-certs-label">Certifications & Standards</span>
      </div>
      <div class="cert-divider" aria-hidden="true"></div>
      <div class="badges-row">
        {trustBadges.map((b) => (
          <div class="badge-chip" data-tooltip={b.full}>
            <span class="material-symbols-outlined badge-chip-icon" aria-hidden="true">{b.icon}</span>
            <span class="badge-chip-label">{b.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Market Position -->
  <div class="trust-position reveal">
    <div class="trust-position-inner">
      <span class="material-symbols-outlined trust-position-icon" aria-hidden="true">hub</span>
      <div class="trust-position-content">
        <h3 class="trust-position-title">First and Only</h3>
        <p class="trust-position-desc">No aerial intelligence provider focuses on data center operations as a primary vertical. Purpose-built for the world's largest data center market.</p>
        <span class="trust-position-source">Northern Virginia — 70%+ of global internet traffic</span>
      </div>
    </div>
  </div>

  <!-- Business Outcomes — Wharton-grade positioning -->
  <div class="trust-outcomes reveal">
    <h2 class="trust-outcomes-title">Why Operations Teams Choose Jinki</h2>
    <p class="trust-outcomes-subtitle">Clear priorities. Honest timelines. Recommendations your team can execute the same week.</p>
    <div class="outcomes-grid">
      {outcomes.map((o) => (
        <div class="outcome-card">
          <div class="outcome-icon-row">
            <span class="material-symbols-outlined outcome-card-icon" aria-hidden="true">{o.icon}</span>
            <div class="outcome-stat-pill">
              <span class="outcome-stat-val">{o.stat}</span>
              <span class="outcome-stat-lbl">{o.statLabel}</span>
            </div>
          </div>
          <h3 class="outcome-card-title">{o.headline}</h3>
          <p class="outcome-desc">{o.description}</p>
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .trust-bar {
    display: flex;
    flex-direction: column;
    padding: 5rem 0;
  }
  @media (min-width: 768px) { .trust-bar { padding: 8rem 0; } }

  /* --- Stats bar --- */
  .trust-counters {
    padding: 96px 24px;
    border-bottom: 1px solid var(--glass-border);
  }

  .trust-counters-grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .trust-counter {
    text-align: center;
  }

  .trust-counter-val {
    display: block;
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .trust-counter-lbl {
    display: block;
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    margin-top: 8px;
  }

  /* --- Industry insight --- */
  .trust-insight {
    text-align: center;
    padding: 24px 24px 0;
    max-width: 700px;
    margin: 0 auto;
  }

  .trust-quote {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-style: italic;
    color: var(--text-tertiary);
    line-height: 1.6;
    position: relative;
  }

  .trust-quote-source {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
    display: block;
    margin-top: 8px;
    font-style: normal;
  }

  /* --- Certifications band --- */
  .trust-certs {
    padding: 32px 24px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 3%, transparent) 0%, color-mix(in srgb, var(--accent) 1%, transparent) 100%);
    border-top: 1px solid color-mix(in srgb, var(--accent) 10%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .trust-certs-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px 32px;
  }

  .trust-certs-heading {
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
  }

  .trust-certs-icon {
    font-size: 1.125rem;
    color: var(--accent);
    font-variation-settings: 'FILL' 1;
  }

  .trust-certs-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .cert-divider {
    width: 1px;
    height: 24px;
    background: color-mix(in srgb, var(--accent) 15%, transparent);
  }

  .badge-chip-icon {
    font-size: 1rem;
    color: var(--accent);
    font-variation-settings: 'FILL' 1;
  }

  .badge-chip-label {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-primary);
  }

  /* --- Market position --- */
  .trust-position {
    padding: 48px 24px;
    border-bottom: 1px solid var(--glass-border);
  }
  .trust-position-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 20px;
    padding: 28px 32px;
    border-radius: 16px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
  }
  .trust-position-icon {
    font-size: 28px;
    color: var(--accent);
    font-variation-settings: 'FILL' 1;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .trust-position-title {
    font-family: var(--font-headline);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 8px;
  }
  .trust-position-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }
  .trust-position-source {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }
  @media (max-width: 767px) {
    .trust-position-inner { flex-direction: column; gap: 12px; padding: 24px 20px; }
  }

  /* --- Business outcomes --- */
  .trust-outcomes {
    padding: 96px 24px;
  }

  .trust-outcomes-title {
    font-family: var(--font-headline);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .trust-outcomes-subtitle {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    text-align: center;
    margin-bottom: 56px;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }

  .outcome-card-icon {
    font-size: 1.5rem;
    color: var(--accent);
    font-variation-settings: 'FILL' 1;
  }

  .outcome-card-title {
    font-family: var(--font-headline);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .badges-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 12px;
  }

  .badge-chip {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(8px);
    transition: border-color 0.25s ease, background 0.25s ease, transform 0.3s var(--ease-out-premium), box-shadow 0.3s ease;
  }
  .badge-chip:hover {
    border-color: color-mix(in srgb, var(--accent) 25%, transparent);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    transform: scale(1.02);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--accent) 10%, transparent), 0 0 20px color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .outcomes-grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .outcome-card {
    padding: 32px 24px;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.4s var(--ease-out-premium), transform 0.4s var(--ease-out-premium);
  }
  .outcome-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent 5%, var(--accent) 50%, transparent 95%);
    opacity: 0;
    transform: scaleX(0.3);
    transition: opacity 0.4s ease, transform 0.4s var(--ease-out-premium);
  }
  .outcome-card:hover::before {
    opacity: 0.8;
    transform: scaleX(1);
  }
  .outcome-card:hover {
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 30px color-mix(in srgb, var(--accent) 5%, transparent);
    transform: translateY(-4px);
  }

  .outcome-icon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .outcome-stat-pill {
    display: flex;
    align-items: baseline;
    gap: 4px;
    padding: 4px 12px;
    background: var(--accent-glow);
    border-radius: 9999px;
  }

  .outcome-stat-val {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
  }

  .outcome-stat-lbl {
    font-family: var(--font-label);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }

  .outcome-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  @media (max-width: 1023px) {
    .outcomes-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
    }
    .trust-counters-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .cert-divider { display: none; }
  }

  @media (max-width: 767px) {
    .trust-counters {
      padding: 2.5rem 16px;
    }
    .trust-outcomes {
      padding: 2.5rem 16px;
    }
    .trust-counters-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    .trust-outcomes-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }
    .trust-outcomes-subtitle {
      margin-bottom: 2rem;
      font-size: 0.875rem;
    }
    .outcome-card {
      padding: 1.25rem 1rem;
    }
    .trust-insight {
      padding: 16px 16px 0;
    }
    .trust-quote {
      font-size: 0.85rem;
    }
    .badges-row {
      gap: 8px;
      justify-content: center;
    }
    .badge-chip {
      padding: 10px 14px;
      min-height: 44px;
    }
    .trust-certs-inner {
      flex-direction: column;
      text-align: center;
    }
    .trust-counter-val {
      font-size: 1.5rem;
    }
    .trust-certs {
      padding: 20px 16px;
    }
  }

  /* === Decorative gradient quotation marks === */
  .quote-mark {
    font-family: var(--font-headline);
    font-size: 2.5rem;
    font-weight: 700;
    font-style: normal;
    line-height: 0;
    vertical-align: -0.25em;
    background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .quote-open { margin-right: 2px; }
  .quote-close { margin-left: 2px; }
  :global([data-theme="light"]) .quote-mark {
    background: linear-gradient(135deg, #00838f, #5B4BC9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* === CSS-only tooltips on badge chips === */
  .badge-chip {
    position: relative;
  }
  .badge-chip::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) scale(0.95);
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--text-primary);
    background: var(--surface-container, rgba(30,32,36,0.95));
    border: 1px solid var(--glass-border);
    border-radius: 6px;
    padding: 8px 12px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 50;
    box-shadow: var(--shadow-elevated);
  }
  .badge-chip:hover::after {
    opacity: 1;
    transform: translateX(-50%) scale(1);
  }
  :global([data-theme="light"]) .badge-chip::after {
    background: rgba(255,255,255,0.97);
    box-shadow: var(--shadow-elevated);
    color: var(--text-primary);
  }

  @media (max-width: 767px) {
    .badge-chip::after { display: none; }
  }

  /* === Stat value animated underline (expands from center on reveal) === */
  .trust-counter-val {
    position: relative;
  }
  .trust-counter-val::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    transform-origin: center;
    width: 60%;
    height: 2px;
    border-radius: 1px;
    background: var(--accent);
    opacity: 0.4;
    transition: transform 0.7s var(--ease-out-premium) 0.2s;
  }
  .trust-counters.revealed .trust-counter-val::after {
    transform: translateX(-50%) scaleX(1);
  }
  :global([data-theme="light"]) .trust-counter-val::after {
    background: #00838f;
    opacity: 0.4;
  }

  @media (prefers-reduced-motion: reduce) {
    .outcome-card, .badge-chip { transition: none; }
    .outcome-card::before { transition: none; }
    .badge-chip::after { transition: none; }
    .trust-counter-val::after { transition: none; }
  }

  :global([data-theme="light"]) .badge-chip {
    border-color: rgba(0,131,143,0.12);
    background: rgba(255,255,255,0.7);
  }
  :global([data-theme="light"]) .badge-chip:hover {
    border-color: rgba(0,131,143,0.25);
    box-shadow: 0 2px 12px rgba(0,131,143,0.08), 0 0 16px rgba(0,131,143,0.04);
  }
  :global([data-theme="light"]) .outcome-card {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(0, 131, 143, 0.12);
    box-shadow: var(--shadow-rest);
  }
  :global([data-theme="light"]) .outcome-card:hover {
    border-color: rgba(0, 131, 143, 0.25);
    box-shadow: var(--shadow-elevated);
  }
</style>
