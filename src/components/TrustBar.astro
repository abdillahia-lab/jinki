---
const outcomes = [
  {
    icon: "speed",
    headline: "From Data to Decisions in 48 Hours",
    description: "Traditional inspections take weeks and deliver raw data. Jinki delivers a prioritized action plan — severity-ranked with clear next steps, ready for your next maintenance window.",
    stat: "48hr",
    statLabel: "data to decisions",
  },
  {
    icon: "visibility",
    headline: "Total Coverage Without Total Headcount",
    description: "One aerial platform covers what would require multiple crew members and extended site access. No scaffolding, no roof access, no operational disruption. Your team stays focused on operations.",
    stat: "Zero",
    statLabel: "roof access needed",
  },
  {
    icon: "trending_up",
    headline: "Catch Degradation Before It Becomes Downtime",
    description: "Autonomous recurring missions build thermal baselines over time. Our AI flags degradation velocity — so you fix what's failing, not just what's failed.",
    stat: "200+",
    statLabel: "autonomous missions per month",
  },
];

const trustBadges = [
  { icon: 'flight_takeoff', label: 'FAA Part 107' },
  { icon: 'radar', label: 'DC SFRA Trained' },
  { icon: 'verified_user', label: 'SOC 2 (In Progress)' },
  { icon: 'lock', label: 'End-to-End Encrypted' },
  { icon: 'health_and_safety', label: 'OSHA Compliant' },
  { icon: 'shield', label: 'NDA by Default' },
];
---

<section class="trust-bar" aria-label="Why teams choose Jinki">

  <!-- Stats Bar -->
  <div class="trust-counters reveal" style="padding: 96px 24px; border-bottom: 1px solid var(--glass-border);">
    <div class="trust-counters-grid" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px;">
      <div class="trust-counter" style="text-align: center;">
        <span class="trust-counter-val" style="display: block; font-family: var(--font-headline); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--accent); letter-spacing: -0.03em; line-height: 1.1;">0.5°C</span>
        <span class="trust-counter-lbl" style="display: block; font-family: var(--font-label); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); margin-top: 8px;">Thermal Accuracy</span>
      </div>
      <div class="trust-counter" style="text-align: center;">
        <span class="trust-counter-val" style="display: block; font-family: var(--font-headline); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--accent); letter-spacing: -0.03em; line-height: 1.1;">50+ mi</span>
        <span class="trust-counter-lbl" style="display: block; font-family: var(--font-label); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); margin-top: 8px;">Daily Corridor Range</span>
      </div>
      <div class="trust-counter" style="text-align: center;">
        <span class="trust-counter-val" style="display: block; font-family: var(--font-headline); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--accent); letter-spacing: -0.03em; line-height: 1.1;">48hr</span>
        <span class="trust-counter-lbl" style="display: block; font-family: var(--font-label); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); margin-top: 8px;">Report Turnaround</span>
      </div>
      <div class="trust-counter" style="text-align: center;">
        <span class="trust-counter-val" style="display: block; font-family: var(--font-headline); font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: var(--accent); letter-spacing: -0.03em; line-height: 1.1;">200/mo</span>
        <span class="trust-counter-lbl" style="display: block; font-family: var(--font-label); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-tertiary); margin-top: 8px;">Autonomous Missions</span>
      </div>
    </div>
  </div>

  <!-- Certifications — distinct elevated band -->
  <div class="trust-certs reveal" style="padding: 32px 24px; background: linear-gradient(180deg, rgba(0,229,255,0.03) 0%, rgba(0,229,255,0.01) 100%); border-top: 1px solid rgba(0,229,255,0.1); border-bottom: 1px solid rgba(0,229,255,0.1);">
    <div style="max-width: 1100px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 16px 32px;">
      <div style="display: flex; align-items: center; gap: 8px; white-space: nowrap;">
        <span class="material-symbols-outlined" style="font-size: 1.125rem; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">verified</span>
        <span style="font-family: var(--font-label); font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent);">Certifications & Standards</span>
      </div>
      <div class="cert-divider" aria-hidden="true" style="width: 1px; height: 24px; background: rgba(0,229,255,0.15);"></div>
      <div class="badges-row">
        {trustBadges.map((b) => (
          <div class="badge-chip">
            <span class="material-symbols-outlined" style="font-size: 1rem; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">{b.icon}</span>
            <span style="font-family: var(--font-label); font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-primary);">{b.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Business Outcomes — Wharton-grade positioning -->
  <div class="trust-outcomes reveal" style="padding: 96px 24px;">
    <h2 style="font-family: var(--font-headline); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; color: var(--text-primary); text-align: center; letter-spacing: -0.02em; margin-bottom: 8px;">Why Operations Teams Choose Jinki</h2>
    <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--text-secondary); text-align: center; margin-bottom: 56px; max-width: 540px; margin-left: auto; margin-right: auto; line-height: 1.7;">Clear priorities. Honest timelines. Recommendations your team can execute the same week.</p>
    <div class="outcomes-grid">
      {outcomes.map((o) => (
        <div class="outcome-card">
          <div class="outcome-icon-row">
            <span class="material-symbols-outlined" style="font-size: 1.5rem; color: var(--accent); font-variation-settings: 'FILL' 1;" aria-hidden="true">{o.icon}</span>
            <div class="outcome-stat-pill">
              <span class="outcome-stat-val">{o.stat}</span>
              <span class="outcome-stat-lbl">{o.statLabel}</span>
            </div>
          </div>
          <h3 style="font-family: var(--font-headline); font-size: 1.125rem; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; line-height: 1.3;">{o.headline}</h3>
          <p class="outcome-desc">{o.description}</p>
        </div>
      ))}
    </div>
  </div>

</section>

<style>
  .trust-bar {
    display: flex;
    flex-direction: column;
  }

  .badges-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 12px;
  }

  .badge-chip {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(8px);
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .badge-chip:hover {
    border-color: rgba(0, 229, 255, 0.2);
    background: rgba(0, 229, 255, 0.05);
  }

  .outcomes-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .outcome-card {
    padding: 32px 24px;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)), transform 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .outcome-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent 10%, var(--accent) 50%, transparent 90%);
    opacity: 0.4;
  }
  .outcome-card:hover {
    border-color: rgba(0, 229, 255, 0.2);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2), 0 0 30px rgba(0, 229, 255, 0.05);
    transform: translateY(-4px);
  }

  .outcome-icon-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .outcome-stat-pill {
    display: flex;
    align-items: baseline;
    gap: 4px;
    padding: 4px 10px;
    background: var(--accent-glow);
    border-radius: 9999px;
  }

  .outcome-stat-val {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--accent);
  }

  .outcome-stat-lbl {
    font-family: var(--font-label);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }

  .outcome-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  @media (max-width: 1023px) {
    .outcomes-grid {
      grid-template-columns: 1fr;
      max-width: 520px;
    }
    .trust-counters-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    .cert-divider { display: none; }
  }

  @media (max-width: 767px) {
    .trust-counters,
    .trust-outcomes {
      padding: 56px 16px !important;
    }
    .trust-counters-grid {
      gap: 16px !important;
    }
    .badges-row {
      gap: 6px 8px;
      justify-content: center;
    }
    .trust-certs > div {
      flex-direction: column !important;
      text-align: center;
    }
    .trust-counter-val {
      font-size: 1.5rem !important;
    }
    .trust-counters-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .outcome-card { transition: none; }
  }
</style>
