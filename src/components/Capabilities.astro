---
/*
  Capabilities Section — Jinki Aerial Intelligence

  Design decisions:
  - 4-column card grid with icon + title + description
  - Hover glow effect per defense-tech convention (Anduril)
  - Nielsen H6 (Recognition): icons + labels make capabilities scannable
  - Staggered reveal animation (100ms between cards)
*/

const capabilities = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/><circle cx="12" cy="12" r="8" stroke-dasharray="4 4"/></svg>`,
    title: 'Autonomous Flight',
    description: 'AI-driven flight planning and execution with real-time obstacle avoidance, adaptive route optimization, and fully autonomous mission completion.'
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/><path d="M6 8h.01M6 12h.01M10 8h4M10 12h4" stroke-dasharray="0"/></svg>`,
    title: 'Real-Time Analytics',
    description: 'On-board AI processing delivers instant analysis of aerial data — thermal anomalies, structural defects, vegetation indices, and security events.'
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>`,
    title: 'Secure Data Pipeline',
    description: 'End-to-end encrypted data transmission with on-premise processing options. Security-first infrastructure built on NIST 800-53 controls for sensitive operational environments.'
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/><circle cx="12" cy="12" r="10" stroke-dasharray="3 3" opacity="0.3"/></svg>`,
    title: 'Predictive Insights',
    description: 'Machine learning models trained on historical aerial data predict equipment failures, crop health trends, and security vulnerabilities before they escalate.'
  }
];
---

<section id="capabilities" class="section" style={`background: var(--bg-elevated);`} aria-label="Capabilities" data-scrollytelling>
  <div class="section-inner">
    <div class="capabilities-header reveal">
      <span class="label">What We Do</span>
      <h2>Capabilities Built for<br/><span class="gradient-text">Mission-Critical Operations</span></h2>
      <p class="capabilities-subtitle">
        Every capability is designed for reliability, precision, and seamless integration
        into your existing operational workflows.
      </p>
    </div>

    <div class="capabilities-grid">
      {capabilities.map((cap, i) => (
        <div class={`card capability-card reveal reveal-delay-${i + 1}`} data-scroll-slide={30 + i * 10}>
          <div class="capability-icon" set:html={cap.icon} />
          <h3 class="capability-title">{cap.title}</h3>
          <p class="capability-desc">{cap.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .capabilities-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .capabilities-subtitle {
    max-width: 560px;
    margin: 16px auto 0;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .capability-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .capability-icon {
    color: var(--accent);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-glow);
    border-radius: 12px;
  }

  .capability-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .capability-desc {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  @media (max-width: 1024px) {
    .capabilities-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .capabilities-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
