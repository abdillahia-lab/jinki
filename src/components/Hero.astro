---
/*
  Hero Section — Jinki Aerial Intelligence
  Globe-centric hero with orbital rings and left-aligned content.
*/
---

<section id="hero" class="hero" aria-label="Hero">
  <!-- Globe Background Layer -->
  <div class="globe-layer" aria-hidden="true">
    <div class="globe-container">
      <img
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuDy1A4xK2fh4u-ziBtcFlOOb5KjOKfmOuS7MfvVS-g8nN4fxdB6y6oiNsM7WKtdclle6eKt22z0CunAEWtrBzZE2lu9jYgkJxzrEUW3pBg-f1yqIOpY4JfMhlJDMCd5-Br8450mbHGYip6_raxUIi3FaABy-ZgB5yudeDDBT5Xe7ms9R4xtvJSfEHVnLNyLtRrkFbPDliZS2-Q_--bTELOZATqObtAC01cN2WiwYNfa4CfoaB0xK0pkzKYEBY0UijYwdoSTAsSV093d"
        alt=""
        class="globe-img globe-rotation"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <!-- Orbital Rings -->
    <div class="orbital-rings">
      <!-- Outer ring — 800px, dashed -->
      <div class="ring ring-outer">
        <span class="ring-dot ring-dot-a orb-pulse"></span>
        <span class="ring-dot ring-dot-b orb-pulse"></span>
      </div>
      <!-- Mid ring — 600px, solid -->
      <div class="ring ring-mid">
        <span class="ring-dot ring-dot-c orb-pulse"></span>
      </div>
      <!-- Inner ellipse — 1000x400, tilted -->
      <div class="ring ring-inner-ellipse">
        <span class="ring-dot ring-dot-d orb-pulse"></span>
        <span class="ring-dot ring-dot-e orb-pulse"></span>
      </div>
    </div>
  </div>

  <!-- Content Layer -->
  <div class="hero-content">
    <div class="hero-eyebrow reveal">
      <span class="eyebrow-line"></span>
      <span class="eyebrow-text">Aerial Intelligence Platform</span>
    </div>

    <h1 class="hero-headline reveal reveal-delay-1">
      See What You <span class="headline-accent">Can't.</span> Act Before It Fails.
    </h1>

    <p class="hero-subtitle reveal reveal-delay-2">
      Jinki turns aerial data into prioritized maintenance recommendations for infrastructure you can't easily reach — power lines, rooftops, data centers, and farmland.
    </p>

    <div class="hero-actions reveal reveal-delay-3">
      <a href="#lead-gen" class="cta-primary btn-premium">Get a Free Assessment</a>
      <a href="#verticals" class="cta-secondary btn-premium">See How It Works</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator reveal reveal-delay-4" aria-hidden="true">
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
  </div>
</section>

<style>
  /* ---- Hero Section ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 6rem; /* pt-24 nav clearance */
    overflow: hidden;
  }

  /* ---- Globe Background Layer ---- */
  .globe-layer {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .globe-layer {
      justify-content: flex-end;
      padding-right: 5%;
    }
  }

  .globe-container {
    width: 700px;
    height: 700px;
    border-radius: 50%;
    filter: drop-shadow(0 0 50px rgba(0, 229, 255, 0.15));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .globe-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    opacity: 0.5;
  }

  :global([data-theme="light"]) .globe-img {
    opacity: 0.8;
  }

  /* ---- Orbital Rings ---- */
  .orbital-rings {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ring {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  /* Outer ring: 800px circle, dashed */
  .ring-outer {
    width: 800px;
    height: 800px;
    border: 1px dashed rgba(0, 229, 255, 0.2);
    animation: spin 40s linear infinite;
  }

  /* Mid ring: 600px circle, solid */
  .ring-mid {
    width: 600px;
    height: 600px;
    border: 1px solid rgba(0, 229, 255, 0.3);
    animation: spin 60s linear infinite reverse;
  }

  /* Inner ellipse: 1000x400, tilted */
  .ring-inner-ellipse {
    width: 1000px;
    height: 400px;
    border: 1px solid rgba(0, 229, 255, 0.1);
    border-radius: 50%;
    transform: rotate(25deg);
    animation: spin 80s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Override for tilted ellipse to preserve the 25deg base */
  .ring-inner-ellipse {
    animation: spinTilted 80s linear infinite;
  }

  @keyframes spinTilted {
    from { transform: rotate(25deg); }
    to { transform: rotate(385deg); }
  }

  /* Ring dots */
  .ring-dot {
    position: absolute;
    border-radius: 50%;
    background: #00E5FF;
    box-shadow: 0 0 15px #00E5FF;
  }

  .ring-dot-a {
    width: 8px;
    height: 8px;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .ring-dot-b {
    width: 6px;
    height: 6px;
    bottom: 15%;
    right: 5%;
  }

  .ring-dot-c {
    width: 8px;
    height: 8px;
    top: 50%;
    right: 0;
    transform: translate(50%, -50%);
  }

  .ring-dot-d {
    width: 6px;
    height: 6px;
    top: 0;
    left: 30%;
    transform: translateY(-50%);
  }

  .ring-dot-e {
    width: 6px;
    height: 6px;
    bottom: 0;
    right: 30%;
    transform: translateY(50%);
  }

  /* ---- Content Layer ---- */
  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 80rem;
    width: 100%;
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-content {
      padding-left: 3rem;
      padding-right: 3rem;
    }

    .hero-headline {
      max-width: 90%;
    }
  }

  @media (min-width: 1024px) {
    .hero-content {
      padding-left: 5rem;
      padding-right: 2.5rem;
      max-width: 80rem;
    }

    .hero-headline {
      max-width: none;
    }
  }

  /* Eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow-line {
    display: block;
    width: 3rem;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .eyebrow-text {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.75rem;
    color: var(--accent);
  }

  /* Headline */
  .hero-headline {
    font-family: var(--font-headline);
    font-size: clamp(2.5rem, 4.5vw + 0.5rem, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .headline-accent {
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  :global([data-theme="light"]) .headline-accent {
    background: linear-gradient(135deg, #00838f, #5B4BC9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtitle */
  .hero-subtitle {
    font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem);
    color: var(--on-surface-variant);
    font-weight: 300;
    max-width: 36rem; /* max-w-xl */
    line-height: 1.6;
    margin-bottom: 2.5rem;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6), 0 0 40px rgba(0, 0, 0, 0.3);
  }

  /* CTAs */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.875rem;
    padding: 1.125rem 2.5rem;
    border-radius: 12px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    cursor: pointer;
  }

  .cta-primary {
    background: linear-gradient(135deg, #00E5FF 0%, #00a8b5 50%, #00626e 100%);
    color: #ffffff;
    box-shadow: 0 4px 16px rgba(0, 229, 255, 0.3), 0 8px 32px rgba(0, 229, 255, 0.15), inset 0 1px 0 rgba(255,255,255,0.2);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }

  .cta-primary:hover {
    background: linear-gradient(135deg, #33ecff 0%, #00c4d4 50%, #007a8a 100%);
    box-shadow: 0 6px 24px rgba(0, 229, 255, 0.4), 0 12px 48px rgba(0, 229, 255, 0.2), inset 0 1px 0 rgba(255,255,255,0.25);
    transform: translateY(-2px);
  }

  .cta-primary:active {
    transform: translateY(0);
    box-shadow: 0 2px 8px rgba(0, 229, 255, 0.3), inset 0 1px 0 rgba(255,255,255,0.15);
  }

  .cta-secondary {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-primary);
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(16px) saturate(1.8);
    -webkit-backdrop-filter: blur(16px) saturate(1.8);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.1), 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .cta-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
    color: #ffffff;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.15), 0 8px 24px rgba(0, 0, 0, 0.2);
    transform: translateY(-2px);
  }

  .cta-secondary:active {
    transform: translateY(0);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
  }

  /* ---- Scroll Indicator ---- */
  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    animation: float 3s ease-in-out infinite;
  }

  .scroll-mouse {
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255, 255, 255, 0.25);
    border-radius: 13px;
    position: relative;
    display: flex;
    justify-content: center;
  }

  .scroll-wheel {
    width: 3px;
    height: 8px;
    background: var(--accent);
    border-radius: 2px;
    margin-top: 8px;
    animation: scroll-wheel 2s ease-in-out infinite;
  }

  @keyframes scroll-wheel {
    0% { opacity: 1; transform: translateY(0); }
    50% { opacity: 0.3; transform: translateY(10px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-6px); }
  }

  :global([data-theme="light"]) .scroll-mouse {
    border-color: rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 767px) {
    .scroll-indicator {
      bottom: 1.5rem;
    }
  }

  /* ---- Responsive: Globe sizing ---- */
  @media (min-width: 768px) {
    .globe-container {
      width: 900px;
      height: 900px;
    }
  }

  @media (min-width: 1024px) {
    .globe-container {
      width: 1100px;
      height: 1100px;
    }
  }

  /* ---- Responsive: Mobile adjustments ---- */
  @media (max-width: 767px) {
    .ring-outer {
      width: 500px;
      height: 500px;
    }

    .ring-mid {
      width: 380px;
      height: 380px;
    }

    .ring-inner-ellipse {
      width: 600px;
      height: 250px;
    }

    .hero-actions {
      flex-direction: column;
    }

    .cta-primary,
    .cta-secondary {
      width: 100%;
      max-width: 320px;
    }
  }

  /* ---- Light mode ring adjustments ---- */
  :global([data-theme="light"]) .ring-outer {
    border-color: rgba(0, 131, 143, 0.2);
  }

  :global([data-theme="light"]) .ring-mid {
    border-color: rgba(0, 131, 143, 0.3);
  }

  :global([data-theme="light"]) .ring-inner-ellipse {
    border-color: rgba(0, 131, 143, 0.1);
  }

  :global([data-theme="light"]) .ring-dot {
    background: var(--accent);
    box-shadow: 0 0 15px var(--accent);
  }

  :global([data-theme="light"]) .globe-img {
    opacity: 0.35;
  }

  :global([data-theme="light"]) .globe-container {
    filter: drop-shadow(0 0 50px rgba(0, 131, 143, 0.12));
  }

  :global([data-theme="light"]) .hero {
    background: var(--bg-primary);
  }

  /* Frosted backdrop behind hero text for light mode readability */
  :global([data-theme="light"]) .hero-content::before {
    content: '';
    position: absolute;
    inset: -2rem;
    border-radius: 1.5rem;
    background: radial-gradient(ellipse at 30% 50%, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.6) 50%, transparent 80%);
    backdrop-filter: blur(8px);
    z-index: -1;
    pointer-events: none;
  }

  :global([data-theme="light"]) .hero-headline {
    color: var(--text-primary);
    text-shadow: 0 1px 12px rgba(255, 255, 255, 0.8);
  }

  :global([data-theme="light"]) .hero-subtitle {
    color: var(--text-secondary);
    text-shadow: 0 1px 8px rgba(255, 255, 255, 0.9), 0 0 30px rgba(255, 255, 255, 0.6);
  }

  :global([data-theme="light"]) .cta-secondary {
    background: rgba(0, 0, 0, 0.04);
    color: var(--text-primary);
    border-color: var(--text-secondary);
    backdrop-filter: blur(8px);
  }

  :global([data-theme="light"]) .cta-primary {
    background: var(--accent);
    color: #ffffff;
    box-shadow: 0 10px 30px rgba(0, 131, 143, 0.2);
  }

  :global([data-theme="light"]) .cta-primary:hover {
    background: #00969e;
    box-shadow: 0 14px 40px rgba(0, 131, 143, 0.3);
  }

  :global([data-theme="light"]) .cta-secondary:hover {
    background: var(--text-primary);
    color: var(--bg-primary);
  }

  :global([data-theme="light"]) .eyebrow-text {
    color: var(--accent);
  }

  :global([data-theme="light"]) .eyebrow-line {
    background: var(--accent);
  }
  /* ---- Cursor parallax on globe ---- */
  @media (hover: hover) and (min-width: 1024px) {
    .globe-layer {
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
  }
</style>

<script is:inline>
  (function() {
    if (window.matchMedia('(hover: hover) and (min-width: 1024px)').matches) {
      var hero = document.getElementById('hero');
      var globe = hero && hero.querySelector('.globe-layer');
      if (!hero || !globe) return;

      hero.addEventListener('mousemove', function(e) {
        var rect = hero.getBoundingClientRect();
        var x = (e.clientX - rect.left) / rect.width - 0.5;
        var y = (e.clientY - rect.top) / rect.height - 0.5;
        globe.style.transform = 'translate(' + (x * 20) + 'px, ' + (y * 15) + 'px)';
      });

      hero.addEventListener('mouseleave', function() {
        globe.style.transform = '';
      });
    }
  })();
</script>
