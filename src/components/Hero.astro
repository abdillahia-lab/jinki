  /* === Reduced motion === */
  @media (prefers-reduced-motion: reduce) {
    .contour { stroke-dashoffset: 0 !important; animation: none !important; }
    .dot, .eyebrow-pip, .scroll-thumb, .scroll-chevron, .eyebrow-text::after { animation: none !important; }
    .dot { display: none; }
  }

  /* === Print === */
  @media print {
    .dot, .scroll-indicator, .topo-map { display: none !important; }
