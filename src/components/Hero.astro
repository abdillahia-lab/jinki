---
/* Hero — Lightweight topographic intelligence map. ~280 lines. */
---

<section id="hero" class="hero" aria-label="Hero — Aerial Intelligence Platform" style="position: relative; min-height: 100vh; min-height: 100dvh; display: flex; align-items: center; overflow: hidden; padding-top: 6rem; padding-bottom: 3rem; background: var(--bg-primary);">

  <!-- Hero video (drop mp4 into public/videos/hero.mp4 to activate) -->
  <video class="hero-video" autoplay muted loop playsinline preload="none" aria-hidden="true">
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>

  <!-- Animated Mesh Gradient Background (fallback when no video) -->
  <div class="hero-mesh" aria-hidden="true"></div>

  <!-- Noise texture overlay for physical depth -->
  <div class="hero-noise" aria-hidden="true"></div>

  <!-- Intelligence grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Background container -->
  <div aria-hidden="true" style="position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden;">
    <!-- Ambient dots (CSS-only, no canvas) -->
    <div class="dot dot-1"></div>
    <div class="dot dot-2"></div>
    <div class="dot dot-3"></div>
    <div class="dot dot-4"></div>
    <div class="dot dot-5"></div>
  </div>

  <!-- Content -->
  <div class="hero-content" style="position: relative; z-index: 10; max-width: var(--container-max); width: 100%; margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem;">
    <div class="hero-text">
      <!-- Eyebrow -->
      <div class="eyebrow reveal" style="display: flex; align-items: center; margin-bottom: 1.5rem;">
        <span class="eyebrow-pip" style="width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 12px var(--accent); flex-shrink: 0;"></span>
        <span style="display: block; width: 2rem; height: 1px; background: var(--accent); opacity: .5; margin-left: .75rem; margin-right: .75rem; flex-shrink: 0;"></span>
        <span class="eyebrow-text" style="font-family: var(--font-label); text-transform: uppercase; letter-spacing: .12em; font-size: 0.6875rem; color: var(--accent); white-space: nowrap;">Aerial Intelligence Platform</span>
      </div>

      <!-- Headline (static, no word-swap) -->
      <h1 class="headline reveal reveal-delay-1" style="font-family: var(--font-headline); font-size: clamp(2.6rem,5vw + .5rem,5.5rem); font-weight: 700; line-height: 1.02; letter-spacing: -.035em; color: var(--text-primary); margin-bottom: 2rem;">
        See What You Can't.<br/>Act Before It <span class="headline-accent">Fails.</span>
      </h1>

      <!-- Subtitle -->
      <p class="reveal reveal-delay-2" style="font-size: clamp(1.05rem,1.3vw + .4rem,1.3rem); color: var(--text-secondary); font-weight: 400; max-width: 34rem; line-height: 1.75; margin-bottom: 2.75rem;">
        Your rooftop infrastructure is degrading right now. Traditional inspections miss it. We find it — and deliver a prioritized fix list within 48 hours.
      </p>

      <!-- CTAs -->
      <div class="hero-actions reveal reveal-delay-3" style="display: flex; flex-wrap: wrap;">
        <a href="#lead-gen" class="cta-primary btn-premium" style="margin-right: 1rem; margin-bottom: .5rem;">Request Assessment</a>
        <a href="#process" class="cta-secondary btn-premium" style="margin-bottom: .5rem;">
          See How It Works
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="margin-left: .5rem;"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <p class="hero-trust-line reveal reveal-delay-4" style="font-family: var(--font-body); font-size: 0.8rem; color: var(--text-tertiary); margin-top: 12px; display: flex; align-items: center; gap: 8px;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 14px; color: var(--accent);">verified</span>
        No commitment required. Zero risk.
      </p>
      <p class="hero-urgency reveal reveal-delay-4" style="font-family: var(--font-mono); font-size: 0.7rem; color: var(--accent); margin-top: 8px; display: flex; align-items: center; gap: 8px; letter-spacing: 0.04em;">
        <span class="material-symbols-outlined" aria-hidden="true" style="font-size: 14px;">schedule</span>
        Responding to new inquiries within 4 hours
      </p>
    </div>

    <!-- Metric Cards -->
    <div class="hero-metrics reveal reveal-delay-2">
      <div class="metric-card mc-1">
        <span class="metric-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="metric-value" data-count="0.5">0</span><span class="metric-unit">°C</span>
        <span class="metric-label">Invisible to the Eye</span>
      </div>
      <div class="metric-card mc-2">
        <span class="metric-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </span>
        <span class="metric-value" data-count="48">0</span><span class="metric-unit">hr</span>
        <span class="metric-label">Scan to Action Plan</span>
      </div>
      <div class="metric-card mc-3">
        <span class="metric-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="metric-value">200</span><span class="metric-unit">/mo</span>
        <span class="metric-label">Autonomous Persistence</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator reveal reveal-delay-4" aria-hidden="true" style="position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 10; display: flex; flex-direction: column; align-items: center;">
    <div style="width: 2px; height: 32px; background: rgba(255,255,255,.1); border-radius: 1px; position: relative; overflow: hidden;">
      <div class="scroll-thumb" style="width: 2px; height: 10px; background: var(--accent); border-radius: 1px; box-shadow: 0 0 6px var(--accent);"></div>
    </div>
    <span style="font-family: var(--font-mono); font-size: .6rem; text-transform: uppercase; letter-spacing: .2em; color: var(--text-tertiary); opacity: .7; margin-top: .5rem;">Scroll</span>
    <svg class="scroll-chevron" width="14" height="8" viewBox="0 0 14 8" fill="none" style="margin-top: .35rem; opacity: .7;">
      <path d="M1 1l6 5.5L13 1" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  /* === Hero Video (hidden until /videos/hero.mp4 exists) === */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: 0;
    transition: opacity 1.2s ease;
  }
  .hero-video.loaded { opacity: 0.35; }
  :global([data-theme="light"]) .hero-video.loaded { opacity: 0.2; }

  /* === Animated Mesh Gradient (Stripe-inspired) === */
  @property --mesh-x1 { syntax: '<percentage>'; initial-value: 25%; inherits: false; }
  @property --mesh-y1 { syntax: '<percentage>'; initial-value: 35%; inherits: false; }
  @property --mesh-x2 { syntax: '<percentage>'; initial-value: 70%; inherits: false; }
  @property --mesh-y2 { syntax: '<percentage>'; initial-value: 55%; inherits: false; }

  .hero-mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 700px 500px at var(--mesh-x1) var(--mesh-y1),
        color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 65%),
      radial-gradient(ellipse 600px 600px at var(--mesh-x2) var(--mesh-y2),
        rgba(123, 97, 255, 0.14) 0%, transparent 60%),
      radial-gradient(ellipse 500px 400px at 55% 75%,
        rgba(0, 180, 220, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse 550px 450px at 88% 85%,
        rgba(139, 92, 246, 0.09) 0%, transparent 60%);
    filter: blur(50px) saturate(1.6);
    animation: meshDrift 25s ease-in-out infinite alternate;
  }
  /* Noise grain composited on mesh for physical texture */
  .hero-mesh::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 128 128' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='g'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.2' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23g)'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    opacity: 0.05;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  @keyframes meshDrift {
    0%   { --mesh-x1: 25%; --mesh-y1: 35%; --mesh-x2: 70%; --mesh-y2: 55%; }
    25%  { --mesh-x1: 45%; --mesh-y1: 25%; --mesh-x2: 60%; --mesh-y2: 65%; }
    50%  { --mesh-x1: 60%; --mesh-y1: 45%; --mesh-x2: 35%; --mesh-y2: 40%; }
    75%  { --mesh-x1: 35%; --mesh-y1: 55%; --mesh-x2: 75%; --mesh-y2: 30%; }
    100% { --mesh-x1: 50%; --mesh-y1: 30%; --mesh-x2: 45%; --mesh-y2: 60%; }
  }

  /* Noise texture for physical depth */
  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.35;
    mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* Intelligence grid — topographic/tech grid, 60px spacing */
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.04;
    background-image:
      linear-gradient(var(--accent) 1px, transparent 1px),
      linear-gradient(90deg, var(--accent) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(0,0,0,0.6) 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(0,0,0,0.6) 0%, transparent 70%);
  }
  :global([data-theme="light"]) .hero-grid { opacity: 0.03; }
  @media (max-width: 767px) { .hero-grid { background-size: 60px 60px; } }

  /* Light mode: softer mesh */
  :global([data-theme="light"]) .hero-mesh {
    filter: blur(60px) saturate(1.4);
    opacity: 0.5;
    background: radial-gradient(ellipse at 20% 50%, rgba(0,131,143,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 70% 30%, rgba(0,80,88,0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 80%, rgba(123,97,255,0.12) 0%, transparent 50%);
  }
  :global([data-theme="light"]) .hero-noise {
    opacity: 0.08;
  }

  /* Mobile: reduce blur for performance */
  @media (max-width: 767px) {
    .hero-mesh { filter: blur(40px) saturate(1.3); }
  }

  /* === Floating CSS dots (replaces canvas particles) === */
  .dot {
    position: absolute;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    animation: floatDot 12s ease-in-out infinite;
  }
  .dot-1 { width: 2px; height: 2px; left: 15%; bottom: 10%; animation-delay: 0s; }
  .dot-2 { width: 2px; height: 2px; left: 55%; bottom: 5%;  animation-delay: 3s; }
  .dot-3 { width: 2px; height: 2px; left: 80%; bottom: 15%; animation-delay: 6s; }
  .dot-4 { width: 2px; height: 2px; left: 35%; bottom: 8%;  animation-delay: 1.5s; }
  .dot-5 { width: 2px; height: 2px; left: 65%; bottom: 20%; animation-delay: 4.5s; }
  @keyframes floatDot {
    0%   { opacity: 0; transform: translateY(0); }
    15%  { opacity: .2; }
    85%  { opacity: .08; }
    100% { opacity: 0; transform: translateY(-100px); }
  }

  /* === Eyebrow pip pulse (subtle, luxury) === */
  .eyebrow-pip { animation: pipPulse 3s ease-in-out infinite; }
  @keyframes pipPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 10px var(--accent); }
    50%      { opacity: .7; box-shadow: 0 0 5px var(--accent); }
  }

  /* === Eyebrow blinking cursor === */
  .eyebrow-text::after {
    content: '';
    display: inline-block;
    width: 1.5px;
    height: 0.75em;
    background: var(--accent);
    margin-left: 0.35em;
    vertical-align: middle;
    animation: cursorBlink 1.2s step-end infinite;
  }
  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* === Scroll thumb === */
  .scroll-thumb { animation: scrollBob 2.5s ease-in-out infinite; }
  @keyframes scrollBob {
    0%   { transform: translateY(0); opacity: 1; }
    70%  { transform: translateY(22px); opacity: .3; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* === Bouncing chevron === */
  .scroll-chevron { animation: chevronBounce 2s ease-in-out infinite; }
  @keyframes chevronBounce {
    0%, 100% { transform: translateY(0); opacity: .4; }
    50%      { transform: translateY(5px); opacity: .7; }
  }

  /* === Headline accent === */
  .headline-accent {
    background: linear-gradient(90deg, var(--accent), #9B7DFF, var(--accent));
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
    animation: heroShimmer 4s ease-in-out 1;
    animation-delay: 0.5s;
    animation-fill-mode: both;
  }
  @keyframes heroShimmer {
    0% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  :global([data-theme="light"]) .headline-accent {
    background: linear-gradient(135deg, #00838f, #5B4BC9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* === Layout === */
  .hero-content {
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 768px)  { .hero-content { padding-left: 3rem; padding-right: 3rem; } }
  @media (min-width: 1024px) { .hero-content { grid-template-columns: 1.1fr .9fr; column-gap: 3rem; padding-left: 5rem; padding-right: 5rem; } }

  /* === CTAs === */
  .cta-primary, .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-size: .85rem;
    padding: 1rem 2.5rem;
    border-radius: 12px;
    transition: transform 0.35s var(--ease-out-premium),
                box-shadow 0.35s var(--ease-out-premium),
                background 0.35s ease,
                border-color 0.35s ease;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }
  .cta-primary {
    background: linear-gradient(135deg, var(--accent) 0%, #00b8cc 100%);
    color: var(--text-on-accent);
    border: none;
    box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 25%, transparent), inset 0 1px 0 rgba(255,255,255,.15);
    text-shadow: 0 1px 2px rgba(0,0,0,.15);
  }
  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px color-mix(in srgb, var(--accent) 45%, transparent), 0 2px 8px color-mix(in srgb, var(--accent) 20%, transparent), inset 0 1px 0 rgba(255,255,255,.3);
  }
  .cta-primary:active {
    transform: translateY(0);
    box-shadow: 0 2px 12px color-mix(in srgb, var(--accent) 30%, transparent), inset 0 1px 0 rgba(255,255,255,.15);
  }
  /* Shimmer on hover */
  .cta-primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.12) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.6s var(--ease-out-premium);
    pointer-events: none;
  }
  .cta-primary:hover::after {
    transform: translateX(100%);
  }
  .cta-secondary {
    background: rgba(255,255,255,.04);
    color: var(--text-primary);
    border: 1.5px solid rgba(255,255,255,.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .cta-secondary:hover {
    background: rgba(255,255,255,.08);
    border-color: rgba(255,255,255,.2);
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevated);
  }
  .cta-secondary:active {
    transform: translateY(0);
  }
  .cta-secondary:hover svg { transform: translateX(4px); }
  .cta-secondary svg { transition: transform 0.35s var(--ease-out-premium); }

  /* === Metric Cards === */
  .hero-metrics { display: flex; flex-direction: column; margin-top: 2.5rem; }
  @media (max-width: 767px) {
    .hero-metrics { flex-direction: row; flex-wrap: wrap; gap: 0.5rem; }
    .metric-card { flex: 1 1 calc(50% - 0.5rem); margin-bottom: 0 !important; padding: 0.75rem 1rem !important; }
    .metric-card .metric-value { font-size: 1.25rem !important; }
    .metric-card .metric-unit { font-size: 0.75rem !important; }
    .metric-card .metric-label { font-size: 0.5rem !important; }
    .metric-card .metric-icon { display: none; }
  }
  @media (min-width: 1024px) { .hero-metrics { margin-top: 0; } }
  .metric-card {
    background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 16px;
    padding: 1.25rem 1.5rem; margin-bottom: 1rem; backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
    box-shadow: var(--glass-shadow); display: flex; align-items: center;
    position: relative; overflow: hidden;
    transition: box-shadow 0.4s var(--ease-out-premium),
                transform 0.4s var(--ease-out-premium),
                border-color 0.4s ease;
  }
  /* Gradient left accent border */
  .metric-card::after {
    content: '';
    position: absolute;
    left: 0; top: 15%; bottom: 15%;
    width: 2px;
    border-radius: 1px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--accent) 60%, transparent), rgba(123,97,255,0.35));
    pointer-events: none;
    z-index: 2;
  }
  .metric-card::before { content: ''; position: absolute; inset: 0; border-radius: inherit; background: var(--glossy-shine); pointer-events: none; z-index: 1; }
  .metric-card:hover {
    box-shadow: var(--glass-shadow), 0 0 24px color-mix(in srgb, var(--accent) 8%, transparent);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 15%, transparent);
  }
  @media (min-width: 1024px) { .mc-2 { margin-left: 2rem; } .mc-3 { margin-left: .5rem; } }
  .metric-icon { width: 40px; height: 40px; border-radius: 12px; background: var(--accent-glow); display: flex; align-items: center; justify-content: center; color: var(--accent); flex-shrink: 0; margin-right: 1rem; box-shadow: 0 0 12px color-mix(in srgb, var(--accent) 15%, transparent), 0 0 4px color-mix(in srgb, var(--accent) 10%, transparent); transition: box-shadow 0.4s ease; }
  .metric-card:hover .metric-icon { box-shadow: 0 0 20px color-mix(in srgb, var(--accent) 30%, transparent), 0 0 8px color-mix(in srgb, var(--accent) 15%, transparent); }
  .metric-value { font-family: var(--font-mono); font-size: 1.75rem; font-weight: 700; color: var(--text-primary); line-height: 1; }
  .metric-unit  { font-family: var(--font-mono); font-size: 1rem; color: var(--accent); margin-left: 2px; }
  .metric-label { font-family: var(--font-label); font-size: .75rem; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: .15em; margin-left: auto; text-align: right; white-space: nowrap; }

  /* === Light mode === */
  :global([data-theme="light"]) .cta-primary { background: var(--accent); color: #ffffff; box-shadow: 0 10px 30px rgba(0,131,143,.2); }
  :global([data-theme="light"]) .cta-primary:hover { background: #00969e; }
  :global([data-theme="light"]) .cta-secondary { background: rgba(0,0,0,.04); color: var(--text-primary); border-color: rgba(0,0,0,.18); }
  :global([data-theme="light"]) .cta-secondary:hover { background: var(--text-primary); color: var(--bg-primary); }
  :global([data-theme="light"]) .hero-text { position: relative; }
  :global([data-theme="light"]) .hero-text::before { content: ''; position: absolute; inset: -2rem; border-radius: 1.5rem; background: radial-gradient(ellipse at 30% 50%, rgba(255,255,255,.85), rgba(255,255,255,.6) 50%, transparent 80%); backdrop-filter: blur(8px); z-index: -1; pointer-events: none; }
  :global([data-theme="light"]) .metric-icon { box-shadow: 0 0 10px rgba(0,131,143,0.12), 0 0 4px rgba(0,131,143,0.08); }
  :global([data-theme="light"]) .metric-card:hover .metric-icon { box-shadow: 0 0 16px rgba(0,131,143,0.2), 0 0 6px rgba(0,131,143,0.12); }
  :global([data-theme="light"]) .metric-card::after { background: linear-gradient(180deg, rgba(0,131,143,0.5), rgba(90,75,201,0.3)); }
  :global([data-theme="light"]) .dot { background: #00838f; }

  /* === Responsive === */
  @media (max-width: 767px) {
    .hero { min-height: auto !important; padding-top: 4rem !important; padding-bottom: 1.5rem !important; }
    .hero .headline { font-size: clamp(1.75rem, 8vw, 2.25rem) !important; margin-bottom: 1.25rem !important; }
    .hero .hero-text p { font-size: 0.95rem !important; line-height: 1.6 !important; margin-bottom: 1.75rem !important; }
    .hero-mesh { animation: none; opacity: 0.3; }
    .eyebrow-text::after { animation: none; display: none; }
    .dot { animation: none; display: none; }
    .eyebrow-pip { animation: none; }
    .scroll-thumb, .scroll-chevron { animation: none; }
    .hero-actions { flex-direction: column; }
    .cta-primary, .cta-secondary { width: 100%; max-width: none; padding: 14px 24px !important; }

    /* Metric cards → compact horizontal strip on mobile */
    .hero-metrics {
      flex-direction: row;
