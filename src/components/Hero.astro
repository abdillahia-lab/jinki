</style>

<script is:inline>
  // Hero video: fade in only if the file loads successfully
  (function() {
    var v = document.querySelector('.hero-video');
    if (!v) return;
    v.addEventListener('canplaythrough', function() { v.classList.add('loaded'); });
    v.addEventListener('error', function() { v.style.display = 'none'; });
    // Kick off load (preload was "none" to avoid wasting bandwidth if file doesn't exist)
    v.load();
  })();
</script>

