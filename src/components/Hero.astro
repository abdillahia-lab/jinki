---
/* Hero — 3-second executive comprehension. Globe breathes behind. */
import GlobeCanvas from './GlobeCanvas.astro';
---

<section id="hero" class="hero" aria-label="Aerial Intelligence for Critical Infrastructure">
  <div class="hero-mesh" aria-hidden="true"></div>
  <GlobeCanvas />
  <div class="globe-mobile" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-text">
      <h1 class="headline">
        Your Infrastructure Is Failing.<br/>You Just Can't See It <span class="headline-accent">Yet.</span>
      </h1>

      <p class="hero-subtitle">
        73% of cooling failures show thermal signatures weeks before catastrophic failure. We find them in a single aerial pass and deliver a prioritized fix list within 48 hours.
      </p>

      <p class="hero-proof">Trusted by data center operators across Northern Virginia.</p>

      <div class="hero-actions">
        <a href="#lead-gen" class="cta-primary btn-premium">Request Assessment</a>
      </div>
    </div>
  </div>

  <div class="hero-dissolve" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative; min-height: 100vh; min-height: 100dvh;
    display: flex; align-items: center; overflow: hidden;
    padding-top: 6rem; padding-bottom: 3rem; background: transparent;
  }
  .hero-content {
    position: relative; z-index: 10;
    max-width: var(--container-max); width: 100%;
    margin-left: auto; margin-right: auto;
    padding-left: 1.5rem; padding-right: 1.5rem;
  }
  .headline {
    font-family: var(--font-headline);
    font-size: clamp(2.8rem, 6vw + .5rem, 5rem);
    font-weight: 700; line-height: 1.02; letter-spacing: -.035em;
    color: var(--text-primary); margin-bottom: 2rem;
    max-width: 16ch;
  }
  .headline-accent {
    color: var(--accent);
    font-style: italic;
  }
  :global([data-theme="light"]) .headline-accent {
    color: var(--accent);
  }
  .hero-subtitle {
    font-size: clamp(1.1rem, 1.4vw + .4rem, 1.375rem);
    color: var(--text-secondary); font-weight: 400;
    max-width: 38rem; line-height: 1.7; margin-bottom: 1.5rem;
  }
  .hero-proof {
    font-family: var(--font-label); font-size: 0.8125rem;
    color: var(--text-tertiary); letter-spacing: 0.04em;
    margin-bottom: 2rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .hero-dissolve {
    position: absolute; bottom: 0; left: 0; right: 0; height: 12rem;
    background: linear-gradient(to bottom, transparent, var(--bg-primary));
    z-index: 5; pointer-events: none;
  }

  .hero-mesh {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background: radial-gradient(ellipse 60% 50% at 65% 45%,
      color-mix(in srgb, var(--accent) 6%, transparent) 0%, transparent 70%);
  }
  :global([data-theme="light"]) .hero-mesh {
    background: radial-gradient(ellipse 60% 50% at 65% 45%,
      rgba(0,131,143,0.06) 0%, transparent 70%);
  }

  /* === Mobile Globe — static image fallback === */
  .globe-mobile { display: none; }
  @media (max-width: 767px) {
    .globe-mobile {
      display: block; position: absolute;
      top: 0; right: -10%;
      width: 70vw; height: 70vw;
      max-width: 320px; max-height: 320px;
      background: url('/images/globe-mobile.webp') center/contain no-repeat;
      opacity: 0.25; z-index: 0; pointer-events: none;
    }
  }

  /* === Layout === */
  @media (min-width: 768px)  { .hero-content { padding-left: 3rem; padding-right: 3rem; } }
  @media (min-width: 1024px) { .hero-content { padding-left: 5rem; padding-right: 5rem; } }

  /* === CTA === */
  .cta-primary {
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-headline); font-weight: 600;
    text-transform: uppercase; letter-spacing: .08em; font-size: .85rem;
    padding: 1rem 2.5rem; border-radius: 12px;
    transition: transform 0.35s var(--ease-out-premium),
                box-shadow 0.35s var(--ease-out-premium),
                background 0.35s ease;
    text-decoration: none; cursor: pointer;
    background: var(--accent); color: var(--text-on-accent); border: none;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .cta-primary:hover {
    transform: translateY(-2px) scale(1.02);
    filter: brightness(1.15);
    box-shadow: 0 8px 30px color-mix(in srgb, var(--accent) 35%, transparent);
  }
  .cta-primary:active { transform: translateY(0) scale(1); filter: brightness(1); }

  /* === Light mode === */
  :global([data-theme="light"]) .cta-primary { background: var(--accent); color: #ffffff; box-shadow: 0 10px 30px rgba(0,131,143,.2); }
  :global([data-theme="light"]) .cta-primary:hover { background: #00969e; }
  :global([data-theme="light"]) .hero-text { text-shadow: 0 0 60px rgba(255,255,255,0.8), 0 0 120px rgba(255,255,255,0.4); }

  /* === Responsive === */
  @media (max-width: 767px) {
    .hero { min-height: auto; padding-top: 3.5rem; padding-bottom: 1rem; }
    .hero .headline { font-size: clamp(1.5rem, 7vw, 2rem) !important; margin-bottom: 1rem !important; line-height: 1.1 !important; }
    .hero .hero-subtitle { font-size: 0.875rem !important; line-height: 1.55 !important; margin-bottom: 1rem !important; }
    .hero-proof { font-size: 0.75rem !important; margin-bottom: 1.5rem !important; }
    .hero-actions { flex-direction: column; gap: 0.5rem; }
    .cta-primary { width: 100%; max-width: none; padding: 12px 20px !important; font-size: 0.75rem !important; }
  }
  @media (max-width: 374px) {
    .hero .headline { font-size: 1.35rem !important; }
    .hero .hero-subtitle { font-size: 0.8125rem !important; }
    .cta-primary { padding: 10px 16px !important; font-size: 0.6875rem !important; }
  }

  /* === Reduced motion === */
  @media (prefers-reduced-motion: reduce) {
    .cta-primary { transition: none; }
  }

  /* === Print === */
  @media print {
    .hero-mesh, .globe-mobile, .hero-dissolve { display: none !important; }
  }
</style>

<script is:inline>
  // Fade out mesh gradient when 3D globe is ready
  (function() {
    var hero = document.getElementById('hero');
    if (!hero) return;
    hero.addEventListener('globe-ready', function() {
      var mesh = hero.querySelector('.hero-mesh');
      if (mesh) {
        mesh.style.setProperty('animation', 'none', 'important');
        mesh.style.setProperty('opacity', '0', 'important');
      }
    });
  })();
</script>
