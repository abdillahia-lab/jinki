  {
    title: "Energy Grid",
    icon: "electric_bolt",
    img: "https://lh3.googleusercontent.com/aida-public/AB6AXuDCZ2S_AXbpqohGFOt8JiOIQHZu69FN4Pm7CPmnAsP6tkDnnH0yZKCZktPxZo_4_QNxdtwrdh9gOquvVlMD8WTQCRrL9-NZ6Pk_ReW6x_ZbgQb_OZv0eaapl2XhYZyWws4tlApotdvQXj-NHIM-zvHiU-oB60RY0wEMfBC3tnJqG-4Yem-zSDHaoAxzxVEskMb1KQNUg085aDuH3t9nZo1bCqZM3MyzPnVu8y3Tl_tN7t7tI7fqDUvNn4UOQ03q-9obbOUqRJZQs00y",
