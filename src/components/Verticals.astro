  {
    title: "Security",
    icon: "security",
    img: "https://lh3.googleusercontent.com/aida/ADBb0ujoL7fVnboOTJkoXrd2ACk3OzVpiWOAz4H-sqpGSFLCsJi5sDYYGATHAYtpBoWjkr-04fwGTrePKTst8g4_9Lw8fIMARGdA87tvqERMfwgmwiYbRlkiEFZWx4Y6IhboC9kuPvEYZirU-qblF-zHYH47qCC5cunj6o4ITIdvm5mfkAYNe84mhcoEWzZDKKrSysgb9glU2_pewA2kqm30G-gq_E200nh17q3a1RqWS_KObnk7onwJICVLyccnSBKJJHmy8dYhZz6Q74o",
    desc: "Automated perimeter monitoring with real-time intrusion alerts and event reports.",
