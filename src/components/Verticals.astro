---
/**
 * Verticals.astro — Industrial verticals section
 * Four-column card grid showcasing target industries.
 */

const verticals = [
  {
    title: "Data Centers",
    icon: "dns",
    img: "/images/dc-rooftop-aerial.jpg",
    webp: "/images/dc-rooftop-aerial.webp",
    imgAlt: "Aerial view of a commercial building rooftop with HVAC equipment",
    gradient: "",
    accent: "#00E5FF",
    desc: "Thermal scans that detect hotspots within 0.5\u00B0C accuracy, pinpointing cooling failures and roof damage before they cause unplanned downtime.",
    link: "/verticals/data-centers",
  },
  {
    title: "Energy & Utilities",
    icon: "electric_bolt",
    img: "/images/energy-powerlines.jpg",
    imgAlt: "Power transmission lines and towers against a blue sky",
    gradient: "",
    accent: "#FF8C00",
    desc: "Condition assessments for power lines, substations, and solar arrays \u2014 inspecting 50+ miles of corridor per day without service interruption.",
    link: "/verticals/energy-grid",
  },
  {
    title: "Perimeter Security",
    icon: "security",
    img: "/images/facility-night-aerial.jpg",
    webp: "/images/facility-night-aerial.webp",
    imgAlt: "Industrial facility complex illuminated at night with perimeter lighting",
    gradient: "",
    accent: "#7B61FF",
    desc: "Persistent aerial monitoring covering 500+ acre perimeters with thermal intrusion detection and autonomous response capability.",
    link: "/verticals/security",
  },
  {
    title: "Agriculture",
    icon: "agriculture",
    img: "/images/agriculture-fields.jpg",
    imgAlt: "Aerial view of agricultural fields showing crop patterns",
    gradient: "",
    accent: "#34D399",
    desc: "Thermal crop stress detection, irrigation analysis, and yield intelligence across thousands of acres \u2014 identifying water stress and field issues before they impact harvest.",
    link: "/verticals/agriculture",
  },
];
---

<section id="verticals" class="verticals-section" aria-label="Industries We Serve">
  <div class="verticals-container">
    <!-- Header -->
    <div class="verticals-header reveal">
      <div class="verticals-header-copy">
        <div class="verticals-eyebrow-row">
          <span class="verticals-accent-line"></span>
          <span class="section-eyebrow">Verticals</span>
        </div>
        <h2 class="verticals-title">
          Find Your Industry
        </h2>
        <p class="verticals-subtitle">
          Each vertical gets purpose-built intelligence — not generic data dumps.
        </p>
      </div>
      <a href="#lead-gen" class="verticals-cta">
        Request Assessment
        <span class="arrow-icon">&rarr;</span>
      </a>
    </div>

    <!-- 4-column grid -->
    <div class="verticals-grid reveal-stagger reveal">
      {verticals.map((v) => (
        <a href={v.link} class="vertical-card" data-tilt style={`--card-accent: ${v.accent};${v.gradient ? ` background: ${v.gradient};` : ''}`}>
          {v.img ? (
            <picture>
              {v.webp && <source srcset={v.webp} type="image/webp" />}
              <img
                src={v.img}
                alt={v.imgAlt || v.title}
                class="vertical-card-img"
                loading="lazy"
                decoding="async"
              />
            </picture>
          ) : (
            <div class="vertical-card-pattern" aria-hidden="true"></div>
          )}
          <div class="card-overlay"></div>
          <div class="vertical-card-content">
            <span class="material-symbols-outlined vertical-card-icon" aria-hidden="true">
              {v.icon}
            </span>
            <h3 class="vertical-card-heading">{v.title}</h3>
            <p class="card-desc">
              {v.desc}
            </p>
            <span class="card-cta">
              Explore
              <span class="material-symbols-outlined card-cta-arrow" aria-hidden="true">arrow_forward</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* --- Section & container --- */
  .verticals-section {
    background: var(--surface-dim);
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  @media (min-width: 768px) {
    .verticals-section { padding-top: 10rem; padding-bottom: 10rem; }
  }

  .verticals-container {
    max-width: var(--container-max);
    margin-left: auto;
    margin-right: auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  /* --- Header --- */
  .verticals-header {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3.5rem;
  }

  @media (min-width: 768px) {
    .verticals-header { flex-direction: row; }
  }

  .verticals-header-copy {
    max-width: 36rem;
  }

  .verticals-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .verticals-accent-line {
    display: block;
    height: 1px;
    width: 2rem;
    background: var(--accent);
  }

  .verticals-title {
    font-family: var(--font-headline);
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
  }

  .verticals-subtitle {
    font-size: 1.125rem;
    font-weight: 300;
    color: var(--text-secondary);
    margin-top: 1rem;
  }

  .verticals-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.875rem;
    font-weight: 600;
    margin-top: 1.5rem;
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  /* --- Card grid --- */
  .verticals-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .verticals-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  }
  @media (min-width: 1024px) {
    .verticals-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .vertical-card {
    position: relative;
    display: block;
    text-decoration: none;
    aspect-ratio: 3 / 4.2;
    border-radius: 0.75rem;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid transparent;
    transition: transform 0.5s var(--ease-out-premium),
                border-color 0.5s var(--ease-out-premium),
                box-shadow 0.5s var(--ease-out-premium);
  }

  .vertical-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vertical-card-pattern {
    position: absolute;
    inset: 0;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
  }

  .vertical-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 10;
    padding: 1.75rem 2rem 2rem;
  }

  .vertical-card-icon {
    font-variation-settings: 'FILL' 1;
    margin-bottom: 0.75rem;
    display: block;
    font-size: 1.75rem;
    color: var(--accent);
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .vertical-card-heading {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 700;
    color: #ffffff;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6), 0 4px 12px rgba(0,0,0,0.3);
  }
  /* Top accent line */
  .vertical-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent)), transparent);
    opacity: 0;
    z-index: 20;
    transition: opacity 0.5s var(--ease-out-premium);
  }
  /* Bottom accent border on hover */
  .vertical-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--card-accent, var(--accent));
    opacity: 0;
    z-index: 20;
    transform: scaleX(0);
    transition: opacity 0.5s var(--ease-out-premium),
                transform 0.5s var(--ease-out-premium);
  }
  .vertical-card:hover::before { opacity: 1; }
  .vertical-card:hover::after { opacity: 1; transform: scaleX(1); }
  .vertical-card:hover {
    transform: scale(1.02) translateY(-6px);
    border-color: color-mix(in srgb, var(--accent) 20%, transparent);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35), 0 0 40px color-mix(in srgb, var(--accent) 6%, transparent);
  }

  .verticals-cta:hover { gap: 0.75rem; }
  .verticals-cta:hover .arrow-icon { transform: translateX(4px); }
  .arrow-icon { transition: transform 0.35s var(--ease-out-premium); }

  /* Parallax-lite: scale + vertical lift on hover */
  .vertical-card-img {
    /* transition added here; position/sizing defined above */
    transition: transform 0.6s var(--ease-out-premium);
    transform: scale(1) translateY(0);
    will-change: transform;
  }
  .vertical-card:hover .vertical-card-img {
    transform: scale(1.08) translateY(-8px);
  }

  .card-overlay {
    background: linear-gradient(to top, rgba(5,5,8,0.98) 0%, rgba(5,5,8,0.92) 25%, rgba(5,5,8,0.65) 50%, rgba(5,5,8,0.25) 70%, rgba(5,5,8,0.08) 85%, rgba(5,5,8,0.02) 100%);
    transition: background 0.6s var(--ease-out-premium);
  }
  .vertical-card:hover .card-overlay {
    background: linear-gradient(to top, rgba(5,5,8,1) 0%, rgba(5,5,8,0.97) 25%, rgba(5,5,8,0.78) 50%, rgba(5,5,8,0.38) 70%, rgba(5,5,8,0.14) 85%, rgba(5,5,8,0.04) 100%);
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.55;
    margin-top: 0.5rem;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
  }

  .card-cta {
    font-family: var(--font-label);
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-shadow: none;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease-out-premium),
                transform 0.4s var(--ease-out-premium);
  }

  .card-cta-arrow {
    font-size: 1rem;
  }

  .card-cta .material-symbols-outlined {
    transition: transform 0.35s var(--ease-out-premium);
  }
  .vertical-card:hover .card-cta,
  .vertical-card:focus-within .card-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .vertical-card:hover .card-cta .material-symbols-outlined {
    transform: translateX(4px);
  }

  @media (max-width: 767px) {
    .vertical-card { aspect-ratio: 4 / 3; }
  }

  /* CSS-only pattern for gradient cards — grid + glow */
  .vertical-card-pattern {
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px),
      radial-gradient(ellipse at 60% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
      radial-gradient(circle at 40% 70%, color-mix(in srgb, var(--accent) 12%, transparent) 0%, transparent 40%);
    background-size: 40px 40px, 40px 40px, 100% 100%, 100% 100%;
    transition: opacity 0.5s ease;
  }
  .vertical-card:hover .vertical-card-pattern {
    opacity: 0.7;
  }

  /* Mobile: always show Explore CTA (no hover on touch) */
  @media (max-width: 767px) {
    .card-cta { opacity: 0.8; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .vertical-card, .vertical-card::before, .vertical-card::after, .card-cta, .card-cta .material-symbols-outlined, .arrow-icon { transition: none; }
    .vertical-card img, .vertical-card-img, .card-overlay { transition: none; }
    .vertical-card:hover .vertical-card-img { transform: scale(1.04) translateY(0); }
  }

  :global([data-theme="light"]) .card-overlay {
    background: linear-gradient(to top, rgba(10,12,14,0.97) 0%, rgba(10,12,14,0.88) 25%, rgba(10,12,14,0.5) 50%, rgba(10,12,14,0.12) 70%, transparent 100%);
  }
</style>
