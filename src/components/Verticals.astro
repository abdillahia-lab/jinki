---
/**
 * Verticals.astro — Industrial verticals section
 * Four-column card grid showcasing target industries.
 */

const verticals = [
  {
    title: "Data Centers",
    icon: "dns",
    img: "/images/dc-rooftop-aerial.jpg",
    webp: "/images/dc-rooftop-aerial.webp",
    imgAlt: "Aerial view of a commercial building rooftop with HVAC equipment",
    gradient: "",
    accent: "#00E5FF",
    desc: "Thermal scans that detect hotspots within 0.5\u00B0C accuracy, pinpointing cooling failures and roof damage before they cause unplanned downtime.",
    link: "/verticals/data-centers",
  },
  {
    title: "Energy & Utilities",
    icon: "electric_bolt",
    img: "/images/energy-powerlines.jpg",
    imgAlt: "Power transmission lines and towers against a blue sky",
    gradient: "",
    accent: "#FF8C00",
    desc: "Condition assessments for power lines, substations, and solar arrays \u2014 inspecting 50+ miles of corridor per day without service interruption.",
    link: "/verticals/energy-grid",
  },
  {
    title: "Perimeter Security",
    icon: "security",
    img: "/images/facility-night-aerial.jpg",
    webp: "/images/facility-night-aerial.webp",
    imgAlt: "Industrial facility complex illuminated at night with perimeter lighting",
    gradient: "",
    accent: "#7B61FF",
    desc: "Persistent aerial monitoring covering 500+ acre perimeters with thermal intrusion detection and autonomous response capability.",
    link: "/verticals/security",
  },
  {
    title: "Agriculture",
    icon: "agriculture",
    img: "/images/agriculture-fields.jpg",
    imgAlt: "Aerial view of agricultural fields showing crop patterns",
    gradient: "",
    accent: "#34D399",
    desc: "Thermal crop stress detection, irrigation analysis, and yield intelligence across thousands of acres \u2014 identifying water stress and field issues before they impact harvest.",
    link: "/verticals/agriculture",
  },
];
---

<section id="verticals" class="verticals-section" style="background: var(--surface-dim); padding-top: 7rem; padding-bottom: 7rem;" aria-label="Industries We Serve">
  <div style="max-width: 80rem; margin-left: auto; margin-right: auto; padding-left: 1.5rem; padding-right: 1.5rem;">
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-end reveal" style="margin-bottom: 3.5rem;">
      <div class="max-w-xl">
        <div class="flex items-center gap-3" style="margin-bottom: 1rem;">
          <span class="block h-[1px] w-8" style="background: var(--accent);"></span>
          <span class="section-eyebrow">Verticals</span>
        </div>
        <h2 class="font-headline text-4xl md:text-5xl font-bold" style="color: var(--text-primary);">
          Industries We Serve
        </h2>
        <p class="text-lg font-light" style="color: var(--text-secondary); margin-top: 1rem;">
          Aerial intelligence tailored to each sector — from 0.5°C thermal precision for data centers to 50+ mile daily corridor inspections for energy infrastructure.
        </p>
      </div>
      <a href="#lead-gen" class="verticals-cta inline-flex items-center gap-2 text-[var(--accent)] uppercase tracking-[0.2em] text-sm font-semibold" style="margin-top: 1.5rem;">
        Get Started
        <span class="arrow-icon inline-block">&rarr;</span>
      </a>
    </div>

    <!-- 4-column grid -->
    <div class="verticals-grid">
      {verticals.map((v) => (
        <a href={v.link} class="group relative rounded-xl overflow-hidden vertical-card reveal" data-tilt style={`--card-accent: ${v.accent}; aspect-ratio: 3 / 4.2; display: block; text-decoration: none;${v.gradient ? ` background: ${v.gradient};` : ''}`}>
          {v.img ? (
            <picture>
              {v.webp && <source srcset={v.webp} type="image/webp" />}
              <img
                src={v.img}
                alt={v.imgAlt || v.title}
                class="absolute inset-0 w-full h-full object-cover vertical-card-img"
                loading="lazy"
                decoding="async"
              />
            </picture>
          ) : (
            <div class="absolute inset-0 vertical-card-pattern" aria-hidden="true"></div>
          )}
          <div class="card-overlay absolute inset-0"></div>
          <div class="absolute bottom-0 left-0 right-0 z-10" style="padding: 1.75rem 2rem 2rem;">
            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; margin-bottom: 0.75rem; display: block; font-size: 1.75rem; color: var(--accent); text-shadow: 0 2px 8px rgba(0,0,0,0.5);" aria-hidden="true">
              {v.icon}
            </span>
            <h3 class="font-headline text-2xl font-bold" style="color: #ffffff; text-shadow: 0 1px 3px rgba(0,0,0,0.6), 0 4px 12px rgba(0,0,0,0.3);">{v.title}</h3>
            <p class="card-desc" style="margin-top: 0.5rem; color: rgba(255,255,255,0.85); text-shadow: 0 1px 3px rgba(0,0,0,0.5);">
              {v.desc}
            </p>
            <span class="card-cta" style="display: inline-flex; align-items: center; gap: 0.375rem; margin-top: 1rem; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--accent); text-shadow: none;">
              Explore
              <span class="material-symbols-outlined" style="font-size: 1rem;" aria-hidden="true">arrow_forward</span>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .verticals-section { padding-top: 8rem !important; padding-bottom: 8rem !important; }
  }

  .verticals-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .verticals-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  }
  @media (min-width: 1024px) {
    .verticals-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .vertical-card {
    cursor: pointer;
    border: 1px solid transparent;
    transition: transform 0.5s var(--ease-out-premium),
                border-color 0.5s var(--ease-out-premium),
                box-shadow 0.5s var(--ease-out-premium);
  }
  /* Top accent line */
  .vertical-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--card-accent, var(--accent)), transparent);
    opacity: 0;
    z-index: 20;
    transition: opacity 0.5s var(--ease-out-premium);
  }
  /* Bottom accent border on hover */
  .vertical-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--card-accent, var(--accent));
    opacity: 0;
    z-index: 20;
    transform: scaleX(0);
    transition: opacity 0.5s var(--ease-out-premium),
                transform 0.5s var(--ease-out-premium);
  }
  .vertical-card:hover::before { opacity: 1; }
  .vertical-card:hover::after { opacity: 1; transform: scaleX(1); }
  .vertical-card:hover {
    transform: scale(1.02) translateY(-6px);
    border-color: rgba(0, 229, 255, 0.2);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.35), 0 0 40px rgba(0, 229, 255, 0.06);
  }

  .verticals-cta {
    transition: gap 0.3s ease;
  }
  .verticals-cta:hover { gap: 0.75rem; }
  .verticals-cta:hover .arrow-icon { transform: translateX(4px); }
  .arrow-icon { transition: transform 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)); }

  /* Parallax-lite: scale + vertical lift on hover */
  .vertical-card-img {
    transition: transform 0.6s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
    transform: scale(1) translateY(0);
    will-change: transform;
  }
  .vertical-card:hover .vertical-card-img {
    transform: scale(1.08) translateY(-8px);
  }

  .card-overlay {
    background: linear-gradient(to top, rgba(5,5,8,0.98) 0%, rgba(5,5,8,0.92) 25%, rgba(5,5,8,0.65) 50%, rgba(5,5,8,0.25) 70%, rgba(5,5,8,0.08) 85%, rgba(5,5,8,0.02) 100%);
    transition: background 0.6s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .vertical-card:hover .card-overlay {
    background: linear-gradient(to top, rgba(5,5,8,1) 0%, rgba(5,5,8,0.97) 25%, rgba(5,5,8,0.78) 50%, rgba(5,5,8,0.38) 70%, rgba(5,5,8,0.14) 85%, rgba(5,5,8,0.04) 100%);
  }

  .card-desc {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.55;
  }

  .card-cta {
    font-family: var(--font-label);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                transform 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .card-cta .material-symbols-outlined {
    transition: transform 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .vertical-card:hover .card-cta,
  .vertical-card:focus-within .card-cta {
    opacity: 1;
    transform: translateY(0);
  }
  .vertical-card:hover .card-cta .material-symbols-outlined {
    transform: translateX(4px);
  }

  @media (max-width: 767px) {
    .vertical-card { aspect-ratio: 4 / 3 !important; }
  }

  /* CSS-only pattern for gradient cards — grid + glow */
  .vertical-card-pattern {
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px),
      radial-gradient(ellipse at 60% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
      radial-gradient(circle at 40% 70%, rgba(0,229,255,0.12) 0%, transparent 40%);
    background-size: 40px 40px, 40px 40px, 100% 100%, 100% 100%;
    transition: opacity 0.5s ease;
  }
  .vertical-card:hover .vertical-card-pattern {
    opacity: 0.7;
  }

  /* Mobile: always show Explore CTA (no hover on touch) */
  @media (max-width: 767px) {
    .card-cta { opacity: 0.8 !important; transform: translateY(0) !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .vertical-card, .vertical-card::before, .vertical-card::after, .card-cta, .card-cta .material-symbols-outlined, .arrow-icon { transition: none; }
    .vertical-card img, .vertical-card-img, .card-overlay { transition: none; }
    .vertical-card:hover .vertical-card-img { transform: scale(1.04) translateY(0); }
  }

  :global([data-theme="light"]) .card-overlay {
    background: linear-gradient(to top, rgba(10,12,14,0.97) 0%, rgba(10,12,14,0.88) 25%, rgba(10,12,14,0.5) 50%, rgba(10,12,14,0.12) 70%, transparent 100%);
  }
</style>
