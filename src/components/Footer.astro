---
/*
  Footer — Jinki Aerial Intelligence
  4-column grid, newsletter, status indicator, copyright bar.
  Zero JavaScript.
*/
const products = [
  { href: '/services/intelligence-scan', label: 'Facility Intelligence Scan' },
  { href: '/services/deployment', label: 'Autonomous Deployment' },
  { href: '/verticals/data-centers', label: 'Data Centers' },
  { href: '/verticals/energy-grid', label: 'Energy Grid' },
  { href: '/verticals/security', label: 'Perimeter Security' },
  { href: '/verticals/agriculture', label: 'Agriculture' },
];
const company = [
  { href: '/about', label: 'About Us' },
  { href: '/careers', label: 'Careers' },
  { href: '/blog', label: 'Blog' },
  { href: '/security', label: 'Security' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
];
---

<div class="footer-divider"></div>

<footer class="footer-main" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand + Social -->
      <div>
        <div class="footer-logo-row">
          <a href="/" aria-label="Jinki — Home" class="footer-logo-link"><svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M8 22 C10 14 18 8 26 10 C34 12 36 20 33 27 C30 34 20 37 13 33 C6 29 6 26 8 22Z" stroke="var(--text-tertiary)" stroke-width="1" opacity="0.4" stroke-linecap="round"/>
            <path d="M13 21 C14 16 20 12 26 14 C32 16 33 22 30 27 C27 32 20 33 16 30 C12 27 12 24 13 21Z" stroke="var(--accent)" stroke-width="1.1" opacity="0.6" stroke-linecap="round"/>
            <path d="M17 20 C18 17 22 15 25 17 C28 19 28 23 26 26 C24 29 20 29 18 27 C16 25 16 22 17 20Z" stroke="var(--accent)" stroke-width="1.3" opacity="0.85" stroke-linecap="round"/>
            <path d="M6 33 C12 26 18 20 22 18 C26 16 32 10 36 6" stroke="var(--accent)" stroke-width="1.5" opacity="0.9" stroke-linecap="round"/>
            <circle cx="22" cy="18" r="2.5" fill="var(--accent)" opacity="0.95"/>
          </svg></a>
          <span class="footer-logo-text">Jinki</span>
        </div>
        <p class="footer-tagline">Aerial intelligence and actionable insights for the infrastructure that keeps the world running.</p>
        <div class="footer-status" aria-label="System status">
          <span class="status-dot"></span>
          <span class="status-text">Booking Q3 2026 Assessments</span>
        </div>
        <a href="mailto:info@jinki.ai" class="footer-email-link">info@jinki.ai</a>
      </div>

      <!-- Products & Services -->
      <div>
        <h3 class="footer-col-title">Products & Services</h3>
        <ul class="footer-links">
          {products.map(link => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="footer-col-title">Company</h3>
        <ul class="footer-links">
          {company.map(link => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="footer-col-title">Stay Informed</h3>
        <p class="footer-newsletter-desc">Monthly intelligence on infrastructure risks, maintenance optimization, and what leading facilities teams are doing differently.</p>
        <form class="footer-newsletter-form" action="https://api.web3forms.com/submit" method="POST" aria-label="Newsletter signup">
          <!-- Web3Forms integration -->
          <input type="hidden" name="access_key" value="b2bd961c-acf2-48a6-bf10-a5717c2dea95" />
          <input type="hidden" name="subject" value="Newsletter Signup from jinki.ai" />
          <input type="hidden" name="from_name" value="Jinki Newsletter" />
          <input type="hidden" name="redirect" value="https://jinki.ai/?subscribed=true" />
          <div aria-hidden="true" class="honeypot"><input type="text" name="botcheck" tabindex="-1" autocomplete="off" /></div>
          <div class="footer-input-row">
            <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" class="footer-email-input" maxlength="254" autocomplete="email" inputmode="email" enterkeyhint="send" />
            <button type="submit" class="footer-submit-btn" aria-label="Subscribe">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
          <p class="footer-newsletter-note">No spam. Unsubscribe anytime.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- Status Bar -->
  <div class="footer-status-bar">
    <div class="footer-status-inner">
      <div class="footer-status-left">
        <span class="status-dot status-dot--blink"></span>
        <span class="status-label">Jinki Aerial Intelligence</span>
      </div>
      <span class="status-uptime">Booking Q3 2026 Assessments</span>
    </div>
  </div>

  <!-- Partner Badges -->
  <div class="footer-badges">
    <div class="footer-badges-inner">
      <a href="https://www.nvidia.com/en-us/startups/" target="_blank" rel="noopener noreferrer" aria-label="NVIDIA Inception Program member" class="footer-badge-link">
        <img src="/images/nvidia-inception-badge-color.svg" alt="NVIDIA Inception Program" class="footer-badge footer-badge--dark" width="180" height="78" loading="lazy" decoding="async" />
        <img src="/images/nvidia-inception-badge-black.svg" alt="NVIDIA Inception Program" class="footer-badge footer-badge--light" width="180" height="78" loading="lazy" decoding="async" />
      </a>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="footer-copyright-bar">
    <div class="footer-copyright-inner">
      <p class="footer-copyright-text">&copy; {new Date().getFullYear()} Jinki Aerial Intelligence. All rights reserved.</p>
      <div class="footer-legal-links">
        <a href="/privacy">Privacy</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/terms">Terms</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/data-security">Data Security</a>
        <span aria-hidden="true">&middot;</span>
        <button type="button" data-cookie-settings class="footer-cookie-btn">Cookies</button>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
(function() {
  var form = document.querySelector('.footer-newsletter-form');
  if (!form) return;
  var submitting = false;
  var lastFooterSubmit = 0;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (submitting) return;
    var now = Date.now();
    if (now - lastFooterSubmit < 5000) return;
    lastFooterSubmit = now;
    var emailInput = form.querySelector('input[type="email"]');
    var btn = form.querySelector('.footer-submit-btn');
    var note = form.querySelector('.footer-newsletter-note');
    if (!emailInput.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailInput.value)) {
      note.textContent = 'Please enter a valid email address.';
      note.style.color = '#ff6b6b';
      return;
    }
    submitting = true;
    btn.disabled = true;
    btn.style.opacity = '0.5';
    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) {
        note.textContent = 'Subscribed! Welcome to Jinki intelligence.';
        note.style.color = '#34d399';
        form.querySelector('input[type="email"]').value = '';
      } else {
        note.textContent = 'Something went wrong. Try again.';
        note.style.color = '#ff6b6b';
      }
      submitting = false;
      btn.disabled = false;
      btn.style.opacity = '1';
    }).catch(function() {
      note.textContent = 'Connection error. Try again.';
      note.style.color = '#ff6b6b';
      submitting = false;
      btn.disabled = false;
      btn.style.opacity = '1';
    });
  });
})();
</script>

<style>
  .footer-divider {
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 5%,
      var(--accent) 25%,
      var(--accent-secondary) 50%,
      transparent 85%
    );
    opacity: 0.5;
  }
  :global([data-theme="light"]) .footer-divider {
    background: linear-gradient(
      to right,
      transparent 5%,
      #0891b2 25%,
      #6d28d9 50%,
      transparent 85%
    );
    opacity: 0.35;
  }
  .footer-main { position: relative; background: var(--surface-container-lowest); }
  .footer-main::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 600px; height: 400px; background: radial-gradient(ellipse, var(--accent-glow) 0%, transparent 70%);
    opacity: 0.3; pointer-events: none;
  }
  .footer-inner { max-width: var(--container-max); margin: 0 auto; padding: 96px 32px 56px; position: relative; z-index: 1; }
  .footer-grid { display: grid; grid-template-columns: 1.3fr 1fr 1fr 1.2fr; gap: 48px; }
  @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; } }
  @media (max-width: 767px) { .footer-grid { grid-template-columns: 1fr; gap: 36px; } .footer-inner { padding: 56px 24px 32px; } .footer-links { gap: 16px; } .footer-links a { padding: 4px 0; } }

  .footer-status {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 16px; margin-bottom: 8px;
    padding: 8px 16px; border-radius: 8px;
    background: rgba(52, 211, 153, 0.06);
    border: 1px solid rgba(52, 211, 153, 0.15);
  }
  /* Footer status badge dot — expanding ring pulse */
  .footer-status .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent-tertiary);
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    position: relative;
    animation: none;
    flex-shrink: 0;
  }
  .footer-status .status-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid var(--accent-tertiary);
    animation: dotRingPulse 2.5s ease-out infinite;
  }
  @keyframes dotRingPulse {
    0% { transform: scale(0.8); opacity: 0.8; }
    60% { transform: scale(2.2); opacity: 0; }
    100% { transform: scale(2.2); opacity: 0; }
  }
  .status-text {
    font-family: var(--font-mono); font-size: 0.75rem; font-weight: 500;
    letter-spacing: 0.06em; color: var(--accent-tertiary);
  }

  /* Status bar dot — blinking */
  .status-dot--blink {
    animation: statusBlink 2s steps(1) infinite !important;
  }
  @keyframes statusBlink {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(52, 211, 153, 0.6); }
    50% { opacity: 0.3; box-shadow: 0 0 3px rgba(52, 211, 153, 0.2); }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-status .status-dot::after { animation: none; display: none; }
    .status-dot--blink { animation: none !important; }
  }

  @media (max-width: 767px) {
    .footer-status .status-dot::after { animation: none; display: none; }
    .status-dot--blink { animation: none !important; }
  }

  .footer-logo-link { display: flex; text-decoration: none; }
  .footer-email-link { display: inline-block; margin-top: 8px; font-family: var(--font-mono); font-size: 0.75rem; color: var(--accent); text-decoration: none; transition: color 0.25s ease; }
  .footer-email-link:hover { color: var(--accent); text-shadow: 0 0 12px color-mix(in srgb, var(--accent) 30%, transparent); }
  .honeypot { position: absolute; left: -9999px; }
  .footer-cookie-btn { background: none; border: none; color: inherit; font: inherit; cursor: pointer; padding: 0; }

  .footer-logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .footer-logo-text { font-family: var(--font-headline); font-weight: 700; font-size: 1.25rem; letter-spacing: 0.02em; color: var(--text-primary); }
  .footer-tagline { font-family: var(--font-body); font-size: 0.875rem; line-height: 1.7; color: var(--text-secondary); max-width: 300px; margin-bottom: 24px; }
  .footer-col-title {
    font-family: var(--font-headline); font-weight: 700; font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-primary);
    margin-bottom: 24px; padding-bottom: 12px; border-bottom: 1px solid var(--glass-border); position: relative;
  }
  .footer-col-title::after { content: ''; position: absolute; bottom: -1px; left: 0; width: 28px; height: 1px; background: var(--accent); transition: width 0.4s var(--ease-out-premium); }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .footer-links a { font-family: var(--font-body); font-size: 0.875rem; color: var(--text-secondary); text-decoration: none; transition: color 0.2s ease; display: inline-block; }
  .footer-links a:hover { color: var(--accent); transform: translateX(4px); }
  .footer-links a { transition: color 0.25s ease, transform 0.3s var(--ease-out-premium); }

  .footer-newsletter-desc { font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 16px; }
  .footer-input-row { display: flex; border-radius: 12px; overflow: hidden; border: 1px solid var(--glass-border); background: var(--surface-container-low); transition: border-color 0.3s ease; }
  .footer-input-row:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow), inset 0 1px 12px color-mix(in srgb, var(--accent) 8%, transparent); }
  :global([data-theme="light"]) .footer-input-row:focus-within { box-shadow: 0 0 0 3px var(--accent-glow), inset 0 1px 12px rgba(8, 145, 178, 0.06); }
  .footer-email-input { flex: 1; background: transparent; border: none; outline: none; padding: 16px 16px; font-family: var(--font-body); font-size: 1rem; color: var(--text-primary); min-width: 0; min-height: 44px; }
  .footer-email-input::placeholder { color: var(--text-tertiary); }
  .footer-submit-btn { display: flex; align-items: center; justify-content: center; width: 46px; background: var(--accent); color: var(--text-on-accent); border: none; cursor: pointer; transition: background 0.2s ease; flex-shrink: 0; }
  .footer-submit-btn:hover { background: #00c8e0; transform: scale(1.05); }
  .footer-submit-btn { transition: background 0.2s ease, transform 0.3s var(--ease-out-premium); }
  .footer-newsletter-note { font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); margin-top: 8px; }

  .footer-status-bar { border-top: 1px solid var(--glass-border); background: var(--surface-container-low); position: relative; z-index: 1; }
  .footer-status-inner { max-width: var(--container-max); margin: 0 auto; padding: 16px 32px; display: flex; align-items: center; justify-content: space-between; }
  .footer-status-left { display: flex; align-items: center; gap: 12px; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-tertiary); flex-shrink: 0; box-shadow: 0 0 6px rgba(52,211,153,0.5); }
  .status-label { font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: var(--accent-tertiary); }
  .status-uptime { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-tertiary); }
  @media (max-width: 767px) { .footer-status-inner { padding: 12px 24px; flex-direction: column; gap: 8px; } }

  /* Partner Badges */
  .footer-badges { border-top: 1px solid var(--glass-border); background: var(--surface-container-low); position: relative; z-index: 1; }
  .footer-badges-inner { max-width: var(--container-max); margin: 0 auto; padding: 20px 32px; display: flex; align-items: center; justify-content: center; }
  .footer-badge-link { display: inline-flex; opacity: 0.7; transition: opacity 0.3s ease; }
  .footer-badge-link:hover { opacity: 1; }
  .footer-badge { height: auto; width: 180px; }
  .footer-badge--light { display: none; }
  :global([data-theme="light"]) .footer-badge--dark { display: none; }
  :global([data-theme="light"]) .footer-badge--light { display: block; }
  @media (max-width: 767px) { .footer-badges-inner { padding: 16px 24px; } .footer-badge { width: 150px; } }

  .footer-copyright-bar { border-top: 1px solid color-mix(in srgb, var(--accent) 6%, transparent); background: var(--surface-container-lowest); position: relative; z-index: 1; }
  .footer-copyright-inner { max-width: var(--container-max); margin: 0 auto; padding: 20px 32px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .footer-copyright-text { font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); }
  .footer-legal-links { display: flex; align-items: center; gap: 8px; }
  .footer-legal-links a { font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); text-decoration: none; transition: color 0.2s ease; }
  .footer-legal-links a:hover { color: var(--accent); }
  .footer-legal-links span { color: var(--text-tertiary); opacity: 0.4; font-size: 0.75rem; }
  @media (max-width: 767px) { .footer-copyright-inner { padding: 16px 24px; flex-direction: column; text-align: center; } }

  @media (prefers-reduced-motion: reduce) { .footer-submit-btn, .footer-links a { transition: none; } }
  @media print { .footer-main { background: #fff !important; } .footer-status-bar { display: none !important; } }

  :global([data-theme="light"]) .footer-email-link:hover { text-shadow: none; }
  :global([data-theme="light"]) .footer-copyright-bar { border-top-color: rgba(0, 0, 0, 0.06); }
</style>

<!-- Newsletter handled by Web3Forms script above -->
