---
/*
  Footer — Jinki Aerial Intelligence
  4-column grid, newsletter, status indicator, copyright bar.
  Zero JavaScript.
*/
const products = [
  { href: '/services/audit', label: 'Facility Intelligence Scan' },
  { href: '/services/deployment', label: 'Autonomous Deployment' },
  { href: '/verticals/data-centers', label: 'Data Centers' },
  { href: '/verticals/energy-grid', label: 'Energy Grid' },
  { href: '/verticals/security', label: 'Perimeter Security' },
  { href: '/verticals/agriculture', label: 'Agriculture' },
];
const company = [
  { href: '/about', label: 'About Us' },
  { href: '/careers', label: 'Careers' },
  { href: '/blog', label: 'Blog' },
  { href: '/security', label: 'Security' },
  { href: '/privacy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms of Service' },
];
---

<div class="footer-divider"></div>

<footer class="footer-main" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-grid">

      <!-- Brand + Social -->
      <div>
        <div class="footer-logo-row">
          <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M8 22 C10 14 18 8 26 10 C34 12 36 20 33 27 C30 34 20 37 13 33 C6 29 6 26 8 22Z" stroke="var(--text-tertiary)" stroke-width="1" opacity="0.4" stroke-linecap="round"/>
            <path d="M13 21 C14 16 20 12 26 14 C32 16 33 22 30 27 C27 32 20 33 16 30 C12 27 12 24 13 21Z" stroke="var(--accent)" stroke-width="1.1" opacity="0.6" stroke-linecap="round"/>
            <path d="M17 20 C18 17 22 15 25 17 C28 19 28 23 26 26 C24 29 20 29 18 27 C16 25 16 22 17 20Z" stroke="var(--accent)" stroke-width="1.3" opacity="0.85" stroke-linecap="round"/>
            <path d="M6 33 C12 26 18 20 22 18 C26 16 32 10 36 6" stroke="var(--accent)" stroke-width="1.5" opacity="0.9" stroke-linecap="round"/>
            <circle cx="22" cy="18" r="2.5" fill="var(--accent)" opacity="0.95"/>
          </svg>
          <span class="footer-logo-text">Jinki</span>
        </div>
        <p class="footer-tagline">Aerial intelligence and actionable insights for the infrastructure that keeps the world running.</p>
        <div class="footer-status" aria-label="System status">
          <span class="status-dot"></span>
          <span class="status-text">Systems Operational</span>
        </div>
        <a href="mailto:info@jinki.ai" style="display: inline-block; margin-top: 8px; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-tertiary); text-decoration: none; transition: color 0.2s ease;">info@jinki.ai</a>
        <div class="footer-socials">
          <a href="#" class="footer-social-btn" aria-label="Follow us on X">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="footer-social-btn" aria-label="Connect on LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="footer-social-btn" aria-label="Follow us on Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Products & Services -->
      <div>
        <h3 class="footer-col-title">Products & Services</h4>
        <ul class="footer-links">
          {products.map(link => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="footer-col-title">Company</h4>
        <ul class="footer-links">
          {company.map(link => <li><a href={link.href}>{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="footer-col-title">Stay Informed</h4>
        <p class="footer-newsletter-desc">Industry insights, product updates, and aerial intelligence news delivered monthly.</p>
        <form class="footer-newsletter-form" action="https://api.web3forms.com/submit" method="POST" aria-label="Newsletter signup">
          <!-- Web3Forms integration -->
          <input type="hidden" name="access_key" value="b2bd961c-acf2-48a6-bf10-a5717c2dea95" />
          <input type="hidden" name="subject" value="Newsletter Signup from jinki.ai" />
          <input type="hidden" name="from_name" value="Jinki Newsletter" />
          <input type="hidden" name="redirect" value="https://jinki.ai/?subscribed=true" />
          <div aria-hidden="true" style="position:absolute;left:-9999px;"><input type="text" name="botcheck" tabindex="-1" autocomplete="off" /></div>
          <div class="footer-input-row">
            <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" class="footer-email-input" />
            <button type="submit" class="footer-submit-btn" aria-label="Subscribe">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
          <p class="footer-newsletter-note">No spam. Unsubscribe anytime.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- Status Bar -->
  <div class="footer-status-bar">
    <div class="footer-status-inner">
      <div class="footer-status-left">
        <span class="status-dot"></span>
        <span class="status-label">Jinki Platform</span>
      </div>
      <span class="status-uptime">Ready to Deploy</span>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="footer-copyright-bar">
    <div class="footer-copyright-inner">
      <p class="footer-copyright-text">&copy; 2026 Jinki Aerial Intelligence. All rights reserved.</p>
      <div class="footer-legal-links">
        <a href="/privacy">Privacy</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/terms">Terms</a>
        <span aria-hidden="true">&middot;</span>
        <a href="/security">Security</a>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
(function() {
  var form = document.querySelector('.footer-newsletter-form');
  if (!form) return;
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn = form.querySelector('.footer-submit-btn');
    var note = form.querySelector('.footer-newsletter-note');
    btn.disabled = true;
    btn.style.opacity = '0.5';
    fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      body: new FormData(form),
      headers: { 'Accept': 'application/json' }
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.success) {
        note.textContent = 'Subscribed! Welcome to Jinki intelligence.';
        note.style.color = '#34d399';
        form.querySelector('input[type="email"]').value = '';
      } else {
        note.textContent = 'Something went wrong. Try again.';
        note.style.color = '#ff6b6b';
      }
      btn.disabled = false;
      btn.style.opacity = '1';
    }).catch(function() {
      note.textContent = 'Connection error. Try again.';
      note.style.color = '#ff6b6b';
      btn.disabled = false;
      btn.style.opacity = '1';
    });
  });
})();
</script>

<style>
  .footer-divider { height: 1px; background: linear-gradient(to right, transparent, var(--border), transparent); }
  .footer-main { position: relative; background: var(--surface-container-lowest); }
  .footer-main::before {
    content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
    width: 600px; height: 400px; background: radial-gradient(ellipse, var(--accent-glow) 0%, transparent 70%);
    opacity: 0.3; pointer-events: none;
  }
  .footer-inner { max-width: 1280px; margin: 0 auto; padding: 96px 32px 56px; position: relative; z-index: 1; }
  .footer-grid { display: grid; grid-template-columns: 1.3fr 1fr 1fr 1.2fr; gap: 48px; }
  @media (max-width: 1024px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; } }
  @media (max-width: 640px) { .footer-grid { grid-template-columns: 1fr; gap: 36px; } .footer-inner { padding: 56px 20px 32px; } .footer-links { gap: 16px; } .footer-links a { padding: 4px 0; } }

  .footer-status {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 16px; margin-bottom: 8px;
    padding: 6px 14px; border-radius: 8px;
    background: rgba(52, 211, 153, 0.06);
    border: 1px solid rgba(52, 211, 153, 0.15);
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #34D399;
    box-shadow: 0 0 8px rgba(52, 211, 153, 0.5);
    animation: statusPulse 2.5s ease-in-out infinite;
  }
  @keyframes statusPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(52, 211, 153, 0.4); }
    50% { opacity: 0.6; box-shadow: 0 0 3px rgba(52, 211, 153, 0.2); }
  }
  .status-text {
    font-family: var(--font-mono); font-size: 0.625rem; font-weight: 500;
    letter-spacing: 0.06em; color: #34D399;
  }
  @media (prefers-reduced-motion: reduce) { .status-dot { animation: none; } }

  .footer-logo-row { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .footer-logo-text { font-family: var(--font-headline); font-weight: 700; font-size: 1.25rem; letter-spacing: 0.02em; color: var(--text-primary); }
  .footer-tagline { font-family: var(--font-body); font-size: 0.875rem; line-height: 1.7; color: var(--text-secondary); max-width: 300px; margin-bottom: 24px; }
  .footer-socials { display: flex; gap: 10px; }
  .footer-social-btn {
    display: flex; align-items: center; justify-content: center; width: 42px; height: 42px;
    border-radius: 12px; color: var(--text-secondary); background: var(--surface-container-low);
    border: 1px solid var(--glass-border); transition: color 0.3s ease, background 0.3s ease, border-color 0.3s ease, transform 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)); text-decoration: none;
  }
  .footer-social-btn:hover { color: var(--accent); background: var(--accent-glow); border-color: rgba(0,229,255,0.2); transform: translateY(-3px); }

  .footer-col-title {
    font-family: var(--font-headline); font-weight: 700; font-size: 0.6875rem;
    text-transform: uppercase; letter-spacing: 0.15em; color: var(--text-primary);
    margin-bottom: 24px; padding-bottom: 10px; border-bottom: 1px solid var(--glass-border); position: relative;
  }
  .footer-col-title::after { content: ''; position: absolute; bottom: -1px; left: 0; width: 28px; height: 1px; background: var(--accent); transition: width 0.4s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)); }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .footer-links a { font-family: var(--font-body); font-size: 0.875rem; color: var(--text-secondary); text-decoration: none; transition: color 0.2s ease; display: inline-block; }
  .footer-links a:hover { color: var(--accent); transform: translateX(4px); }
  .footer-links a { transition: color 0.25s ease, transform 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)); }

  .footer-newsletter-desc { font-family: var(--font-body); font-size: 0.8125rem; color: var(--text-secondary); line-height: 1.65; margin-bottom: 16px; }
  .footer-input-row { display: flex; border-radius: 12px; overflow: hidden; border: 1px solid var(--glass-border); background: var(--surface-container-low); transition: border-color 0.3s ease; }
  .footer-input-row:focus-within { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
  .footer-email-input { flex: 1; background: transparent; border: none; outline: none; padding: 14px 16px; font-family: var(--font-body); font-size: 0.875rem; color: var(--text-primary); min-width: 0; min-height: 44px; }
  .footer-email-input::placeholder { color: var(--text-tertiary); }
  .footer-submit-btn { display: flex; align-items: center; justify-content: center; width: 46px; background: var(--accent); color: #050508; border: none; cursor: pointer; transition: background 0.2s ease; flex-shrink: 0; }
  .footer-submit-btn:hover { background: #00c8e0; transform: scale(1.05); }
  .footer-submit-btn { transition: background 0.2s ease, transform 0.3s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)); }
  .footer-newsletter-note { font-family: var(--font-body); font-size: 0.6875rem; color: var(--text-tertiary); margin-top: 8px; }

  .footer-status-bar { border-top: 1px solid var(--glass-border); background: var(--surface-container-low); position: relative; z-index: 1; }
  .footer-status-inner { max-width: 1280px; margin: 0 auto; padding: 14px 32px; display: flex; align-items: center; justify-content: space-between; }
  .footer-status-left { display: flex; align-items: center; gap: 10px; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; background: #34d399; flex-shrink: 0; box-shadow: 0 0 6px rgba(52,211,153,0.5); }
  .status-label { font-family: var(--font-body); font-size: 0.75rem; font-weight: 600; color: #34d399; }
  .status-uptime { font-family: var(--font-mono); font-size: 0.6875rem; color: var(--text-tertiary); }
  @media (max-width: 640px) { .footer-status-inner { padding: 12px 20px; flex-direction: column; gap: 8px; } }

  .footer-copyright-bar { border-top: 1px solid var(--glass-border); background: var(--surface-container-lowest); position: relative; z-index: 1; }
  .footer-copyright-inner { max-width: 1280px; margin: 0 auto; padding: 20px 32px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .footer-copyright-text { font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); }
  .footer-legal-links { display: flex; align-items: center; gap: 8px; }
  .footer-legal-links a { font-family: var(--font-body); font-size: 0.75rem; color: var(--text-tertiary); text-decoration: none; transition: color 0.2s ease; }
  .footer-legal-links a:hover { color: var(--accent); }
  .footer-legal-links span { color: var(--text-tertiary); opacity: 0.4; font-size: 0.75rem; }
  @media (max-width: 640px) { .footer-copyright-inner { padding: 16px 20px; flex-direction: column; text-align: center; } }

  @media (prefers-reduced-motion: reduce) { .footer-social-btn, .footer-submit-btn, .footer-links a { transition: none; } }
  @media print { .footer-main { background: #fff !important; } .footer-status-bar, .footer-social-btn { display: none !important; } }
</style>

<script is:inline>
(function() {
  var form = document.querySelector('.footer-newsletter-form');
  if (!form) return;
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var input = form.querySelector('.footer-email-input');
    var btn = form.querySelector('.footer-submit-btn');
    var note = form.querySelector('.footer-newsletter-note');
    if (!input || !input.value) return;

    btn.disabled = true;
    btn.style.opacity = '0.5';

    try {
      var res = await fetch('https://formspree.io/f/xpznqkdl', {
        method: 'POST',
        body: JSON.stringify({ email: input.value, _subject: 'Newsletter Signup' }),
        headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
      });
      if (res.ok) {
        input.value = '';
        note.textContent = 'Subscribed! We\'ll be in touch.';
        note.style.color = '#34D399';
      } else {
        throw new Error('fail');
      }
    } catch(err) {
      note.textContent = 'Something went wrong. Try again.';
      note.style.color = '#FF6B6B';
    }
    btn.disabled = false;
    btn.style.opacity = '1';
  });
})();
</script>
