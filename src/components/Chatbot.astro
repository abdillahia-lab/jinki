---
/*
  Chatbot — Jinki Intelligence Concierge
  Pill launcher + fixed chat panel with quick-reply buttons.
  No session persistence, no command palette, no typewriter, no drag-to-resize.
*/
---

<div id="jinki-chatbot" class="jc-root" role="complementary" aria-label="Jinki Intelligence Concierge">

  <!-- Pill Launcher -->
  <button id="jc-launcher" class="jc-launcher" type="button" aria-label="Open Jinki Concierge chat" aria-expanded="false" aria-controls="jc-panel">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
    </svg>
    <span>Ask Jinki</span>
  </button>

  <!-- Chat Panel -->
  <div id="jc-panel" class="jc-panel" role="dialog" aria-label="Jinki Concierge" aria-hidden="true">

    <!-- Header -->
    <div class="jc-header">
      <span class="jc-status" aria-hidden="true"></span>
      <div style="flex: 1;">
        <span class="jc-title">Jinki Concierge</span>
        <span class="jc-subtitle">Aerial Intelligence Assistant</span>
      </div>
      <button id="jc-minimize" type="button" class="jc-hdr-btn" aria-label="Minimize chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <button id="jc-close" type="button" class="jc-hdr-btn" aria-label="Close chat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="jc-messages" class="jc-messages"></div>

    <!-- Input -->
    <div class="jc-input-row">
      <input id="jc-input" type="text" placeholder="Type a question..." autocomplete="off" aria-label="Chat message" />
      <button id="jc-send" type="button" class="jc-send-btn" aria-label="Send message">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<style>
  .jc-root { position: fixed; bottom: 24px; right: 24px; z-index: 9999; font-family: var(--font-body); }

  /* Launcher */
  .jc-launcher {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 20px 10px 14px; border-radius: 999px;
    background: var(--accent); color: #050508; border: none; cursor: pointer;
    font-family: var(--font-label); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.03em; box-shadow: 0 4px 24px rgba(0,212,255,0.3);
    transition: transform 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)),
                box-shadow 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1));
  }
  .jc-launcher:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 8px 32px rgba(0,212,255,0.4); }
  .jc-launcher[aria-expanded="true"] { display: none; }

  /* Panel */
  .jc-panel {
    position: fixed; bottom: 24px; right: 24px;
    width: 380px; height: 520px;
    display: none; flex-direction: column;
    background: var(--surface-container); border: 1px solid var(--glass-border);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 16px 48px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.05) inset;
  }
  .jc-panel[aria-hidden="false"] { display: flex; animation: chatPanelIn 0.35s var(--ease-out-premium, cubic-bezier(0.16, 1, 0.3, 1)); }
  @keyframes chatPanelIn {
    from { opacity: 0; transform: translateY(16px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Header */
  .jc-header {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 16px; border-bottom: 1px solid var(--glass-border);
    background: var(--glass-bg); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  }
  .jc-status { width: 8px; height: 8px; border-radius: 50%; background: #34d399; flex-shrink: 0; }
  .jc-title { font-family: var(--font-headline); font-size: 0.875rem; font-weight: 700; color: var(--text-primary); display: block; }
  .jc-subtitle { font-size: 0.6875rem; color: var(--text-tertiary); display: block; }
  .jc-hdr-btn {
    width: 32px; height: 32px; border-radius: 8px; border: none;
    background: transparent; color: var(--text-secondary); cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: background 0.15s ease;
  }
  .jc-hdr-btn:hover { background: var(--surface-container-high); }

  /* Messages */
  .jc-messages { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  .jc-msg { max-width: 88%; border-radius: 12px; padding: 10px 14px; font-size: 0.8125rem; line-height: 1.55; }
  .jc-bot { background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary); align-self: flex-start; }
  .jc-user { background: var(--accent); color: #050508; align-self: flex-end; }
  .jc-bot a { color: var(--accent); text-decoration: underline; font-weight: 600; }

  /* Quick replies */
  .jc-quick { display: flex; flex-wrap: wrap; gap: 8px; align-self: flex-start; }
  .jc-qbtn {
    padding: 6px 14px; border-radius: 999px; font-size: 0.75rem; font-weight: 600;
    font-family: var(--font-label); letter-spacing: 0.03em; white-space: nowrap;
    background: transparent; color: var(--accent); border: 1px solid var(--accent);
    cursor: pointer; transition: background 0.15s ease, color 0.15s ease;
  }
  .jc-qbtn:hover { background: var(--accent); color: #050508; }

  /* Input */
  .jc-input-row { display: flex; gap: 8px; padding: 10px 12px; border-top: 1px solid var(--glass-border); background: var(--glass-bg); }
  .jc-input-row input {
    flex: 1; background: var(--surface-container-low); border: 1px solid var(--glass-border);
    border-radius: 12px; padding: 10px 14px; font-size: 0.8125rem; font-family: var(--font-body);
    color: var(--text-primary); outline: none; min-width: 0; transition: border-color 0.2s ease;
  }
  .jc-input-row input:focus { border-color: var(--accent); }
  .jc-input-row input::placeholder { color: var(--text-tertiary); }
  .jc-send-btn {
    width: 40px; height: 40px; border-radius: 12px; border: none;
    background: var(--accent); color: #050508; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: filter 0.15s ease; flex-shrink: 0;
  }
  .jc-send-btn:hover { filter: brightness(1.1); }

  /* Responsive */
  @media (max-width: 480px) {
    .jc-panel { width: calc(100vw - 16px); right: 8px; bottom: 8px; height: 480px; }
    .jc-root { bottom: 12px; right: 12px; }
  }

  /* Light mode */
  :global([data-theme="light"]) .jc-panel { box-shadow: 0 16px 48px rgba(0,0,0,0.12); }
  :global([data-theme="light"]) .jc-bot { background: var(--surface-container-low); }

  /* Typing indicator */
  .jc-typing { font-family: var(--font-mono); letter-spacing: 0.2em; animation: typingPulse 1s ease-in-out infinite; }
  @keyframes typingPulse { 0%,100% { opacity: 0.3; } 50% { opacity: 0.7; } }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) { .jc-launcher, .jc-hdr-btn, .jc-qbtn, .jc-send-btn { transition: none; } }
  @media print { .jc-root { display: none !important; } }
</style>

<script is:inline>
(function () {
  var launcher = document.getElementById('jc-launcher');
  var panel = document.getElementById('jc-panel');
  var closeBtn = document.getElementById('jc-close');
  var minBtn = document.getElementById('jc-minimize');
  var msgs = document.getElementById('jc-messages');
  var input = document.getElementById('jc-input');
  var sendBtn = document.getElementById('jc-send');
  var initialized = false;

  var answers = {
    Assessment: {
      text: 'Our Facility Intelligence Scan is a one-time aerial assessment that delivers a prioritized report with thermal, structural, and environmental findings — typically within 48 hours.',
      link: '/services/audit', cta: 'Learn about scans'
    },
    Deployment: {
      text: 'Autonomous Deployment stations a DJI Dock 3 at your facility for persistent monitoring — 150 to 200 missions per month with no operator required.',
      link: '/services/deployment', cta: 'Explore deployment'
    },
    'Data Centers': {
      text: 'We inspect rooftop HVAC arrays, cooling infrastructure, and electrical systems using 0.5°C thermal precision — identifying failures before they cause downtime.',
      link: '/verticals/data-centers', cta: 'Data center intelligence'
    },
    'Energy': {
      text: 'Condition assessments for power lines, substations, and solar arrays — inspecting 50+ miles of corridor per day without service interruption.',
      link: '/verticals/energy-grid', cta: 'Energy intelligence'
    },
    Security: {
      text: 'Persistent aerial perimeter monitoring with thermal threat detection covering 500+ acre perimeters and real-time intrusion alerts.',
      link: '/verticals/security', cta: 'Security intelligence'
    },
    Agriculture: {
      text: 'NDVI crop health mapping, soil moisture analysis, and yield intelligence across thousands of acres — identifying irrigation issues and crop stress early.',
      link: '/verticals/agriculture', cta: 'Agriculture intelligence'
    },
    Thermal: {
      text: 'Our H30T thermal sensor detects temperature differences as small as 0.5°C. We identify overheating equipment, insulation gaps, water leaks, and structural weak points.',
      link: '/#thermal-hud', cta: 'See thermal capabilities'
    },
    Process: {
      text: 'Three steps: (1) We scope your facility and build a mission plan, (2) Our platform captures and analyzes with AI, (3) You receive a prioritized intelligence report within 48 hours.',
      link: '/#process', cta: 'See our process'
    },
    Contact: {
      text: 'Ready to get started? Fill out our quick form and our intelligence team will scope your facility and recommend the right engagement.',
      link: '#lead-gen', cta: 'Request a demo'
    }
  };

  function addBot(html) {
    var d = document.createElement('div');
    d.className = 'jc-msg jc-bot';
    d.innerHTML = html;
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function addUser(text) {
    var d = document.createElement('div');
    d.className = 'jc-msg jc-user';
    d.textContent = text;
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  var quickTopics = ['Assessment', 'Deployment', 'Data Centers', 'Process', 'Contact'];

  function addQuickReplies() {
    var wrap = document.createElement('div');
    wrap.className = 'jc-quick';
    for (var i = 0; i < quickTopics.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'jc-qbtn';
      btn.type = 'button';
      btn.textContent = quickTopics[i];
      btn.setAttribute('data-key', quickTopics[i]);
      wrap.appendChild(btn);
    }
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function removeQuickReplies() {
    var els = msgs.querySelectorAll('.jc-quick');
    for (var i = 0; i < els.length; i++) els[i].remove();
  }

  function showAnswer(key) {
    var a = answers[key];
    if (!a) return;
    removeQuickReplies();
    addUser(key);
    addBot(a.text + ' <a href="' + a.link + '">' + a.cta + ' &rarr;</a>');
    addQuickReplies();
  }

  function openPanel() {
    panel.setAttribute('aria-hidden', 'false');
    launcher.setAttribute('aria-expanded', 'true');
    if (!initialized) {
      addBot('Welcome to Jinki Aerial Intelligence. How can I help you today?');
      addQuickReplies();
      initialized = true;
    }
    input.focus();
  }

  function closePanel() {
    panel.setAttribute('aria-hidden', 'true');
    launcher.setAttribute('aria-expanded', 'false');
  }

  launcher.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  minBtn.addEventListener('click', closePanel);

  // Quick reply delegation
  msgs.addEventListener('click', function (e) {
    var btn = e.target.closest('.jc-qbtn');
    if (btn) showAnswer(btn.getAttribute('data-key'));
  });

  // Typed input with keyword matching
  function handleSend() {
    var v = input.value.trim();
    if (!v) return;
    input.value = '';
    removeQuickReplies();
    addUser(v);
    var lc = v.toLowerCase();
    if (/scan|assess|evaluation|inspect|one.?time|report/.test(lc)) { showAnswer('Assessment'); return; }
    if (/deploy|autonom|persistent|dock|continuous|monitor/.test(lc)) { showAnswer('Deployment'); return; }
    if (/data.?center|hvac|cooling|rooftop|server/.test(lc)) { showAnswer('Data Centers'); return; }
    if (/energy|power|grid|solar|substation|transmission|utilit/.test(lc)) { showAnswer('Energy'); return; }
    if (/secur|perime|surveillance|intru|patrol|fence/.test(lc)) { showAnswer('Security'); return; }
    if (/agri|farm|crop|ndvi|irrigat|field|harvest/.test(lc)) { showAnswer('Agriculture'); return; }
    if (/thermal|heat|temperature|infrared|hotspot/.test(lc)) { showAnswer('Thermal'); return; }
    if (/process|how|work|step|engage|what happen/.test(lc)) { showAnswer('Process'); return; }
    if (/price|cost|pricing|quote|much/.test(lc)) {
      addBot('We tailor each engagement to your facility\'s specific needs. <a href="#lead-gen">Request a demo</a> and our team will provide a custom scope and recommendation.');
      addQuickReplies(); return;
    }
    if (/contact|touch|start|talk|demo|call|meet|schedule/.test(lc)) { showAnswer('Contact'); return; }
    if (/hello|hi\b|hey|good/.test(lc)) {
      addBot('Hello! I\'m here to help you learn about Jinki\'s aerial intelligence services. What would you like to know about?');
      addQuickReplies(); return;
    }
    // No keyword match — call LLM
    askLLM(v);
  }

  function escText(s) { var d = document.createElement('div'); d.textContent = s; return d.textContent; }

  function askLLM(q) {
    var t = document.createElement('div');
    t.className = 'jc-msg jc-bot jc-typing';
    t.textContent = '...';
    t.style.opacity = '0.5';
    msgs.appendChild(t);
    msgs.scrollTop = msgs.scrollHeight;
    fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: q })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      t.remove();
      var reply = escText(d.reply || d.error || 'Please email info@jinki.ai.');
      addBot(reply + ' <a href="#lead-gen">Request a demo &rarr;</a>');
      addQuickReplies();
    })
    .catch(function() {
      t.remove();
      addBot('I\'m temporarily unavailable. Please <a href="#lead-gen">request a demo</a> or email info@jinki.ai.');
      addQuickReplies();
    });
  }

  sendBtn.addEventListener('click', handleSend);
  input.addEventListener('keydown', function (e) { if (e.key === 'Enter') handleSend(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && panel.getAttribute('aria-hidden') === 'false') closePanel(); });
})();
</script>
