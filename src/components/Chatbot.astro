---
/*
  Chatbot — Jinki Intelligence Concierge
  Pill launcher + fixed chat panel with quick-reply buttons.
  No session persistence, no command palette, no typewriter, no drag-to-resize.
*/
---

<div id="jinki-chatbot" class="jc-root" role="complementary" aria-label="Jinki Intelligence Concierge">

  <!-- Pill Launcher -->
  <button id="jc-launcher" class="jc-launcher" type="button" aria-label="Open Jinki Concierge chat" aria-expanded="false" popovertarget="jc-panel">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
    </svg>
    <span>Ask Jinki</span>
  </button>

  <!-- Chat Panel (Popover API — light-dismiss + Escape for free) -->
  <div id="jc-panel" class="jc-panel" role="dialog" aria-label="Jinki Concierge" popover="auto">

    <!-- Header -->
    <div class="jc-header">
      <span class="jc-status" aria-hidden="true"></span>
      <div style="flex: 1;">
        <span class="jc-title">Jinki Concierge</span>
        <span class="jc-subtitle">Aerial Intelligence Assistant</span>
      </div>
      <button type="button" class="jc-hdr-btn" aria-label="Minimize chat" popovertarget="jc-panel" popovertargetaction="hide">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <button type="button" class="jc-hdr-btn" aria-label="Close chat" popovertarget="jc-panel" popovertargetaction="hide">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Messages -->
    <div id="jc-messages" class="jc-messages" role="log" aria-live="polite" aria-label="Chat messages"></div>

    <!-- Input -->
    <div class="jc-input-row">
      <input id="jc-input" type="text" placeholder="Type a question..." autocomplete="off" aria-label="Chat message" maxlength="500" enterkeyhint="send" />
      <button id="jc-send" type="button" class="jc-send-btn" aria-label="Send message">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  .jc-root { position: fixed; bottom: 24px; right: 24px; z-index: 9999; font-family: var(--font-body); }

  /* Launcher */
  .jc-launcher {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 20px 12px 16px; border-radius: 9999px;
    background: var(--accent); color: var(--text-on-accent); border: none; cursor: pointer;
    font-family: var(--font-label); font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.03em; box-shadow: 0 4px 24px var(--accent-glow-strong);
    transition: transform 0.35s var(--ease-out-premium),
                box-shadow 0.35s var(--ease-out-premium);
  }
  .jc-launcher { animation: jcBreathePulse 3s ease-in-out infinite; }
  .jc-launcher:hover { transform: translateY(-3px) scale(1.02); box-shadow: var(--shadow-elevated), 0 0 32px var(--accent-glow-strong); animation: none; }
  .jc-launcher[aria-expanded="true"] { display: none; }
  @keyframes jcBreathePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.03); }
  }

  /* Mobile: smaller launcher — sits above sticky CTA bar */
  @media (max-width: 767px) {
    .jc-root { bottom: 80px; right: 16px; }
    .jc-launcher {
      padding: 8px 16px 8px 12px;
      font-size: 0.6875rem;
      gap: 8px;
      box-shadow: 0 2px 16px var(--accent-glow-strong);
      animation: none;
    }
    .jc-launcher svg { width: 14px; height: 14px; }
    .jc-panel {
      bottom: 72px; right: 16px;
      width: calc(100vw - 32px);
      height: calc(100dvh - 160px);
      max-height: 420px;
    }
  }

  /* Panel — uses Popover API for light-dismiss + Escape */
  .jc-panel {
    position: fixed; bottom: 24px; right: 24px;
    width: 380px; height: 520px;
    flex-direction: column;
    background: var(--surface-container); border: 1px solid var(--glass-border);
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 16px 48px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.05) inset;
    margin: 0; padding: 0; inset: auto;
    opacity: 1; transform: translateY(0) scale(1);
    transition: opacity 0.25s var(--ease-out-premium),
                transform 0.25s var(--ease-out-premium),
                display 0.25s var(--ease-out-premium) allow-discrete;
  }
  .jc-panel:popover-open { display: flex; }
  @starting-style {
    .jc-panel:popover-open {
      opacity: 0;
      transform: translateY(16px) scale(0.96);
    }
  }

  /* Header */
  .jc-header {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 16px; border-bottom: 1px solid var(--glass-border);
    background: var(--glass-bg); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    position: relative;
  }
  .jc-header::after {
    content: '';
    position: absolute; bottom: -1px; left: 16px; right: 16px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.3;
  }
  .jc-status { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-tertiary); flex-shrink: 0; box-shadow: 0 0 6px rgba(52,211,153,0.4); animation: statusBlink 2.5s ease-in-out infinite; }
  @keyframes statusBlink { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
  .jc-title { font-family: var(--font-headline); font-size: 0.875rem; font-weight: 700; color: var(--text-primary); display: block; }
  .jc-subtitle { font-size: 0.6875rem; color: var(--text-tertiary); display: block; }
  .jc-hdr-btn {
    width: 32px; height: 32px; border-radius: 8px; border: none;
    background: transparent; color: var(--text-secondary); cursor: pointer;
    display: flex; align-items: center; justify-content: center; transition: background 0.15s ease;
  }
  .jc-hdr-btn:hover { background: var(--surface-container-high); }

  /* Messages */
  .jc-messages { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 12px; }
  .jc-msg { max-width: 88%; border-radius: 12px; padding: 12px 16px; font-size: 0.8125rem; line-height: 1.55; }
  .jc-bot { background: var(--glass-bg); border: 1px solid var(--glass-border); color: var(--text-primary); align-self: flex-start; }
  .jc-user { background: var(--accent); color: var(--text-on-accent); align-self: flex-end; }
  .jc-bot a { color: var(--accent); text-decoration: underline; font-weight: 600; }

  /* Quick replies */
  .jc-quick { display: flex; flex-wrap: wrap; gap: 8px; align-self: flex-start; }
  .jc-qbtn {
    padding: 8px 16px; border-radius: 9999px; font-size: 0.75rem; font-weight: 600;
    font-family: var(--font-label); letter-spacing: 0.03em; white-space: nowrap;
    background: transparent; color: var(--accent); border: 1px solid var(--accent);
    cursor: pointer; transition: background 0.15s ease, color 0.15s ease;
  }
  .jc-qbtn:hover { background: var(--accent); color: var(--text-on-accent); }

  /* Input */
  .jc-input-row { display: flex; gap: 8px; padding: 12px 12px; border-top: 1px solid var(--glass-border); background: var(--glass-bg); }
  .jc-input-row input {
    flex: 1; background: var(--surface-container-low); border: 1px solid var(--glass-border);
    border-radius: 12px; padding: 12px 16px; font-size: 1rem; font-family: var(--font-body);
    color: var(--text-primary); outline: none; min-width: 0; transition: border-color 0.2s ease;
  }
  .jc-input-row input:focus { border-color: var(--accent); }
  .jc-input-row input::placeholder { color: var(--text-tertiary); }
  .jc-send-btn {
    width: 40px; height: 40px; border-radius: 12px; border: none;
    background: var(--accent); color: var(--text-on-accent); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: filter 0.15s ease; flex-shrink: 0;
  }
  .jc-send-btn:hover { filter: brightness(1.1); }

  /* Responsive */
  @media (max-width: 480px) {
    .jc-panel { width: calc(100vw - 16px); right: 8px; bottom: 8px; height: 480px; }
    .jc-root { bottom: 12px; right: 12px; }
  }

  /* Light mode */
  :global([data-theme="light"]) .jc-panel { box-shadow: 0 16px 48px rgba(0,0,0,0.12); }
  :global([data-theme="light"]) .jc-bot { background: var(--surface-container-low); }
  :global([data-theme="light"]) .jc-launcher { box-shadow: 0 4px 16px rgba(0, 131, 143, 0.2); }
  :global([data-theme="light"]) .jc-launcher:hover { box-shadow: 0 8px 24px rgba(0, 131, 143, 0.25); }

  /* Typing indicator — 3 bouncing dots */
  .jc-typing-dots {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 12px 16px;
  }
  .jc-typing-dots span {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); opacity: 0.4;
    animation: jcDotBounce 1.2s ease-in-out infinite;
  }
  .jc-typing-dots span:nth-child(2) { animation-delay: 0.15s; }
  .jc-typing-dots span:nth-child(3) { animation-delay: 0.3s; }
  @keyframes jcDotBounce {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
  }

  /* Quick reply stagger entrance */
  .jc-quick { opacity: 0; animation: jcQuickFadeIn 0.3s ease forwards; }
  .jc-qbtn {
    opacity: 0; transform: translateY(6px);
    animation: jcChipStagger 0.25s ease forwards;
  }
  .jc-qbtn:nth-child(1) { animation-delay: 0.05s; }
  .jc-qbtn:nth-child(2) { animation-delay: 0.1s; }
  .jc-qbtn:nth-child(3) { animation-delay: 0.15s; }
  .jc-qbtn:nth-child(4) { animation-delay: 0.2s; }
  .jc-qbtn:nth-child(5) { animation-delay: 0.25s; }
  @keyframes jcQuickFadeIn {
    to { opacity: 1; }
  }
  @keyframes jcChipStagger {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .jc-panel { transition: none; }
    .jc-launcher, .jc-hdr-btn, .jc-qbtn, .jc-send-btn { transition: none; }
    .jc-launcher { animation: none; }
    .jc-typing-dots span { animation: none; opacity: 0.6; }
    .jc-quick, .jc-qbtn { animation: none; opacity: 1; transform: none; }
  }
  @media print { .jc-root { display: none !important; } }
</style>

<script is:inline>
(function () {
  var launcher = document.getElementById('jc-launcher');
  var panel = document.getElementById('jc-panel');
  var msgs = document.getElementById('jc-messages');
  var input = document.getElementById('jc-input');
  var sendBtn = document.getElementById('jc-send');
  if (!launcher || !panel || !msgs || !input || !sendBtn) return;
  var initialized = false;

  var answers = {
    Assessment: {
      text: 'Our Facility Intelligence Scan is a one-time aerial assessment that delivers a prioritized report with thermal, structural, and environmental findings — typically within 48 hours.',
      link: '/services/audit', cta: 'Learn about scans'
    },
    Deployment: {
      text: 'Autonomous Deployment stations an on-site autonomous dock at your facility for persistent monitoring — 150 to 200 missions per month with no operator required.',
      link: '/services/deployment', cta: 'Explore deployment'
    },
    'Data Centers': {
      text: 'We inspect rooftop HVAC arrays, cooling infrastructure, and electrical systems using 0.5°C thermal precision — identifying failures before they cause downtime.',
      link: '/verticals/data-centers', cta: 'Data center intelligence'
    },
    'Energy': {
      text: 'Condition assessments for power lines, substations, and solar arrays — inspecting 50+ miles of corridor per day without service interruption.',
      link: '/verticals/energy-grid', cta: 'Energy intelligence'
    },
    Security: {
      text: 'Persistent aerial perimeter monitoring with thermal threat detection covering 500+ acre perimeters and real-time intrusion alerts.',
      link: '/verticals/security', cta: 'Security intelligence'
    },
    Agriculture: {
      text: 'Thermal crop stress detection, irrigation analysis, and yield intelligence across thousands of acres — identifying water stress and drainage issues before they impact yield.',
      link: '/verticals/agriculture', cta: 'Agriculture intelligence'
    },
    Thermal: {
      text: 'Our thermal sensors detect temperature differences as small as 0.5°C. We identify overheating equipment, insulation gaps, water leaks, and structural weak points across your facility.',
      link: '/#thermal-hud', cta: 'See thermal capabilities'
    },
    Process: {
      text: 'Three steps: (1) We scope your facility and build a mission plan, (2) Our platform captures and analyzes with AI, (3) You receive a prioritized intelligence report within 48 hours.',
      link: '/#process', cta: 'See our process'
    },
    Contact: {
      text: 'Ready to get started? Fill out our quick form and our intelligence team will scope your facility and recommend the right engagement.',
      link: '#lead-gen', cta: 'Request a demo'
    }
  };

  function addBot(text, linkHref, linkText) {
    var d = document.createElement('div');
    d.className = 'jc-msg jc-bot';
    // Use textContent for the message body (XSS-safe)
    var span = document.createElement('span');
    span.textContent = text;
    d.appendChild(span);
    // Append a safe link if provided (href must be relative or whitelisted)
    if (linkHref && linkText) {
      var a = document.createElement('a');
      // Only allow relative URLs and # anchors — block javascript: and data: schemes
      if (/^(\/|#|https:\/\/jinki\.ai(\/|$))/.test(linkHref)) {
        a.href = linkHref;
      } else {
        a.href = '#lead-gen';
      }
      a.textContent = ' ' + linkText + ' \u2192';
      d.appendChild(a);
    }
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function addUser(text) {
    var d = document.createElement('div');
    d.className = 'jc-msg jc-user';
    d.textContent = text;
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
  }

  var quickTopics = ['Assessment', 'Deployment', 'Data Centers', 'Process', 'Contact'];

  function addQuickReplies() {
    var wrap = document.createElement('div');
    wrap.className = 'jc-quick';
    for (var i = 0; i < quickTopics.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'jc-qbtn';
      btn.type = 'button';
      btn.textContent = quickTopics[i];
      btn.setAttribute('data-key', quickTopics[i]);
      wrap.appendChild(btn);
    }
    msgs.appendChild(wrap);
    msgs.scrollTop = msgs.scrollHeight;
  }

  function removeQuickReplies() {
    var els = msgs.querySelectorAll('.jc-quick');
    for (var i = 0; i < els.length; i++) els[i].remove();
  }

  function showAnswer(key) {
    var a = answers[key];
    if (!a) return;
    removeQuickReplies();
    addUser(key);
    addBot(a.text, a.link, a.cta);
    addQuickReplies();
  }

  // Popover toggle event — sync launcher state + lazy init
  panel.addEventListener('toggle', function(e) {
    var open = e.newState === 'open';
    launcher.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) {
      if (!initialized) {
        addBot('Welcome to Jinki Aerial Intelligence. How can I help you today?');
        addQuickReplies();
        initialized = true;
      }
      input.focus();
    }
  });

  // Quick reply delegation
  msgs.addEventListener('click', function (e) {
    var btn = e.target.closest('.jc-qbtn');
    if (btn) showAnswer(btn.getAttribute('data-key'));
  });

  // Typed input with keyword matching
  function handleSend() {
    var v = input.value.trim();
    if (!v) return;
    input.value = '';
    removeQuickReplies();
    addUser(v);
    var lc = v.toLowerCase();
    if (/\b(scan|assess|evaluation|inspect|one.?time|report)\b/.test(lc)) { showAnswer('Assessment'); return; }
    if (/\b(deploy|autonom|persistent|dock|continuous|monitor)\b/.test(lc)) { showAnswer('Deployment'); return; }
    if (/data.?center|\b(hvac|cooling|rooftop|server)\b/.test(lc)) { showAnswer('Data Centers'); return; }
    if (/\b(energy|power|grid|solar|substation|transmission|utilit)/.test(lc)) { showAnswer('Energy'); return; }
    if (/\b(secur|perime|surveillance|intru|patrol|fence)/.test(lc)) { showAnswer('Security'); return; }
    if (/\b(agri|farm|crop|ndvi|irrigat|field|harvest)\b/.test(lc)) { showAnswer('Agriculture'); return; }
    if (/\b(thermal|heat|temperature|infrared|hotspot)\b/.test(lc)) { showAnswer('Thermal'); return; }
    if (/\b(process|how|work|step|engage)\b|what happen/.test(lc)) { showAnswer('Process'); return; }
    if (/\b(price|cost|pricing|quote|much)\b/.test(lc)) {
      addBot('We tailor each engagement to your facility\'s specific needs. Our team will provide a custom scope and recommendation.', '#lead-gen', 'Request a demo');
      addQuickReplies(); return;
    }
    if (/contact|touch|start|talk|demo|call|meet|schedule/.test(lc)) { showAnswer('Contact'); return; }
    if (/hello|hi\b|hey|good/.test(lc)) {
      addBot('Hello! I\'m here to help you learn about Jinki\'s aerial intelligence services. What would you like to know about?');
      addQuickReplies(); return;
    }
    // No keyword match — call LLM
    askLLM(v);
  }

  function askLLM(q) {
    var t = document.createElement('div');
    t.className = 'jc-msg jc-bot';
    t.innerHTML = '<span class="jc-typing-dots"><span></span><span></span><span></span></span>';
    msgs.appendChild(t);
    msgs.scrollTop = msgs.scrollHeight;
    input.disabled = true;
    sendBtn.disabled = true;
    sendBtn.style.opacity = '0.5';
    var controller = new AbortController();
    var timeoutId = setTimeout(function() { controller.abort(); }, 15000);
    fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: q }),
      signal: controller.signal
    })
    .then(function(r) { clearTimeout(timeoutId); return r.json(); })
    .then(function(d) {
      t.remove();
      input.disabled = false;
      sendBtn.disabled = false;
      sendBtn.style.opacity = '1';
      input.focus();
      var reply = d.reply || d.error || 'Please email info@jinki.ai.';
      addBot(reply, '#lead-gen', 'Get Your Facility Report');
      addQuickReplies();
    })
    .catch(function(err) {
      clearTimeout(timeoutId);
      t.remove();
      input.disabled = false;
      sendBtn.disabled = false;
      sendBtn.style.opacity = '1';
      input.focus();
      var msg = err && err.name === 'AbortError'
        ? 'Response took too long. Please try again or email info@jinki.ai.'
        : 'I\'m temporarily unavailable. Please email info@jinki.ai.';
      addBot(msg, '#lead-gen', 'Request a demo');
      addQuickReplies();
    });
  }

  sendBtn.addEventListener('click', handleSend);
  input.addEventListener('keydown', function (e) { if (e.key === 'Enter') handleSend(); });
})();
</script>
