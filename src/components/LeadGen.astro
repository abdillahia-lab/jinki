---
/*
  LeadGen — 2-field form for maximum conversion.
  Email + Company only. Everything else comes in the follow-up.
  Web3Forms integration, honeypot anti-spam, rate limiting.
*/
---

<section id="lead-gen" class="leadgen-section reveal" aria-label="Schedule Your Facility Scan">
  <div class="leadgen-container">
    <div class="leadgen-inner">
      <div class="leadgen-copy">
        <h2 class="leadgen-headline">Schedule Your Facility Scan</h2>
        <p class="leadgen-subtitle">
          Get a prioritized report with thermal, structural, and environmental findings — typically within 48 hours of your aerial assessment.
        </p>
      </div>

      <div class="leadgen-form-wrap">
        <form id="lg-form" action="https://api.web3forms.com/submit" method="POST" class="leadgen-form">
          <input type="hidden" name="access_key" value="b2bd961c-acf2-48a6-bf10-a5717c2dea95" />
          <input type="hidden" name="subject" value="New Assessment Request from jinki.ai" />
          <input type="hidden" name="from_name" value="Jinki Website" />
          <input type="hidden" name="redirect" value="https://jinki.ai/?submitted=true" />
          <!-- Honeypot -->
          <div aria-hidden="true" style="position: absolute; left: -9999px; top: -9999px;">
            <label for="lg-botcheck">Website</label>
            <input type="text" id="lg-botcheck" name="botcheck" tabindex="-1" autocomplete="off" />
          </div>

          <div class="leadgen-fields">
            <input type="email" name="email" required placeholder="Work email" autocomplete="email" inputmode="email" maxlength="254" class="leadgen-input" aria-label="Work email address" />
            <input type="text" name="company" placeholder="Company name" autocomplete="organization" maxlength="100" class="leadgen-input" aria-label="Company name" />
            <button type="submit" class="leadgen-submit">Get Your Facility Report</button>
          </div>

          <div class="leadgen-trust">
            <span class="leadgen-badge">
              <span class="material-symbols-outlined" aria-hidden="true">lock</span>
              AES-256 Encrypted
            </span>
            <span class="leadgen-badge">
              <span class="material-symbols-outlined" aria-hidden="true">handshake</span>
              NDA by Default
            </span>
            <span class="leadgen-badge">
              <span class="material-symbols-outlined" aria-hidden="true">schedule</span>
              Response within 4 hours
            </span>
          </div>
        </form>

        <!-- Success -->
        <div id="lg-success" class="leadgen-success" style="display: none;">
          <svg class="lg-check-svg" width="48" height="48" viewBox="0 0 64 64" fill="none" aria-hidden="true">
            <circle cx="32" cy="32" r="29" stroke="#34d399" stroke-width="2.5" class="lg-check-circle"/>
            <polyline points="20,33 28,41 44,25" stroke="#34d399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lg-check-mark" fill="none"/>
          </svg>
          <h3 class="leadgen-success-title">Request Received</h3>
          <p class="leadgen-success-desc">We'll review your submission and reach out within one business day with next steps.</p>
        </div>
      </div>
    </div>

    <div class="leadgen-alt">
      <a href="mailto:info@jinki.ai?subject=Facility%20Assessment%20—%20Jinki&body=I'm%20interested%20in%20an%20aerial%20assessment%20for%20our%20facility." class="leadgen-alt-link">
        <span class="material-symbols-outlined" aria-hidden="true">email</span>
        Or email us directly
      </a>
    </div>
  </div>
</section>

<style>
  .leadgen-section {
    padding: 8rem 0;
    position: relative;
  }
  @media (min-width: 768px) { .leadgen-section { padding: 10rem 0; } }

  .leadgen-container {
    max-width: var(--container-max);
    margin-left: auto; margin-right: auto;
    padding-left: 1.5rem; padding-right: 1.5rem;
  }

  .leadgen-inner {
    max-width: 48rem;
    margin-left: auto; margin-right: auto;
    background: var(--surface-container);
    border: 1px solid var(--glass-border);
    border-radius: 1rem;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .leadgen-inner::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent 10%, var(--accent) 50%, transparent 90%);
    opacity: 0.6;
  }
  @media (min-width: 768px) { .leadgen-inner { padding: 4rem 3rem; } }

  .leadgen-copy { text-align: center; margin-bottom: 2.5rem; }
  .leadgen-headline {
    font-family: var(--font-headline);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  .leadgen-subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-secondary);
    max-width: 32rem;
    margin-left: auto; margin-right: auto;
    line-height: 1.6;
  }

  .leadgen-fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .leadgen-fields {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .leadgen-submit { grid-column: 1 / -1; }
  }

  .leadgen-input {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text-primary);
    background: var(--surface-container-low);
    border: 1px solid var(--glass-border);
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    outline: none;
    min-height: 48px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .leadgen-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent);
  }
  .leadgen-input::placeholder { color: var(--text-tertiary); }

  .leadgen-submit {
    font-family: var(--font-headline);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--accent);
    color: var(--text-on-accent);
    border: none;
    border-radius: 0.75rem;
    padding: 1rem 2rem;
    cursor: pointer;
    min-height: 48px;
    transition: filter 0.2s ease, transform 0.2s var(--ease-out-premium),
                box-shadow 0.2s var(--ease-out-premium);
  }
  .leadgen-submit:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .leadgen-submit:active { transform: translateY(0); }
  .leadgen-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .leadgen-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.25rem;
  }
  .leadgen-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-label);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-tertiary);
  }
  .leadgen-badge .material-symbols-outlined {
    font-size: 14px;
    color: var(--accent-tertiary);
  }

  .leadgen-success { text-align: center; padding: 2rem 0; }
  .leadgen-success-title {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-top: 1rem;
  }
  .leadgen-success-desc {
    font-family: var(--font-body);
    color: var(--text-secondary);
    margin-top: 0.5rem;
    max-width: 28rem;
    margin-left: auto; margin-right: auto;
  }

  .leadgen-alt {
    text-align: center;
    margin-top: 1.5rem;
  }
  .leadgen-alt-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .leadgen-alt-link:hover { color: var(--accent); }
  .leadgen-alt-link .material-symbols-outlined { font-size: 16px; }

  /* Self-drawing checkmark */
  .lg-check-circle {
    stroke-dasharray: 183; stroke-dashoffset: 183;
    animation: lgDrawCircle 0.6s ease forwards;
  }
  .lg-check-mark {
    stroke-dasharray: 40; stroke-dashoffset: 40;
    animation: lgDrawCheck 0.4s ease forwards 0.5s;
  }
  @keyframes lgDrawCircle { to { stroke-dashoffset: 0; } }
  @keyframes lgDrawCheck { to { stroke-dashoffset: 0; } }

  /* Spinner */
  .lg-spinner {
    display: inline-block; width: 16px; height: 16px;
    border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff;
    border-radius: 50%; animation: lgSpin 0.6s linear infinite;
    vertical-align: middle; margin-right: 6px;
  }
  @keyframes lgSpin { to { transform: rotate(360deg); } }

  /* Light mode */
  :global([data-theme="light"]) .leadgen-input { background: var(--surface-container-lowest); }
  :global([data-theme="light"]) .leadgen-submit { color: #ffffff; }

  @media (prefers-reduced-motion: reduce) {
    .lg-check-circle, .lg-check-mark { animation: none; stroke-dashoffset: 0; }
    .lg-spinner { animation-duration: 1.5s; }
    .leadgen-submit { transition: none; }
  }

  @media (max-width: 767px) {
    .leadgen-inner { padding: 2rem 1.25rem !important; }
    .leadgen-headline { font-size: 1.5rem !important; }
  }
</style>

<script>
  const form = document.getElementById('lg-form') as HTMLFormElement;
  const success = document.getElementById('lg-success')!;
  let submitting = false;
  let lastSubmitTime = 0;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitting) return;
    const now = Date.now();
    if (now - lastSubmitTime < 5000) return;
    lastSubmitTime = now;
    submitting = true;

    // Honeypot check
    const hp = document.getElementById('lg-botcheck') as HTMLInputElement;
    if (hp && hp.value) { submitting = false; return; }

    const submitBtn = form.querySelector('.leadgen-submit') as HTMLButtonElement;
    const originalText = submitBtn.textContent || 'Get Your Facility Report';
    submitBtn.disabled = true;
    const spinner = document.createElement('span');
    spinner.className = 'lg-spinner';
    submitBtn.textContent = ' Sending...';
    submitBtn.prepend(spinner);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });

      if (response.ok) {
        form.style.display = 'none';
        success.style.display = 'block';
        const liveRegion = document.getElementById('aria-live-region');
        if (liveRegion) liveRegion.textContent = 'Your request has been received.';
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      submitting = false;
      submitBtn.disabled = false;
      submitBtn.querySelector('.lg-spinner')?.remove();
      submitBtn.textContent = originalText;
      let errMsg = form.querySelector('.lg-error') as HTMLElement;
      if (!errMsg) {
        errMsg = document.createElement('div');
        errMsg.className = 'lg-error';
        errMsg.setAttribute('role', 'alert');
        errMsg.style.cssText = 'color: #FF6B6B; font-size: 0.875rem; text-align: center; margin-top: 1rem; padding: 0.75rem; border: 1px solid rgba(255,107,107,0.2); border-radius: 8px; background: rgba(255,107,107,0.05);';
        submitBtn.parentElement?.appendChild(errMsg);
      }
      errMsg.textContent = 'Something went wrong. Please try again or email info@jinki.ai directly.';
    }
  });
</script>
